import { HorizontalBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";

component BaseActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <brush> fill;
    in property <color> text-color;
    in property <color> outline-color;
    in property <image> icon;
    in property <bool> icon-leading: false;
    in property <bool> has-icon: false;
    in property <int> text-weight: 600;
    callback clicked();

    height: 44px;
    border-radius: 18px;
    border-width: 1px;
    background: root.enabled ? root.fill : Theme.palette.secondary-start;
    border-color: root.outline-color;

    HorizontalBox {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 12px;

        if root.has-icon && root.icon-leading : Image {
            width: 16px;
            height: 16px;
            source: root.icon;
        }

        Text {
            text: root.text;
            color: root.enabled ? root.text-color : Theme.palette.text-secondary;
            vertical-alignment: center;
            horizontal-alignment: center;
            font-size: Theme.typo.button.size;
            font-weight: root.text-weight;
        }

        if root.has-icon && !root.icon-leading : Image {
            width: 16px;
            height: 16px;
            source: root.icon;
        }
    }

    TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

export component PrimaryActionButton inherits BaseActionButton {
    width: 136px;
    fill: @linear-gradient(180deg, Theme.palette.accent-start 0%, Theme.palette.accent-end 100%);
    outline-color: Theme.palette.accent-border;
    text-color: #f6f8ff;
    text-weight: 700;
}

export component SecondaryActionButton inherits BaseActionButton {
    width: 120px;
    fill: @linear-gradient(180deg, Theme.palette.secondary-start 0%, Theme.palette.secondary-end 100%);
    outline-color: Theme.palette.secondary-border;
    text-color: Theme.palette.text-secondary;
}

component BaseIconActionButton inherits Rectangle {
    in property <bool> enabled: true;
    in property <brush> fill;
    in property <color> outline-color;
    in property <image> icon;
    callback clicked();

    width: 40px;
    height: 40px;
    border-radius: 14px;
    border-width: 1px;
    background: root.enabled ? root.fill : Theme.palette.secondary-start;
    border-color: root.outline-color;

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 18px;
        height: 18px;
        source: root.icon;
    }

    TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

export component PrimaryIconActionButton inherits BaseIconActionButton {
    fill: @linear-gradient(180deg, Theme.palette.accent-start 0%, Theme.palette.accent-end 100%);
    outline-color: Theme.palette.accent-border;
}

export component SecondaryIconActionButton inherits BaseIconActionButton {
    fill: @linear-gradient(180deg, Theme.palette.secondary-start 0%, Theme.palette.secondary-end 100%);
    outline-color: Theme.palette.secondary-border;
}

export component IconAction inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    callback clicked();

    width: 18px;
    height: 18px;
    background: transparent;

    Image {
        width: parent.width;
        height: parent.height;
        source: root.icon;
    }

    TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}
