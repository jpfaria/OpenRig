import { ScrollView } from "std-widgets.slint";
import { CompactBlockItem, BlockTypePickerItem, ChainRigNav, StreamMeter } from "../models.slint";
import { BlockTypeCard } from "../components/block_value_widgets.slint";
import { PowerSwitch } from "../components/power_switch.slint";
import { ChainTitlePreset } from "../components/chain_title_preset.slint";
import { ChainActionIcon } from "../components/chain_chips.slint";
import { ChainVolumeButton } from "../components/chain_volume_button.slint";
import { CompactBlockRow } from "compact_block_row.slint";

import "../fonts/BebasNeue.ttf";

export component CompactChainViewPage inherits Rectangle {
    in property <string> chain-title;
    in property <int> chain-index;
    in property <[CompactBlockItem]> compact-blocks;
    // Measured DSP latency for this chain (#613). >0 ⇒ the badge shows
    // for the probe's 10 s window; mirrors the main chain row's badge so
    // the result renders where the user clicked (the compact view), not
    // only on the chains list behind the overlay.
    in property <float> latency-ms: 0.0;

    // Preset / scene model (same shape the main chains screen uses
    // — issue #436 #1). Empty `preset_labels` ⇒ combobox is hidden.
    in property <ChainRigNav> rig-nav;
    // Per-chain peak meters (#496) — same range as the main row.
    in property <float> meter-in-dbfs: -120.0;
    in property <float> meter-out-dbfs: -120.0;
    // Per-stream IN/OUT meter rows. Empty ⇒ fall back to the single
    // aggregate `meter-in-dbfs` / `meter-out-dbfs` pair so old wiring
    // keeps working. Non-empty ⇒ render one IN/OUT bar per stream
    // (multi-input chains, same shape `ChainRow` uses on the main page).
    in property <[StreamMeter]> stream-meters;
    // Chain output volume %, 0..200 (#440). Hooked to the volume button.
    in property <int> volume: 100;

    in property <bool> chain-enabled;
    callback toggle-chain-enabled(int);
    callback toggle-block-enabled(int, int);
    callback update-block-parameter-number(int, int, string, float);
    callback update-block-parameter-bool(int, int, string, bool);
    callback select-block-parameter-option(int, int, string, int);
    callback choose-block-model(int, int, int);
    callback choose-block-model-by-id(int, int, string);
    callback search-block-model(int, int, string);
    callback insert-block(int, int); // chain_index, before_index
    callback reorder-block(int, int, int); // chain_index, from_index, before_index
    callback open-block-detail(int, int);
    callback close-compact-view();
    callback choose-block-type(int, int, int); // chain_index, before_index, type_index
    callback remove-block(int, int); // chain_index, block_index
    callback open-plugin(string); // model-id, for VST3 blocks

    // I/O device configuration (reuses the chain list's configure flow)
    callback configure-input(int); // chain_index
    callback configure-output(int); // chain_index
    // Preset & chain admin — mirror the main row's callbacks so the
    // compact view is feature-parity with the chains screen.
    callback switch-chain-preset(int);          // bank slot or sentinel (-1 add, -2 remove)
    callback switch-chain-scene(int);           // scene index or sentinel (-1 add, -2 remove)
    callback rename-chain-preset(string);       // new name typed in the popup
    callback load-chain-preset();
    callback save-chain-preset-as();
    callback configure-chain(int);              // chain config dialog
    callback probe-chain-latency(int);
    callback chain-volume-changed(int, int);    // chain_index, value
    callback remove-chain(int);

    // Type picker state
    in property <[BlockTypePickerItem]> block-type-options;
    private property <bool> show-type-picker: false;
    private property <int> insert-before-index: 0;

    // Drag-to-reorder state
    private property <int> dragging-block-index: -1;
    private property <int> drag-hover-before-index: -1;
    private property <float> drag-start-y: 0;
    private property <float> drag-current-y: 0;
    private property <bool> drag-active: false;

    background: #0a0c10;

    // Header — preset select + scene bar + chain action cluster.
    // Taller than the original 44 px header so `ChainTitlePreset`
    // (which carries the rename popup) has room to render the popup
    // anchor without overlapping the block grid.
    Rectangle {
        x: 0; y: 0; width: parent.width; height: 62px;
        background: #12141a;
        border-width: 0px; border-color: #252830;

        // Chain power toggle (sprite)
        PowerSwitch {
            x: 8px;
            y: (parent.height - 40px) / 2;
            width: 40px; height: 40px;
            enabled: root.chain-enabled;
            clicked => { root.toggle-chain-enabled(root.chain-index); }
        }

        // Title + preset combobox + preset actions + scene bar.
        // `fullscreen: true` disables the "click to expand" interaction
        // (we're already in the compact view).
        ChainTitlePreset {
            x: 56px;
            y: (parent.height - 40px) / 2;
            width: parent.width - 56px - 376px;
            height: 40px;
            title: root.chain-title;
            nav: root.rig-nav;
            fullscreen: true;
            preset-picked(slot) => { root.switch-chain-preset(slot); }
            scene-picked(s) => { root.switch-chain-scene(s); }
            rename-preset(name) => { root.rename-chain-preset(name); }
            load-preset => { root.load-chain-preset(); }
            save-preset => { root.save-chain-preset-as(); }
        }

        // Right-side chain action cluster — 40 px stride matches the
        // main chain row. Order: volume, sonar, latency badge, gear, IN,
        // OUT, trash. Chain reorder (↑/↓) lives only on the chains list —
        // the compact view is single-chain focused (#613). The IN / OUT
        // chips configure the endpoints; the dBFS bars at the footer
        // report the live signal level.
        ChainVolumeButton {
            x: parent.width - 372px;
            y: (parent.height - 36px) / 2;
            volume: root.volume;
            value-changed(v) => { root.chain-volume-changed(root.chain-index, v); }
        }

        ChainActionIcon {
            x: parent.width - 308px;
            y: (parent.height - 30px) / 2;
            icon: @image-url("../assets/sonar.svg");
            tooltip: @tr("tooltip-measure-latency");
            clicked => { root.probe-chain-latency(root.chain-index); }
        }

        // Measured-latency badge (#613) — renders next to the sonar
        // button that triggers the probe, so the result shows inside the
        // compact view instead of only on the chains list. Same colours
        // and `label-lat` key as the main chain row's badge.
        if root.latency-ms > 0 : Rectangle {
            x: parent.width - 268px;
            y: (parent.height - 22px) / 2;
            width: 64px;
            height: 22px;
            border-radius: 4px;
            background: root.latency-ms < 10.0 ? #4ade8018
                      : root.latency-ms < 20.0 ? #facc1518
                      : #f8717118;
            border-width: 1px;
            border-color: root.latency-ms < 10.0 ? #4ade8055
                        : root.latency-ms < 20.0 ? #facc1555
                        : #f8717155;

            Text {
                x: 0px;
                y: 2px;
                width: 26px;
                height: parent.height;
                text: @tr("label-lat");
                color: root.latency-ms < 10.0 ? #4ade8099
                     : root.latency-ms < 20.0 ? #facc1599
                     : #f8717199;
                font-size: 8px;
                font-weight: 700;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            Text {
                x: 29px;
                y: 0px;
                width: parent.width - 30px;
                height: parent.height;
                text: Math.round(root.latency-ms) + "ms";
                color: root.latency-ms < 10.0 ? #4ade80
                     : root.latency-ms < 20.0 ? #facc15
                     : #f87171;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
            }
        }

        ChainActionIcon {
            x: parent.width - 188px;
            y: (parent.height - 30px) / 2;
            icon: @image-url("../assets/gear.svg");
            tooltip: @tr("tooltip-configure");
            clicked => { root.configure-chain(root.chain-index); }
        }

        Rectangle {
            x: parent.width - 148px;
            y: (parent.height - 30px) / 2;
            width: 30px; height: 30px;
            border-radius: 4px;
            background: in-ta.has-hover ? #29df8520 : #29df8510;
            border-width: 1px;
            border-color: #29df8540;
            Text {
                width: 100%; height: 100%;
                text: @tr("label-in");
                color: #29df85;
                font-size: 9px; font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            in-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.configure-input(root.chain-index); }
            }
        }
        Rectangle {
            x: parent.width - 108px;
            y: (parent.height - 30px) / 2;
            width: 30px; height: 30px;
            border-radius: 4px;
            background: out-ta.has-hover ? #e0704020 : #e0704010;
            border-width: 1px;
            border-color: #e0704040;
            Text {
                width: 100%; height: 100%;
                text: @tr("label-out");
                color: #e07040;
                font-size: 9px; font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            out-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.configure-output(root.chain-index); }
            }
        }

        ChainActionIcon {
            x: parent.width - 42px;
            y: (parent.height - 30px) / 2;
            icon: @image-url("../assets/trash.svg");
            tooltip: @tr("tooltip-delete");
            clicked => { root.remove-chain(root.chain-index); }
        }
    }

    // Footer reservation: one 22 px row per stream meter (multi-input
    // chains stack), minimum one row so the IN/OUT pair always fits.
    property <int> meter-row-count:
        root.stream-meters.length > 0 ? root.stream-meters.length : 1;
    property <length> meter-footer-height: root.meter-row-count * 22px + 6px;

    // Block rows with insert slots between them
    Flickable {
        x: 0; y: 66px;
        width: parent.width;
        // Leave room at the bottom for the per-stream IN/OUT meter rows.
        height: parent.height - 66px - root.meter-footer-height;
        viewport-height: root.compact-blocks.length * 112px + 24px;
        interactive: false;

        // Insert slot before first block (invisible until hover)
        Rectangle {
            x: 0; y: 0;
            width: parent.width; height: 12px;

            insert0-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.insert-before-index = 0; root.show-type-picker = true; }
            }

            Rectangle {
                x: 4px; y: 5px;
                width: parent.width - 8px; height: 2px;
                background: #3366cc;
                border-radius: 1px;
                opacity: insert0-ta.has-hover ? 1.0 : 0.0;
            }
            Rectangle {
                x: (parent.width - 24px) / 2; y: 0;
                width: 24px; height: 12px;
                border-radius: 6px;
                background: #3366cc;
                opacity: insert0-ta.has-hover ? 1.0 : 0.0;

                Text {
                    width: 100%; height: 100%;
                    text: @tr("+"); color: #ffffff; font-size: 12px; font-weight: 800;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }

        for block-item[bi] in root.compact-blocks : Rectangle {
            y: 12px + bi * 112px;
            width: parent.width;
            height: 100px;
            // Dim the row being dragged
            opacity: root.drag-active && root.dragging-block-index == bi ? 0.3 : 1.0;

            CompactBlockRow {
                width: parent.width;
                height: 100px;
                block-data: block-item;
                toggle-enabled(ci, bi2) => { root.toggle-block-enabled(ci, bi2); }
                update-parameter-number(ci, bi2, p, v) => { root.update-block-parameter-number(ci, bi2, p, v); }
                update-parameter-bool(ci, bi2, p, v) => { root.update-block-parameter-bool(ci, bi2, p, v); }
                select-parameter-option(ci, bi2, p, oi) => { root.select-block-parameter-option(ci, bi2, p, oi); }
                choose-model(ci, bi2, mi) => { root.choose-block-model(ci, bi2, mi); }
                choose-model-by-id(ci, bi2, mid) => { root.choose-block-model-by-id(ci, bi2, mid); }
                search-model(ci, bi2, text) => { root.search-block-model(ci, bi2, text); }
                open-block-detail(ci, bi2) => { root.open-block-detail(ci, bi2); }
                remove-block(ci, bi2) => { root.remove-block(ci, bi2); }
                open-plugin(model-id) => { root.open-plugin(model-id); }
            }

            // Drag handle — visible grip on left edge
            Rectangle {
                x: 0; y: 0;
                width: 8px; height: parent.height;
                background: drag-ta.has-hover ? #ffffff15 : #ffffff08;
                border-radius: 2px;

                // Grip dots
                Rectangle { x: 2px; y: parent.height / 2 - 10px; width: 4px; height: 4px; border-radius: 2px; background: #ffffff30; }
                Rectangle { x: 2px; y: parent.height / 2;        width: 4px; height: 4px; border-radius: 2px; background: #ffffff30; }
                Rectangle { x: 2px; y: parent.height / 2 + 10px; width: 4px; height: 4px; border-radius: 2px; background: #ffffff30; }
            }

            drag-ta := TouchArea {
                x: 0; y: 0;
                width: 8px; height: parent.height;
                mouse-cursor: grab;

                pointer-event(ev) => {
                    if ev.kind == PointerEventKind.down {
                        root.drag-start-y = self.absolute-position.y / 1px + self.mouse-y / 1px;
                        root.drag-current-y = root.drag-start-y;
                        root.dragging-block-index = bi;
                        root.drag-hover-before-index = -1;
                    }
                    if ev.kind == PointerEventKind.up {
                        if root.drag-active && root.drag-hover-before-index >= 0
                            && root.drag-hover-before-index != root.dragging-block-index
                            && root.drag-hover-before-index != root.dragging-block-index + 1 {
                            root.reorder-block(root.chain-index, root.dragging-block-index, root.drag-hover-before-index);
                        }
                        root.dragging-block-index = -1;
                        root.drag-hover-before-index = -1;
                        root.drag-active = false;
                    }
                }

                moved => {
                    if self.pressed && root.dragging-block-index >= 0 {
                        root.drag-current-y = self.absolute-position.y / 1px + self.mouse-y / 1px;
                        let delta = root.drag-current-y - root.drag-start-y;
                        if !root.drag-active && (delta > 8.0 || delta < -8.0) {
                            root.drag-active = true;
                        }
                        if root.drag-active {
                            // Calculate target slot from drag delta
                            // Each row is 112px. Delta of +112 = move down 1 slot.
                            let delta-slots = Math.round(delta / 112.0);
                            let target = root.dragging-block-index + delta-slots;
                            // Clamp: if moving down, target is "before" index (0..length)
                            let clamped = target < 0 ? 0 : (target > root.compact-blocks.length ? root.compact-blocks.length : target);
                            root.drag-hover-before-index = clamped;
                        }
                    }
                }
            }
        }

        // Drop indicator line (shown during drag)
        if root.drag-active && root.drag-hover-before-index >= 0
            && root.drag-hover-before-index != root.dragging-block-index
            && root.drag-hover-before-index != root.dragging-block-index + 1 : Rectangle {
            x: 8px;
            y: root.drag-hover-before-index * 112px + 12px - 1px;
            width: parent.width - 16px;
            height: 3px;
            border-radius: 1.5px;
            background: #4488ff;
        }

        // Insert slots after each block
        for block-item[bi] in root.compact-blocks : Rectangle {
            x: 0; y: 12px + bi * 112px + 100px;
            width: parent.width; height: 12px;
            visible: !root.drag-active;

            insert-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.insert-before-index = bi + 1; root.show-type-picker = true; }
            }

            Rectangle {
                x: 4px; y: 5px;
                width: parent.width - 8px; height: 2px;
                background: #3366cc;
                border-radius: 1px;
                opacity: insert-ta.has-hover ? 1.0 : 0.0;
            }
            Rectangle {
                x: (parent.width - 24px) / 2; y: 0;
                width: 24px; height: 12px;
                border-radius: 6px;
                background: #3366cc;
                opacity: insert-ta.has-hover ? 1.0 : 0.0;

                Text {
                    width: 100%; height: 100%;
                    text: @tr("+"); color: #ffffff; font-size: 12px; font-weight: 800;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }
    }

    // ── Type picker modal overlay ──
    if root.show-type-picker : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #0405069a;

        TouchArea {
            width: 100%; height: 100%;
            clicked => { root.show-type-picker = false; }
        }

        Rectangle {
            property <int> row-count: Math.max(1, Math.floor((root.block-type-options.length - 1) / 4) + 1);
            property <length> content-height: self.row-count * 100px;
            x: (parent.width - 472px) / 2;
            y: (parent.height - self.height) / 2;
            width: 472px;
            height: Math.min(parent.height - 80px, self.content-height + 40px);
            background: #171a20f8;
            border-width: 1px;
            border-color: #2d3340;
            border-radius: 6px;

            ScrollView {
                x: 20px; y: 20px;
                width: parent.width - 40px;
                height: parent.height - 40px;
                viewport-height: parent.content-height;

                // Same BlockTypeCard the main chains screen uses (#613) —
                // single source of truth for the tile icons, so VST3 /
                // input / output / insert match across both pickers.
                for type-item[index] in root.block-type-options : BlockTypeCard {
                    x: Math.mod(index, 4) * 106px;
                    y: Math.floor(index / 4) * 100px;
                    item: type-item;
                    selected: false;
                    clicked => {
                        root.show-type-picker = false;
                        root.choose-block-type(root.chain-index, root.insert-before-index, index);
                    }
                }
            }
        }
    }

    // ── Footer: per-stream IN / OUT peak meter rows (#496 / #559) ─────
    // One IN/OUT pair per `stream-meters` entry. Multi-input chains
    // (e.g. a 3-input chain) get 3 stacked rows here. Empty list ⇒
    // fall back to the single aggregate `meter-in-dbfs` /
    // `meter-out-dbfs` pair so old wiring keeps working.
    for stream[i] in root.stream-meters: Rectangle {
        x: 0px;
        y: parent.height - 22px
            - (root.stream-meters.length - 1 - i) * 22px;
        width: parent.width;
        height: 16px;

        Rectangle {
            x: 60px; y: 0px;
            width: 220px; height: 16px;
            Text {
                x: 0px; y: 0px;
                width: 44px; height: parent.height;
                text: "INPUT";
                font-size: 8px; font-weight: 700;
                color: #9ca3af;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
            Rectangle {
                x: 48px; y: 2px;
                width: 130px; height: 12px;
                border-width: 1px;
                border-color: stream.in_dbfs > 0.0 ? #f87171 : #2a313a;
                border-radius: 2px;
                background: @linear-gradient(90deg,
                    #facc1560 0%,
                    #facc15 6%,
                    #facc15 35%,
                    #4ade80 50%,
                    #4ade80 88%,
                    #f87171 95%,
                    #f87171 100%);
                Rectangle {
                    x: parent.width * Math.max(0.0,
                        Math.min(1.0, (stream.in_dbfs + 60.0) / 60.0));
                    y: 0px;
                    width: parent.width * (1.0 - Math.max(0.0,
                        Math.min(1.0, (stream.in_dbfs + 60.0) / 60.0)));
                    height: parent.height;
                    background: #0b0e13e8;
                }
            }
            Text {
                x: 182px; y: 0px;
                width: 36px; height: parent.height;
                text: stream.in_dbfs <= -119.0
                    ? "—"
                    : Math.round(stream.in_dbfs) + " dB";
                font-size: 9px; font-weight: 700;
                color: stream.in_dbfs <= -119.0 ? #6b7280
                     : stream.in_dbfs > -3.0     ? #f87171
                     : stream.in_dbfs >= -30.0   ? #4ade80
                     :                              #facc15;
                horizontal-alignment: left;
                vertical-alignment: center;
            }
        }

        Rectangle {
            x: parent.width - 240px; y: 0px;
            width: 230px; height: 16px;
            Text {
                x: 0px; y: 0px;
                width: 50px; height: parent.height;
                text: "OUTPUT";
                font-size: 8px; font-weight: 700;
                color: #9ca3af;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
            Rectangle {
                x: 54px; y: 2px;
                width: 130px; height: 12px;
                border-width: 1px;
                border-color: stream.out_dbfs > 0.0 ? #f87171 : #2a313a;
                border-radius: 2px;
                background: @linear-gradient(90deg,
                    #facc1560 0%,
                    #facc15 6%,
                    #facc15 35%,
                    #4ade80 50%,
                    #4ade80 88%,
                    #f87171 95%,
                    #f87171 100%);
                Rectangle {
                    x: parent.width * Math.max(0.0,
                        Math.min(1.0, (stream.out_dbfs + 60.0) / 60.0));
                    y: 0px;
                    width: parent.width * (1.0 - Math.max(0.0,
                        Math.min(1.0, (stream.out_dbfs + 60.0) / 60.0)));
                    height: parent.height;
                    background: #0b0e13e8;
                }
            }
            Text {
                x: 188px; y: 0px;
                width: 40px; height: parent.height;
                text: stream.out_dbfs <= -119.0
                    ? "—"
                    : Math.round(stream.out_dbfs) + " dB";
                font-size: 9px; font-weight: 700;
                color: stream.out_dbfs <= -119.0 ? #6b7280
                     : stream.out_dbfs > -3.0     ? #f87171
                     : stream.out_dbfs >= -30.0   ? #4ade80
                     :                               #facc15;
                horizontal-alignment: left;
                vertical-alignment: center;
            }
        }
    }

    // Fallback: when `stream-meters` is empty, render the legacy
    // single aggregate IN/OUT pair so wiring that hasn't migrated
    // to per-stream meters still shows something at the footer.
    if root.stream-meters.length == 0 : Rectangle {
        x: 60px;
        y: parent.height - 22px;
        width: 220px;
        height: 16px;
        Text {
            x: 0; y: 0;
            width: 44px; height: parent.height;
            text: "INPUT";
            font-size: 8px; font-weight: 700;
            color: #9ca3af;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
        Rectangle {
            x: 48px; y: 2px;
            width: 130px; height: 12px;
            border-width: 1px;
            border-color: root.meter-in-dbfs > 0.0 ? #f87171 : #2a313a;
            border-radius: 2px;
            background: @linear-gradient(90deg,
                #facc1560 0%,
                #facc15 6%,
                #facc15 35%,
                #4ade80 50%,
                #4ade80 88%,
                #f87171 95%,
                #f87171 100%);
            Rectangle {
                x: parent.width * Math.max(0.0,
                    Math.min(1.0, (root.meter-in-dbfs + 60.0) / 60.0));
                y: 0;
                width: parent.width * (1.0 - Math.max(0.0,
                    Math.min(1.0, (root.meter-in-dbfs + 60.0) / 60.0)));
                height: parent.height;
                background: #0b0e13e8;
            }
        }
        Text {
            x: 182px; y: 0;
            width: 36px; height: parent.height;
            text: root.meter-in-dbfs <= -119.0
                ? "—"
                : Math.round(root.meter-in-dbfs) + " dB";
            font-size: 9px; font-weight: 700;
            color: root.meter-in-dbfs <= -119.0 ? #6b7280
                 : root.meter-in-dbfs > -3.0     ? #f87171
                 : root.meter-in-dbfs >= -30.0   ? #4ade80
                 :                                  #facc15;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }
    if root.stream-meters.length == 0 : Rectangle {
        x: parent.width - 240px;
        y: parent.height - 22px;
        width: 230px;
        height: 16px;
        Text {
            x: 0; y: 0;
            width: 50px; height: parent.height;
            text: "OUTPUT";
            font-size: 8px; font-weight: 700;
            color: #9ca3af;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
        Rectangle {
            x: 54px; y: 2px;
            width: 130px; height: 12px;
            border-width: 1px;
            border-color: root.meter-out-dbfs > 0.0 ? #f87171 : #2a313a;
            border-radius: 2px;
            background: @linear-gradient(90deg,
                #facc1560 0%,
                #facc15 6%,
                #facc15 35%,
                #4ade80 50%,
                #4ade80 88%,
                #f87171 95%,
                #f87171 100%);
            Rectangle {
                x: parent.width * Math.max(0.0,
                    Math.min(1.0, (root.meter-out-dbfs + 60.0) / 60.0));
                y: 0;
                width: parent.width * (1.0 - Math.max(0.0,
                    Math.min(1.0, (root.meter-out-dbfs + 60.0) / 60.0)));
                height: parent.height;
                background: #0b0e13e8;
            }
        }
        Text {
            x: 188px; y: 0;
            width: 40px; height: parent.height;
            text: root.meter-out-dbfs <= -119.0
                ? "—"
                : Math.round(root.meter-out-dbfs) + " dB";
            font-size: 9px; font-weight: 700;
            color: root.meter-out-dbfs <= -119.0 ? #6b7280
                 : root.meter-out-dbfs > -3.0     ? #f87171
                 : root.meter-out-dbfs >= -30.0   ? #4ade80
                 :                                   #facc15;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }
}
