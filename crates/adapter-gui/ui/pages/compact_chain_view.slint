import { ScrollView } from "std-widgets.slint";
import { CompactBlockItem, BlockKnobOverlay, BlockParameterItem, BlockTypePickerItem } from "../models.slint";
import { EffectTypeIcon } from "../components/effect_type_icon.slint";
import { BrandLogo } from "../components/brand_logo.slint";
import { PanelKnob } from "../components/panel_knob.slint";
import { FootSwitch } from "../components/foot_switch.slint";
import { PowerSwitch } from "../components/power_switch.slint";
import { ToggleSwitch } from "../components/toggle_switch.slint";
import { PanelSlider } from "../components/panel_slider.slint";
import { SelectorKnob } from "../components/selector_knob.slint";

import "../fonts/BebasNeue.ttf";

// Single block row
component CompactBlockRow inherits Rectangle {
    in property <CompactBlockItem> block-data;
    callback toggle-enabled(int, int);
    callback update-parameter-number(int, int, string, float);
    callback update-parameter-bool(int, int, string, bool);
    callback select-parameter-option(int, int, string, int);
    callback choose-model(int, int, int); // chain_index, block_index, model_index
    callback open-block-detail(int, int);
    callback remove-block(int, int);
    callback open-plugin(string); // model-id, for VST3 blocks

    height: 100px;
    background: root.block-data.panel-bg;
    border-width: 1px;
    border-color: root.block-data.enabled ? root.block-data.panel-bg.darker(0.3) : #252830;
    opacity: root.block-data.enabled ? 1.0 : 0.5;
    border-radius: 4px;
    clip: true;

    // Subtle metal texture overlay
    Image {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        source: @image-url("../assets/sprites/rack-texture.png");
        image-fit: fill;
        image-rendering: smooth;
        opacity: 0.3;
    }

    // ── 1. Block enable (footswitch sprite) ──
    FootSwitch {
        x: 10px;
        y: (parent.height - 66px) / 2;
        width: 48px; height: 66px;
        enabled: root.block-data.enabled;
        clicked => { root.toggle-enabled(root.block-data.chain-index, root.block-data.block-index); }
    }

    // ── 2. Type icon (always shown) ──
    EffectTypeIcon {
        x: 66px;
        y: (parent.height - 32px) / 2;
        width: 32px; height: 32px;
        icon-kind: root.block-data.icon-kind;
        tint: root.block-data.panel-text;
    }

    // ── 3. Block type label ──
    Text {
        x: 96px;
        y: (parent.height - 18px) / 2;
        width: 60px;
        height: 18px;
        text: root.block-data.display-label;
        color: root.block-data.panel-text;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 1.5px;
        vertical-alignment: center;
    }

    // ── 4. Model selector dropdown (after type label) ──
    Rectangle {
        x: 158px;
        y: (parent.height - 32px) / 2;
        width: 260px;
        height: 32px;
        background: #060610;
        border-width: 1px;
        border-color: #252538;
        border-radius: 5px;

        Text {
            x: 8px; y: 0;
            width: parent.width - 28px;
            height: parent.height;
            text: root.block-data.display-name;
            color: #d8e0ff;
            font-size: 12px;
            font-weight: 700;
            vertical-alignment: center;
            overflow: elide;
        }

        Text {
            x: parent.width - 20px; y: 0;
            width: 16px; height: parent.height;
            text: "\u{25BC}";
            color: #8090a0;
            font-size: 9px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }

        if root.block-data.type-label != "" : Rectangle {
            x: parent.width - 64px;
            y: (parent.height - 16px) / 2;
            width: 36px; height: 16px;
            border-radius: 3px;
            background: root.block-data.type-label == "NATIVE" ? #0d2a0d
                : root.block-data.type-label == "NAM" ? #0d1a2e : #2e1a0d;
            border-width: 1px;
            border-color: root.block-data.type-label == "NATIVE" ? #1a6b1a
                : root.block-data.type-label == "NAM" ? #1a4488 : #883300;
            Text {
                width: 100%; height: 100%;
                text: root.block-data.type-label;
                color: root.block-data.type-label == "NATIVE" ? #33bb33
                    : root.block-data.type-label == "NAM" ? #4499ff : #ff8833;
                font-size: 7px; font-weight: 800;
                horizontal-alignment: center; vertical-alignment: center;
            }
        }

        model-select-ta := TouchArea {
            mouse-cursor: pointer;
            clicked => { model-select-popup.show(); }
        }

        model-select-popup := PopupWindow {
            property <length> list-h: Math.min(root.block-data.model-labels.length * 32px + 6px, 300px);
            x: 0; y: parent.height + 4px;
            width: parent.width; height: self.list-h;
            Rectangle {
                width: 100%; height: 100%;
                background: #08080e; border-width: 1px; border-color: #2a2a40;
                border-radius: 5px; clip: true;
                drop-shadow-blur: 16px; drop-shadow-color: #000000c0;
                Flickable {
                    width: parent.width; height: parent.height;
                    viewport-height: root.block-data.model-labels.length * 32px + 6px;
                    for label[mi] in root.block-data.model-labels : Rectangle {
                        x: 3px; y: 3px + mi * 32px;
                        width: parent.width - 6px; height: 30px;
                        border-radius: 4px;
                        background: mi == root.block-data.model-selected-index ? #14142a : (ml-sel-ta.has-hover ? #ffffff08 : transparent);
                        Text {
                            x: 8px; width: parent.width - 16px; height: parent.height;
                            text: label;
                            color: mi == root.block-data.model-selected-index ? #7788ff : #b0bce0;
                            font-size: 11px;
                            font-weight: mi == root.block-data.model-selected-index ? 700 : 400;
                            vertical-alignment: center; overflow: elide;
                        }
                        ml-sel-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.choose-model(root.block-data.chain-index, root.block-data.block-index, mi); }
                        }
                    }
                }
            }
        }
    }

    // ── 5. Brand logo (branded) or native model illustration ──
    BrandLogo {
        x: 432px;
        y: (parent.height - 28px) / 2;
        width: 60px;
        height: 28px;
        brand: root.block-data.brand;
        tint: root.block-data.panel-text;
    }
    // Native models: show model illustration SVG
    if root.block-data.brand == "" : Image {
        x: 432px; y: (parent.height - 40px) / 2; width: 40px; height: 40px;
        source: root.block-data.model-id == "gate_basic" ? @image-url("../../../../assets/models/gate_basic.svg")
            : root.block-data.model-id == "compressor_studio_clean" ? @image-url("../../../../assets/models/compressor_studio_clean.svg")
            : root.block-data.model-id == "analog_warm" ? @image-url("../../../../assets/models/analog_warm.svg")
            : root.block-data.model-id == "digital_clean" ? @image-url("../../../../assets/models/digital_clean.svg")
            : root.block-data.model-id == "modulated_delay" ? @image-url("../../../../assets/models/modulated_delay.svg")
            : root.block-data.model-id == "reverse" ? @image-url("../../../../assets/models/reverse.svg")
            : root.block-data.model-id == "slapback" ? @image-url("../../../../assets/models/slapback.svg")
            : root.block-data.model-id == "tape_vintage" ? @image-url("../../../../assets/models/tape_vintage.svg")
            : root.block-data.model-id == "plate_foundation" ? @image-url("../../../../assets/models/plate_foundation.svg")
            : root.block-data.model-id == "eq_three_band_basic" ? @image-url("../../../../assets/models/eq_three_band_basic.svg")
            : root.block-data.model-id == "cry_classic" ? @image-url("../../../../assets/models/cry_classic.svg")
            : root.block-data.model-id == "tremolo_sine" ? @image-url("../../../../assets/models/tremolo_sine.svg")
            : root.block-data.model-id == "tuner_chromatic" ? @image-url("../../../../assets/models/tuner_chromatic.svg")
            : root.block-data.model-id == "american_clean" ? @image-url("../../../../assets/models/american_clean.svg")
            : root.block-data.model-id == "brit_crunch" ? @image-url("../../../../assets/models/brit_crunch.svg")
            : root.block-data.model-id == "modern_high_gain" ? @image-url("../../../../assets/models/modern_high_gain.svg")
            : root.block-data.model-id == "blackface_clean" ? @image-url("../../../../assets/models/blackface_clean.svg")
            : root.block-data.model-id == "tweed_breakup" ? @image-url("../../../../assets/models/tweed_breakup.svg")
            : root.block-data.model-id == "chime" ? @image-url("../../../../assets/models/chime.svg")
            : root.block-data.model-id == "american_2x12" ? @image-url("../../../../assets/models/american_2x12.svg")
            : root.block-data.model-id == "brit_4x12" ? @image-url("../../../../assets/models/brit_4x12.svg")
            : root.block-data.model-id == "vintage_1x12" ? @image-url("../../../../assets/models/vintage_1x12.svg")
            : root.block-data.model-id == "generic_ir" ? @image-url("../../../../assets/models/generic_ir.svg")
            : root.block-data.model-id == "generic_nam" ? @image-url("../../../../assets/models/generic_nam.svg")
            : root.block-data.icon-kind == "preamp" ? @image-url("../assets/amp-head.svg")
            : root.block-data.icon-kind == "amp" ? @image-url("../assets/amp-combo.svg")
            : root.block-data.icon-kind == "cab" ? @image-url("../assets/cab.svg")
            : root.block-data.icon-kind == "delay" ? @image-url("../assets/delay.svg")
            : root.block-data.icon-kind == "reverb" ? @image-url("../assets/reverb.svg")
            : root.block-data.icon-kind == "dynamics" ? @image-url("../assets/dyn.svg")
            : root.block-data.icon-kind == "modulation" ? @image-url("../assets/mod.svg")
            : @image-url("../assets/gear.svg");
        image-fit: contain;
        colorize: root.block-data.panel-text;
    }

    // ── Knob overlays (HorizontalLayout, right-aligned) ──
    HorizontalLayout {
        visible: root.block-data.knob-overlays.length > 0;
        alignment: end;
        spacing: 4px;
        padding-right: 34px;
        x: 0;
        y: (parent.height - 90px) / 2;
        width: parent.width;
        height: 90px;

        for knob[ki] in root.block-data.knob-overlays : Rectangle {
            min-width: 56px;
            preferred-width: 62px;
            height: 90px;

            Text {
                x: 0; y: 0; width: parent.width; height: 12px;
                text: knob.label;
                color: root.block-data.panel-text;
                font-family: "Bebas Neue";
                font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
                horizontal-alignment: center;
                overflow: elide;
            }

            PanelKnob {
                x: 2px; y: 14px;
                width: 58px; height: 76px;
                value: knob.value;
                min-val: knob.min_val;
                max-val: knob.max_val;
                step: knob.step;
                path: knob.path;
                changed(p, v) => { root.update-parameter-number(root.block-data.chain-index, root.block-data.block-index, p, v); }
            }
        }
    }

    // ── All parameters (HorizontalLayout, right-aligned) ──
    HorizontalLayout {
        visible: root.block-data.knob-overlays.length == 0 && !root.block-data.has-external-gui;
        alignment: end;
        spacing: 4px;
        padding-right: 34px;
        x: 0;
        y: (parent.height - 90px) / 2;
        width: parent.width;
        height: 90px;

        for param[pi] in root.block-data.parameter-items : Rectangle {
            visible: param.widget_kind != "";
            min-width: param.widget_kind == "enum" && param.option_labels.length <= 4 ? 100px
                : param.widget_kind == "bool" ? 44px
                : 56px;
            preferred-width: param.widget_kind == "enum" && param.option_labels.length <= 4 ? 110px
                : param.widget_kind == "enum" && param.option_labels.length > 4 ? 140px
                : param.widget_kind == "bool" ? 48px
                : 62px;
            height: 90px;

            // Label
            Text {
                x: 0;
                y: 0;
                width: parent.width;
                height: 14px;
                text: param.label;
                color: root.block-data.panel-text;
                font-family: "Bebas Neue";
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 1.5px;
                horizontal-alignment: center;
                overflow: elide;
            }

            // ── Numeric knob/stepper/slider ──
            if param.widget_kind == "stepper" || param.widget_kind == "slider" || param.widget_kind == "knob" : PanelKnob {
                x: 2px; y: 23px;
                width: 52px; height: 68px;
                value: param.numeric_value;
                min-val: param.numeric_min;
                max-val: param.numeric_max;
                step: param.numeric_step;
                path: param.path;
                changed(p, v) => { root.update-parameter-number(root.block-data.chain-index, root.block-data.block-index, p, v); }
            }

            // ── Enum ≤4 options (selector knob + inline labels) ──
            if param.widget_kind == "enum" && param.option_labels.length <= 4 : Rectangle {
                x: 0; y: 14px;
                width: parent.width; height: 76px;
                background: transparent;

                property <length> ks: 48px;
                property <length> cx: self.width / 2;
                property <length> top-row: 4px;
                property <length> knob-y: 16px;
                property <length> bot-row: self.knob-y + self.ks + 2px;
                property <length> lw: Math.max((self.width - self.ks) / 2 - 4px, 0px);
                property <int> n: param.option_labels.length;
                property <int> sel: param.selected_option_index;
                property <color> tc: root.block-data.panel-text;

                SelectorKnob {
                    x: parent.cx - parent.ks / 2;
                    y: parent.knob-y;
                    width: parent.ks; height: parent.ks;
                    num-options: parent.n;
                    selected-index: parent.sel;
                    select(i) => { root.select-parameter-option(root.block-data.chain-index, root.block-data.block-index, param.path, i); }
                }

                // ── Bottom-left label (7h) — option 0 ──
                Text {
                    visible: parent.n >= 2;
                    x: 0; y: parent.bot-row;
                    width: parent.lw; height: 14px;
                    text: param.option_labels.length > 0 ? param.option_labels[0] : "";
                    color: 0 == parent.sel ? #ffaa44 : parent.tc.with-alpha(0.7);
                    font-size: 11px;
                    font-weight: 0 == parent.sel ? 700 : 400;
                    horizontal-alignment: right;
                    overflow: elide;
                }
                TouchArea {
                    visible: parent.n >= 2;
                    x: 0; y: parent.bot-row;
                    width: parent.lw; height: 14px;
                    mouse-cursor: pointer;
                    clicked => { root.select-parameter-option(root.block-data.chain-index, root.block-data.block-index, param.path, 0); }
                }

                // ── Bottom-right label (5h) — last option ──
                Text {
                    visible: parent.n >= 2;
                    x: parent.cx + parent.ks / 2 + 4px; y: parent.bot-row;
                    width: parent.lw; height: 14px;
                    text: parent.n == 2 ? (param.option_labels.length > 1 ? param.option_labels[1] : "")
                        : parent.n == 3 ? (param.option_labels.length > 2 ? param.option_labels[2] : "")
                        : (param.option_labels.length > 3 ? param.option_labels[3] : "");
                    color: (parent.n == 2 ? 1 : parent.n == 3 ? 2 : 3) == parent.sel
                        ? #ffaa44 : parent.tc.with-alpha(0.7);
                    font-size: 11px;
                    font-weight: (parent.n == 2 ? 1 : parent.n == 3 ? 2 : 3) == parent.sel ? 700 : 400;
                    horizontal-alignment: left;
                    overflow: elide;
                }
                TouchArea {
                    visible: parent.n >= 2;
                    x: parent.cx + parent.ks / 2 + 4px; y: parent.bot-row;
                    width: parent.lw; height: 14px;
                    mouse-cursor: pointer;
                    clicked => { root.select-parameter-option(root.block-data.chain-index, root.block-data.block-index, param.path, parent.n == 2 ? 1 : parent.n == 3 ? 2 : 3); }
                }

                // ── Top-center label (12h) — option 1 for 3-opt ──
                Text {
                    visible: parent.n == 3;
                    x: parent.cx - 55px; y: parent.top-row;
                    width: 110px; height: 14px;
                    text: param.option_labels.length > 1 ? param.option_labels[1] : "";
                    color: 1 == parent.sel ? #ffaa44 : parent.tc.with-alpha(0.7);
                    font-size: 11px;
                    font-weight: 1 == parent.sel ? 700 : 400;
                    horizontal-alignment: center;
                    overflow: elide;
                }
                TouchArea {
                    visible: parent.n == 3;
                    x: parent.cx - 55px; y: parent.top-row; width: 110px; height: 14px;
                    mouse-cursor: pointer;
                    clicked => { root.select-parameter-option(root.block-data.chain-index, root.block-data.block-index, param.path, 1); }
                }

                // ── Upper-left label (10h) — option 1 for 4-opt ──
                Text {
                    visible: parent.n == 4;
                    x: 0; y: parent.top-row;
                    width: parent.lw; height: 14px;
                    text: param.option_labels.length > 1 ? param.option_labels[1] : "";
                    color: 1 == parent.sel ? #ffaa44 : parent.tc.with-alpha(0.7);
                    font-size: 11px;
                    font-weight: 1 == parent.sel ? 700 : 400;
                    horizontal-alignment: right;
                    overflow: elide;
                }
                TouchArea {
                    visible: parent.n == 4;
                    x: 0; y: parent.top-row; width: parent.lw; height: 14px;
                    mouse-cursor: pointer;
                    clicked => { root.select-parameter-option(root.block-data.chain-index, root.block-data.block-index, param.path, 1); }
                }

                // ── Upper-right label (2h) — option 2 for 4-opt ──
                Text {
                    visible: parent.n == 4;
                    x: parent.cx + parent.ks / 2 + 4px; y: parent.top-row;
                    width: parent.lw; height: 14px;
                    text: param.option_labels.length > 2 ? param.option_labels[2] : "";
                    color: 2 == parent.sel ? #ffaa44 : parent.tc.with-alpha(0.7);
                    font-size: 11px;
                    font-weight: 2 == parent.sel ? 700 : 400;
                    horizontal-alignment: left;
                    overflow: elide;
                }
                TouchArea {
                    visible: parent.n == 4;
                    x: parent.cx + parent.ks / 2 + 4px; y: parent.top-row; width: parent.lw; height: 14px;
                    mouse-cursor: pointer;
                    clicked => { root.select-parameter-option(root.block-data.chain-index, root.block-data.block-index, param.path, 2); }
                }
            }

            // ── Enum 5+ options (dropdown) ──
            if param.widget_kind == "enum" && param.option_labels.length > 4 : Rectangle {
                x: 0; y: 14px;
                width: parent.width; height: 28px;
                background: #060610;
                border-width: 1px; border-color: #252538; border-radius: 5px;

                Text {
                    x: 8px; width: parent.width - 24px; height: parent.height;
                    text: param.selected_option_index >= 0 && param.selected_option_index < param.option_labels.length
                        ? param.option_labels[param.selected_option_index] : "";
                    color: #d8e0ff; font-size: 11px; font-weight: 600;
                    vertical-alignment: center; overflow: elide;
                }
                Text {
                    x: parent.width - 18px; width: 14px; height: parent.height;
                    text: "\u{25BC}"; color: #ffffff; font-size: 9px;
                    vertical-alignment: center; horizontal-alignment: center;
                }
                dd-ta2 := TouchArea { mouse-cursor: pointer; clicked => { dd-popup2.show(); } }
                dd-popup2 := PopupWindow {
                    property <length> list-h: Math.min(param.option_labels.length * 30px + 6px, 200px);
                    x: 0; y: -self.list-h - 4px; width: parent.width; height: self.list-h;
                    Rectangle {
                        width: 100%; height: 100%;
                        background: #08080e; border-width: 1px; border-color: #2a2a40;
                        border-radius: 5px; clip: true;
                        drop-shadow-blur: 12px; drop-shadow-color: #000000a0;
                        Flickable {
                            width: parent.width; height: parent.height;
                            viewport-height: param.option_labels.length * 30px + 6px;
                            for option[oi] in param.option_labels : Rectangle {
                                x: 3px; y: 3px + oi * 30px;
                                width: parent.width - 6px; height: 28px;
                                border-radius: 4px;
                                background: oi == param.selected_option_index ? #14142a : (opt-ta.has-hover ? #ffffff08 : transparent);
                                Text {
                                    x: 8px; width: parent.width - 16px; height: parent.height;
                                    text: option;
                                    color: oi == param.selected_option_index ? #7788ff : #b0bce0;
                                    font-size: 11px; font-weight: oi == param.selected_option_index ? 600 : 400;
                                    vertical-alignment: center; overflow: elide;
                                }
                                opt-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.select-parameter-option(root.block-data.chain-index, root.block-data.block-index, param.path, oi); }
                                }
                            }
                        }
                    }
                }
            }

            // ── Bool toggle (sprite) ──
            if param.widget_kind == "bool" : ToggleSwitch {
                x: (parent.width - 36px) / 2; y: 26px;
                width: 36px; height: 62px;
                checked: param.bool_value;
                toggled => { root.update-parameter-bool(root.block-data.chain-index, root.block-data.block-index, param.path, !param.bool_value); }
            }
        }
    }

    // ── Stream data display (tuner readings, meter, etc.) ──
    // Width stops before parameter knobs on the right (~180px reserved for params)
    if root.block-data.stream-data.stream-kind != "" && root.block-data.stream-data.stream-kind != "spectrum" : Rectangle {
        x: 470px;
        y: 4px;
        width: parent.width - 470px - 180px;
        height: parent.height - 8px;
        background: transparent;

        // Waiting for signal — shown until pitch is detected
        if !root.block-data.stream-data.active : Text {
            x: 0; y: 0; width: parent.width; height: parent.height;
            text: "–";
            color: #3a4050;
            font-size: 28px; font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        for entry[ei] in root.block-data.stream-data.entries : Rectangle {
            property <length> slot-w: parent.width / root.block-data.stream-data.entries.length;
            x: ei * slot-w;
            y: 0;
            width: slot-w;
            height: parent.height;

            Text {
                x: 0; y: 2px; width: parent.width; height: 12px;
                text: entry.key;
                color: #506070;
                font-size: 7px; font-weight: 700; letter-spacing: 1px;
                horizontal-alignment: center;
            }

            Text {
                x: 0; y: 14px; width: parent.width; height: parent.height - 32px;
                text: entry.text;
                color: entry.value > 0.5 ? #29df85 : root.block-data.panel-text;
                font-size: entry.text.character-count <= 3 ? 28px : 14px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            if entry.key == "cents" : Rectangle {
                x: 8px; y: parent.height - 14px;
                width: parent.width - 16px; height: 6px;
                background: #1a1e28;
                border-radius: 3px;

                Rectangle {
                    x: (parent.width - 1px) / 2;
                    y: 0; width: 1px; height: parent.height;
                    background: #405060;
                }

                Rectangle {
                    property <float> norm: (entry.value / 50.0).clamp(-1.0, 1.0);
                    x: (parent.width / 2) + self.norm * (parent.width / 2) - 3px;
                    y: 0; width: 6px; height: parent.height;
                    background: self.norm > -0.1 && self.norm < 0.1 ? #29df85 : #ff6a57;
                    border-radius: 3px;
                }
            }
        }
    }

    // ── Spectrum analyzer mini bars in compact view ──
    if root.block-data.stream-data.active && root.block-data.stream-data.stream-kind == "spectrum" : Rectangle {
        x: 470px;
        y: 6px;
        width: parent.width - 510px;
        height: parent.height - 12px;
        background: #06060e;
        border-radius: 3px;
        clip: true;

        for entry[ei] in root.block-data.stream-data.entries : Rectangle {
            property <length> bar-slot-w: parent.width / root.block-data.stream-data.entries.length;
            x: ei * self.bar-slot-w;
            y: 0;
            width: self.bar-slot-w;
            height: parent.height;
            background: transparent;

            Rectangle {
                property <length> bar-h: Math.max(1px, entry.value * parent.height);
                x: 1px;
                y: parent.height - self.bar-h;
                width: parent.width - 2px;
                height: self.bar-h;
                background: entry.value > 0.85 ? #ff4433
                    : entry.value > 0.65 ? #ffaa22
                    : entry.value > 0.3 ? #44cc88
                    : #4488ff;
                border-radius: 1px;
            }

            // Peak hold line
            Rectangle {
                x: 1px;
                y: Math.max(0px, parent.height - entry.peak * parent.height - 1px);
                width: parent.width - 2px;
                height: 2px;
                background: entry.peak > 0.85 ? #ff8877
                    : entry.peak > 0.65 ? #ffcc66
                    : entry.peak > 0.3 ? #88ffcc
                    : #88bbff;
                opacity: entry.peak > 0.01 ? 1.0 : 0.0;
            }
        }
    }

    // ── "Abrir Plugin" button (VST3 only, center-right) ──
    if root.block-data.has-external-gui : TouchArea {
        x: parent.width - 148px;
        y: (parent.height - 30px) / 2;
        width: 110px;
        height: 30px;
        mouse-cursor: pointer;
        clicked => { root.open-plugin(root.block-data.model-id); }
        Rectangle {
            width: parent.width; height: parent.height;
            border-radius: 5px;
            background: #2563eb;
            Text {
                width: 100%; height: 100%;
                text: "Abrir Plugin";
                color: #ffffff;
                font-size: 11px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    // ── Delete button (top-right corner, visible on hover) ──
    Rectangle {
        x: parent.width - 28px;
        y: 4px;
        width: 24px;
        height: 24px;
        border-radius: 4px;
        background: del-ta.has-hover ? #ff4444 : transparent;
        opacity: del-ta.has-hover ? 1.0 : 0.4;

        Image {
            x: 4px; y: 4px; width: 16px; height: 16px;
            source: @image-url("../assets/trash.svg");
            image-fit: contain;
            colorize: del-ta.has-hover ? white : #8090a0;
        }

        del-ta := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.remove-block(root.block-data.chain-index, root.block-data.block-index); }
        }
    }
}

// Main page
export component CompactChainViewPage inherits Rectangle {
    in property <string> chain-title;
    in property <int> chain-index;
    in property <[CompactBlockItem]> compact-blocks;

    in property <bool> chain-enabled;
    callback toggle-chain-enabled(int);
    callback toggle-block-enabled(int, int);
    callback update-block-parameter-number(int, int, string, float);
    callback update-block-parameter-bool(int, int, string, bool);
    callback select-block-parameter-option(int, int, string, int);
    callback choose-block-model(int, int, int);
    callback insert-block(int, int); // chain_index, before_index
    callback reorder-block(int, int, int); // chain_index, from_index, before_index
    callback open-block-detail(int, int);
    callback close-compact-view();
    callback choose-block-type(int, int, int); // chain_index, before_index, type_index
    callback remove-block(int, int); // chain_index, block_index
    callback open-plugin(string); // model-id, for VST3 blocks

    // I/O device configuration (reuses the chain list's configure flow)
    callback configure-input(int); // chain_index
    callback configure-output(int); // chain_index

    // Type picker state
    in property <[BlockTypePickerItem]> block-type-options;
    private property <bool> show-type-picker: false;
    private property <int> insert-before-index: 0;

    // Drag-to-reorder state
    private property <int> dragging-block-index: -1;
    private property <int> drag-hover-before-index: -1;
    private property <float> drag-start-y: 0;
    private property <float> drag-current-y: 0;
    private property <bool> drag-active: false;

    background: #0a0c10;

    // Header
    Rectangle {
        x: 0; y: 0; width: parent.width; height: 44px;
        background: #12141a;
        border-width: 0px; border-color: #252830;

        // Chain power toggle (sprite)
        PowerSwitch {
            x: 8px;
            y: (parent.height - 40px) / 2;
            width: 40px; height: 40px;
            enabled: root.chain-enabled;
            clicked => { root.toggle-chain-enabled(root.chain-index); }
        }

        Text {
            x: 44px; width: parent.width - 160px; height: parent.height;
            text: root.chain-title;
            color: #d8e0ff; font-size: 14px; font-weight: 700;
            vertical-alignment: center;
        }

        // IN button
        Rectangle {
            x: parent.width - 108px;
            y: (parent.height - 28px) / 2;
            width: 46px; height: 28px;
            background: in-ta.has-hover ? #29df8520 : #29df8510;
            border-width: 1px;
            border-color: #29df8540;
            border-radius: 4px;

            Text {
                width: 100%; height: 100%;
                text: "IN";
                color: #29df85;
                font-size: 10px; font-weight: 800; letter-spacing: 1px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            in-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    debug("compact IN clicked", root.chain-index);
                    root.configure-input(root.chain-index);
                }
            }
        }

        // OUT button
        Rectangle {
            x: parent.width - 56px;
            y: (parent.height - 28px) / 2;
            width: 46px; height: 28px;
            background: out-ta.has-hover ? #e0704020 : #e0704010;
            border-width: 1px;
            border-color: #e0704040;
            border-radius: 4px;

            Text {
                width: 100%; height: 100%;
                text: "OUT";
                color: #e07040;
                font-size: 10px; font-weight: 800; letter-spacing: 1px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            out-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    debug("compact OUT clicked", root.chain-index);
                    root.configure-output(root.chain-index);
                }
            }
        }
    }

    // Block rows with insert slots between them
    Flickable {
        x: 0; y: 48px;
        width: parent.width;
        height: parent.height - 48px;
        viewport-height: root.compact-blocks.length * 112px + 24px;
        interactive: false;

        // Insert slot before first block (invisible until hover)
        Rectangle {
            x: 0; y: 0;
            width: parent.width; height: 12px;

            insert0-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.insert-before-index = 0; root.show-type-picker = true; }
            }

            Rectangle {
                x: 4px; y: 5px;
                width: parent.width - 8px; height: 2px;
                background: #3366cc;
                border-radius: 1px;
                opacity: insert0-ta.has-hover ? 1.0 : 0.0;
            }
            Rectangle {
                x: (parent.width - 24px) / 2; y: 0;
                width: 24px; height: 12px;
                border-radius: 6px;
                background: #3366cc;
                opacity: insert0-ta.has-hover ? 1.0 : 0.0;

                Text {
                    width: 100%; height: 100%;
                    text: "+"; color: #ffffff; font-size: 12px; font-weight: 800;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }

        for block-item[bi] in root.compact-blocks : Rectangle {
            y: 12px + bi * 112px;
            width: parent.width;
            height: 100px;
            // Dim the row being dragged
            opacity: root.drag-active && root.dragging-block-index == bi ? 0.3 : 1.0;

            CompactBlockRow {
                width: parent.width;
                height: 100px;
                block-data: block-item;
                toggle-enabled(ci, bi2) => { root.toggle-block-enabled(ci, bi2); }
                update-parameter-number(ci, bi2, p, v) => { root.update-block-parameter-number(ci, bi2, p, v); }
                update-parameter-bool(ci, bi2, p, v) => { root.update-block-parameter-bool(ci, bi2, p, v); }
                select-parameter-option(ci, bi2, p, oi) => { root.select-block-parameter-option(ci, bi2, p, oi); }
                choose-model(ci, bi2, mi) => { root.choose-block-model(ci, bi2, mi); }
                open-block-detail(ci, bi2) => { root.open-block-detail(ci, bi2); }
                remove-block(ci, bi2) => { root.remove-block(ci, bi2); }
                open-plugin(model-id) => { root.open-plugin(model-id); }
            }

            // Drag handle — visible grip on left edge
            Rectangle {
                x: 0; y: 0;
                width: 8px; height: parent.height;
                background: drag-ta.has-hover ? #ffffff15 : #ffffff08;
                border-radius: 2px;

                // Grip dots
                Rectangle { x: 2px; y: parent.height / 2 - 10px; width: 4px; height: 4px; border-radius: 2px; background: #ffffff30; }
                Rectangle { x: 2px; y: parent.height / 2;        width: 4px; height: 4px; border-radius: 2px; background: #ffffff30; }
                Rectangle { x: 2px; y: parent.height / 2 + 10px; width: 4px; height: 4px; border-radius: 2px; background: #ffffff30; }
            }

            drag-ta := TouchArea {
                x: 0; y: 0;
                width: 8px; height: parent.height;
                mouse-cursor: grab;

                pointer-event(ev) => {
                    if ev.kind == PointerEventKind.down {
                        root.drag-start-y = self.absolute-position.y / 1px + self.mouse-y / 1px;
                        root.drag-current-y = root.drag-start-y;
                        root.dragging-block-index = bi;
                        root.drag-hover-before-index = -1;
                    }
                    if ev.kind == PointerEventKind.up {
                        if root.drag-active && root.drag-hover-before-index >= 0
                            && root.drag-hover-before-index != root.dragging-block-index
                            && root.drag-hover-before-index != root.dragging-block-index + 1 {
                            root.reorder-block(root.chain-index, root.dragging-block-index, root.drag-hover-before-index);
                        }
                        root.dragging-block-index = -1;
                        root.drag-hover-before-index = -1;
                        root.drag-active = false;
                    }
                }

                moved => {
                    if self.pressed && root.dragging-block-index >= 0 {
                        root.drag-current-y = self.absolute-position.y / 1px + self.mouse-y / 1px;
                        let delta = root.drag-current-y - root.drag-start-y;
                        if !root.drag-active && (delta > 8.0 || delta < -8.0) {
                            root.drag-active = true;
                        }
                        if root.drag-active {
                            // Calculate target slot from drag delta
                            // Each row is 112px. Delta of +112 = move down 1 slot.
                            let delta-slots = Math.round(delta / 112.0);
                            let target = root.dragging-block-index + delta-slots;
                            // Clamp: if moving down, target is "before" index (0..length)
                            let clamped = target < 0 ? 0 : (target > root.compact-blocks.length ? root.compact-blocks.length : target);
                            root.drag-hover-before-index = clamped;
                        }
                    }
                }
            }
        }

        // Drop indicator line (shown during drag)
        if root.drag-active && root.drag-hover-before-index >= 0
            && root.drag-hover-before-index != root.dragging-block-index
            && root.drag-hover-before-index != root.dragging-block-index + 1 : Rectangle {
            x: 8px;
            y: root.drag-hover-before-index * 112px + 12px - 1px;
            width: parent.width - 16px;
            height: 3px;
            border-radius: 1.5px;
            background: #4488ff;
        }

        // Insert slots after each block
        for block-item[bi] in root.compact-blocks : Rectangle {
            x: 0; y: 12px + bi * 112px + 100px;
            width: parent.width; height: 12px;
            visible: !root.drag-active;

            insert-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.insert-before-index = bi + 1; root.show-type-picker = true; }
            }

            Rectangle {
                x: 4px; y: 5px;
                width: parent.width - 8px; height: 2px;
                background: #3366cc;
                border-radius: 1px;
                opacity: insert-ta.has-hover ? 1.0 : 0.0;
            }
            Rectangle {
                x: (parent.width - 24px) / 2; y: 0;
                width: 24px; height: 12px;
                border-radius: 6px;
                background: #3366cc;
                opacity: insert-ta.has-hover ? 1.0 : 0.0;

                Text {
                    width: 100%; height: 100%;
                    text: "+"; color: #ffffff; font-size: 12px; font-weight: 800;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }
    }

    // ── Type picker modal overlay ──
    if root.show-type-picker : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #0405069a;

        TouchArea {
            width: 100%; height: 100%;
            clicked => { root.show-type-picker = false; }
        }

        Rectangle {
            property <int> row-count: Math.max(1, Math.floor((root.block-type-options.length - 1) / 4) + 1);
            property <length> content-height: self.row-count * 100px;
            x: (parent.width - 472px) / 2;
            y: (parent.height - self.height) / 2;
            width: 472px;
            height: Math.min(parent.height - 80px, self.content-height + 40px);
            background: #171a20f8;
            border-width: 1px;
            border-color: #2d3340;
            border-radius: 6px;

            ScrollView {
                x: 20px; y: 20px;
                width: parent.width - 40px;
                height: parent.height - 40px;
                viewport-height: parent.content-height;

                for type-item[index] in root.block-type-options : Rectangle {
                    x: Math.mod(index, 4) * 106px;
                    y: Math.floor(index / 4) * 100px;
                    width: 100px;
                    height: 96px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: type-item.accent-color;
                    background: type-ta.has-hover ? #252830 : #1a1d24;

                    Text {
                        x: 0; y: 6px; width: parent.width; height: 16px;
                        text: type-item.label;
                        color: #d8e0ff;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                    }

                    EffectTypeIcon {
                        x: (parent.width - 48px) / 2;
                        y: 28px;
                        width: 48px;
                        height: 48px;
                        icon-kind: type-item.icon-kind;
                        tint: type-item.accent-color;
                    }

                    type-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.show-type-picker = false;
                            root.choose-block-type(root.chain-index, root.insert-before-index, index);
                        }
                    }
                }
            }
        }
    }

}
