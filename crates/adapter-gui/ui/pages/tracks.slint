// Tracks catalog screen (#553).
//
// Layout: search bar + import button on top, list of cards (Moises-
// style) below. Empty state when the catalog is empty. Routing into
// this page and the Track detail view land in follow-up commits.

import { ScrollView, LineEdit } from "std-widgets.slint";

export struct TrackRowData {
    id: string,
    title: string,
    artist: string,
    duration: string,
    stem-count: int,
    cover-art: image,
    pending: bool,
}

export component TracksPage inherits Rectangle {
    in property <[TrackRowData]> tracks;
    in-out property <string> search-text;

    callback import-clicked();
    callback track-clicked(string);
    callback search-changed(string);
    callback back-clicked();

    background: #15171a;

    VerticalLayout {
        padding: 24px;
        spacing: 16px;

        // Header
        HorizontalLayout {
            spacing: 12px;
            alignment: stretch;

            Rectangle {
                width: 64px;
                height: 32px;
                background: #2f3339;
                border-width: 1px;
                border-color: #4c515b;
                border-radius: 4px;
                y: 8px;

                Text {
                    text: @tr("tracks-back");
                    color: #f4f7fb;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea { clicked => { root.back-clicked(); } }
            }

            Text {
                text: @tr("tracks-title");
                color: #f4f7fb;
                font-size: 22px;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 220px;
                height: 36px;
                background: #2f3339;
                border-width: 1px;
                border-color: #4c515b;
                border-radius: 4px;

                LineEdit {
                    x: 8px;
                    y: 0px;
                    width: parent.width - 16px;
                    height: parent.height;
                    placeholder-text: @tr("tracks-search-placeholder");
                    text <=> root.search-text;
                    edited(t) => { root.search-changed(t); }
                }
            }

            Rectangle {
                width: 180px;
                height: 36px;
                background: #188cff;
                border-width: 1px;
                border-color: #45a7ff;
                border-radius: 4px;

                Text {
                    text: @tr("tracks-import");
                    color: #f4f7fb;
                    font-size: 13px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.import-clicked(); }
                }
            }
        }

        // Empty state OR list
        if root.tracks.length == 0 : Rectangle {
            background: transparent;
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 14px;
                alignment: center;
                width: parent.width;
                height: parent.height;

                Rectangle {
                    width: 96px;
                    height: 96px;
                    background: @linear-gradient(180deg, #2a2d33 0%, #16181c 100%);
                    border-radius: 16px;
                    border-width: 1px;
                    border-color: #3d4148;
                    horizontal-stretch: 0;

                    Image {
                        x: 22px;
                        y: 22px;
                        width: 52px;
                        height: 52px;
                        source: @image-url("../assets/tracks.svg");
                        image-fit: contain;
                        colorize: #6e7682;
                    }
                }

                Text {
                    text: @tr("tracks-empty");
                    color: #b6bcc4;
                    font-size: 16px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }
                Text {
                    text: @tr("tracks-empty-hint");
                    color: #6e7682;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }
        }

        if root.tracks.length > 0 : ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 8px;

                for track in root.tracks : Rectangle {
                    height: 72px;
                    background: track.pending
                        ? @linear-gradient(180deg, #1a2530 0%, #14202b 100%)
                        : @linear-gradient(180deg, #1d2024 0%, #16181c 100%);
                    border-width: 1px;
                    border-color: track.pending ? #2e8ad9 : #2f3339;
                    border-radius: 8px;
                    drop-shadow-color: track.pending ? #2e8ad988 : #00000060;
                    drop-shadow-offset-y: 1px;
                    drop-shadow-blur: track.pending ? 8px : 3px;

                    HorizontalLayout {
                        padding: 10px;
                        spacing: 14px;
                        alignment: stretch;

                        // Cover art (or stylized placeholder when no embedded image).
                        Rectangle {
                            width: 52px;
                            height: 52px;
                            background: @linear-gradient(180deg, #2a2d33 0%, #16181c 100%);
                            border-width: 1px;
                            border-color: track.pending ? #2e8ad9 : #3d4148;
                            border-radius: 6px;
                            clip: true;

                            if !track.pending : Image {
                                width: parent.width;
                                height: parent.height;
                                source: track.cover-art;
                                image-fit: cover;
                            }

                            // Pulse indicator for pending entries.
                            if track.pending : Rectangle {
                                x: (parent.width - 28px) / 2;
                                y: (parent.height - 28px) / 2;
                                width: 28px;
                                height: 28px;
                                border-radius: 14px;
                                background: #2e8ad9;
                                opacity: 0.85;
                                border-width: 2px;
                                border-color: #69b7ff;
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 2px;
                            alignment: center;
                            Text {
                                text: track.title;
                                color: #f4f7fb;
                                font-size: 15px;
                                font-weight: 700;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: track.artist;
                                    color: track.pending ? #69b7ff : #b6bcc4;
                                    font-size: 12px;
                                    font-weight: track.pending ? 600 : 400;
                                }
                                Text {
                                    text: track.pending ? "" : track.stem-count + " stems";
                                    color: #8a929e;
                                    font-size: 11px;
                                    font-weight: 600;
                                }
                            }
                        }
                        Text {
                            text: track.duration;
                            color: track.pending ? #69b7ff : #8a929e;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            width: 100px;
                            horizontal-alignment: right;
                        }
                    }

                    TouchArea {
                        clicked => {
                            if (!track.pending) {
                                root.track-clicked(track.id);
                            }
                        }
                    }
                }
            }
        }
    }
}
