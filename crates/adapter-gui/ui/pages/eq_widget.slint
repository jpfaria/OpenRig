import { MultiSliderPoint, CurveEditorPoint } from "../models.slint";

import "../fonts/BebasNeue.ttf";

// Single vertical band slider used inside EqWidget. Built from primitives
// (Rectangle + TouchArea) — no sprite — so the slider scales to whatever
// height the parent gives it.
component EqBandSlider inherits Rectangle {
    in property <string> path;
    in property <string> freq-label;
    in property <float> value;
    in property <float> min-val;
    in property <float> max-val;
    in property <float> step;

    callback changed(string, float);

    private property <float> drag-y0: 0;
    private property <float> drag-val0: 0;
    private property <bool> preview-active: false;
    private property <float> preview-val: 0;
    private property <float> shown-val:
        root.preview-active ? root.preview-val : root.value;
    private property <float> norm: root.max-val > root.min-val
        ? Math.max(0.0, Math.min(1.0,
            (root.shown-val - root.min-val) / (root.max-val - root.min-val)))
        : 0.5;

    // Layout slots
    private property <length> top-h: 18px;
    private property <length> bottom-h: 14px;
    private property <length> track-y: root.top-h + 8px;
    private property <length> track-h: root.height - root.top-h - root.bottom-h - 16px;
    private property <length> handle-y: root.track-y + (1.0 - root.norm) * root.track-h;

    background: transparent;

    // ── dB value (top) ──
    Text {
        x: 0; y: 0;
        width: parent.width;
        height: root.top-h;
        text: Math.abs(root.shown-val) < 0.05
            ? "0.0"
            : root.shown-val >= 0
                ? "+" + Math.round(root.shown-val * 10) / 10
                : Math.round(root.shown-val * 10) / 10;
        color: Math.abs(root.shown-val) < 0.05 ? #6a7185 : white;
        font-family: "Bebas Neue";
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // ── Track ──
    Rectangle {
        x: (parent.width - 4px) / 2;
        y: root.track-y;
        width: 4px;
        height: root.track-h;
        background: #1d2230;
        border-radius: 2px;
    }

    // ── Center 0 dB tick (only if range crosses zero) ──
    if root.min-val < 0 && root.max-val > 0 : Rectangle {
        x: (parent.width - 16px) / 2;
        y: root.track-y + root.track-h / 2 - 0.5px;
        width: 16px;
        height: 1px;
        background: #5a6175;
    }

    // ── Filled segment (centerline → handle) ──
    Rectangle {
        property <length> center-y: root.track-y + root.track-h / 2;
        x: (parent.width - 4px) / 2;
        y: Math.min(root.handle-y, self.center-y);
        width: 4px;
        height: Math.max(1px, Math.abs(root.handle-y - self.center-y));
        background: #5cb8ff;
        opacity: 0.55;
        border-radius: 2px;
    }

    // ── Handle ──
    Rectangle {
        x: (parent.width - 36px) / 2;
        y: root.handle-y - 8px;
        width: 36px;
        height: 16px;
        border-radius: 4px;
        background: ta.pressed ? #ffffff
            : ta.has-hover ? #e8eef8
            : #d8e0ff;
        border-width: 1px;
        border-color: #00000080;
        // Ridge lines on the handle (fader cap detail)
        Rectangle {
            x: 4px; y: parent.height / 2 - 3px;
            width: parent.width - 8px; height: 1px;
            background: #00000040;
        }
        Rectangle {
            x: 4px; y: parent.height / 2 + 2px;
            width: parent.width - 8px; height: 1px;
            background: #00000040;
        }
    }

    // ── Frequency label (bottom) ──
    Text {
        x: 0;
        y: parent.height - root.bottom-h;
        width: parent.width;
        height: root.bottom-h;
        text: root.freq-label;
        color: #8090a5;
        font-family: "Bebas Neue";
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.5px;
        horizontal-alignment: center;
        overflow: elide;
    }

    // ── Drag interaction ──
    ta := TouchArea {
        x: 0;
        y: root.top-h;
        width: parent.width;
        height: parent.height - root.top-h - root.bottom-h;
        mouse-cursor: ta.pressed ? none : ns-resize;

        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down) {
                root.drag-y0 = ta.mouse-y / 1px;
                root.drag-val0 = root.value;
                root.preview-active = true;
                root.preview-val = root.value;
            }
            if (ev.kind == PointerEventKind.up) {
                if (root.preview-active) {
                    root.changed(root.path, root.preview-val);
                    root.preview-active = false;
                }
            }
        }

        moved => {
            if (ta.pressed) {
                let delta-px = root.drag-y0 - ta.mouse-y / 1px;
                let range = root.max-val - root.min-val;
                let raw = root.drag-val0 + delta-px * range / 120.0;
                let clamped = raw < root.min-val
                    ? root.min-val
                    : (raw > root.max-val ? root.max-val : raw);
                let stepped = root.step > 0.0
                    ? Math.round(clamped / root.step) * root.step
                    : clamped;
                root.preview-val = stepped;
            }
        }

        // Double-click resets to centre (0 dB if range crosses zero)
        double-clicked => {
            let target = root.min-val < 0 && root.max-val > 0
                ? 0
                : (root.max-val + root.min-val) / 2;
            root.changed(root.path, target);
        }
    }
}

// Graphic-EQ widget — bands carry only a gain value.
export component MultiSliderControl inherits Rectangle {
    in property <[MultiSliderPoint]> points;
    callback update-parameter(string, float);

    background: transparent;
    private property <length> slot-w: root.points.length > 0
        ? root.width / root.points.length
        : 64px;

    for point[i] in root.points : EqBandSlider {
        x: i * root.slot-w;
        y: 0;
        width: root.slot-w;
        height: parent.height;
        path: point.path;
        freq-label: point.label;
        value: point.value;
        min-val: point.min-val;
        max-val: point.max-val;
        step: point.step;
        changed(p, v) => { root.update-parameter(p, v); }
    }
}

// Parametric-EQ widget — bands have a gain plus formatted frequency text.
export component CurveEditorControl inherits Rectangle {
    in property <[CurveEditorPoint]> points;
    in property <string> total-curve;     // unused — kept for prop compatibility
    in property <[string]> band-curves;   // unused — kept for prop compatibility
    callback update-parameter(string, float);

    background: transparent;
    private property <length> slot-w: root.points.length > 0
        ? root.width / root.points.length
        : 64px;

    for point[i] in root.points : EqBandSlider {
        x: i * root.slot-w;
        y: 0;
        width: root.slot-w;
        height: parent.height;
        path: point.y-path;
        freq-label: point.x-label;
        value: point.y-value;
        min-val: point.y-min;
        max-val: point.y-max;
        step: point.y-step > 0 ? point.y-step : 0.1;
        changed(p, v) => { root.update-parameter(p, v); }
    }
}
