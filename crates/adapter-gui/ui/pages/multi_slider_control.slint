import { MultiSliderPoint } from "../models.slint";
import { PanelSlider } from "../components/panel_slider.slint";

import "../fonts/BebasNeue.ttf";

export component MultiSliderControl inherits Rectangle {
    in property <[MultiSliderPoint]> points;

    callback update-parameter(string, float);

    height: 180px;
    background: #06060e;
    border-radius: 6px;
    clip: true;

    // Adaptive width per slider: fill available space
    private property <length> slot-w: root.points.length > 0
        ? Math.max(24px, (root.width - 16px) / root.points.length)
        : 64px;
    private property <length> slider-w: Math.min(self.slot-w - 2px, 36px);

    Flickable {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        viewport-width: root.points.length * root.slot-w + 16px;
        viewport-height: parent.height;

        for point[i] in root.points : Rectangle {
            x: 8px + i * root.slot-w;
            y: 0;
            width: root.slot-w;
            height: parent.height;

            // Band label at top
            Text {
                x: 0; y: 2px;
                width: parent.width; height: 12px;
                text: point.label;
                color: #ffffff80;
                font-family: "Bebas Neue";
                font-size: root.slot-w < 36px ? 7px : 9px;
                font-weight: 700; letter-spacing: 0.5px;
                horizontal-alignment: center;
                overflow: elide;
            }

            // PanelSlider sprite (amsynth light-slider, aspect 1:3.2)
            PanelSlider {
                x: (parent.width - root.slider-w) / 2;
                y: 16px;
                width: root.slider-w;
                height: parent.height - 18px;
                value: point.value;
                min-val: point.min-val;
                max-val: point.max-val;
                step: point.step;
                path: point.path;
                changed(p, v) => { root.update-parameter(p, v); }
            }
        }
    }
}
