import { MultiSliderPoint } from "../models.slint";

export component MultiSliderControl inherits Rectangle {
    in property <[MultiSliderPoint]> points;

    callback update-parameter(string, float);

    height: 180px;
    background: #06060e;
    border-radius: 6px;
    clip: true;

    // Bottom 20px reserved for band labels
    private property <length> chart-h: root.height - 20px;

    // 0 dB center line
    Rectangle {
        x: 0; y: root.chart-h / 2;
        width: parent.width; height: 1px;
        background: #ffffff30;
    }

    // Sliders — one per point
    for point[i] in root.points : Rectangle {
        private property <float> norm: (point.value - point.min-val) / Math.max(0.001, point.max-val - point.min-val);

        property <length> slider-w: Math.max(4px, (root.width - 2px) / Math.max(1, root.points.length) - 1px);
        x: i * (self.slider-w + 1px);
        y: 0;
        width: self.slider-w;
        height: parent.height;

        // Full-column touch area — absolute mouse-y → value, no start-norm
        TouchArea {
            mouse-cursor: ns-resize;
            moved => {
                let track-top = 4.0;
                let track-h = root.chart-h / 1px - 8.0;
                let norm = Math.clamp(1.0 - (self.mouse-y / 1px - track-top) / track-h, 0.0, 1.0);
                let new-val = Math.clamp(
                    point.min-val + norm * (point.max-val - point.min-val),
                    point.min-val, point.max-val);
                root.update-parameter(point.path, new-val);
            }
            clicked => {
                let track-top = 4.0;
                let track-h = root.chart-h / 1px - 8.0;
                let norm = Math.clamp(1.0 - (self.mouse-y / 1px - track-top) / track-h, 0.0, 1.0);
                let new-val = Math.clamp(
                    point.min-val + norm * (point.max-val - point.min-val),
                    point.min-val, point.max-val);
                root.update-parameter(point.path, new-val);
            }
        }

        // Track
        Rectangle {
            x: parent.width / 2 - 1px;
            y: 4px;
            width: 2px;
            height: root.chart-h - 8px;
            background: #ffffff15;
        }

        // Fill from 0 dB to current value
        Rectangle {
            property <float> center-norm: (0.0 - point.min-val) / Math.max(0.001, point.max-val - point.min-val);
            property <length> center-y: (1.0 - parent.norm) * (root.chart-h - 8px) + 4px;
            property <length> zero-y: (1.0 - self.center-norm) * (root.chart-h - 8px) + 4px;
            x: parent.width / 2 - 2px;
            y: Math.min(self.center-y, self.zero-y);
            width: 4px;
            height: Math.abs(self.center-y - self.zero-y);
            background: #4488ff80;
        }

        // Thumb (visual only — interaction is on TouchArea above)
        Rectangle {
            property <length> thumb-w: Math.min(parent.width - 4px, 48px);
            x: (parent.width - self.thumb-w) / 2;
            y: (1.0 - parent.norm) * (root.chart-h - 8px) + 4px - 2px;
            width: self.thumb-w;
            height: 4px;
            border-radius: 2px;
            background: #88aaff;
        }

        // Band frequency label at the bottom
        Text {
            x: 0;
            y: root.chart-h + 4px;
            width: parent.width;
            text: point.label;
            color: #ffffff80;
            font-size: 9px;
            horizontal-alignment: center;
            overflow: elide;
        }
    }
}
