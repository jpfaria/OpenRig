// TunerWindow — top-bar feature replacing the chromatic_tuner plugin block.
// One row per active input channel of each enabled chain.
//
// Visual: stompbox-style card with amber LCD à la x42 Tuna / Korg / Boss.
// Card paints `tuner-box.png` (scratched-black pedal texture, lifted from
// the LV2 tuna plugin assets) as background, then floats an LCD rectangle
// in front. LCD goes amber (#ccaa66) when active, vivid green (#ccff66)
// when in tune, dim ochre (#776633) when no signal.
import { ScrollView } from "std-widgets.slint";

export struct TunerRow {
    label: string,
    note: string,
    octave: int,
    cents: float,
    frequency: float,
    active: bool,
}

// ── Header mute pill ─────────────────────────────────────────────────────
component MutePill inherits Rectangle {
    in-out property <bool> muted;
    callback toggled(bool);

    width: 110px;
    height: 28px;
    border-radius: 14px;
    background: root.muted ? #5a1818 : #1c2028;
    border-width: 1px;
    border-color: root.muted ? #ff5050 : #2c323d;

    Rectangle {
        x: 8px;
        y: 9px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: root.muted ? #ff7878 : #4a525e;
    }

    Text {
        x: 26px; y: 0;
        width: parent.width - 36px; height: parent.height;
        text: root.muted ? "MUTED" : "MUTE OUT";
        color: root.muted ? #ffe0e0 : #c5cdd9;
        font-family: "Bebas Neue";
        font-size: 11px;
        letter-spacing: 1.5px;
        vertical-alignment: center;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.muted = !root.muted;
            root.toggled(root.muted);
        }
    }
}

// ── Single-row tuner card — stompbox + LCD ───────────────────────────────
component TunerCard inherits Rectangle {
    in property <TunerRow> data;

    property <bool> in-tune: data.active && Math.abs(data.cents) < 5.0;
    property <color> lcd-bg: !data.active
        ? #776633  // dim ochre (no signal)
        : in-tune
            ? #ccff66  // vivid green (in tune)
            : #ccaa66; // amber (active, off pitch)
    property <color> needle-color: !data.active
        ? #4a3a1a
        : in-tune
            ? #2a6633
            : Math.abs(data.cents) < 15.0 ? #b87a1a : #a02828;

    height: 132px;
    border-radius: 10px;
    clip: true;
    background: black;
    drop-shadow-blur: 8px;
    drop-shadow-color: #000000aa;

    // Stompbox texture background — lifted from tuna.lv2/modgui/box.png
    Image {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        source: @image-url("../assets/tuner-box.png");
        image-fit: cover;
    }

    // ── Top label strip (channel info) ──────────────────────────────────
    Rectangle {
        x: 16px; y: 10px;
        width: parent.width - 32px;
        height: 18px;

        Text {
            x: 0; y: 0;
            width: parent.width; height: parent.height;
            text: root.data.label;
            color: #b8a070;
            font-family: "Bebas Neue";
            font-size: 11px;
            letter-spacing: 1.6px;
            overflow: elide;
        }
    }

    // ── LCD area ────────────────────────────────────────────────────────
    Rectangle {
        x: 16px; y: 36px;
        width: parent.width - 32px;
        height: parent.height - 52px;
        border-radius: 4px;
        background: root.lcd-bg;
        border-width: 1px;
        border-color: #00000088;
        clip: true;

        // Inner shadow simulation (top + left dark inset)
        Rectangle {
            x: 0; y: 0;
            width: parent.width; height: 3px;
            background: #00000044;
        }
        Rectangle {
            x: 0; y: 0;
            width: 3px; height: parent.height;
            background: #00000044;
        }

        // ── Note glyph (huge, left) ─────────────────────────────────────
        Text {
            x: 18px; y: 0;
            width: 130px;
            height: parent.height;
            text: root.data.active ? root.data.note : "—";
            color: #1a1206;
            font-family: "Bebas Neue";
            font-size: 76px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
        // Octave subscript
        if root.data.active : Text {
            x: 110px; y: 22px;
            width: 60px; height: 28px;
            text: root.data.octave + "";
            color: #1a1206;
            font-family: "Bebas Neue";
            font-size: 26px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        // ── Hz readout (top-right) ──────────────────────────────────────
        Text {
            x: parent.width - 130px; y: 8px;
            width: 120px; height: 18px;
            text: root.data.active && root.data.frequency > 0.0
                ? Math.round(root.data.frequency * 100) / 100 + " Hz"
                : "----- Hz";
            color: #1a1206;
            font-family: "Bebas Neue";
            font-size: 14px;
            letter-spacing: 1.2px;
            horizontal-alignment: right;
        }

        // ── Cents bar (right side) ──────────────────────────────────────
        Rectangle {
            x: parent.width - 240px;
            y: 38px;
            width: 220px;
            height: 22px;
            background: #00000033;
            border-radius: 3px;
            border-width: 1px;
            border-color: #00000066;

            // Center marker (zero)
            Rectangle {
                x: parent.width / 2 - 1px;
                y: 3px;
                width: 2px;
                height: parent.height - 6px;
                background: #1a120688;
            }

            // Major ticks at ±25 / ±50
            for tick in [-50, -25, 25, 50] : Rectangle {
                x: (parent.width / 2) + (tick / 50.0 * (parent.width / 2 - 6px)) - 0.5px;
                y: 4px;
                width: 1px;
                height: 6px;
                background: #1a120666;
            }

            // Sub-ticks at ±5 / ±10
            for tick in [-10, -5, 5, 10] : Rectangle {
                x: (parent.width / 2) + (tick / 50.0 * (parent.width / 2 - 6px)) - 0.5px;
                y: parent.height - 9px;
                width: 1px;
                height: 5px;
                background: #1a120666;
            }

            // Needle
            if root.data.active : Rectangle {
                x: (parent.width / 2)
                    + (Math.clamp(root.data.cents, -50.0, 50.0) / 50.0 * (parent.width / 2 - 6px))
                    - 3px;
                y: 2px;
                width: 6px;
                height: parent.height - 4px;
                border-radius: 3px;
                background: root.needle-color;
            }
        }

        // ── Cents readout (below bar) ───────────────────────────────────
        Text {
            x: parent.width - 240px;
            y: 64px;
            width: 220px;
            height: 16px;
            text: root.data.active
                ? (root.data.cents >= 0
                    ? "+" + Math.round(root.data.cents) + " ¢"
                    : Math.round(root.data.cents) + " ¢")
                : "-- ¢";
            color: #1a1206;
            font-family: "Bebas Neue";
            font-size: 16px;
            letter-spacing: 1.4px;
            horizontal-alignment: center;
        }
    }
}

export component TunerWindow inherits Window {
    icon: @image-url("../assets/openrig-logomark.svg");
    default-font-family: "Bebas Neue";
    default-font-size: 13px;
    title: "OpenRig · Tuner";
    min-width: 720px;
    min-height: 280px;
    preferred-width: 880px;
    preferred-height: 480px;
    background: @linear-gradient(180deg, #08090d 0%, #050608 100%);

    in property <[TunerRow]> tuner-rows;
    in property <bool> mute-active;
    callback close-tuner-window();
    callback toggle-mute(bool);

    // ── Header bar ───────────────────────────────────────────────────────
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: 56px;
        background: #0c0e12;

        Rectangle {
            x: 0; y: parent.height - 1px;
            width: parent.width; height: 1px;
            background: #1c2028;
        }

        // LED dot
        Rectangle {
            x: 20px; y: 18px;
            width: 20px; height: 20px;
            border-radius: 10px;
            background: @radial-gradient(circle, #5cffaa 0%, #1a8855 60%, #08382a 100%);
        }

        Text {
            x: 50px; y: 0;
            width: 160px; height: parent.height;
            text: "TUNER";
            color: #e5ebf2;
            font-family: "Bebas Neue";
            font-size: 18px;
            letter-spacing: 3.0px;
            vertical-alignment: center;
        }

        // Input count chip
        if root.tuner-rows.length > 0 : Rectangle {
            x: 130px; y: 18px;
            width: 70px; height: 20px;
            border-radius: 10px;
            background: #1a2230;
            border-width: 1px;
            border-color: #2a3340;

            Text {
                x: 0; y: 0;
                width: parent.width; height: parent.height;
                text: root.tuner-rows.length
                    + (root.tuner-rows.length == 1 ? " INPUT" : " INPUTS");
                color: #88a3c7;
                font-family: "Bebas Neue";
                font-size: 10px;
                letter-spacing: 1.4px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        // Mute pill
        MutePill {
            x: parent.width - 130px; y: 14px;
            muted: root.mute-active;
            toggled(m) => { root.toggle-mute(m); }
        }
    }

    // ── Empty state ──────────────────────────────────────────────────────
    if root.tuner-rows.length == 0 : Rectangle {
        x: 0; y: 56px;
        width: parent.width;
        height: parent.height - 56px;

        Text {
            x: 0; y: parent.height / 2 - 32px;
            width: parent.width; height: 24px;
            text: "NO ACTIVE INPUTS";
            color: #4a525e;
            font-family: "Bebas Neue";
            font-size: 16px;
            letter-spacing: 2.4px;
            horizontal-alignment: center;
        }
        Text {
            x: 0; y: parent.height / 2 - 4px;
            width: parent.width; height: 20px;
            text: "Enable a chain with a configured input to see its tuners here.";
            color: #4a525e;
            font-family: "Inter";
            font-size: 11px;
            horizontal-alignment: center;
        }
    }

    // ── Tuner cards ──────────────────────────────────────────────────────
    if root.tuner-rows.length > 0 : ScrollView {
        x: 16px; y: 72px;
        width: parent.width - 32px;
        height: parent.height - 88px;
        viewport-height: root.tuner-rows.length * 144px;

        for row[index] in root.tuner-rows : TunerCard {
            x: 0;
            y: index * 144px;
            width: parent.width - 8px;
            data: row;
        }
    }
}
