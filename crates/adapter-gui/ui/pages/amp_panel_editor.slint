import { BlockTypePickerItem, BlockModelPickerItem, BlockKnobOverlay } from "../models.slint";

// Beautiful dark model selector with popup
component ModelSelector inherits Rectangle {
    in property <[string]> labels;
    in-out property <int> current-index: 0;
    callback selected(int);

    height: 34px;
    background: #060610;
    border-width: 1px;
    border-color: #252538;
    border-radius: 6px;

    Text {
        x: 12px; y: 0;
        width: parent.width - 34px;
        height: parent.height;
        text: root.current-index >= 0 && root.current-index < root.labels.length
            ? root.labels[root.current-index]
            : "";
        color: #d8e0ff;
        font-size: 13px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }

    // Chevron
    Text {
        x: parent.width - 22px; y: 0;
        width: 18px;
        height: parent.height;
        text: "▼";
        color: #ffffff;
        font-size: 11px;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    ta-open := TouchArea {
        mouse-cursor: pointer;
        clicked => { popup.show(); }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 4px;
        width: root.width;
        height: root.labels.length * 36px + 8px;

        Rectangle {
            width: 100%;
            height: 100%;
            background: #08080e;
            border-width: 1px;
            border-color: #2a2a40;
            border-radius: 6px;
            drop-shadow-blur: 20px;
            drop-shadow-color: #000000c0;
            drop-shadow-offset-x: 0px;
            drop-shadow-offset-y: 6px;

            for label[i] in root.labels : Rectangle {
                x: 4px;
                y: 4px + i * 36px;
                width: parent.width - 8px;
                height: 36px;
                border-radius: 5px;
                background: i == root.current-index ? #14142a : transparent;

                Text {
                    x: 12px; y: 0;
                    width: parent.width - 24px;
                    height: parent.height;
                    text: label;
                    color: i == root.current-index ? #7788ff : #b0bce0;
                    font-size: 13px;
                    font-weight: i == root.current-index ? 700 : 400;
                    vertical-alignment: center;
                    overflow: elide;
                }

                TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.current-index = i;
                        root.selected(i);
                    }
                }
            }
        }
    }
}

// Interactive rotary knob overlay — sits on top of the SVG circle
component PanelKnob inherits Rectangle {
    in property <float> value;
    in property <float> min-val;
    in property <float> max-val;
    in property <float> step: 1.0;
    in property <string> path;
    callback changed(string, float);

    // normalized 0..1
    private property <float> norm: root.max-val > root.min-val
        ? (root.value - root.min-val) / (root.max-val - root.min-val)
        : 0.0;
    private property <float> drag-y0: 0;
    private property <float> drag-val0: 0;

    background: transparent;

    // Hover / active ring
    Rectangle {
        x: 2px; y: 2px;
        width: parent.width - 4px;
        height: parent.height - 4px;
        border-radius: (parent.width - 4px) / 2;
        border-width: ta.has-hover || ta.pressed ? 1.5px : 0px;
        border-color: ta.pressed ? #8899ffcc : #4455aa44;
        background: transparent;
    }

    // Indicator line:
    //   - Image positioned with top-left at knob center (= rotation pivot)
    //   - Extends DOWNWARD so at 0° it points to 6 o'clock
    //   - Formula: 45deg + norm * 270deg puts min at 7:30, max at 4:30 o'clock
    Image {
        x: parent.width / 2 - 2px;
        y: parent.height / 2;
        width: 4px;
        height: parent.height / 2 - 5px;
        source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/knob-indicator.svg");
        image-fit: fill;
        colorize: ta.pressed ? #ffffff : (ta.has-hover ? #e8f0ff : #b8c8ee);
        transform-rotation: 45deg + root.norm * 270deg;
    }

    ta := TouchArea {
        mouse-cursor: ns-resize;

        pointer-event(ev) => {
            if ev.kind == PointerEventKind.down {
                root.drag-y0 = ta.mouse-y / 1px;
                root.drag-val0 = root.value;
            }
        }

        moved => {
            if ta.pressed {
                let delta = root.drag-y0 - ta.mouse-y / 1px;
                let range = root.max-val - root.min-val;
                let raw = root.drag-val0 + delta * range / 200.0;
                let clamped = raw < root.min-val ? root.min-val : (raw > root.max-val ? root.max-val : raw);
                // Snap to step grid (required by discrete NAM models like JCM 800)
                let stepped = root.step > 0.0 ? Math.round(clamped / root.step) * root.step : clamped;
                root.changed(root.path, stepped);
            }
        }
    }
}

// Full visual amp head editor window content
export component AmpPanelEditor inherits Rectangle {
    in property <[BlockTypePickerItem]> block-type-options;
    in property <[BlockModelPickerItem]> block-model-options;
    in property <[string]> block-model-option-labels;
    in property <int> block-drawer-selected-type-index: -1;
    in-out property <int> block-drawer-selected-model-index: -1;
    in property <bool> block-drawer-edit-mode: true;
    in property <bool> block-drawer-enabled: true;
    in property <[BlockKnobOverlay]> block-knob-overlays;
    in property <string> block-drawer-confirm-label: "Adicionar";

    callback choose-block-model(int);
    callback close-block-drawer();
    callback save-block-drawer();
    callback delete-block-drawer();
    callback toggle-block-drawer-enabled();
    callback update-block-parameter-number(string, float);

    // Computed
    private property <string> selected-model-id:
        root.block-drawer-selected-model-index >= 0
        && root.block-drawer-selected-model-index < root.block-model-options.length
        ? root.block-model-options[root.block-drawer-selected-model-index].model_id
        : "";

    private property <string> selected-brand:
        root.block-drawer-selected-model-index >= 0
        && root.block-drawer-selected-model-index < root.block-model-options.length
        ? root.block-model-options[root.block-drawer-selected-model-index].brand
        : "";

    private property <string> selected-type-label:
        root.block-drawer-selected-model-index >= 0
        && root.block-drawer-selected-model-index < root.block-model-options.length
        ? root.block-model-options[root.block-drawer-selected-model-index].type_label
        : "";

    private property <string> selected-model-label:
        root.block-drawer-selected-model-index >= 0
        && root.block-drawer-selected-model-index < root.block-model-options.length
        ? root.block-model-options[root.block-drawer-selected-model-index].label
        : "";

    private property <string> block-type-label:
        root.block-drawer-selected-type-index >= 0
        && root.block-drawer-selected-type-index < root.block-type-options.length
        ? root.block-type-options[root.block-drawer-selected-type-index].label
        : "PREAMP";

    // Badge dimensions (for computing ModelSelector right boundary)
    private property <length> badge-width:
        root.selected-type-label == "" ? 0px : 56px;
    private property <length> header-height: 48px;
    private property <length> brand-strip-height: 40px;
    private property <length> panel-height: root.width / 4;
    private property <length> footer-height: root.block-drawer-edit-mode ? 44px : 52px;

    background: #0a0a0e;

    // ── HEADER (48px) ──────────────────────────────────────────────
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: root.header-height;
        background: #06060c;

        // Block type label (left)
        Text {
            x: 14px; y: 0;
            width: 60px;
            height: parent.height;
            text: root.block-type-label;
            color: #3344aa;
            font-size: 10px;
            font-weight: 900;
            vertical-alignment: center;
            letter-spacing: 1.5px;
        }

        // Model selector (fills middle)
        ModelSelector {
            x: 82px;
            y: (parent.height - 34px) / 2;
            width: parent.width - 82px - root.badge-width - 16px;
            labels: root.block-model-option-labels;
            current-index <=> root.block-drawer-selected-model-index;
            selected(i) => { root.choose-block-model(i); }
        }

        // Type badge (right, shown only when type_label is non-empty)
        if root.selected-type-label != "" : Rectangle {
            x: parent.width - root.badge-width - 8px;
            y: (parent.height - 22px) / 2;
            width: root.badge-width;
            height: 22px;
            border-radius: 4px;
            background: root.selected-type-label == "NATIVE" ? #0d2a0d
                : root.selected-type-label == "NAM" ? #0d1a2e
                : #2e1a0d;
            border-width: 1px;
            border-color: root.selected-type-label == "NATIVE" ? #1a6b1a
                : root.selected-type-label == "NAM" ? #1a4488
                : #883300;

            Text {
                x: 8px; y: 0;
                width: parent.width - 16px;
                height: parent.height;
                text: root.selected-type-label;
                color: root.selected-type-label == "NATIVE" ? #33bb33
                    : root.selected-type-label == "NAM" ? #4499ff
                    : #ff8833;
                font-size: 9px;
                font-weight: 800;
                letter-spacing: 0.8px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }

    // ── BRAND STRIP (40px) ─────────────────────────────────────────
    Rectangle {
        x: 0;
        y: root.header-height;
        width: parent.width;
        height: root.brand-strip-height;
        background: #040408;

        // Bottom separator
        Rectangle {
            x: 0; y: parent.height - 1px;
            width: parent.width; height: 1px;
            background: #0e0e1e;
        }

        // Marshall brand logo
        if root.selected-brand == "marshall" : Image {
            x: 16px;
            y: (parent.height - 24px) / 2;
            width: 120px;
            height: 24px;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/assets/brands/marshall/logo.svg");
            image-fit: contain;
            colorize: #808080;
        }

        // Vox brand logo
        if root.selected-brand == "vox" : Image {
            x: 16px;
            y: (parent.height - 20px) / 2;
            width: 80px;
            height: 20px;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/assets/brands/vox/logo.svg");
            image-fit: contain;
        }

        // Native / default brand: OR monogram + OPENRIG text
        if root.selected-brand == "native" || root.selected-brand == "" : Rectangle {
            x: 16px;
            y: (parent.height - 28px) / 2;
            width: 28px;
            height: 28px;
            border-radius: 4px;
            background: #1a1a3a;
            border-width: 1px;
            border-color: #3344aa;

            Text {
                x: 0; y: 0;
                width: 28px;
                height: 28px;
                text: "OR";
                color: #6677ff;
                font-size: 14px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.selected-brand == "native" || root.selected-brand == "" : Text {
            x: 50px;
            y: 0;
            width: 100px;
            height: parent.height;
            text: "OPENRIG";
            color: #4455aa;
            font-size: 14px;
            font-weight: 900;
            letter-spacing: 2px;
            vertical-alignment: center;
        }

        // Model name right-aligned
        Text {
            x: 0; y: 0;
            width: parent.width - 16px;
            height: parent.height;
            text: root.selected-model-label;
            color: #5566aa;
            font-size: 13px;
            font-weight: 600;
            horizontal-alignment: right;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // ── PANEL RECT ─────────────────────────────────────────────────
    Rectangle {
        x: 0;
        y: root.header-height + root.brand-strip-height;
        width: parent.width;
        height: root.panel-height;
        clip: true;
        background: #111;

        // controls.svg panel image (full width, 4:1 ratio)
        Image {
            x: 0; y: 0;
            width: parent.width;
            height: parent.height;
            source: root.selected-model-id == "marshall_jcm_800_2203"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/assets/amps/marshall/jcm800-2203/controls.svg")
                : root.selected-model-id == "american_clean"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/assets/amps/native/american-clean/controls.svg")
                : root.selected-model-id == "brit_crunch"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/assets/amps/native/brit-crunch/controls.svg")
                : root.selected-model-id == "modern_high_gain"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/assets/amps/native/modern-high-gain/controls.svg")
                : @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/assets/amps/generic/controls.svg");
            image-fit: fill;
        }

        // Power LED (x=10px, vertically centered) — simulates front panel power switch
        Rectangle {
            x: 10px;
            y: (parent.height - 28px) / 2;
            width: 28px;
            height: 28px;
            border-radius: 14px;
            background: transparent;
            border-width: 1px;
            border-color: root.block-drawer-enabled ? #22aa4440 : #661111;

            // Inner LED dot (centered at 14,14 = 28/2 - 12/2 = 8px offset)
            Rectangle {
                x: 8px; y: 8px;
                width: 12px; height: 12px;
                border-radius: 6px;
                background: root.block-drawer-enabled ? #33ee55 : #221111;
                drop-shadow-blur: root.block-drawer-enabled ? 10px : 0px;
                drop-shadow-color: root.block-drawer-enabled ? #33ee5599 : #00000000;
                drop-shadow-offset-x: 0px;
                drop-shadow-offset-y: 0px;
            }

            ta-power := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.toggle-block-drawer-enabled(); }
            }
        }

        // Knob overlays (positioned at exact svg_cx / svg_cy relative to panel)
        for knob in root.block-knob-overlays : PanelKnob {
            x: knob.svg_cx / 800 * parent.width - knob.svg_r / 800 * parent.width;
            y: knob.svg_cy / 200 * parent.height - knob.svg_r / 200 * parent.height;
            width: knob.svg_r * 2 / 800 * parent.width;
            height: knob.svg_r * 2 / 200 * parent.height;
            value: knob.value;
            min-val: knob.min_val;
            max-val: knob.max_val;
            step: knob.step;
            path: knob.path;
            changed(p, v) => { root.update-block-parameter-number(p, v); }
        }
    }

    // ── FOOTER ─────────────────────────────────────────────────────
    // Edit mode: shows delete button only (auto-save, no save button)
    if root.block-drawer-edit-mode : Rectangle {
        x: 0;
        y: root.header-height + root.brand-strip-height + root.panel-height;
        width: parent.width;
        height: 44px;
        background: #040408;

        // Top separator
        Rectangle {
            x: 0; y: 0;
            width: parent.width; height: 1px;
            background: #0e0e1e;
        }

        // Delete button
        Rectangle {
            x: 16px;
            y: (44px - 32px) / 2;
            width: 32px;
            height: 32px;
            border-radius: 6px;
            background: ta-del.has-hover ? #1a0000 : transparent;
            border-width: 1px;
            border-color: ta-del.has-hover ? #441111 : #331111;

            Image {
                x: 7px; y: 7px;
                width: 18px; height: 18px;
                source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/trash.svg");
                image-fit: contain;
                colorize: ta-del.has-hover ? #ff4433 : #662222;
            }

            ta-del := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.delete-block-drawer(); }
            }
        }
    }

    // Insert mode footer: save/add button
    if !root.block-drawer-edit-mode : Rectangle {
        x: 0;
        y: root.header-height + root.brand-strip-height + root.panel-height;
        width: parent.width;
        height: 52px;
        background: #040408;

        Rectangle {
            x: 0; y: 0;
            width: parent.width; height: 1px;
            background: #0e0e1e;
        }

        Rectangle {
            x: parent.width - 120px;
            y: (52px - 36px) / 2;
            width: 104px;
            height: 36px;
            background: ta-save.has-hover ? #1a5acc : #102a88;
            border-radius: 6px;

            Text {
                width: parent.width; height: parent.height;
                text: root.block-drawer-confirm-label;
                color: #e8edff;
                font-size: 13px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            ta-save := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.save-block-drawer(); }
            }
        }
    }
}
