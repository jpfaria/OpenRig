import { ComboBox, ScrollView, VerticalBox } from "std-widgets.slint";
import { ProjectChainItem, BlockModelPickerItem, BlockParameterItem, BlockTypePickerItem, ChainBlockItem } from "../models.slint";
import { EffectTypeIcon } from "../components/effect_type_icon.slint";

component ToolbarButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 140px : 116px;
    height: 40px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 600;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component ParamFieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1a1e25;
    border-width: 1px;
    border-color: #3c4350;
    border-radius: 4px;

    TextInput {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.text = self.text;
            root.changed(self.text);
        }
    }
}

component BlockValueStepper inherits Rectangle {
    in property <string> label;
    in property <string> value-text;
    in property <string> unit-text;
    in property <float> numeric-value: 0;
    in property <float> numeric-min: 0;
    in property <float> numeric-max: 1;
    in property <float> numeric-step: 1;
    callback changed(float);
    callback text-changed(string);

    pure function previous-value() -> float {
        let next = root.numeric-value - root.numeric-step;
        return next < root.numeric-min ? root.numeric-min : next;
    }

    pure function next-value() -> float {
        let next = root.numeric-value + root.numeric-step;
        return next > root.numeric-max ? root.numeric-max : next;
    }

    width: 320px;
    height: 58px;
    background: transparent;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 800;
    }

    Rectangle {
        x: 0px;
        y: 24px;
        width: parent.width;
        height: 34px;
        background: #1b2028;
        border-width: 1px;
        border-color: #414956;
        border-radius: 6px;

        Rectangle {
            x: 0px;
            y: 0px;
            width: 42px;
            height: parent.height;
            background: dec-hover.has-hover ? #ffffff10 : transparent;
            border-width: 0px;

            Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                text: "−";
                color: #f4f7fb;
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            dec-hover := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.changed(root.previous-value()); }
            }
        }

        Rectangle {
            x: 42px;
            y: 0px;
            width: parent.width - 84px;
            height: parent.height;
            background: transparent;

            TextInput {
                x: 8px;
                y: 1px;
                width: parent.width - 16px;
                height: 18px;
                text: root.value-text;
                color: #f5f7fb;
                font-size: 16px;
                font-weight: 800;
                single-line: true;
                horizontal-alignment: center;
                vertical-alignment: center;
                edited => { root.text-changed(self.text); }
            }

            if root.unit-text != "" : Text {
                x: 0px;
                y: 18px;
                width: parent.width;
                height: 12px;
                text: root.unit-text;
                color: #aab4c3;
                font-size: 9px;
                font-weight: 700;
                horizontal-alignment: center;
            }
        }

        Rectangle {
            x: parent.width - 42px;
            y: 0px;
            width: 42px;
            height: parent.height;
            background: inc-hover.has-hover ? #ffffff10 : transparent;
            border-width: 0px;

            Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                text: "+";
                color: #f4f7fb;
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            inc-hover := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.changed(root.next-value()); }
            }
        }
    }
}

component BlockValueSlider inherits Rectangle {
    in property <string> label;
    in property <string> value-text;
    in property <string> unit-text;
    in property <float> progress: 0;
    callback moved(float);
    callback text-changed(string);

    width: 320px;
    height: 78px;
    background: transparent;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 800;
    }

    Rectangle {
        x: 0px;
        y: 34px;
        width: parent.width - 112px;
        height: 8px;
        background: #3a404b;
        border-radius: 4px;

        Rectangle {
            x: 0px;
            y: 0px;
            width: Math.max(10px, parent.width * root.progress);
            height: parent.height;
            background: #dce3ee;
            border-radius: 4px;
        }

        Rectangle {
            x: (parent.width * root.progress) - 8px;
            y: -4px;
            width: 16px;
            height: 16px;
            background: #eef2f8;
            border-width: 1px;
            border-color: #7b8595;
            border-radius: 8px;
        }

        TouchArea {
            x: 0px;
            y: -8px;
            width: parent.width;
            height: 24px;
            mouse-cursor: pointer;
            moved => {
                if self.pressed {
                    let next = self.mouse-x / parent.width;
                    root.moved(next < 0 ? 0 : next > 1 ? 1 : next);
                }
            }
        }
    }

    Rectangle {
        x: parent.width - 92px;
        y: 18px;
        width: 92px;
        height: 40px;
        background: #1b2028;
        border-width: 1px;
        border-color: #414956;
        border-radius: 6px;

        TextInput {
            x: 8px;
            y: 4px;
            width: parent.width - 16px;
            height: 18px;
            text: root.value-text;
            color: #f5f7fb;
            font-size: 15px;
            font-weight: 800;
            single-line: true;
            horizontal-alignment: center;
            edited => { root.text-changed(self.text); }
        }

        if root.unit-text != "" : Text {
            x: 0px;
            y: 21px;
            width: parent.width;
            height: 12px;
            text: root.unit-text;
            color: #aab4c3;
            font-size: 9px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }
}

component BlockFootswitch inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback toggled(bool);

    width: 160px;
    height: 42px;
    background: transparent;

    Rectangle {
        x: 0px;
        y: 0px;
        width: 160px;
        height: 42px;
        background: root.active ? #1d4d35 : #1b2028;
        border-width: 1px;
        border-color: root.active ? #29df85 : #414956;
        border-radius: 6px;

        Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: root.label;
            color: root.active ? #ecfff4 : #c4ccd8;
            font-size: 13px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.toggled(!root.active); }
        }
    }
}

component BlockTypeCard inherits Rectangle {
    in property <BlockTypePickerItem> item;
    in property <bool> selected: false;
    property <color> accent-color: root.item.accent-color;
    callback clicked();

    width: 88px;
    height: 88px;
    background: #151920;
    border-width: 1px;
    border-color: root.accent-color;
    border-radius: 4px;

    Text {
        x: 8px;
        y: 5px;
        width: parent.width - 16px;
        height: 14px;
        text: root.item.label;
        color: #f3f6fb;
        font-size: 10px;
        font-weight: 900;
        vertical-alignment: center;
    }

    EffectTypeIcon {
        x: 14px;
        y: 20px;
        width: 60px;
        height: 60px;
        icon-kind: root.item.icon-kind;
        tint: root.accent-color;
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component BlockParameterRow inherits Rectangle {
    in property <BlockParameterItem> item;
    callback text-changed(string, string);
    callback number-changed(string, float);
    callback number-text-changed(string, string);
    callback bool-changed(string, bool);
    callback option-changed(string, int);
    callback file-picked(string);

    height: root.item.widget_kind == "bool" ? 52px
        : (root.item.widget_kind == "float" || root.item.widget_kind == "int") ? 86px
        : root.item.widget_kind == "slider" ? 86px
        : root.item.widget_kind == "stepper" ? 78px
        : 84px;
    background: transparent;

    if root.item.widget_kind != "bool"
        && root.item.widget_kind != "stepper"
        && root.item.widget_kind != "slider" : Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.item.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 650;
    }

    if root.item.widget_kind == "bool" : BlockFootswitch {
        x: 0px;
        y: 0px;
        width: parent.width;
        label: root.item.label;
        active: root.item.bool_value;
        toggled(value) => {
            root.bool-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "enum" : ComboBox {
        x: 0px;
        y: 28px;
        width: parent.width;
        height: 32px;
        model: root.item.option_labels;
        current-index: root.item.selected_option_index;
        selected(_) => {
            root.option-changed(root.item.path, self.current-index);
        }
    }

    if root.item.widget_kind == "text" : ParamFieldBox {
        x: 0px;
        y: 28px;
        width: root.item.unit_text == "" ? parent.width : parent.width - 54px;
        height: 34px;
        text: root.item.value_text;
        changed(value) => {
            root.text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "stepper" : BlockValueStepper {
        x: 0px;
        y: 0px;
        width: parent.width;
        label: root.item.label;
        value-text: root.item.value_text;
        unit-text: root.item.unit_text;
        numeric-value: root.item.numeric_value;
        numeric-min: root.item.numeric_min;
        numeric-max: root.item.numeric_max;
        numeric-step: root.item.numeric_step;
        changed(value) => {
            root.number-changed(root.item.path, value);
        }
        text-changed(value) => {
            root.number-text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "slider" || root.item.widget_kind == "float" || root.item.widget_kind == "int" : BlockValueSlider {
        x: 0px;
        y: 0px;
        width: parent.width;
        label: root.item.label;
        value-text: root.item.value_text;
        unit-text: root.item.unit_text;
        progress: root.item.numeric_max > root.item.numeric_min
            ? (root.item.numeric_value - root.item.numeric_min) / (root.item.numeric_max - root.item.numeric_min)
            : 0;
        moved(progress) => {
            root.number-changed(
                root.item.path,
                root.item.numeric_min + ((root.item.numeric_max - root.item.numeric_min) * progress)
            );
        }
        text-changed(value) => {
            root.number-text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "path" : ParamFieldBox {
        x: 0px;
        y: 28px;
        width: parent.width - 46px;
        height: 34px;
        text: root.item.value_text;
        changed(value) => {
            root.text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "path" : Rectangle {
        x: parent.width - 30px;
        y: 33px;
        width: 24px;
        height: 24px;
        background: file-hover.has-hover ? #ffffff10 : transparent;

        Image {
            x: 2px;
            y: 2px;
            width: 20px;
            height: 20px;
            source: @image-url("../assets/open-file.svg");
            image-fit: contain;
        }

        file-hover := TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.file-picked(root.item.path); }
        }
    }

    if root.item.widget_kind == "text" && root.item.unit_text != "" : Rectangle {
        x: parent.width - 42px;
        y: 35px;
        width: 42px;
        height: 20px;
        background: transparent;
        border-width: 1px;
        border-color: #465063;
        border-radius: 3px;

        Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: root.item.unit_text;
            color: #a6b7ce;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component ChainActionIcon inherits Rectangle {
    in property <image> icon;
    in property <string> tooltip;
    callback clicked();

    width: 24px;
    height: 24px;
    background: hover-area.has-hover ? #ffffff10 : transparent;

    Image {
        x: 2px;
        y: 2px;
        width: 20px;
        height: 20px;
        source: root.icon;
        image-fit: contain;
        colorize: hover-area.has-hover ? #ffffff : #8a94a2;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if hover-area.has-hover && root.tooltip != "" : Rectangle {
        x: -26px;
        y: -30px;
        width: 76px;
        height: 24px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 50;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.tooltip;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component ChainEndpointChip inherits Rectangle {
    in property <string> label;
    in property <string> tooltip;
    in property <bool> is-input: true;
    callback clicked();
    out property <bool> is-hovered: hover-area.has-hover;

    width: 72px;
    height: 52px;
    background: hover-area.has-hover ? #1e2530e0 : #141820e0;
    border-width: 1px;
    border-color: hover-area.has-hover ? #5a7fa8 : #364050;
    border-radius: 10px;

    // Ícone de entrada ou saída
    Image {
        x: (parent.width - 18px) / 2;
        y: 8px;
        width: 18px;
        height: 18px;
        source: root.is-input
            ? @image-url("../assets/chain-input.svg")
            : @image-url("../assets/chain-output.svg");
        image-fit: contain;
        colorize: hover-area.has-hover ? #a8c8f0 : #6a8aaa;
    }

    // Label (nome do dispositivo/canal)
    Text {
        x: 4px;
        y: 29px;
        width: parent.width - 8px;
        height: 16px;
        text: root.label;
        color: hover-area.has-hover ? #d0e4f8 : #8aaac8;
        font-size: 9px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    hover-area := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component ChainPowerToggle inherits Rectangle {
    in property <bool> enabled: false;
    in property <string> tooltip;
    callback clicked();

    width: 28px;
    height: 28px;
    background: hover-area.has-hover ? #ffffff08 : transparent;

    Rectangle {
        x: 4px;
        y: 4px;
        width: 20px;
        height: 20px;
        background: transparent;
        border-width: 2px;
        border-color: root.enabled ? #29df85 : #6a7483;
        border-radius: 10px;
    }

    Rectangle {
        x: 13px;
        y: 3px;
        width: 2px;
        height: 10px;
        background: root.enabled ? #29df85 : #6a7483;
        border-radius: 1px;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if hover-area.has-hover && root.tooltip != "" : Rectangle {
        x: -24px;
        y: -30px;
        width: 76px;
        height: 24px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 50;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.tooltip;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component HeaderIconAction inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    in property <color> tint: root.active ? #188cff : #eef2f8;
    in property <string> tooltip;
    callback clicked();

    width: 24px;
    height: 24px;
    background: action-area.has-hover ? #ffffff10 : transparent;

    Image {
        x: 2px;
        y: 2px;
        width: 20px;
        height: 20px;
        source: root.icon;
        image-fit: contain;
        colorize: root.tint;
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    action-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if action-area.has-hover && root.tooltip != "" : Rectangle {
        x: -30px;
        y: -30px;
        width: 84px;
        height: 24px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 50;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.tooltip;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component BlockChip inherits Rectangle {
    in property <ChainBlockItem> block;
    in property <bool> selected: false;
    in property <bool> dragging: false;
    property <color> accent-color: root.block.accent-color;
    property <string> block-type-label: root.block.type_label;
    callback clicked();
    callback drag-moved(float, float);
    callback drag-finished(float, float);
    property <bool> did-drag: false;
    property <bool> drag-origin-set: false;
    property <float> drag-origin-x: 0;
    property <float> drag-origin-y: 0;

    width: 84px;
    height: 100px;
    background: transparent;
    border-width: 0px;
    border-radius: 6px;

    // Type label on top
    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 14px;
        text: root.block-type-label;
        color: root.block.enabled ? root.accent-color : #5c6678;
        font-size: 8px;
        font-weight: 700;
        letter-spacing: 1px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // Calculate rendered thumbnail size (image-fit: contain in 80x76 area)
    property <float> img-aspect: root.block.thumb-height > 0 ? root.block.thumb-width / root.block.thumb-height : 1.0;
    property <float> area-aspect: 80.0 / 76.0;
    property <float> rendered-w: img-aspect > area-aspect ? 80.0 : 76.0 * img-aspect;
    property <float> rendered-h: img-aspect > area-aspect ? 80.0 / img-aspect : 76.0;
    property <length> rw: rendered-w * 1px;
    property <length> rh: rendered-h * 1px;
    property <length> rx: (84px - rw) / 2;
    property <length> ry: 15px + (76px - rh) / 2;

    if root.block.has-thumbnail : Image {
        x: 2px;
        y: 15px;
        width: 80px;
        height: 76px;
        source: root.block.thumbnail;
        image-fit: contain;
    }

    if !root.block.has-thumbnail : EffectTypeIcon {
        x: 0px;
        y: 17px;
        width: parent.width;
        height: 72px;
        icon-kind: root.block.icon-kind;
        tint: root.dragging ? #8b95a5 : root.block.enabled ? #f3f6fb : #5c6678;
    }

    // White hover outline — hugs the actual rendered thumbnail
    if hover-area.has-hover && root.block.has-thumbnail : Rectangle {
        x: root.rx - 2px;
        y: root.ry - 2px;
        width: root.rw + 4px;
        height: root.rh + 4px;
        background: transparent;
        border-width: 1.5px;
        border-color: #ffffff60;
        border-radius: 4px;
    }

    // Fallback hover for non-thumbnail blocks
    if hover-area.has-hover && !root.block.has-thumbnail : Rectangle {
        x: 4px;
        y: 15px;
        width: parent.width - 8px;
        height: 74px;
        background: transparent;
        border-width: 1.5px;
        border-color: #ffffff60;
        border-radius: 4px;
    }

    // LED status dot
    Rectangle {
        x: parent.width - 10px;
        y: parent.height - 10px;
        width: 5px;
        height: 5px;
        background: root.block.enabled ? #29df85 : #697382;
        border-radius: 3px;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        moved => {
            if self.pressed {
                let pointer-x = (self.mouse-x + root.x) / 1px;
                let pointer-y = (self.mouse-y + root.y) / 1px;
                if !root.drag-origin-set {
                    root.drag-origin-set = true;
                    root.drag-origin-x = pointer-x;
                    root.drag-origin-y = pointer-y;
                } else {
                    let delta-x = pointer-x - root.drag-origin-x;
                    let delta-y = pointer-y - root.drag-origin-y;
                    let distance = (delta-x < 0 ? -delta-x : delta-x) + (delta-y < 0 ? -delta-y : delta-y);
                    if distance > 8 {
                        root.did-drag = true;
                        root.drag-moved(pointer-x, pointer-y);
                    }
                }
            }
        }
        pointer-event(e) => {
            if e.kind == PointerEventKind.up {
                let pointer-x = (self.mouse-x + root.x) / 1px;
                let pointer-y = (self.mouse-y + root.y) / 1px;
                if root.did-drag {
                    root.drag-finished(pointer-x, pointer-y);
                } else {
                    root.clicked();
                }
                root.did-drag = false;
                root.drag-origin-set = false;
            }
        }
    }
}

component BlockInsertSlot inherits Rectangle {
    in property <bool> empty-slot: false;
    in property <bool> active-drop-target: false;
    in property <bool> move-target: false;
    in property <bool> suppress-hover-affordance: false;
    callback clicked();

    width: 32px;
    height: 24px;
    background: transparent;

    if !root.empty-slot : Rectangle {
        x: 0px;
        y: 11px;
        width: parent.width;
        height: 2px;
        background: #3b4250;
        border-radius: 1px;
    }

    if root.empty-slot || root.active-drop-target || (!root.move-target && hover-area.has-hover && !root.suppress-hover-affordance) : Rectangle {
        x: (parent.width - 24px) / 2;
        y: 0px;
        width: 24px;
        height: 24px;
        background: root.empty-slot || root.active-drop-target ? #20252d : #252a33;
        border-width: 1px;
        border-color: root.active-drop-target ? #a9b2bf : root.empty-slot ? #5a6577 : #7c8798;
        border-radius: 12px;

        if root.active-drop-target : Image {
            x: 2px;
            y: 2px;
            width: 20px;
            height: 20px;
            source: @image-url("../assets/block-drop-target.svg");
            image-fit: contain;
        }

        if !root.active-drop-target : Text {
            x: 0px;
            y: -1px;
            width: parent.width;
            height: parent.height;
            text: "+";
            color: #eef2f8;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 15px;
            font-weight: 700;
        }
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component ChainRow inherits Rectangle {
    in property <ProjectChainItem> chain;
    in property <int> chain-index;
    in property <int> selected-block-chain-index;
    in property <int> selected-block-index;
    callback toggle-chain-enabled(int);
    callback remove-chain(int);
    callback configure-chain(int);
    callback configure-chain-input(int);
    callback configure-chain-output(int);
    callback configure-chain-preset(int);
    callback save-chain-preset(int);
    callback select-chain-block(int, int);
    callback toggle-chain-block-enabled(int, int);
    callback start-block-insert(int, int);
    callback reorder-chain-block(int, int, int);
    callback open-compact-chain-view(int);
    property <int> blocks-per-row: Math.max(1, Math.floor((root.width - 188px) / 116px));
    property <int> block-row-count: root.chain.blocks.length == 0 ? 1 : Math.floor((root.chain.blocks.length - 1) / root.blocks-per-row) + 1;
    property <int> insert-row-count: root.block-row-count;
    in-out property <int> dragging-chain-index: -1;
    in-out property <int> dragging-block-index: -1;
    in-out property <int> drag-hover-before-index: -1;
    property <bool> suppress-insert-hover: false;
    property <int> last-block-col: root.chain.blocks.length == 0 ? 0 : Math.mod(root.chain.blocks.length - 1, root.blocks-per-row);
    property <int> last-block-row: root.chain.blocks.length == 0 ? 0 : Math.floor((root.chain.blocks.length - 1) / root.blocks-per-row);
    // Out sempre fixo na borda direita da linha do último bloco
    property <length> out-chip-x: root.width - 108px;
    property <length> out-chip-y: root.last-block-row * 108px + 24px;
    out property <bool> any-chip-hovered: in-chip.is-hovered || out-chip.is-hovered;

    pure function slot-index-for-position(pointer-x: float, pointer-y: float) -> int {
        // Blocks start at x=120, each 116px wide.
        // Slot 0 is before block 0 (x<172), slot N is after block N-1 center.
        // Block N center = 172 + N*116. Crossing the center moves to slot N+1.
        let row = Math.max(0, Math.min(root.insert-row-count - 1, Math.floor((pointer-y + 18) / 92)));
        let col = Math.max(0, Math.min(root.blocks-per-row, Math.round((pointer-x - 172) / 116 + 0.5)));
        let candidate = row * root.blocks-per-row + col;
        return Math.max(0, Math.min(root.chain.blocks.length, candidate));
    }

    background: @linear-gradient(180deg, #1c2333 0%, #111720 100%);
    border-width: 1px;
    border-color: #1e2d42;
    border-radius: 6px;
    height: 74px + (root.block-row-count * 108px);

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 58px;
        background: transparent;

        ChainPowerToggle {
            x: 18px;
            y: 14px;
            enabled: root.chain.enabled;
            clicked => { root.toggle-chain-enabled(root.chain-index); }
        }

        Image {
            x: 48px;
            y: 17px;
            width: 16px;
            height: 16px;
            source: root.chain.instrument == "electric_guitar" ? @image-url("../../../../assets/instruments/electric_guitar.svg")
                : root.chain.instrument == "acoustic_guitar" ? @image-url("../../../../assets/instruments/acoustic_guitar.svg")
                : root.chain.instrument == "bass" ? @image-url("../../../../assets/instruments/bass.svg")
                : root.chain.instrument == "voice" ? @image-url("../../../../assets/instruments/voice.svg")
                : root.chain.instrument == "keys" ? @image-url("../../../../assets/instruments/keys.svg")
                : root.chain.instrument == "drums" ? @image-url("../../../../assets/instruments/drums.svg")
                : @image-url("../../../../assets/instruments/generic.svg");
            image-fit: contain;
            colorize: #6a7483;
        }

        Rectangle {
            x: 72px;
            y: 14px;
            width: 320px;
            height: 24px;

            Text {
                width: parent.width;
                height: parent.height;
                text: root.chain.title;
                color: title-ta.has-hover ? #ffffff : #f1f4f8;
                font-size: 14px;
                font-weight: 600;
                vertical-alignment: center;
            }

            title-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.open-compact-chain-view(root.chain-index); }
            }
        }

        ChainActionIcon {
            x: parent.width - 196px;
            y: 14px;
            icon: @image-url("../assets/expand.svg");
            tooltip: "Expandir blocos";
            clicked => { root.open-compact-chain-view(root.chain-index); }
        }

        ChainActionIcon {
            x: parent.width - 156px;
            y: 14px;
            icon: @image-url("../assets/gear.svg");
            tooltip: "Configurar";
            clicked => { root.configure-chain(root.chain-index); }
        }

        ChainActionIcon {
            x: parent.width - 116px;
            y: 14px;
            icon: @image-url("../assets/open-file.svg");
            tooltip: "Abrir preset";
            clicked => { root.configure-chain-preset(root.chain-index); }
        }

        ChainActionIcon {
            x: parent.width - 76px;
            y: 14px;
            icon: @image-url("../assets/save.svg");
            tooltip: "Salvar preset";
            clicked => { root.save-chain-preset(root.chain-index); }
        }

        ChainActionIcon {
            x: parent.width - 36px;
            y: 14px;
            icon: @image-url("../assets/trash.svg");
            tooltip: "Excluir";
            clicked => { root.remove-chain(root.chain-index); }
        }
    }

    Rectangle {
        x: 18px;
        y: 62px;
        width: parent.width - 36px;
        height: root.block-row-count * 108px;
        background: transparent;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            moved => {
                if !self.pressed {
                    root.suppress-insert-hover = false;
                }
            }
        }

        // Routing lines — pedal center is at y = 52px + row * 108px
        // Row 0 horizontal
        Rectangle {
            x: 72px;
            y: 52px;
            width: root.block-row-count == 1 ? (root.out-chip-x - 72px) : (parent.width - 72px);
            height: 2px;
            background: #3b4250;
            border-radius: 1px;
        }

        // U-turn row 0 → row 1
        if root.block-row-count > 1 : Rectangle {
            x: parent.width - 2px;
            y: 52px;
            width: 2px;
            height: 56px;
            background: #3b4250;
            border-radius: 1px;
        }
        if root.block-row-count > 1 : Rectangle {
            x: 0px;
            y: 106px;
            width: parent.width;
            height: 2px;
            background: #3b4250;
            border-radius: 1px;
        }
        if root.block-row-count > 1 : Rectangle {
            x: 0px;
            y: 106px;
            width: 2px;
            height: 54px;
            background: #3b4250;
            border-radius: 1px;
        }

        // Row 1 horizontal
        if root.block-row-count > 1 : Rectangle {
            x: 0px;
            y: 160px;
            width: root.block-row-count == 2 ? root.out-chip-x : parent.width;
            height: 2px;
            background: #3b4250;
            border-radius: 1px;
        }

        // U-turn row 1 → row 2
        if root.block-row-count > 2 : Rectangle {
            x: parent.width - 2px;
            y: 160px;
            width: 2px;
            height: 56px;
            background: #3b4250;
            border-radius: 1px;
        }
        if root.block-row-count > 2 : Rectangle {
            x: 0px;
            y: 214px;
            width: parent.width;
            height: 2px;
            background: #3b4250;
            border-radius: 1px;
        }
        if root.block-row-count > 2 : Rectangle {
            x: 0px;
            y: 214px;
            width: 2px;
            height: 54px;
            background: #3b4250;
            border-radius: 1px;
        }

        // Row 2 horizontal
        if root.block-row-count > 2 : Rectangle {
            x: 0px;
            y: 268px;
            width: root.block-row-count == 3 ? root.out-chip-x : parent.width;
            height: 2px;
            background: #3b4250;
            border-radius: 1px;
        }

        // U-turn row 2 → row 3
        if root.block-row-count > 3 : Rectangle {
            x: parent.width - 2px;
            y: 268px;
            width: 2px;
            height: 56px;
            background: #3b4250;
            border-radius: 1px;
        }
        if root.block-row-count > 3 : Rectangle {
            x: 0px;
            y: 322px;
            width: parent.width;
            height: 2px;
            background: #3b4250;
            border-radius: 1px;
        }
        if root.block-row-count > 3 : Rectangle {
            x: 0px;
            y: 322px;
            width: 2px;
            height: 54px;
            background: #3b4250;
            border-radius: 1px;
        }

        // Row 3 horizontal
        if root.block-row-count > 3 : Rectangle {
            x: 0px;
            y: 376px;
            width: root.out-chip-x;
            height: 2px;
            background: #3b4250;
            border-radius: 1px;
        }

        BlockInsertSlot {
            x: 88px;
            y: 41px;
            empty-slot: root.chain.blocks.length == 0;
            move-target: root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0;
            suppress-hover-affordance: root.suppress-insert-hover;
            active-drop-target: root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0 && root.drag-hover-before-index == 0;
            clicked => {
                if root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0 {
                    root.reorder-chain-block(root.chain-index, root.dragging-block-index, 0);
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                    root.suppress-insert-hover = true;
                } else {
                    root.start-block-insert(root.chain-index, 0);
                }
            }
        }

        for block[block-index] in root.chain.blocks : BlockChip {
            x: 120px + Math.mod(block-index, root.blocks-per-row) * 116px;
            y: Math.floor(block-index / root.blocks-per-row) * 108px;
            block: block;
            selected: root.dragging-chain-index == root.chain-index && root.dragging-block-index == block.real_index
                ? false
                : root.selected-block-chain-index == root.chain-index && root.selected-block-index == block.real_index;
            dragging: root.dragging-chain-index == root.chain-index && root.dragging-block-index == block.real_index;
            clicked => { root.select-chain-block(root.chain-index, block.real_index); }
            drag-moved(pointer-x, pointer-y) => {
                root.suppress-insert-hover = false;
                root.dragging-chain-index = root.chain-index;
                root.dragging-block-index = block.real_index;
                root.drag-hover-before-index = root.slot-index-for-position(pointer-x, pointer-y);
            }
            drag-finished(pointer-x, pointer-y) => {
                if root.dragging-chain-index == root.chain-index && root.dragging-block-index == block.real_index {
                    let before-index = root.slot-index-for-position(pointer-x, pointer-y);
                    root.drag-hover-before-index = before-index;
                    root.reorder-chain-block(root.chain-index, block.real_index, before-index);
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                    root.suppress-insert-hover = true;
                }
            }
        }

        for block[block-index] in root.chain.blocks : BlockInsertSlot {
            x: 204px + Math.mod(block-index, root.blocks-per-row) * 116px;
            y: 41px + Math.floor(block-index / root.blocks-per-row) * 108px;
            move-target: root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0;
            suppress-hover-affordance: root.suppress-insert-hover;
            active-drop-target: root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0 && root.drag-hover-before-index == block-index + 1;
            clicked => {
                if root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0 {
                    root.reorder-chain-block(root.chain-index, root.dragging-block-index, block-index + 1);
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                    root.suppress-insert-hover = true;
                } else {
                    root.start-block-insert(root.chain-index, block-index + 1);
                }
            }
        }

        in-chip := ChainEndpointChip {
            x: 0px;
            y: 15px;
            is-input: true;
            label: root.chain.input_label;
            tooltip: root.chain.input_tooltip;
            clicked => { root.configure-chain-input(root.chain-index); }
        }

        out-chip := ChainEndpointChip {
            x: root.out-chip-x;
            y: root.out-chip-y;
            is-input: false;
            label: root.chain.output_label;
            tooltip: root.chain.output_tooltip;
            clicked => { root.configure-chain-output(root.chain-index); }
        }

        if root.chain.latency_ms > 0 : Rectangle {
            x: root.out-chip-x + 4px;
            y: root.out-chip-y + 56px;
            width: 64px;
            height: 22px;
            border-radius: 4px;
            background: root.chain.latency_ms < 10.0 ? #4ade8018
                      : root.chain.latency_ms < 20.0 ? #facc1518
                      : #f8717118;
            border-width: 1px;
            border-color: root.chain.latency_ms < 10.0 ? #4ade8055
                        : root.chain.latency_ms < 20.0 ? #facc1555
                        : #f8717155;

            Text {
                x: 0px;
                y: 2px;
                width: 26px;
                height: parent.height;
                text: "LAT";
                color: root.chain.latency_ms < 10.0 ? #4ade8099
                     : root.chain.latency_ms < 20.0 ? #facc1599
                     : #f8717199;
                font-size: 8px;
                font-weight: 700;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            Text {
                x: 29px;
                y: 0px;
                width: parent.width - 30px;
                height: parent.height;
                text: Math.round(root.chain.latency_ms) + "ms";
                color: root.chain.latency_ms < 10.0 ? #4ade80
                     : root.chain.latency_ms < 20.0 ? #facc15
                     : #f87171;
                font-size: 10px;
                font-weight: 600;
                horizontal-alignment: left;
                vertical-alignment: center;
            }
        }

        // In chip tooltip — aparece à direita do chip In
        if in-chip.is-hovered && root.chain.input_tooltip != "" : Rectangle {
            x: 76px;
            y: 8px;
            width: 312px;
            height: Math.max(92px, input-tooltip-text.preferred-height + 42px);
            background: #0e1218f7;
            border-width: 1px;
            border-color: #4d5868;
            border-radius: 8px;

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: 26px;
                background: #171d26;
                border-radius: 8px;

                Text {
                    x: 12px;
                    width: parent.width - 24px;
                    height: parent.height;
                    text: "Entrada";
                    color: #edf2f9;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
            }

            input-tooltip-text := Text {
                x: 12px;
                y: 34px;
                width: parent.width - 24px;
                height: parent.height - 42px;
                text: root.chain.input_tooltip;
                color: #dfe6f0;
                font-size: 11px;
                font-weight: 700;
                wrap: word-wrap;
                horizontal-alignment: left;
                vertical-alignment: top;
            }
        }

        // Out chip tooltip — aparece à esquerda do chip Out (borda direita 8px antes do chip)
        if out-chip.is-hovered && root.chain.output_tooltip != "" : Rectangle {
            x: root.out-chip-x - 320px;
            y: root.out-chip-y;
            width: 312px;
            height: Math.max(92px, output-tooltip-text.preferred-height + 42px);
            background: #0e1218f7;
            border-width: 1px;
            border-color: #4d5868;
            border-radius: 8px;

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: 26px;
                background: #171d26;
                border-radius: 8px;

                Text {
                    x: 12px;
                    width: parent.width - 24px;
                    height: parent.height;
                    text: "Saída";
                    color: #edf2f9;
                    font-size: 12px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
            }

            output-tooltip-text := Text {
                x: 12px;
                y: 34px;
                width: parent.width - 24px;
                height: parent.height - 42px;
                text: root.chain.output_tooltip;
                color: #dfe6f0;
                font-size: 11px;
                font-weight: 700;
                wrap: word-wrap;
                horizontal-alignment: left;
                vertical-alignment: top;
            }
        }
    }

}

export component BlockEditorPanel inherits Rectangle {
    in property <[BlockTypePickerItem]> block-type-options;
    in property <[BlockModelPickerItem]> block-model-options;
    in property <[string]> block-model-option-labels;
    in property <string> block-drawer-title;
    in property <string> block-drawer-confirm-label;
    in property <string> block-drawer-status-message;
    in property <bool> block-drawer-edit-mode;
    in property <int> block-drawer-selected-type-index;
    in-out property <int> block-drawer-selected-model-index;
    in property <bool> block-drawer-enabled;
    in property <[BlockParameterItem]> block-parameter-items;
    callback choose-block-model(int);
    callback close-block-drawer();
    callback save-block-drawer();
    callback delete-block-drawer();
    callback toggle-block-drawer-enabled();
    callback update-block-parameter-text(string, string);
    callback update-block-parameter-number(string, float);
    callback update-block-parameter-number-text(string, string);
    callback update-block-parameter-bool(string, bool);
    callback select-block-parameter-option(string, int);
    callback pick-block-parameter-file(string);

    // Computed helpers
    property <bool> is-preamp:
        root.block-drawer-selected-type-index >= 0
        && root.block-drawer-selected-type-index < root.block-type-options.length
        && root.block-type-options[root.block-drawer-selected-type-index].icon_kind == "preamp";

    property <string> selected-model-id:
        root.block-drawer-selected-model-index >= 0
        && root.block-drawer-selected-model-index < root.block-model-options.length
        ? root.block-model-options[root.block-drawer-selected-model-index].model_id
        : "";

    background: transparent;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #171a20f8;
        border-width: 1px;
        border-color: #2d3340;

        // ── CABEÇALHO ────────────────────────────────────────────
        EffectTypeIcon {
            x: 20px;
            y: 18px;
            width: 28px;
            height: 28px;
            icon-kind: root.block-drawer-selected-type-index >= 0 && root.block-drawer-selected-type-index < root.block-type-options.length
                ? root.block-type-options[root.block-drawer-selected-type-index].icon_kind
                : "";
            tint: #f3f6fb;
        }

        Text {
            x: 56px;
            y: 20px;
            width: parent.width - 160px;
            height: 24px;
            text: root.block-drawer-selected-type-index >= 0 && root.block-drawer-selected-type-index < root.block-type-options.length
                ? root.block-type-options[root.block-drawer-selected-type-index].label
                : "";
            color: #f3f6fb;
            font-size: 18px;
            font-weight: 800;
            vertical-alignment: center;
        }

        if root.block-drawer-edit-mode : ChainPowerToggle {
            x: parent.width - 72px;
            y: 20px;
            enabled: root.block-drawer-enabled;
            tooltip: root.block-drawer-enabled ? "Desativar" : "Ativar";
            clicked => { root.toggle-block-drawer-enabled(); }
        }

        if root.block-drawer-edit-mode : ChainActionIcon {
            x: parent.width - 40px;
            y: 20px;
            icon: @image-url("../assets/trash.svg");
            tooltip: "Excluir";
            clicked => { root.delete-block-drawer(); }
        }

        Rectangle {
            x: 20px;
            y: 62px;
            width: parent.width - 40px;
            height: 1px;
            background: #313743;
        }

        // ── AMP HEAD: seletor de modelo + imagem do painel + parâmetros ───────
        if root.is-preamp : ComboBox {
            x: 20px;
            y: 74px;
            width: parent.width - 40px;
            height: 34px;
            model: root.block-model-option-labels;
            current-index <=> root.block-drawer-selected-model-index;
            selected(_) => { root.choose-block-model(self.current-index); }
        }

        if root.is-preamp && root.block-drawer-selected-model-index >= 0 && root.block-drawer-selected-model-index < root.block-model-options.length : Text {
            x: 20px;
            y: 112px;
            width: parent.width - 40px;
            height: 16px;
            text: root.block-model-options[root.block-drawer-selected-model-index].subtitle;
            color: #94a0b0;
            font-size: 11px;
        }

        // (controls.svg removidos — painel agora é renderizado pelo BlockPanelEditor)

        // Parâmetros do amp head
        if root.is-preamp : ScrollView {
            x: 20px;
            y: 132px + (parent.width - 16px) / 4 + 12px;
            width: parent.width - 40px;
            height: parent.height - (132px + (parent.width - 16px) / 4 + 12px) - (root.block-drawer-edit-mode ? 20px : 74px);
            viewport-width: self.width;
            viewport-height: root.block-parameter-items.length * 96px;

            for param-item[index] in root.block-parameter-items : BlockParameterRow {
                x: 0px;
                y: index * 96px;
                width: parent.width - 24px;
                item: param-item;
                text-changed(path, value) => { root.update-block-parameter-text(path, value); }
                number-changed(path, value) => { root.update-block-parameter-number(path, value); }
                number-text-changed(path, value) => { root.update-block-parameter-number-text(path, value); }
                bool-changed(path, value) => { root.update-block-parameter-bool(path, value); }
                option-changed(path, value) => { root.select-block-parameter-option(path, value); }
                file-picked(path) => { root.pick-block-parameter-file(path); }
            }
        }

        // ── OUTROS TIPOS: layout original ───────────────────────
        if !root.is-preamp : ScrollView {
            x: 20px;
            y: 78px;
            width: parent.width - 40px;
            height: parent.height - 98px;
            viewport-width: self.width;
            viewport-height: 92px + (root.block-parameter-items.length * 96px);

            ComboBox {
                x: 0px;
                y: 0px;
                width: parent.width - 24px;
                height: 34px;
                model: root.block-model-option-labels;
                current-index <=> root.block-drawer-selected-model-index;
                selected(_) => { root.choose-block-model(self.current-index); }
            }

            if root.block-drawer-selected-model-index >= 0 && root.block-drawer-selected-model-index < root.block-model-options.length : Text {
                x: 0px;
                y: 40px;
                width: parent.width - 24px;
                height: 16px;
                text: root.block-model-options[root.block-drawer-selected-model-index].subtitle;
                color: #94a0b0;
                font-size: 11px;
            }

            for param-item[index] in root.block-parameter-items : BlockParameterRow {
                x: 0px;
                y: 72px + (index * 96px);
                width: parent.width - 24px;
                item: param-item;
                text-changed(path, value) => { root.update-block-parameter-text(path, value); }
                number-changed(path, value) => { root.update-block-parameter-number(path, value); }
                number-text-changed(path, value) => { root.update-block-parameter-number-text(path, value); }
                bool-changed(path, value) => { root.update-block-parameter-bool(path, value); }
                option-changed(path, value) => { root.select-block-parameter-option(path, value); }
                file-picked(path) => { root.pick-block-parameter-file(path); }
            }
        }

        if !root.block-drawer-edit-mode : ToolbarButton {
            x: parent.width - 116px;
            y: parent.height - 54px;
            width: 96px;
            label: root.block-drawer-confirm-label;
            primary: true;
            clicked => { root.save-block-drawer(); }
        }
    }
}

export component ProjectChainsPage inherits Rectangle {
    in property <string> project-title;
    in property <string> project-path-label;
    in property <bool> project-dirty;
    in property <[ProjectChainItem]> project-chains;
    in property <int> selected-chain-block-chain-index;
    in property <int> selected-chain-block-index;
    in property <[BlockTypePickerItem]> block-type-options;
    in property <[BlockModelPickerItem]> block-model-options;
    in property <[string]> block-model-option-labels;
    in property <bool> show-block-type-picker;
    in property <bool> show-block-drawer;
    in property <bool> show-inline-block-drawer: true;
    in property <string> block-drawer-title;
    in property <string> block-drawer-confirm-label;
    in property <string> block-drawer-status-message;
    in property <bool> block-drawer-edit-mode;
    in property <int> block-drawer-selected-type-index;
    in-out property <int> block-drawer-selected-model-index;
    in property <bool> block-drawer-enabled;
    in property <[BlockParameterItem]> block-parameter-items;
    in-out property <string> status-message;
    property <int> dragging-chain-index: -1;
    property <int> dragging-block-index: -1;
    property <int> drag-hover-before-index: -1;
    callback back-to-launcher();
    callback add-chain();
    callback save-project();
    callback configure-project();
    callback remove-chain(int);
    callback toggle-chain-enabled(int);
    callback configure-chain(int);
    callback configure-chain-input(int);
    callback configure-chain-output(int);
    callback configure-chain-preset(int);
    callback save-chain-preset(int);
    callback open-compact-chain-view(int);
    callback select-chain-block(int, int);
    callback clear-chain-block();
    callback toggle-chain-block-enabled(int, int);
    callback start-block-insert(int, int);
    callback reorder-chain-block(int, int, int);
    callback choose-block-type(int);
    callback choose-block-model(int);
    callback cancel-block-picker();
    callback close-block-drawer();
    callback save-block-drawer();
    callback delete-block-drawer();
    callback toggle-block-drawer-enabled();
    callback update-block-parameter-text(string, string);
    callback update-block-parameter-number(string, float);
    callback update-block-parameter-number-text(string, string);
    callback update-block-parameter-bool(string, bool);
    callback select-block-parameter-option(string, int);
    callback pick-block-parameter-file(string);

    background: @linear-gradient(135deg, #0d1a2e 0%, #08090d 65%);

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => {
                if root.dragging-block-index >= 0 {
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                }
            }
        }
    }

    Rectangle {
        x: 24px;
        y: 18px;
        width: parent.width - 48px;
        height: 52px;
        background: transparent;

        Text {
            x: 0px;
            y: 6px;
            width: 360px;
            height: 36px;
            text: root.project-title;
            color: #f1f4f8;
            font-size: 28px;
            font-weight: 700;
            vertical-alignment: center;
        }

        HeaderIconAction {
            x: parent.width - 160px;
            y: 14px;
            icon: @image-url("../assets/arrow-left.svg");
            tooltip: "Voltar";
            clicked => { root.back-to-launcher(); }
        }

        HeaderIconAction {
            x: parent.width - 120px;
            y: 14px;
            icon: @image-url("../assets/gear.svg");
            tooltip: "Projeto";
            clicked => { root.configure-project(); }
        }

        HeaderIconAction {
            x: parent.width - 80px;
            y: 14px;
            icon: @image-url("../assets/save.svg");
            tint: root.project-dirty ? #f3c64f : #eef2f8;
            tooltip: "Salvar";
            clicked => { root.save-project(); }
        }

        HeaderIconAction {
            x: parent.width - 40px;
            y: 14px;
            icon: @image-url("../assets/plus.svg");
            tooltip: "Nova chain";
            clicked => { root.add-chain(); }
        }

    }

    Rectangle {
        x: 24px;
        y: 78px;
        width: parent.width - 48px;
        height: 1px;
        background: #34383f;
    }

    TouchArea {
        x: 24px;
        y: 96px;
        width: parent.width - 48px;
        height: parent.height - 96px;
        clicked => {
            if root.dragging-block-index >= 0 {
                root.dragging-chain-index = -1;
                root.dragging-block-index = -1;
                root.drag-hover-before-index = -1;
            }
        }
    }

    ScrollView {
        x: 24px;
        y: 96px;
        width: parent.width - 48px;
        height: parent.height - 96px;
        viewport-height: chains-column.preferred-height;
        viewport-width: chains-column.width;

        chains-column := VerticalBox {
            x: 0px;
            y: 0px;
            width: parent.width - 18px;
            spacing: 12px;

            for chain[index] in root.project-chains : ChainRow {
                width: parent.width;
                chain: chain;
                chain-index: index;
                selected-block-chain-index: root.selected-chain-block-chain-index;
                selected-block-index: root.selected-chain-block-index;
                toggle-chain-enabled(index) => { root.toggle-chain-enabled(index); }
                remove-chain(index) => { root.remove-chain(index); }
                configure-chain(index) => { root.configure-chain(index); }
                configure-chain-input(index) => { root.configure-chain-input(index); }
                configure-chain-output(index) => { root.configure-chain-output(index); }
                configure-chain-preset(index) => { root.configure-chain-preset(index); }
                save-chain-preset(index) => { root.save-chain-preset(index); }
                open-compact-chain-view(index) => { root.open-compact-chain-view(index); }
                select-chain-block(chain-index, block-index) => { root.select-chain-block(chain-index, block-index); }
                toggle-chain-block-enabled(chain-index, block-index) => { root.toggle-chain-block-enabled(chain-index, block-index); }
                start-block-insert(chain-index, before-index) => { root.start-block-insert(chain-index, before-index); }
                reorder-chain-block(chain-index, from-index, before-index) => {
                    root.reorder-chain-block(chain-index, from-index, before-index);
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                }
                dragging-chain-index <=> root.dragging-chain-index;
                dragging-block-index <=> root.dragging-block-index;
                drag-hover-before-index <=> root.drag-hover-before-index;
            }
        }
    }

    if root.show-inline-block-drawer && root.show-block-drawer : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0405068a;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width - 420px;
            height: parent.height;
            clicked => { root.close-block-drawer(); }
        }

        BlockEditorPanel {
            x: parent.width - 520px;
            y: 0px;
            width: 520px;
            height: parent.height;
            block-type-options: root.block-type-options;
            block-model-options: root.block-model-options;
            block-model-option-labels: root.block-model-option-labels;
            block-drawer-title: root.block-drawer-title;
            block-drawer-confirm-label: root.block-drawer-confirm-label;
            block-drawer-status-message: root.block-drawer-status-message;
            block-drawer-edit-mode: root.block-drawer-edit-mode;
            block-drawer-selected-type-index: root.block-drawer-selected-type-index;
            block-drawer-selected-model-index <=> root.block-drawer-selected-model-index;
            block-drawer-enabled: root.block-drawer-enabled;
            block-parameter-items: root.block-parameter-items;
            choose-block-model(index) => { root.choose-block-model(index); }
            close-block-drawer => { root.close-block-drawer(); }
            save-block-drawer => { root.save-block-drawer(); }
            delete-block-drawer => { root.delete-block-drawer(); }
            toggle-block-drawer-enabled => { root.toggle-block-drawer-enabled(); }
            update-block-parameter-text(path, value) => { root.update-block-parameter-text(path, value); }
            update-block-parameter-number(path, value) => { root.update-block-parameter-number(path, value); }
            update-block-parameter-number-text(path, value) => { root.update-block-parameter-number-text(path, value); }
            update-block-parameter-bool(path, value) => { root.update-block-parameter-bool(path, value); }
            select-block-parameter-option(path, index) => { root.select-block-parameter-option(path, index); }
            pick-block-parameter-file(path) => { root.pick-block-parameter-file(path); }
        }
    }

    if root.show-block-type-picker : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0405069a;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => { root.cancel-block-picker(); }
        }

        picker-modal := Rectangle {
            property <int> row-count: Math.max(1, Math.floor((root.block-type-options.length - 1) / 4) + 1);
            property <length> content-height: self.row-count * 100px;
            x: (parent.width - 472px) / 2;
            y: (parent.height - self.height) / 2;
            width: 472px;
            height: Math.min(parent.height - 80px, self.content-height + 40px);
            background: #171a20f8;
            border-width: 1px;
            border-color: #2d3340;
            border-radius: 6px;

            ScrollView {
                x: 20px;
                y: 20px;
                width: parent.width - 40px;
                height: parent.height - 40px;
                viewport-height: picker-modal.content-height;

                for type-item[index] in root.block-type-options : BlockTypeCard {
                    x: Math.mod(index, 4) * 106px;
                    y: Math.floor(index / 4) * 100px;
                    item: type-item;
                    selected: false;
                    clicked => { root.choose-block-type(index); }
                }
            }
        }
    }
}
