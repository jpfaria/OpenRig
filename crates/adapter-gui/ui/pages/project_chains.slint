import { ComboBox, ScrollView, VerticalBox } from "std-widgets.slint";
import { ProjectChainItem, BlockModelPickerItem, BlockParameterItem, BlockTypePickerItem, ChainBlockItem } from "../models.slint";

component ToolbarButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 140px : 116px;
    height: 40px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 600;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component ParamFieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1a1e25;
    border-width: 1px;
    border-color: #3c4350;
    border-radius: 4px;

    TextInput {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.text = self.text;
            root.changed(self.text);
        }
    }
}

component BlockValueStepper inherits Rectangle {
    in property <string> label;
    in property <string> value-text;
    in property <string> unit-text;
    in property <float> numeric-value: 0;
    in property <float> numeric-min: 0;
    in property <float> numeric-max: 1;
    in property <float> numeric-step: 1;
    callback changed(float);
    callback text-changed(string);

    pure function previous-value() -> float {
        let next = root.numeric-value - root.numeric-step;
        return next < root.numeric-min ? root.numeric-min : next;
    }

    pure function next-value() -> float {
        let next = root.numeric-value + root.numeric-step;
        return next > root.numeric-max ? root.numeric-max : next;
    }

    width: 320px;
    height: 58px;
    background: transparent;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 800;
    }

    Rectangle {
        x: 0px;
        y: 24px;
        width: parent.width;
        height: 34px;
        background: #1b2028;
        border-width: 1px;
        border-color: #414956;
        border-radius: 6px;

        Rectangle {
            x: 0px;
            y: 0px;
            width: 42px;
            height: parent.height;
            background: dec-hover.has-hover ? #ffffff10 : transparent;
            border-width: 0px;

            Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                text: "−";
                color: #f4f7fb;
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            dec-hover := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.changed(root.previous-value()); }
            }
        }

        Rectangle {
            x: 42px;
            y: 0px;
            width: parent.width - 84px;
            height: parent.height;
            background: transparent;

            TextInput {
                x: 8px;
                y: 1px;
                width: parent.width - 16px;
                height: 18px;
                text: root.value-text;
                color: #f5f7fb;
                font-size: 16px;
                font-weight: 800;
                single-line: true;
                horizontal-alignment: center;
                vertical-alignment: center;
                edited => { root.text-changed(self.text); }
            }

            if root.unit-text != "" : Text {
                x: 0px;
                y: 18px;
                width: parent.width;
                height: 12px;
                text: root.unit-text;
                color: #aab4c3;
                font-size: 9px;
                font-weight: 700;
                horizontal-alignment: center;
            }
        }

        Rectangle {
            x: parent.width - 42px;
            y: 0px;
            width: 42px;
            height: parent.height;
            background: inc-hover.has-hover ? #ffffff10 : transparent;
            border-width: 0px;

            Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                text: "+";
                color: #f4f7fb;
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            inc-hover := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.changed(root.next-value()); }
            }
        }
    }
}

component BlockValueSlider inherits Rectangle {
    in property <string> label;
    in property <string> value-text;
    in property <string> unit-text;
    in property <float> progress: 0;
    callback moved(float);
    callback text-changed(string);

    width: 320px;
    height: 78px;
    background: transparent;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 800;
    }

    Rectangle {
        x: 0px;
        y: 34px;
        width: parent.width - 112px;
        height: 8px;
        background: #3a404b;
        border-radius: 4px;

        Rectangle {
            x: 0px;
            y: 0px;
            width: Math.max(10px, parent.width * root.progress);
            height: parent.height;
            background: #dce3ee;
            border-radius: 4px;
        }

        Rectangle {
            x: (parent.width * root.progress) - 8px;
            y: -4px;
            width: 16px;
            height: 16px;
            background: #eef2f8;
            border-width: 1px;
            border-color: #7b8595;
            border-radius: 8px;
        }

        TouchArea {
            x: 0px;
            y: -8px;
            width: parent.width;
            height: 24px;
            mouse-cursor: pointer;
            moved => {
                if self.pressed {
                    let next = self.mouse-x / parent.width;
                    root.moved(next < 0 ? 0 : next > 1 ? 1 : next);
                }
            }
        }
    }

    Rectangle {
        x: parent.width - 92px;
        y: 18px;
        width: 92px;
        height: 40px;
        background: #1b2028;
        border-width: 1px;
        border-color: #414956;
        border-radius: 6px;

        TextInput {
            x: 8px;
            y: 4px;
            width: parent.width - 16px;
            height: 18px;
            text: root.value-text;
            color: #f5f7fb;
            font-size: 15px;
            font-weight: 800;
            single-line: true;
            horizontal-alignment: center;
            edited => { root.text-changed(self.text); }
        }

        if root.unit-text != "" : Text {
            x: 0px;
            y: 21px;
            width: parent.width;
            height: 12px;
            text: root.unit-text;
            color: #aab4c3;
            font-size: 9px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }
}

component BlockFootswitch inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback toggled(bool);

    width: 160px;
    height: 42px;
    background: transparent;

    Rectangle {
        x: 0px;
        y: 0px;
        width: 160px;
        height: 42px;
        background: root.active ? #1d4d35 : #1b2028;
        border-width: 1px;
        border-color: root.active ? #29df85 : #414956;
        border-radius: 6px;

        Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: root.label;
            color: root.active ? #ecfff4 : #c4ccd8;
            font-size: 13px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.toggled(!root.active); }
        }
    }
}

component BlockTypeCard inherits Rectangle {
    in property <BlockTypePickerItem> item;
    in property <bool> selected: false;
    in property <image> icon-source;
    property <color> accent-color: root.item.effect_type == "amp_head" ? #f29f38
        : root.item.effect_type == "amp_combo" ? #f06292
        : root.item.effect_type == "cab" ? #f2cb54
        : root.item.effect_type == "ir" ? #7cc9ff
        : root.item.effect_type == "full_rig" ? #63d2ff
        : root.item.effect_type == "drive" ? #ff6a57
        : root.item.effect_type == "dynamics" ? #41b8ff
        : root.item.effect_type == "filter" ? #d6c85a
        : root.item.effect_type == "wah" ? #78d06b
        : root.item.effect_type == "modulation" ? #58d39b
        : root.item.effect_type == "delay" ? #ba8cff
        : root.item.effect_type == "reverb" ? #6de1d2
        : root.item.effect_type == "utility" ? #95a0b2
        : root.item.effect_type == "nam" ? #ff7cd7
        : #7fb0ff;
    property <string> type-label: root.item.label;
    callback clicked();

    width: 88px;
    height: 88px;
    background: #151920;
    border-width: 1px;
    border-color: root.accent-color;
    border-radius: 4px;

    Text {
        x: 8px;
        y: 5px;
        width: parent.width - 16px;
        height: 14px;
        text: root.type-label;
        color: #f3f6fb;
        font-size: 10px;
        font-weight: 900;
        vertical-alignment: center;
    }

    Image {
        x: 14px;
        y: 20px;
        width: 60px;
        height: 60px;
        source: root.icon-source;
        image-fit: contain;
        colorize: root.accent-color;
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component BlockParameterRow inherits Rectangle {
    in property <BlockParameterItem> item;
    callback text-changed(string, string);
    callback number-changed(string, float);
    callback number-text-changed(string, string);
    callback bool-changed(string, bool);
    callback option-changed(string, int);
    callback file-picked(string);

    height: root.item.widget_kind == "bool" ? 52px
        : (root.item.widget_kind == "float" || root.item.widget_kind == "int") ? 86px
        : root.item.widget_kind == "slider" ? 86px
        : root.item.widget_kind == "stepper" ? 78px
        : 84px;
    background: transparent;

    if root.item.widget_kind != "bool"
        && root.item.widget_kind != "stepper"
        && root.item.widget_kind != "slider" : Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.item.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 650;
    }

    if root.item.widget_kind == "bool" : BlockFootswitch {
        x: 0px;
        y: 0px;
        width: parent.width;
        label: root.item.label;
        active: root.item.bool_value;
        toggled(value) => {
            root.bool-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "enum" : ComboBox {
        x: 0px;
        y: 28px;
        width: parent.width;
        height: 32px;
        model: root.item.option_labels;
        current-index: root.item.selected_option_index;
        selected(_) => {
            root.option-changed(root.item.path, self.current-index);
        }
    }

    if root.item.widget_kind == "text" : ParamFieldBox {
        x: 0px;
        y: 28px;
        width: root.item.unit_text == "" ? parent.width : parent.width - 54px;
        height: 34px;
        text: root.item.value_text;
        changed(value) => {
            root.text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "stepper" : BlockValueStepper {
        x: 0px;
        y: 0px;
        width: parent.width;
        label: root.item.label;
        value-text: root.item.value_text;
        unit-text: root.item.unit_text;
        numeric-value: root.item.numeric_value;
        numeric-min: root.item.numeric_min;
        numeric-max: root.item.numeric_max;
        numeric-step: root.item.numeric_step;
        changed(value) => {
            root.number-changed(root.item.path, value);
        }
        text-changed(value) => {
            root.number-text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "slider" || root.item.widget_kind == "float" || root.item.widget_kind == "int" : BlockValueSlider {
        x: 0px;
        y: 0px;
        width: parent.width;
        label: root.item.label;
        value-text: root.item.value_text;
        unit-text: root.item.unit_text;
        progress: root.item.numeric_max > root.item.numeric_min
            ? (root.item.numeric_value - root.item.numeric_min) / (root.item.numeric_max - root.item.numeric_min)
            : 0;
        moved(progress) => {
            root.number-changed(
                root.item.path,
                root.item.numeric_min + ((root.item.numeric_max - root.item.numeric_min) * progress)
            );
        }
        text-changed(value) => {
            root.number-text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "path" : ParamFieldBox {
        x: 0px;
        y: 28px;
        width: parent.width - 46px;
        height: 34px;
        text: root.item.value_text;
        changed(value) => {
            root.text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "path" : Rectangle {
        x: parent.width - 30px;
        y: 33px;
        width: 24px;
        height: 24px;
        background: file-hover.has-hover ? #ffffff10 : transparent;

        Image {
            x: 2px;
            y: 2px;
            width: 20px;
            height: 20px;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/open-file.svg");
            image-fit: contain;
        }

        file-hover := TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.file-picked(root.item.path); }
        }
    }

    if root.item.widget_kind == "text" && root.item.unit_text != "" : Rectangle {
        x: parent.width - 42px;
        y: 35px;
        width: 42px;
        height: 20px;
        background: transparent;
        border-width: 1px;
        border-color: #465063;
        border-radius: 3px;

        Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: root.item.unit_text;
            color: #a6b7ce;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component ChainActionIcon inherits Rectangle {
    in property <image> icon;
    in property <string> tooltip;
    callback clicked();

    width: 24px;
    height: 24px;
    background: hover-area.has-hover ? #ffffff10 : transparent;

    Image {
        x: 2px;
        y: 2px;
        width: 20px;
        height: 20px;
        source: root.icon;
        image-fit: contain;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if hover-area.has-hover && root.tooltip != "" : Rectangle {
        x: -26px;
        y: -30px;
        width: 76px;
        height: 24px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 50;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.tooltip;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component ChainEndpointChip inherits Rectangle {
    in property <string> label;
    in property <string> tooltip;
    callback clicked();

    width: 64px;
    height: 32px;
    background: hover-area.has-hover ? #20262fdc : #161a20dc;
    border-width: 1px;
    border-color: #4b5563;
    border-radius: 8px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f1f4f8;
        font-size: 12px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    hover-area := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if hover-area.has-hover && root.tooltip != "" : Rectangle {
        x: -42px;
        y: -42px;
        width: 148px;
        height: 34px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 60;

        Text {
            x: 6px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.tooltip;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            wrap: word-wrap;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component ChainPowerToggle inherits Rectangle {
    in property <bool> enabled: false;
    in property <string> tooltip;
    callback clicked();

    width: 28px;
    height: 28px;
    background: hover-area.has-hover ? #ffffff08 : transparent;

    Rectangle {
        x: 4px;
        y: 4px;
        width: 20px;
        height: 20px;
        background: transparent;
        border-width: 2px;
        border-color: root.enabled ? #29df85 : #6a7483;
        border-radius: 10px;
    }

    Rectangle {
        x: 13px;
        y: 3px;
        width: 2px;
        height: 10px;
        background: root.enabled ? #29df85 : #6a7483;
        border-radius: 1px;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if hover-area.has-hover && root.tooltip != "" : Rectangle {
        x: -24px;
        y: -30px;
        width: 76px;
        height: 24px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 50;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.tooltip;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component HeaderIconAction inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    in property <color> tint: root.active ? #188cff : #eef2f8;
    in property <string> tooltip;
    callback clicked();

    width: 24px;
    height: 24px;
    background: action-area.has-hover ? #ffffff10 : transparent;

    Image {
        x: 2px;
        y: 2px;
        width: 20px;
        height: 20px;
        source: root.icon;
        image-fit: contain;
        colorize: root.tint;
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    action-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    if action-area.has-hover && root.tooltip != "" : Rectangle {
        x: -30px;
        y: -30px;
        width: 84px;
        height: 24px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 50;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.tooltip;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component BlockChip inherits Rectangle {
    in property <ChainBlockItem> block;
    in property <bool> selected: false;
    in property <image> icon-source;
    in property <bool> dragging: false;
    property <color> accent-color: root.block.kind == "amp_head" ? #f29f38
        : root.block.kind == "amp_combo" ? #f06292
        : root.block.kind == "cab" ? #f2cb54
        : root.block.kind == "ir" ? #7cc9ff
        : root.block.kind == "full_rig" ? #63d2ff
        : root.block.kind == "drive" ? #ff6a57
        : root.block.kind == "dynamics" ? #41b8ff
        : root.block.kind == "filter" ? #d6c85a
        : root.block.kind == "wah" ? #78d06b
        : root.block.kind == "modulation" ? #58d39b
        : root.block.kind == "delay" ? #ba8cff
        : root.block.kind == "reverb" ? #6de1d2
        : root.block.kind == "utility" ? #95a0b2
        : root.block.kind == "nam" ? #ff7cd7
        : #7fb0ff;
    property <string> block-type-label: root.block.kind == "amp_head" ? "AMP"
        : root.block.kind == "amp_combo" ? "COMBO"
        : root.block.kind == "cab" ? "CAB"
        : root.block.kind == "ir" ? "IR"
        : root.block.kind == "full_rig" ? "RIG"
        : root.block.kind == "drive" ? "DRIVE"
        : root.block.kind == "dynamics" ? "DYN"
        : root.block.kind == "filter" ? "FILTER"
        : root.block.kind == "wah" ? "WAH"
        : root.block.kind == "modulation" ? "MOD"
        : root.block.kind == "delay" ? "DLY"
        : root.block.kind == "reverb" ? "RVB"
        : root.block.kind == "utility" ? "UTIL"
        : root.block.kind == "nam" ? "NAM"
        : "CORE";
    callback clicked();
    callback drag-moved(float, float);
    callback drag-finished(float, float);
    property <bool> did-drag: false;
    property <bool> drag-origin-set: false;
    property <float> drag-origin-x: 0;
    property <float> drag-origin-y: 0;

    width: 84px;
    height: 84px;
    background: transparent;
    border-width: hover-area.has-hover || (root.selected && !root.dragging) ? 3px : 2px;
    border-color: root.dragging ? #8b95a5 : root.accent-color;
    border-radius: 6px;
    opacity: root.block.enabled ? 1 : 0.42;

    Image {
        x: 0px;
        y: 8px;
        width: parent.width;
        height: parent.height - 4px;
        source: root.icon-source;
        image-fit: contain;
        colorize: root.dragging ? #8b95a5 : root.selected ? root.accent-color : #f3f6fb;
    }

    Text {
        x: 8px;
        y: 4px;
        width: parent.width - 16px;
        height: 14px;
        text: root.block-type-label;
        color: root.dragging ? #8b95a5 : root.selected ? root.accent-color : #f3f6fb;
        font-size: 10px;
        font-weight: 900;
        vertical-alignment: center;
    }

    Rectangle {
        x: parent.width - 10px;
        y: parent.height - 10px;
        width: 5px;
        height: 5px;
        background: root.block.enabled ? #29df85 : #697382;
        border-radius: 3px;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        moved => {
            if self.pressed {
                let pointer-x = (self.mouse-x + root.x) / 1px;
                let pointer-y = (self.mouse-y + root.y) / 1px;
                if !root.drag-origin-set {
                    root.drag-origin-set = true;
                    root.drag-origin-x = pointer-x;
                    root.drag-origin-y = pointer-y;
                } else {
                    let delta-x = pointer-x - root.drag-origin-x;
                    let delta-y = pointer-y - root.drag-origin-y;
                    let distance = (delta-x < 0 ? -delta-x : delta-x) + (delta-y < 0 ? -delta-y : delta-y);
                    if distance > 8 {
                        root.did-drag = true;
                        root.drag-moved(pointer-x, pointer-y);
                    }
                }
            }
        }
        clicked => {
            let pointer-x = (self.mouse-x + root.x) / 1px;
            let pointer-y = (self.mouse-y + root.y) / 1px;
            if root.did-drag {
                root.drag-finished(pointer-x, pointer-y);
            } else {
                root.clicked();
            }
            root.did-drag = false;
            root.drag-origin-set = false;
        }
    }
}

component BlockInsertSlot inherits Rectangle {
    in property <bool> empty-slot: false;
    in property <bool> active-drop-target: false;
    in property <bool> move-target: false;
    in property <bool> suppress-hover-affordance: false;
    callback clicked();

    width: 32px;
    height: 24px;
    background: transparent;

    if !root.empty-slot : Rectangle {
        x: 0px;
        y: 11px;
        width: parent.width;
        height: 2px;
        background: root.active-drop-target ? #a9b2bf : hover-area.has-hover && !root.suppress-hover-affordance ? #8b95a5 : #3b4250;
        border-radius: 1px;
    }

    if root.empty-slot || root.active-drop-target || (!root.move-target && hover-area.has-hover && !root.suppress-hover-affordance) : Rectangle {
        x: (parent.width - 24px) / 2;
        y: 0px;
        width: 24px;
        height: 24px;
        background: root.empty-slot || root.active-drop-target ? #20252d : #252a33;
        border-width: 1px;
        border-color: root.active-drop-target ? #a9b2bf : root.empty-slot ? #5a6577 : #7c8798;
        border-radius: 12px;

        if root.active-drop-target : Image {
            x: 2px;
            y: 2px;
            width: 20px;
            height: 20px;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/block-drop-target.svg");
            image-fit: contain;
        }

        if !root.active-drop-target : Text {
            x: 0px;
            y: -1px;
            width: parent.width;
            height: parent.height;
            text: "+";
            color: #eef2f8;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 15px;
            font-weight: 700;
        }
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component ChainRow inherits Rectangle {
    in property <ProjectChainItem> chain;
    in property <int> chain-index;
    in property <int> selected-block-chain-index;
    in property <int> selected-block-index;
    callback toggle-chain-enabled(int);
    callback remove-chain(int);
    callback configure-chain(int);
    callback configure-chain-input(int);
    callback configure-chain-output(int);
    callback configure-chain-preset(int);
    callback save-chain-preset(int);
    callback select-chain-block(int, int);
    callback toggle-chain-block-enabled(int, int);
    callback start-block-insert(int, int);
    callback reorder-chain-block(int, int, int);
    property <int> blocks-per-row: Math.max(1, Math.floor((root.width - 360px) / 116px));
    property <int> block-row-count: root.chain.blocks.length == 0 ? 1 : Math.floor((root.chain.blocks.length - 1) / root.blocks-per-row) + 1;
    property <int> insert-row-count: root.block-row-count;
    in-out property <int> dragging-chain-index: -1;
    in-out property <int> dragging-block-index: -1;
    in-out property <int> drag-hover-before-index: -1;
    property <bool> suppress-insert-hover: false;

    pure function slot-index-for-position(pointer-x: float, pointer-y: float) -> int {
        let row = Math.max(0, Math.min(root.insert-row-count - 1, Math.floor((pointer-y + 18) / 92)));
        let col = Math.max(0, Math.min(root.blocks-per-row, Math.round((pointer-x - 16) / 116)));
        let candidate = row * root.blocks-per-row + col;
        return Math.max(0, Math.min(root.chain.blocks.length, candidate));
    }

    background: transparent;
    border-width: 1px;
    border-color: #31353d;
    border-radius: 6px;
    height: 74px + (root.block-row-count * 92px);

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 58px;
        background: transparent;

        ChainPowerToggle {
            x: 18px;
            y: 14px;
            enabled: root.chain.enabled;
            clicked => { root.toggle-chain-enabled(root.chain-index); }
        }

        Text {
            x: 56px;
            y: 14px;
            width: 320px;
            height: 24px;
            text: root.chain.title;
            color: #f1f4f8;
            font-size: 18px;
            font-weight: 650;
            vertical-alignment: center;
        }

        ChainActionIcon {
            x: parent.width - 156px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
            tooltip: "Configurar";
            clicked => { root.configure-chain(root.chain-index); }
        }

        ChainActionIcon {
            x: parent.width - 116px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/open-file.svg");
            tooltip: "Abrir preset";
            clicked => { root.configure-chain-preset(root.chain-index); }
        }

        ChainActionIcon {
            x: parent.width - 76px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/save.svg");
            tooltip: "Salvar preset";
            clicked => { root.save-chain-preset(root.chain-index); }
        }

        ChainActionIcon {
            x: parent.width - 36px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/trash.svg");
            tooltip: "Excluir";
            clicked => { root.remove-chain(root.chain-index); }
        }
    }

    Rectangle {
        x: 18px;
        y: 62px;
        width: parent.width - 36px;
        height: root.block-row-count * 92px;
        background: transparent;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            moved => {
                if !self.pressed {
                    root.suppress-insert-hover = false;
                }
            }
        }

        ChainEndpointChip {
            x: 0px;
            y: 26px;
            label: root.chain.input_label;
            tooltip: root.chain.input_tooltip;
            clicked => { root.configure-chain-input(root.chain-index); }
        }

        BlockInsertSlot {
            x: 88px;
            y: 30px;
            empty-slot: root.chain.blocks.length == 0;
            move-target: root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0;
            suppress-hover-affordance: root.suppress-insert-hover;
            active-drop-target: root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0 && root.drag-hover-before-index == 0;
            clicked => {
                if root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0 {
                    root.reorder-chain-block(root.chain-index, root.dragging-block-index, 0);
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                    root.suppress-insert-hover = true;
                } else {
                    root.start-block-insert(root.chain-index, 0);
                }
            }
        }

        for block[block-index] in root.chain.blocks : BlockChip {
            x: 120px + Math.mod(block-index, root.blocks-per-row) * 116px;
            y: Math.floor(block-index / root.blocks-per-row) * 92px;
            block: block;
            icon-source: block.kind == "amp_head"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-head.svg")
                : block.kind == "amp_combo"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-combo.svg")
                : block.kind == "cab"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/cab.svg")
                : block.kind == "ir"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/ir-loader.svg")
                : block.kind == "full_rig"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/full-rig.svg")
                : block.kind == "drive"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gain.svg")
                : block.kind == "dynamics"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/dyn.svg")
                : block.kind == "filter"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/filter.svg")
                : block.kind == "wah"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/expression.svg")
                : block.kind == "modulation"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/mod.svg")
                : block.kind == "delay"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/delay.svg")
                : block.kind == "reverb"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/reverb.svg")
                : block.kind == "utility"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/util.svg")
                : block.kind == "nam"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/nam.svg")
                : @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
            selected: root.dragging-chain-index == root.chain-index && root.dragging-block-index == block-index
                ? false
                : root.selected-block-chain-index == root.chain-index && root.selected-block-index == block-index;
            dragging: root.dragging-chain-index == root.chain-index && root.dragging-block-index == block-index;
            clicked => { root.select-chain-block(root.chain-index, block-index); }
            drag-moved(pointer-x, pointer-y) => {
                root.suppress-insert-hover = false;
                root.dragging-chain-index = root.chain-index;
                root.dragging-block-index = block-index;
                root.drag-hover-before-index = root.slot-index-for-position(pointer-x, pointer-y);
            }
            drag-finished(pointer-x, pointer-y) => {
                if root.dragging-chain-index == root.chain-index && root.dragging-block-index == block-index {
                    let before-index = root.slot-index-for-position(pointer-x, pointer-y);
                    root.drag-hover-before-index = before-index;
                    root.reorder-chain-block(root.chain-index, block-index, before-index);
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                    root.suppress-insert-hover = true;
                }
            }
        }

        for block[block-index] in root.chain.blocks : BlockInsertSlot {
            x: 204px + Math.mod(block-index, root.blocks-per-row) * 116px;
            y: 30px + Math.floor(block-index / root.blocks-per-row) * 92px;
            move-target: root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0;
            suppress-hover-affordance: root.suppress-insert-hover;
            active-drop-target: root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0 && root.drag-hover-before-index == block-index + 1;
            clicked => {
                if root.dragging-chain-index == root.chain-index && root.dragging-block-index >= 0 {
                    root.reorder-chain-block(root.chain-index, root.dragging-block-index, block-index + 1);
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                    root.suppress-insert-hover = true;
                } else {
                    root.start-block-insert(root.chain-index, block-index + 1);
                }
            }
        }

        ChainEndpointChip {
            x: parent.width - 64px;
            y: 26px;
            label: root.chain.output_label;
            tooltip: root.chain.output_tooltip;
            clicked => { root.configure-chain-output(root.chain-index); }
        }
    }

}

export component ProjectChainsPage inherits Rectangle {
    in property <string> project-title;
    in property <string> project-path-label;
    in property <bool> project-running;
    in property <bool> project-dirty;
    in property <[ProjectChainItem]> project-chains;
    in property <int> selected-chain-block-chain-index;
    in property <int> selected-chain-block-index;
    in property <[BlockTypePickerItem]> block-type-options;
    in property <[BlockModelPickerItem]> block-model-options;
    in property <[string]> block-model-option-labels;
    in property <bool> show-block-type-picker;
    in property <bool> show-block-drawer;
    in property <string> block-drawer-title;
    in property <string> block-drawer-confirm-label;
    in property <string> block-drawer-status-message;
    in property <bool> block-drawer-edit-mode;
    in property <int> block-drawer-selected-type-index;
    in property <int> block-drawer-selected-model-index;
    in property <bool> block-drawer-enabled;
    in property <[BlockParameterItem]> block-parameter-items;
    in-out property <string> status-message;
    property <int> dragging-chain-index: -1;
    property <int> dragging-block-index: -1;
    property <int> drag-hover-before-index: -1;
    callback back-to-launcher();
    callback add-chain();
    callback save-project();
    callback configure-project();
    callback remove-chain(int);
    callback toggle-chain-enabled(int);
    callback configure-chain(int);
    callback configure-chain-input(int);
    callback configure-chain-output(int);
    callback configure-chain-preset(int);
    callback save-chain-preset(int);
    callback start-project();
    callback stop-project();
    callback select-chain-block(int, int);
    callback clear-chain-block();
    callback toggle-chain-block-enabled(int, int);
    callback start-block-insert(int, int);
    callback reorder-chain-block(int, int, int);
    callback choose-block-type(int);
    callback choose-block-model(int);
    callback cancel-block-picker();
    callback close-block-drawer();
    callback save-block-drawer();
    callback delete-block-drawer();
    callback toggle-block-drawer-enabled();
    callback update-block-parameter-text(string, string);
    callback update-block-parameter-number(string, float);
    callback update-block-parameter-number-text(string, string);
    callback update-block-parameter-bool(string, bool);
    callback select-block-parameter-option(string, int);
    callback pick-block-parameter-file(string);

    background: #1f2023;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #1b1d22;

        Image {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/launcher-block-bg.jpg");
            image-fit: cover;
            opacity: 1;
        }

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: @linear-gradient(180deg, #17191dcc 0%, #17191de6 38%, #17191dd9 100%);
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => {
                if root.dragging-block-index >= 0 {
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                }
            }
        }
    }

    Rectangle {
        x: 24px;
        y: 18px;
        width: parent.width - 48px;
        height: 52px;
        background: transparent;

        Text {
            x: 0px;
            y: 6px;
            width: 360px;
            height: 36px;
            text: root.project-title;
            color: #f1f4f8;
            font-size: 28px;
            font-weight: 700;
            vertical-alignment: center;
        }

        HeaderIconAction {
            x: parent.width - 160px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/arrow-left.svg");
            tooltip: "Voltar";
            clicked => { root.back-to-launcher(); }
        }

        HeaderIconAction {
            x: parent.width - 120px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
            tooltip: "Projeto";
            clicked => { root.configure-project(); }
        }

        HeaderIconAction {
            x: parent.width - 80px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/save.svg");
            tint: root.project-dirty ? #f3c64f : #eef2f8;
            tooltip: "Salvar";
            clicked => { root.save-project(); }
        }

        if root.project-running : HeaderIconAction {
            x: parent.width - 40px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/stop.svg");
            active: true;
            tooltip: "Parar";
            clicked => { root.stop-project(); }
        }

        if !root.project-running : HeaderIconAction {
            x: parent.width - 40px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/play.svg");
            active: true;
            tooltip: "Iniciar";
            clicked => { root.start-project(); }
        }
    }

    Rectangle {
        x: 24px;
        y: 78px;
        width: parent.width - 48px;
        height: 1px;
        background: #34383f;
    }

    Rectangle {
        x: 24px;
        y: 96px;
        width: parent.width - 48px;
        height: parent.height - 120px;
        background: #22242988;
        border-width: 1px;
        border-color: #32363daa;
        border-radius: 6px;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => {
                if root.dragging-block-index >= 0 {
                    root.dragging-chain-index = -1;
                    root.dragging-block-index = -1;
                    root.drag-hover-before-index = -1;
                }
            }
        }

        ToolbarButton {
            x: parent.width - 154px;
            y: 16px;
            width: 136px;
            label: "Nova chain";
            primary: true;
            clicked => { root.add-chain(); }
        }

        ScrollView {
            x: 18px;
            y: 66px;
            width: parent.width - 36px;
            height: parent.height - 84px;
            viewport-height: chains-column.preferred-height;
            viewport-width: chains-column.width;

            chains-column := VerticalBox {
                x: 0px;
                y: 0px;
                width: parent.width - 18px;
                spacing: 12px;

                for chain[index] in root.project-chains : ChainRow {
                    width: parent.width;
                    chain: chain;
                    chain-index: index;
                    selected-block-chain-index: root.selected-chain-block-chain-index;
                    selected-block-index: root.selected-chain-block-index;
                    toggle-chain-enabled(index) => { root.toggle-chain-enabled(index); }
                    remove-chain(index) => { root.remove-chain(index); }
                configure-chain(index) => { root.configure-chain(index); }
                configure-chain-input(index) => { root.configure-chain-input(index); }
                configure-chain-output(index) => { root.configure-chain-output(index); }
                configure-chain-preset(index) => { root.configure-chain-preset(index); }
                    save-chain-preset(index) => { root.save-chain-preset(index); }
                    select-chain-block(chain-index, block-index) => { root.select-chain-block(chain-index, block-index); }
                    toggle-chain-block-enabled(chain-index, block-index) => { root.toggle-chain-block-enabled(chain-index, block-index); }
                    start-block-insert(chain-index, before-index) => { root.start-block-insert(chain-index, before-index); }
                    reorder-chain-block(chain-index, from-index, before-index) => {
                        root.reorder-chain-block(chain-index, from-index, before-index);
                        root.dragging-chain-index = -1;
                        root.dragging-block-index = -1;
                        root.drag-hover-before-index = -1;
                    }
                    dragging-chain-index <=> root.dragging-chain-index;
                    dragging-block-index <=> root.dragging-block-index;
                    drag-hover-before-index <=> root.drag-hover-before-index;
                }
            }
        }
    }

    if root.show-block-drawer : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0405068a;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width - 420px;
            height: parent.height;
            clicked => { root.close-block-drawer(); }
        }

        Rectangle {
            x: parent.width - 420px;
            y: 0px;
            width: 420px;
            height: parent.height;
            background: #171a20f8;
            border-width: 1px;
            border-color: #2d3340;

            Image {
                x: 20px;
                y: 18px;
                width: 28px;
                height: 28px;
                source: root.block-drawer-selected-type-index >= 0 && root.block-drawer-selected-type-index < root.block-type-options.length
                    ? (
                        root.block-type-options[root.block-drawer-selected-type-index].effect_type == "amp_head"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-head.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "amp_combo"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-combo.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "cab"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/cab.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "ir"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/ir-loader.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "full_rig"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/full-rig.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "drive"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gain.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "dynamics"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/dyn.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "filter"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/filter.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "wah"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/expression.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "modulation"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/mod.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "delay"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/delay.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "reverb"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/reverb.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "utility"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/util.svg")
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "nam"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/nam.svg")
                        : @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg")
                    )
                    : @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
                image-fit: contain;
                colorize: #f3f6fb;
            }

            Text {
                x: 56px;
                y: 20px;
                width: parent.width - 108px;
                height: 24px;
                text: root.block-drawer-selected-type-index >= 0 && root.block-drawer-selected-type-index < root.block-type-options.length
                    ? (
                        root.block-type-options[root.block-drawer-selected-type-index].effect_type == "amp_head" ? "AMP"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "amp_combo" ? "COMBO"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "cab" ? "CAB"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "ir" ? "IR"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "full_rig" ? "RIG"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "drive" ? "DRIVE"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "dynamics" ? "DYN"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "filter" ? "FILTER"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "wah" ? "WAH"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "modulation" ? "MOD"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "delay" ? "DLY"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "reverb" ? "RVB"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "utility" ? "UTIL"
                        : root.block-type-options[root.block-drawer-selected-type-index].effect_type == "nam" ? "NAM"
                        : "BLOCK"
                    )
                    : "";
                color: #f3f6fb;
                font-size: 18px;
                font-weight: 800;
                vertical-alignment: center;
            }

            ChainActionIcon {
                x: parent.width - 40px;
                y: 20px;
                icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/close.svg");
                tooltip: "Fechar";
                clicked => { root.close-block-drawer(); }
            }

            Rectangle {
                x: 20px;
                y: 62px;
                width: parent.width - 40px;
                height: 1px;
                background: #313743;
            }

            ScrollView {
                x: 20px;
                y: 78px;
                width: parent.width - 40px;
                height: parent.height - 168px;
                viewport-height: 92px + (root.block-parameter-items.length * 96px);

                ComboBox {
                    x: 0px;
                    y: 0px;
                    width: parent.width - 24px;
                    height: 34px;
                    model: root.block-model-option-labels;
                    current-index: root.block-drawer-selected-model-index;
                    selected(_) => { root.choose-block-model(self.current-index); }
                }

                if root.block-drawer-selected-model-index >= 0 && root.block-drawer-selected-model-index < root.block-model-options.length : Text {
                    x: 0px;
                    y: 40px;
                    width: parent.width - 24px;
                    height: 16px;
                    text: root.block-model-options[root.block-drawer-selected-model-index].subtitle;
                    color: #94a0b0;
                    font-size: 11px;
                }

                for param-item[index] in root.block-parameter-items : BlockParameterRow {
                    x: 0px;
                    y: 72px + (index * 96px);
                    width: parent.width - 24px;
                    item: param-item;
                    text-changed(path, value) => { root.update-block-parameter-text(path, value); }
                    number-changed(path, value) => { root.update-block-parameter-number(path, value); }
                    number-text-changed(path, value) => { root.update-block-parameter-number-text(path, value); }
                    bool-changed(path, value) => { root.update-block-parameter-bool(path, value); }
                    option-changed(path, value) => { root.select-block-parameter-option(path, value); }
                    file-picked(path) => { root.pick-block-parameter-file(path); }
                }
            }

            if root.block-drawer-edit-mode : ChainPowerToggle {
                x: 20px;
                y: parent.height - 48px;
                enabled: root.block-drawer-enabled;
                tooltip: root.block-drawer-enabled ? "Desativar" : "Ativar";
                clicked => { root.toggle-block-drawer-enabled(); }
            }

            if root.block-drawer-edit-mode : ChainActionIcon {
                x: 60px;
                y: parent.height - 46px;
                icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/trash.svg");
                tooltip: "Excluir";
                clicked => { root.delete-block-drawer(); }
            }

            if !root.block-drawer-edit-mode : ToolbarButton {
                x: parent.width - 116px;
                y: parent.height - 54px;
                width: 96px;
                label: root.block-drawer-confirm-label;
                primary: true;
                clicked => { root.save-block-drawer(); }
            }
        }
    }

    if root.show-block-type-picker : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0405069a;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => { root.cancel-block-picker(); }
        }

        picker-modal := Rectangle {
            property <int> row-count: Math.max(1, Math.floor((root.block-type-options.length - 1) / 4) + 1);
            property <length> content-height: self.row-count * 100px;
            x: (parent.width - 472px) / 2;
            y: (parent.height - self.height) / 2;
            width: 472px;
            height: Math.min(parent.height - 80px, self.content-height + 40px);
            background: #171a20f8;
            border-width: 1px;
            border-color: #2d3340;
            border-radius: 6px;

            ScrollView {
                x: 20px;
                y: 20px;
                width: parent.width - 40px;
                height: parent.height - 40px;
                viewport-height: picker-modal.content-height;

                for type-item[index] in root.block-type-options : BlockTypeCard {
                    x: Math.mod(index, 4) * 106px;
                    y: Math.floor(index / 4) * 100px;
                    item: type-item;
                    selected: false;
                    icon-source: type-item.icon_kind == "amp_head"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-head.svg")
                        : type-item.icon_kind == "amp_combo"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-combo.svg")
                        : type-item.icon_kind == "cab"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/cab.svg")
                        : type-item.icon_kind == "ir"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/ir-loader.svg")
                        : type-item.icon_kind == "full_rig"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/full-rig.svg")
                        : type-item.icon_kind == "drive"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gain.svg")
                        : type-item.icon_kind == "dynamics"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/dyn.svg")
                        : type-item.icon_kind == "filter"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/filter.svg")
                        : type-item.icon_kind == "wah"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/expression.svg")
                        : type-item.icon_kind == "modulation"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/mod.svg")
                        : type-item.icon_kind == "delay"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/delay.svg")
                        : type-item.icon_kind == "reverb"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/reverb.svg")
                        : type-item.icon_kind == "utility"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/util.svg")
                        : type-item.icon_kind == "nam"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/nam.svg")
                        : @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
                    clicked => { root.choose-block-type(index); }
                }
            }
        }
    }
}
