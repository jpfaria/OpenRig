import { ComboBox, ScrollView, VerticalBox } from "std-widgets.slint";
import { ProjectTrackItem, StageModelPickerItem, StageParameterItem, StageTypePickerItem, TrackStageItem } from "../models.slint";

component ToolbarButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 140px : 116px;
    height: 40px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 600;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component ParamFieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1a1e25;
    border-width: 1px;
    border-color: #3c4350;
    border-radius: 4px;

    TextInput {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.text = self.text;
            root.changed(self.text);
        }
    }
}

component StageValueKnob inherits Rectangle {
    in property <string> label;
    in property <string> value-text;
    in property <string> unit-text;
    in property <float> progress: 0;
    callback moved(float);

    width: 124px;
    height: 128px;
    background: transparent;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
    }

    Rectangle {
        x: 14px;
        y: 28px;
        width: 96px;
        height: 96px;
        background: #2b2f35;
        border-width: 2px;
        border-color: #454c58;
        border-radius: 48px;

        Rectangle {
            x: 6px;
            y: 6px;
            width: parent.width - 12px;
            height: parent.height - 12px;
            background: #1b1f26;
            border-width: 1px;
            border-color: #0f1217;
            border-radius: self.width / 2;
        }

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: transparent;
            transform-rotation: (-135deg + (root.progress * 270deg));

            Rectangle {
                x: (parent.width - 4px) / 2;
                y: 8px;
                width: 4px;
                height: 24px;
                background: #d7dde7;
                border-radius: 2px;
            }
        }

        Text {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: 22px;
            text: root.value-text;
            color: #f5f7fb;
            font-size: 18px;
            font-weight: 800;
            horizontal-alignment: center;
        }

        if root.unit-text != "" : Text {
            x: 0px;
            y: 52px;
            width: parent.width;
            height: 14px;
            text: root.unit-text;
            color: #aab4c3;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            moved => {
                let next = 1 - (self.mouse-y / parent.height);
                root.moved(next < 0 ? 0 : next > 1 ? 1 : next);
            }
        }
    }
}

component StageFootswitch inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback toggled(bool);

    width: 160px;
    height: 78px;
    background: transparent;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 700;
    }

    Rectangle {
        x: 0px;
        y: 28px;
        width: 160px;
        height: 42px;
        background: transparent;

        Rectangle {
            x: 0px;
            y: 14px;
            width: 10px;
            height: 10px;
            background: root.active ? #29df85 : #5f6776;
            border-radius: 5px;
        }

        Rectangle {
            x: 28px;
            y: 0px;
            width: 42px;
            height: 42px;
            background: #c7ccd4;
            border-width: 2px;
            border-color: root.active ? #ecf7ef : #a3a9b2;
            border-radius: 21px;

            Rectangle {
                x: 7px;
                y: 7px;
                width: 24px;
                height: 24px;
                background: #8f97a4;
                border-radius: 12px;
            }

            TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.toggled(!root.active); }
            }
        }

        Text {
            x: 84px;
            y: 10px;
            width: 70px;
            height: 20px;
            text: root.active ? "ON" : "OFF";
            color: root.active ? #ecf7ef : #8d98a9;
            font-size: 12px;
            font-weight: 800;
        }
    }
}

component StageTypeCard inherits Rectangle {
    in property <StageTypePickerItem> item;
    in property <bool> selected: false;
    in property <image> icon-source;
    property <color> accent-color: root.item.effect_type == "amp_head" ? #f29f38
        : root.item.effect_type == "amp_combo" ? #f06292
        : root.item.effect_type == "cab" ? #f2cb54
        : root.item.effect_type == "full_rig" ? #63d2ff
        : root.item.effect_type == "drive" ? #ff6a57
        : root.item.effect_type == "compressor" ? #41b8ff
        : root.item.effect_type == "gate" ? #74d680
        : root.item.effect_type == "eq" ? #d6c85a
        : root.item.effect_type == "tremolo" ? #58d39b
        : root.item.effect_type == "delay" ? #ba8cff
        : root.item.effect_type == "reverb" ? #6de1d2
        : root.item.effect_type == "tuner" ? #95a0b2
        : root.item.effect_type == "nam" ? #ff7cd7
        : #7fb0ff;
    property <string> type-label: root.item.effect_type == "amp_head" ? "AMP"
        : root.item.effect_type == "amp_combo" ? "COMBO"
        : root.item.effect_type == "cab" ? "CAB"
        : root.item.effect_type == "full_rig" ? "RIG"
        : root.item.effect_type == "drive" ? "GAIN"
        : root.item.effect_type == "compressor" ? "DYN"
        : root.item.effect_type == "gate" ? "DYN"
        : root.item.effect_type == "eq" ? "FILTER"
        : root.item.effect_type == "tremolo" ? "MOD"
        : root.item.effect_type == "delay" ? "DLY"
        : root.item.effect_type == "reverb" ? "RVB"
        : root.item.effect_type == "tuner" ? "UTIL"
        : root.item.effect_type == "nam" ? "NAM"
        : "CORE";
    callback clicked();

    width: 88px;
    height: 88px;
    background: #151920;
    border-width: 1px;
    border-color: root.accent-color;
    border-radius: 4px;

    Text {
        x: 8px;
        y: 5px;
        width: parent.width - 16px;
        height: 14px;
        text: root.type-label;
        color: #f3f6fb;
        font-size: 10px;
        font-weight: 900;
        vertical-alignment: center;
    }

    Image {
        x: 14px;
        y: 20px;
        width: 60px;
        height: 60px;
        source: root.icon-source;
        image-fit: contain;
        colorize: root.accent-color;
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component StageParameterRow inherits Rectangle {
    in property <StageParameterItem> item;
    callback text-changed(string, string);
    callback number-changed(string, float);
    callback bool-changed(string, bool);
    callback option-changed(string, int);
    callback file-picked(string);

    height: root.item.widget_kind == "bool" ? 96px
        : (root.item.widget_kind == "float" || root.item.widget_kind == "int") ? 148px
        : 84px;
    background: transparent;

    if root.item.widget_kind != "bool" && root.item.widget_kind != "float" && root.item.widget_kind != "int" : Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 18px;
        text: root.item.label;
        color: #eef2f8;
        font-size: 13px;
        font-weight: 650;
    }

    if root.item.widget_kind == "bool" : StageFootswitch {
        x: 0px;
        y: 0px;
        label: root.item.label;
        active: root.item.bool_value;
        toggled(value) => {
            root.bool-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "enum" : ComboBox {
        x: 0px;
        y: 28px;
        width: parent.width;
        height: 32px;
        model: root.item.option_labels;
        current-index: root.item.selected_option_index;
        selected(_) => {
            root.option-changed(root.item.path, self.current-index);
        }
    }

    if root.item.widget_kind == "text" : ParamFieldBox {
        x: 0px;
        y: 28px;
        width: root.item.unit_text == "" ? parent.width : parent.width - 54px;
        height: 34px;
        text: root.item.value_text;
        changed(value) => {
            root.text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "float" || root.item.widget_kind == "int" : StageValueKnob {
        x: 0px;
        y: 0px;
        label: root.item.label;
        value-text: root.item.value_text;
        unit-text: root.item.unit_text;
        progress: root.item.numeric_max > root.item.numeric_min
            ? (root.item.numeric_value - root.item.numeric_min) / (root.item.numeric_max - root.item.numeric_min)
            : 0;
        moved(progress) => {
            root.number-changed(
                root.item.path,
                root.item.numeric_min + ((root.item.numeric_max - root.item.numeric_min) * progress)
            );
        }
    }

    if root.item.widget_kind == "path" : ParamFieldBox {
        x: 0px;
        y: 28px;
        width: parent.width - 46px;
        height: 34px;
        text: root.item.value_text;
        changed(value) => {
            root.text-changed(root.item.path, value);
        }
    }

    if root.item.widget_kind == "path" : Rectangle {
        x: parent.width - 30px;
        y: 33px;
        width: 24px;
        height: 24px;
        background: file-hover.has-hover ? #ffffff10 : transparent;

        Image {
            x: 2px;
            y: 2px;
            width: 20px;
            height: 20px;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/open-file.svg");
            image-fit: contain;
        }

        file-hover := TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.file-picked(root.item.path); }
        }
    }

    if root.item.widget_kind == "text" && root.item.unit_text != "" : Rectangle {
        x: parent.width - 42px;
        y: 35px;
        width: 42px;
        height: 20px;
        background: transparent;
        border-width: 1px;
        border-color: #465063;
        border-radius: 3px;

        Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: root.item.unit_text;
            color: #a6b7ce;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component TrackActionIcon inherits Rectangle {
    in property <image> icon;
    callback clicked();

    width: 24px;
    height: 24px;
    background: hover-area.has-hover ? #ffffff10 : transparent;

    Image {
        x: 2px;
        y: 2px;
        width: 20px;
        height: 20px;
        source: root.icon;
        image-fit: contain;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component TrackPowerToggle inherits Rectangle {
    in property <bool> enabled: false;
    callback clicked();

    width: 28px;
    height: 28px;
    background: hover-area.has-hover ? #ffffff08 : transparent;

    Rectangle {
        x: 4px;
        y: 4px;
        width: 20px;
        height: 20px;
        background: transparent;
        border-width: 2px;
        border-color: root.enabled ? #29df85 : #6a7483;
        border-radius: 10px;
    }

    Rectangle {
        x: 13px;
        y: 3px;
        width: 2px;
        height: 10px;
        background: root.enabled ? #29df85 : #6a7483;
        border-radius: 1px;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component HeaderIconAction inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    in property <color> tint: root.active ? #188cff : #eef2f8;
    callback clicked();

    width: 24px;
    height: 24px;
    background: action-area.has-hover ? #ffffff10 : transparent;

    Image {
        x: 2px;
        y: 2px;
        width: 20px;
        height: 20px;
        source: root.icon;
        image-fit: contain;
        colorize: root.tint;
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    action-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component StageChip inherits Rectangle {
    in property <TrackStageItem> stage;
    in property <bool> selected: false;
    in property <image> icon-source;
    in property <bool> dragging: false;
    property <color> accent-color: root.stage.kind == "amp_head" ? #f29f38
        : root.stage.kind == "amp_combo" ? #f06292
        : root.stage.kind == "cab" ? #f2cb54
        : root.stage.kind == "full_rig" ? #63d2ff
        : root.stage.kind == "drive" ? #ff6a57
        : root.stage.kind == "compressor" ? #41b8ff
        : root.stage.kind == "gate" ? #74d680
        : root.stage.kind == "eq" ? #d6c85a
        : root.stage.kind == "tremolo" ? #58d39b
        : root.stage.kind == "delay" ? #ba8cff
        : root.stage.kind == "reverb" ? #6de1d2
        : root.stage.kind == "tuner" ? #95a0b2
        : root.stage.kind == "nam" ? #ff7cd7
        : #7fb0ff;
    property <string> stage-type-label: root.stage.kind == "amp_head" ? "AMP"
        : root.stage.kind == "amp_combo" ? "COMBO"
        : root.stage.kind == "cab" ? "CAB"
        : root.stage.kind == "full_rig" ? "RIG"
        : root.stage.kind == "drive" ? "GAIN"
        : root.stage.kind == "compressor" ? "DYN"
        : root.stage.kind == "gate" ? "DYN"
        : root.stage.kind == "eq" ? "FILTER"
        : root.stage.kind == "tremolo" ? "MOD"
        : root.stage.kind == "delay" ? "DLY"
        : root.stage.kind == "reverb" ? "RVB"
        : root.stage.kind == "tuner" ? "UTIL"
        : root.stage.kind == "nam" ? "NAM"
        : "CORE";
    callback clicked();
    callback drag-moved(float, float);
    callback drag-finished(float, float);
    property <bool> did-drag: false;
    property <bool> drag-origin-set: false;
    property <float> drag-origin-x: 0;
    property <float> drag-origin-y: 0;

    width: 84px;
    height: 84px;
    background: transparent;
    border-width: hover-area.has-hover || (root.selected && !root.dragging) ? 3px : 2px;
    border-color: root.dragging ? #8b95a5 : root.accent-color;
    border-radius: 6px;
    opacity: root.stage.enabled ? 1 : 0.42;

    Image {
        x: 0px;
        y: 8px;
        width: parent.width;
        height: parent.height - 4px;
        source: root.icon-source;
        image-fit: contain;
        colorize: root.dragging ? #8b95a5 : root.selected ? root.accent-color : #f3f6fb;
    }

    Text {
        x: 8px;
        y: 4px;
        width: parent.width - 16px;
        height: 14px;
        text: root.stage-type-label;
        color: root.dragging ? #8b95a5 : root.selected ? root.accent-color : #f3f6fb;
        font-size: 10px;
        font-weight: 900;
        vertical-alignment: center;
    }

    Rectangle {
        x: parent.width - 10px;
        y: parent.height - 10px;
        width: 5px;
        height: 5px;
        background: root.stage.enabled ? #29df85 : #697382;
        border-radius: 3px;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        moved => {
            if self.pressed {
                let pointer-x = (self.mouse-x + root.x) / 1px;
                let pointer-y = (self.mouse-y + root.y) / 1px;
                if !root.drag-origin-set {
                    root.drag-origin-set = true;
                    root.drag-origin-x = pointer-x;
                    root.drag-origin-y = pointer-y;
                } else {
                    let delta-x = pointer-x - root.drag-origin-x;
                    let delta-y = pointer-y - root.drag-origin-y;
                    let distance = (delta-x < 0 ? -delta-x : delta-x) + (delta-y < 0 ? -delta-y : delta-y);
                    if distance > 8 {
                        root.did-drag = true;
                        root.drag-moved(pointer-x, pointer-y);
                    }
                }
            }
        }
        clicked => {
            if !root.did-drag {
                root.clicked();
            }
            root.did-drag = false;
            root.drag-origin-set = false;
        }
    }
}

component StageInsertSlot inherits Rectangle {
    in property <bool> empty-slot: false;
    in property <bool> active-drop-target: false;
    in property <bool> move-target: false;
    in property <bool> suppress-hover-affordance: false;
    callback clicked();

    width: 40px;
    height: 24px;
    background: transparent;

    if !root.empty-slot : Rectangle {
        x: 0px;
        y: 11px;
        width: parent.width;
        height: 2px;
        background: root.active-drop-target ? #a9b2bf : hover-area.has-hover && !root.suppress-hover-affordance ? #8b95a5 : #3b4250;
        border-radius: 1px;
    }

    if root.active-drop-target : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;

        Text {
            x: 0px;
            y: -8px;
            width: parent.width;
            height: 10px;
            text: "v";
            color: #ffffff;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 12px;
            font-weight: 900;
        }

        Text {
            x: 0px;
            y: 16px;
            width: parent.width;
            height: 10px;
            text: "^";
            color: #ffffff;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 12px;
            font-weight: 900;
        }
    }

    if !root.move-target && (root.empty-slot || (hover-area.has-hover && !root.suppress-hover-affordance)) : Rectangle {
        x: (parent.width - 24px) / 2;
        y: 0px;
        width: 24px;
        height: 24px;
        background: root.empty-slot ? #20252d : #252a33;
        border-width: 1px;
        border-color: root.empty-slot ? #5a6577 : #7c8798;
        border-radius: 12px;

        Text {
            x: 0px;
            y: -1px;
            width: parent.width;
            height: parent.height;
            text: "+";
            color: #eef2f8;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 15px;
            font-weight: 700;
        }
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component TrackRow inherits Rectangle {
    in property <ProjectTrackItem> track;
    in property <int> track-index;
    in property <int> selected-stage-track-index;
    in property <int> selected-stage-index;
    callback toggle-track-enabled(int);
    callback remove-track(int);
    callback configure-track(int);
    callback configure-track-preset(int);
    callback save-track-preset(int);
    callback select-track-stage(int, int);
    callback toggle-track-stage-enabled(int, int);
    callback start-stage-insert(int, int);
    callback reorder-track-stage(int, int, int);
    property <int> stages-per-row: Math.max(1, Math.floor((root.width - 120px) / 124px));
    property <int> stage-row-count: root.track.stages.length == 0 ? 1 : Math.floor((root.track.stages.length - 1) / root.stages-per-row) + 1;
    property <int> insert-row-count: Math.floor(root.track.stages.length / root.stages-per-row) + 1;
    in-out property <int> dragging-track-index: -1;
    in-out property <int> dragging-stage-index: -1;
    in-out property <int> drag-hover-before-index: -1;
    property <bool> suppress-insert-hover: false;

    pure function slot-index-for-position(pointer-x: float, pointer-y: float) -> int {
        let row = Math.max(0, Math.min(root.insert-row-count - 1, Math.floor((pointer-y + 26) / 112)));
        let col = Math.max(0, Math.min(root.stages-per-row, Math.round((pointer-x - 16) / 124)));
        let candidate = row * root.stages-per-row + col;
        return Math.max(0, Math.min(root.track.stages.length, candidate));
    }

    background: transparent;
    border-width: 1px;
    border-color: #31353d;
    border-radius: 6px;
    height: 108px + (root.insert-row-count * 112px);

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 80px;
        background: transparent;

        TrackPowerToggle {
            x: 18px;
            y: 18px;
            enabled: root.track.enabled;
            clicked => { root.toggle-track-enabled(root.track-index); }
        }

        Text {
            x: 56px;
            y: 18px;
            width: 320px;
            height: 24px;
            text: root.track.title;
            color: #f1f4f8;
            font-size: 18px;
            font-weight: 650;
            vertical-alignment: center;
        }

        TrackActionIcon {
            x: parent.width - 156px;
            y: 18px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
            clicked => { root.configure-track(root.track-index); }
        }

        TrackActionIcon {
            x: parent.width - 116px;
            y: 18px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/open-file.svg");
            clicked => { root.configure-track-preset(root.track-index); }
        }

        TrackActionIcon {
            x: parent.width - 76px;
            y: 18px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/save.svg");
            clicked => { root.save-track-preset(root.track-index); }
        }

        TrackActionIcon {
            x: parent.width - 36px;
            y: 18px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/trash.svg");
            clicked => { root.remove-track(root.track-index); }
        }
    }

    Rectangle {
        x: 18px;
        y: 58px;
        width: parent.width - 36px;
        height: root.insert-row-count * 112px;
        background: transparent;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            moved => {
                if !self.pressed {
                    root.suppress-insert-hover = false;
                }
            }
        }

        StageInsertSlot {
            x: 16px;
            y: 30px;
            empty-slot: root.track.stages.length == 0;
            move-target: root.dragging-track-index == root.track-index && root.dragging-stage-index >= 0;
            suppress-hover-affordance: root.suppress-insert-hover;
            active-drop-target: root.dragging-track-index == root.track-index && root.dragging-stage-index >= 0 && root.drag-hover-before-index == 0;
            clicked => {
                if root.dragging-track-index == root.track-index && root.dragging-stage-index >= 0 {
                    root.reorder-track-stage(root.track-index, root.dragging-stage-index, 0);
                    root.dragging-track-index = -1;
                    root.dragging-stage-index = -1;
                    root.drag-hover-before-index = -1;
                    root.suppress-insert-hover = true;
                } else {
                    root.start-stage-insert(root.track-index, 0);
                }
            }
        }

        for stage[stage-index] in root.track.stages : StageChip {
            x: 56px + Math.mod(stage-index, root.stages-per-row) * 124px;
            y: Math.floor(stage-index / root.stages-per-row) * 112px;
            stage: stage;
            icon-source: stage.kind == "amp_head"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-head.svg")
                : stage.kind == "amp_combo"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-combo.svg")
                : stage.kind == "cab"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/cab.svg")
                : stage.kind == "full_rig"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/full-rig.svg")
                : stage.kind == "drive"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gain.svg")
                : stage.kind == "compressor"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/compressor.svg")
                : stage.kind == "gate"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gate.svg")
                : stage.kind == "eq"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/eq.svg")
                : stage.kind == "tremolo"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/mod.svg")
                : stage.kind == "delay"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/delay.svg")
                : stage.kind == "reverb"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/reverb.svg")
                : stage.kind == "tuner"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/tuner.svg")
                : stage.kind == "nam"
                ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/nam.svg")
                : @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
            selected: root.dragging-track-index == root.track-index && root.dragging-stage-index == stage-index
                ? false
                : root.selected-stage-track-index == root.track-index && root.selected-stage-index == stage-index;
            dragging: root.dragging-track-index == root.track-index && root.dragging-stage-index == stage-index;
            clicked => { root.select-track-stage(root.track-index, stage-index); }
            drag-moved(pointer-x, pointer-y) => {
                root.suppress-insert-hover = false;
                root.dragging-track-index = root.track-index;
                root.dragging-stage-index = stage-index;
                root.drag-hover-before-index = root.slot-index-for-position(pointer-x, pointer-y);
            }
            drag-finished(pointer-x, pointer-y) => {
                if root.dragging-track-index == root.track-index && root.dragging-stage-index == stage-index {
                    root.drag-hover-before-index = root.slot-index-for-position(pointer-x, pointer-y);
                }
            }
        }

        for stage[stage-index] in root.track.stages : StageInsertSlot {
            x: 140px + Math.mod(stage-index, root.stages-per-row) * 124px;
            y: 30px + Math.floor(stage-index / root.stages-per-row) * 112px;
            move-target: root.dragging-track-index == root.track-index && root.dragging-stage-index >= 0;
            suppress-hover-affordance: root.suppress-insert-hover;
            active-drop-target: root.dragging-track-index == root.track-index && root.dragging-stage-index >= 0 && root.drag-hover-before-index == stage-index + 1;
            clicked => {
                if root.dragging-track-index == root.track-index && root.dragging-stage-index >= 0 {
                    root.reorder-track-stage(root.track-index, root.dragging-stage-index, stage-index + 1);
                    root.dragging-track-index = -1;
                    root.dragging-stage-index = -1;
                    root.drag-hover-before-index = -1;
                    root.suppress-insert-hover = true;
                } else {
                    root.start-stage-insert(root.track-index, stage-index + 1);
                }
            }
        }
    }

}

export component ProjectTracksPage inherits Rectangle {
    in property <string> project-title;
    in property <string> project-path-label;
    in property <bool> project-running;
    in property <bool> project-dirty;
    in property <[ProjectTrackItem]> project-tracks;
    in property <int> selected-track-stage-track-index;
    in property <int> selected-track-stage-index;
    in property <[StageTypePickerItem]> stage-type-options;
    in property <[StageModelPickerItem]> stage-model-options;
    in property <[string]> stage-model-option-labels;
    in property <bool> show-stage-type-picker;
    in property <bool> show-stage-drawer;
    in property <string> stage-drawer-title;
    in property <string> stage-drawer-confirm-label;
    in property <string> stage-drawer-status-message;
    in property <bool> stage-drawer-edit-mode;
    in property <int> stage-drawer-selected-type-index;
    in property <int> stage-drawer-selected-model-index;
    in property <bool> stage-drawer-enabled;
    in property <[StageParameterItem]> stage-parameter-items;
    in-out property <string> status-message;
    property <int> dragging-track-index: -1;
    property <int> dragging-stage-index: -1;
    property <int> drag-hover-before-index: -1;
    callback back-to-launcher();
    callback add-track();
    callback save-project();
    callback configure-project();
    callback remove-track(int);
    callback toggle-track-enabled(int);
    callback configure-track(int);
    callback configure-track-preset(int);
    callback save-track-preset(int);
    callback start-project();
    callback stop-project();
    callback select-track-stage(int, int);
    callback clear-track-stage();
    callback toggle-track-stage-enabled(int, int);
    callback start-stage-insert(int, int);
    callback reorder-track-stage(int, int, int);
    callback choose-stage-type(int);
    callback choose-stage-model(int);
    callback cancel-stage-picker();
    callback close-stage-drawer();
    callback save-stage-drawer();
    callback delete-stage-drawer();
    callback toggle-stage-drawer-enabled();
    callback update-stage-parameter-text(string, string);
    callback update-stage-parameter-number(string, float);
    callback update-stage-parameter-bool(string, bool);
    callback select-stage-parameter-option(string, int);
    callback pick-stage-parameter-file(string);

    background: #1f2023;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #1b1d22;

        Image {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/launcher-stage-bg.jpg");
            image-fit: cover;
            opacity: 1;
        }

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: @linear-gradient(180deg, #17191dcc 0%, #17191de6 38%, #17191dd9 100%);
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => {
                if root.dragging-stage-index >= 0 {
                    root.dragging-track-index = -1;
                    root.dragging-stage-index = -1;
                    root.drag-hover-before-index = -1;
                }
            }
        }
    }

    Rectangle {
        x: 24px;
        y: 18px;
        width: parent.width - 48px;
        height: 52px;
        background: transparent;

        Image {
            x: 0px;
            y: -4px;
            width: 68px;
            height: 68px;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/openrig-logomark.svg");
            image-fit: contain;
        }

        Image {
            x: 40px;
            y: 2px;
            width: 210px;
            height: 52px;
            source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/openrig-logotype.png");
            image-fit: contain;
        }

        HeaderIconAction {
            x: parent.width - 160px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/arrow-left.svg");
            clicked => { root.back-to-launcher(); }
        }

        HeaderIconAction {
            x: parent.width - 120px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
            clicked => { root.configure-project(); }
        }

        HeaderIconAction {
            x: parent.width - 80px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/save.svg");
            tint: root.project-dirty ? #f3c64f : #eef2f8;
            clicked => { root.save-project(); }
        }

        if root.project-running : HeaderIconAction {
            x: parent.width - 40px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/stop.svg");
            active: true;
            clicked => { root.stop-project(); }
        }

        if !root.project-running : HeaderIconAction {
            x: parent.width - 40px;
            y: 14px;
            icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/play.svg");
            active: true;
            clicked => { root.start-project(); }
        }
    }

    Rectangle {
        x: 24px;
        y: 78px;
        width: parent.width - 48px;
        height: 1px;
        background: #34383f;
    }

    Rectangle {
        x: 24px;
        y: 96px;
        width: parent.width - 48px;
        height: parent.height - 120px;
        background: #22242988;
        border-width: 1px;
        border-color: #32363daa;
        border-radius: 6px;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => {
                if root.dragging-stage-index >= 0 {
                    root.dragging-track-index = -1;
                    root.dragging-stage-index = -1;
                    root.drag-hover-before-index = -1;
                }
            }
        }

        Text {
            x: 18px;
            y: 18px;
            width: 340px;
            height: 28px;
            text: root.project-title;
            color: #f1f4f8;
            font-size: 24px;
            font-weight: 680;
            vertical-alignment: center;
        }

        Text {
            x: 18px;
            y: 52px;
            width: 280px;
            height: 18px;
            text: root.status-message;
            color: #8db9ff;
            font-size: 12px;
            vertical-alignment: center;
        }

        ToolbarButton {
            x: parent.width - 154px;
            y: 28px;
            width: 136px;
            label: "Nova track";
            primary: true;
            clicked => { root.add-track(); }
        }

        ScrollView {
            x: 18px;
            y: 88px;
            width: parent.width - 36px;
            height: parent.height - 106px;
            viewport-height: tracks-column.preferred-height;
            viewport-width: self.width;

            tracks-column := VerticalBox {
                x: 6px;
                y: 0px;
                width: parent.width - 12px;
                spacing: 20px;

                for track[index] in root.project-tracks : TrackRow {
                    width: parent.width;
                    track: track;
                    track-index: index;
                    selected-stage-track-index: root.selected-track-stage-track-index;
                    selected-stage-index: root.selected-track-stage-index;
                    toggle-track-enabled(index) => { root.toggle-track-enabled(index); }
                    remove-track(index) => { root.remove-track(index); }
                    configure-track(index) => { root.configure-track(index); }
                    configure-track-preset(index) => { root.configure-track-preset(index); }
                    save-track-preset(index) => { root.save-track-preset(index); }
                    select-track-stage(track-index, stage-index) => { root.select-track-stage(track-index, stage-index); }
                    toggle-track-stage-enabled(track-index, stage-index) => { root.toggle-track-stage-enabled(track-index, stage-index); }
                    start-stage-insert(track-index, before-index) => { root.start-stage-insert(track-index, before-index); }
                    reorder-track-stage(track-index, from-index, before-index) => { root.reorder-track-stage(track-index, from-index, before-index); }
                    dragging-track-index <=> root.dragging-track-index;
                    dragging-stage-index <=> root.dragging-stage-index;
                    drag-hover-before-index <=> root.drag-hover-before-index;
                }
            }
        }
    }

    if root.show-stage-drawer : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0405068a;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width - 420px;
            height: parent.height;
            clicked => { root.close-stage-drawer(); }
        }

        Rectangle {
            x: parent.width - 420px;
            y: 0px;
            width: 420px;
            height: parent.height;
            background: #171a20f8;
            border-width: 1px;
            border-color: #2d3340;

            Text {
                x: 20px;
                y: 22px;
                width: parent.width - 72px;
                height: 22px;
                text: root.stage-drawer-title;
                color: #f3f6fb;
                font-size: 18px;
                font-weight: 700;
            }

            TrackActionIcon {
                x: parent.width - 40px;
                y: 20px;
                icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/close.svg");
                clicked => { root.close-stage-drawer(); }
            }

            Rectangle {
                x: 20px;
                y: 62px;
                width: parent.width - 40px;
                height: 1px;
                background: #313743;
            }

            ScrollView {
                x: 20px;
                y: 78px;
                width: parent.width - 40px;
                height: parent.height - 168px;
                viewport-height: 300px + (((root.stage-parameter-items.length + 1) / 2) * 156px);

                Text {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: 16px;
                    text: "Modelo";
                    color: #aab4c3;
                    font-size: 12px;
                    font-weight: 700;
                }

                ComboBox {
                    x: 0px;
                    y: 24px;
                    width: parent.width - 64px;
                    height: 34px;
                    model: root.stage-model-option-labels;
                    current-index: root.stage-drawer-selected-model-index;
                    selected(_) => { root.choose-stage-model(self.current-index); }
                }

                if root.stage-drawer-selected-model-index >= 0 && root.stage-drawer-selected-model-index < root.stage-model-options.length : Text {
                    x: 0px;
                    y: 64px;
                    width: parent.width - 64px;
                    height: 16px;
                    text: root.stage-model-options[root.stage-drawer-selected-model-index].subtitle;
                    color: #94a0b0;
                    font-size: 11px;
                }

                Text {
                    x: 0px;
                    y: 98px;
                    width: parent.width;
                    height: 16px;
                    text: "Parâmetros";
                    color: #aab4c3;
                    font-size: 12px;
                    font-weight: 700;
                }

                for param-item[index] in root.stage-parameter-items : StageParameterRow {
                    x: (Math.mod(index, 2) * (((parent.width - 16px) / 2) + 16px));
                    y: 122px + (((index - Math.mod(index, 2)) / 2) * 156px);
                    width: (parent.width - 16px) / 2;
                    item: param-item;
                    text-changed(path, value) => { root.update-stage-parameter-text(path, value); }
                    number-changed(path, value) => { root.update-stage-parameter-number(path, value); }
                    bool-changed(path, value) => { root.update-stage-parameter-bool(path, value); }
                    option-changed(path, value) => { root.select-stage-parameter-option(path, value); }
                    file-picked(path) => { root.pick-stage-parameter-file(path); }
                }
            }

            Text {
                x: 20px;
                y: parent.height - 84px;
                width: parent.width - 40px;
                height: 16px;
                text: root.stage-drawer-status-message;
                color: #f3c64f;
                font-size: 12px;
            }

            if root.stage-drawer-edit-mode : TrackPowerToggle {
                x: 20px;
                y: parent.height - 48px;
                enabled: root.stage-drawer-enabled;
                clicked => { root.toggle-stage-drawer-enabled(); }
            }

            if root.stage-drawer-edit-mode : TrackActionIcon {
                x: 60px;
                y: parent.height - 46px;
                icon: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/trash.svg");
                clicked => { root.delete-stage-drawer(); }
            }

            if !root.stage-drawer-edit-mode : ToolbarButton {
                x: parent.width - 116px;
                y: parent.height - 54px;
                width: 96px;
                label: root.stage-drawer-confirm-label;
                primary: true;
                clicked => { root.save-stage-drawer(); }
            }
        }
    }

    if root.show-stage-type-picker : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0405069a;

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => { root.cancel-stage-picker(); }
        }

        picker-modal := Rectangle {
            property <int> row-count: Math.max(1, Math.floor((root.stage-type-options.length - 1) / 4) + 1);
            property <length> content-height: self.row-count * 100px;
            x: (parent.width - 472px) / 2;
            y: (parent.height - self.height) / 2;
            width: 472px;
            height: Math.min(parent.height - 80px, self.content-height + 40px);
            background: #171a20f8;
            border-width: 1px;
            border-color: #2d3340;
            border-radius: 6px;

            ScrollView {
                x: 20px;
                y: 20px;
                width: parent.width - 40px;
                height: parent.height - 40px;
                viewport-height: picker-modal.content-height;

                for type-item[index] in root.stage-type-options : StageTypeCard {
                    x: Math.mod(index, 4) * 106px;
                    y: Math.floor(index / 4) * 100px;
                    item: type-item;
                    selected: false;
                    icon-source: type-item.icon_kind == "amp_head"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-head.svg")
                        : type-item.icon_kind == "amp_combo"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/amp-combo.svg")
                        : type-item.icon_kind == "cab"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/cab.svg")
                        : type-item.icon_kind == "full_rig"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/full-rig.svg")
                        : type-item.icon_kind == "drive"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gain.svg")
                        : type-item.icon_kind == "compressor"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/compressor.svg")
                        : type-item.icon_kind == "gate"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gate.svg")
                        : type-item.icon_kind == "eq"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/eq.svg")
                        : type-item.icon_kind == "tremolo"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/mod.svg")
                        : type-item.icon_kind == "delay"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/delay.svg")
                        : type-item.icon_kind == "reverb"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/reverb.svg")
                        : type-item.icon_kind == "tuner"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/tuner.svg")
                        : type-item.icon_kind == "nam"
                        ? @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/nam.svg")
                        : @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/gear.svg");
                    clicked => { root.choose-stage-type(index); }
                }
            }
        }
    }
}
