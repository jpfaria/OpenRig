import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ProjectTrackItem } from "../models.slint";
import { SCard, SText } from "../modules/surrealism-ui/index.slint";
import { Themes } from "../modules/surrealism-ui/use/index.slint";
import { PrimaryIconActionButton, SecondaryIconActionButton } from "../widgets/action_button.slint";

export component ProjectTracksPage inherits SCard {
    in property <string> project-title;
    in property <[ProjectTrackItem]> tracks;
    in-out property <string> status-message;
    callback add-track();
    callback save-project();
    callback configure-project();
    callback save-track-preset(int);
    callback create-track-preset(int);
    callback configure-track-preset(int);

    theme: Themes.Dark;
    card-width: 720px;
    private property <length> row-height: 52px;
    private property <length> rows-height: (tracks.length * row-height) + (tracks.length > 0 ? (tracks.length - 1) * 10px : 0px);
    card-height: 208px + rows-height;

    VerticalBox {
        padding: Theme.spaces.xlarge;
        spacing: Theme.spaces.large;

        HorizontalBox {
            SText {
                theme: Themes.Dark;
                text: project-title;
                font-size: Theme.typo.section.size;
                font-weight: Theme.typo.section.weight;
            }

            Rectangle { horizontal-stretch: 1; background: transparent; }

            SecondaryIconActionButton {
                icon: @image-url("../assets/setup.svg");
                clicked => { root.configure-project(); }
            }

            PrimaryIconActionButton {
                icon: @image-url("../assets/save.svg");
                clicked => { root.save-project(); }
            }

            PrimaryIconActionButton {
                icon: @image-url("../assets/plus.svg");
                clicked => { root.add-track(); }
            }
        }

        if tracks.length == 0 : SText {
            theme: Themes.Dark;
            text: "Nenhuma track criada.";
            font-size: Theme.typo.caption.size;
        }

        if tracks.length > 0 : VerticalBox {
            spacing: 10px;

            for track[index] in tracks : SCard {
                theme: Themes.Dark;
                card-width: 640px;
                height: 112px;
                card-height: 112px;

                VerticalBox {
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-top: 14px;
                    padding-bottom: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        spacing: 12px;

                        SText {
                            theme: Themes.Dark;
                            text: track.title;
                            font-size: Theme.typo.button.size;
                        }

                        Rectangle { horizontal-stretch: 1; background: transparent; }

                        SText {
                            theme: Themes.Dark;
                            text: track.subtitle;
                            font-size: Theme.typo.caption.size;
                        }
                    }

                    HorizontalBox {
                        spacing: 10px;

                        SecondaryIconActionButton {
                            width: 34px;
                            height: 34px;
                            border-radius: 12px;
                            icon: @image-url("../assets/save.svg");
                            clicked => { root.save-track-preset(index); }
                        }

                        SecondaryIconActionButton {
                            width: 34px;
                            height: 34px;
                            border-radius: 12px;
                            icon: @image-url("../assets/plus.svg");
                            clicked => { root.create-track-preset(index); }
                        }

                        SecondaryIconActionButton {
                            width: 34px;
                            height: 34px;
                            border-radius: 12px;
                            icon: @image-url("../assets/preset.svg");
                            clicked => { root.configure-track-preset(index); }
                        }
                    }
                }
            }
        }

        if status-message != "" : SText {
            theme: Themes.Dark;
            text: status-message;
            font-size: Theme.typo.caption.size;
        }
    }
}
