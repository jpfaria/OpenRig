import { CheckBox, ComboBox, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ChannelOptionItem } from "../models.slint";
import { SButton, SCard, SInput, SText } from "../modules/surrealism-ui/index.slint";
import { Themes } from "../modules/surrealism-ui/use/index.slint";

export component TrackEditorPage inherits SCard {
    in property <string> title;
    in property <string> save-label;
    in-out property <string> track-name;
    in property <[string]> input-device-options;
    in property <[string]> output-device-options;
    in property <int> selected-input-device-index;
    in property <int> selected-output-device-index;
    in property <[ChannelOptionItem]> input-channel-options;
    in property <[ChannelOptionItem]> output-channel-options;
    in-out property <string> status-message;
    callback update-track-name(string);
    callback select-input-device(int);
    callback select-output-device(int);
    callback toggle-input-channel(int, bool);
    callback toggle-output-channel(int, bool);
    callback save-track();
    callback cancel-track();

    theme: Themes.Dark;
    card-width: 720px;
    private property <length> channels-block-height: 48px + (input-channel-options.length > output-channel-options.length ? input-channel-options.length : output-channel-options.length) * 28px;
    card-height: 410px + channels-block-height;

    VerticalBox {
        padding: Theme.spaces.xlarge;
        spacing: Theme.spaces.large;

        SText {
            theme: Themes.Dark;
            text: root.title;
            font-size: Theme.typo.section.size;
            font-weight: Theme.typo.section.weight;
        }

        VerticalBox {
            spacing: Theme.spaces.medium;

            SText {
                theme: Themes.Dark;
                text: "Nome";
                font-size: Theme.typo.body.size;
                font-weight: Theme.typo.section.weight;
            }

            SInput {
                theme: Themes.Dark;
                text: root.track-name;
                card-width: 320px;
                changed(value) => {
                    root.update-track-name(value);
                }
            }
        }

        HorizontalBox {
            spacing: Theme.spaces.large;

            VerticalBox {
                spacing: Theme.spaces.medium;

                SText {
                    theme: Themes.Dark;
                    text: "Dispositivo de entrada";
                    font-size: Theme.typo.body.size;
                    font-weight: Theme.typo.section.weight;
                }

                ComboBox {
                    min-width: 320px;
                    model: root.input-device-options;
                    current-index: root.selected-input-device-index;
                    selected(_) => {
                        root.select-input-device(self.current-index);
                    }
                }
            }

            VerticalBox {
                spacing: Theme.spaces.medium;

                SText {
                    theme: Themes.Dark;
                    text: "Dispositivo de saída";
                    font-size: Theme.typo.body.size;
                    font-weight: Theme.typo.section.weight;
                }

                ComboBox {
                    min-width: 320px;
                    model: root.output-device-options;
                    current-index: root.selected-output-device-index;
                    selected(_) => {
                        root.select-output-device(self.current-index);
                    }
                }
            }
        }

        HorizontalBox {
            spacing: Theme.spaces.large;

            SCard {
                theme: Themes.Dark;
                card-width: 320px;
                card-height: channels-block-height;

                VerticalBox {
                    padding: Theme.spaces.large;
                    spacing: Theme.spaces.small;

                    SText {
                        theme: Themes.Dark;
                        text: "Canais de entrada";
                        font-size: Theme.typo.body.size;
                        font-weight: Theme.typo.section.weight;
                    }

                    for channel in root.input-channel-options : CheckBox {
                        text: channel.label;
                        checked: channel.selected;
                        enabled: channel.available;
                        toggled => {
                            root.toggle-input-channel(channel.index, self.checked);
                        }
                    }
                }
            }

            SCard {
                theme: Themes.Dark;
                card-width: 320px;
                card-height: channels-block-height;

                VerticalBox {
                    padding: Theme.spaces.large;
                    spacing: Theme.spaces.small;

                    SText {
                        theme: Themes.Dark;
                        text: "Canais de saída";
                        font-size: Theme.typo.body.size;
                        font-weight: Theme.typo.section.weight;
                    }

                    for channel in root.output-channel-options : CheckBox {
                        text: channel.label;
                        checked: channel.selected;
                        enabled: channel.available;
                        toggled => {
                            root.toggle-output-channel(channel.index, self.checked);
                        }
                    }
                }
            }
        }

        if status-message != "" : SText {
            theme: Themes.Dark;
            text: status-message;
            font-size: Theme.typo.caption.size;
        }

        HorizontalBox {
            spacing: Theme.spaces.medium;

            Rectangle { horizontal-stretch: 1; background: transparent; }

            SButton {
                theme: Themes.Dark;
                text: "Cancelar";
                card-width: 120px;
                card-height: 44px;
                round: true;
                clicked => { root.cancel-track(); }
            }

            SButton {
                theme: Themes.Primary;
                text: root.save-label;
                card-width: 140px;
                card-height: 44px;
                round: true;
                clicked => { root.save-track(); }
            }
        }
    }
}
