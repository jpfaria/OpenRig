import { VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { RecentProjectItem } from "../models.slint";
import { SButton, SCard, SText } from "../modules/surrealism-ui/index.slint";
import { Themes } from "../modules/surrealism-ui/use/index.slint";
import { IconAction } from "../widgets/widgets.slint";

export component ProjectLauncherPage inherits SCard {
    in property <string> project-path-label;
    in property <[RecentProjectItem]> recent-projects;
    in-out property <string> status-message;
    callback open-project-file();
    callback create-project-file();
    callback open-recent-project(int);
    callback remove-recent-project(int);

    theme: Themes.Dark;
    card-width: 720px;
    card-height: 520px;

    VerticalBox {
        padding: Theme.spaces.xlarge;
        spacing: Theme.spaces.large;

        SText {
            theme: Themes.Dark;
            text: "Projeto";
            font-size: Theme.typo.section.size;
            font-weight: Theme.typo.section.weight;
        }

        SText {
            theme: Themes.Dark;
            text: "Escolha um projeto existente ou crie um novo.";
            font-size: Theme.typo.caption.size;
        }

        SText {
            theme: Themes.Dark;
            text: project-path-label;
            font-size: Theme.typo.caption.size;
        }

        Rectangle { height: 8px; background: transparent; }

        HorizontalBox {
            spacing: Theme.spaces.medium;

            SButton {
                theme: Themes.Dark;
                text: "Abrir projeto";
                card-width: 140px;
                card-height: 44px;
                round: true;
                clicked => { root.open-project-file(); }
            }

            SButton {
                theme: Themes.Primary;
                text: "Criar novo projeto";
                card-width: 170px;
                card-height: 44px;
                round: true;
                clicked => { root.create-project-file(); }
            }
        }

        if recent-projects.length > 0 : VerticalBox {
            spacing: Theme.spaces.medium;

            SText {
                theme: Themes.Dark;
                text: "Projetos recentes";
                font-size: Theme.typo.caption.size;
            }

            ScrollView {
                width: 640px;
                height: 220px;

                VerticalBox {
                    spacing: Theme.spaces.small;

                    for recent[index] in recent-projects : SCard {
                        theme: Themes.Dark;
                        card-width: 640px;
                        card-height: 64px;

                        HorizontalBox {
                            padding: Theme.spaces.medium;
                            spacing: Theme.spaces.medium;

                            VerticalBox {
                                spacing: 2px;

                                SText {
                                    theme: Themes.Dark;
                                    text: recent.title;
                                    font-size: Theme.typo.caption.size;
                                    color: recent.is_valid ? Theme.palette.text-primary : #ff8c8c;
                                }

                                SText {
                                    theme: Themes.Dark;
                                    text: recent.subtitle;
                                    font-size: 11px;
                                    color: Theme.palette.text-muted;
                                }

                                if !recent.is_valid && recent.invalid_reason != "" : SText {
                                    theme: Themes.Dark;
                                    text: recent.invalid_reason;
                                    font-size: 11px;
                                    color: #ff8c8c;
                                }
                            }

                            Rectangle { horizontal-stretch: 1; background: transparent; }

                            IconAction {
                                icon: @image-url("../assets/arrow-right.svg");
                                enabled: recent.is_valid;
                                clicked => { root.open-recent-project(index); }
                            }

                            IconAction {
                                icon: @image-url("../assets/remove.svg");
                                clicked => { root.remove-recent-project(index); }
                            }
                        }
                    }
                }
            }
        }

        if status-message != "" : SText {
            theme: Themes.Dark;
            text: status-message;
            font-size: Theme.typo.caption.size;
        }
    }
}
