import { CheckBox, ComboBox, ScrollView } from "std-widgets.slint";
import { DeviceSelectionItem } from "../models.slint";

component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 80px : 96px;
    height: 36px;
    background: primary ? #188cff : #2a2f38;
    border-width: 1px;
    border-color: primary ? #45a7ff : #41464f;
    border-radius: 6px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component FieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1d2025;
    border-width: 1px;
    border-color: #41454e;
    border-radius: 4px;

    TextInput {
        x: 12px;
        width: parent.width - 24px;
        height: parent.height;
        text <=> root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.changed(self.text);
        }
    }
}

component DeviceRow inherits Rectangle {
    in property <DeviceSelectionItem> device;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    callback toggled(bool);
    callback sample-rate-selected(string);
    callback buffer-size-selected(string);

    height: 48px;
    background: transparent;

    pure function sample-rate-index(value: string) -> int {
        return value == "44100" ? 0
            : value == "48000" ? 1
            : value == "88200" ? 2
            : value == "96000" ? 3
            : 1;
    }

    pure function buffer-size-index(value: string) -> int {
        return value == "32" ? 0
            : value == "64" ? 1
            : value == "128" ? 2
            : value == "256" ? 3
            : value == "512" ? 4
            : value == "1024" ? 5
            : 3;
    }

    // Separator line
    Rectangle {
        x: 0px;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: #252a33;
    }

    // Custom toggle indicator
    Rectangle {
        x: 0px;
        y: 14px;
        width: 20px;
        height: 20px;
        background: root.device.selected ? #188cff : #1e2229;
        border-width: 1px;
        border-color: root.device.selected ? #45a7ff : #3d4450;
        border-radius: 4px;

        if root.device.selected : Text {
            width: parent.width;
            height: parent.height;
            text: "✓";
            color: #ffffff;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: 32px;
        y: 0px;
        width: parent.width - 32px - (root.device.selected ? 310px : 0px);
        height: parent.height;
        text: root.device.name;
        color: root.device.selected ? #edf2f9 : #8a95a5;
        font-size: 13px;
        font-weight: root.device.selected ? 600 : 400;
        vertical-alignment: center;
        overflow: elide;
    }

    if root.device.selected : Text {
        x: parent.width - 314px;
        y: 0px;
        width: 26px;
        height: parent.height;
        text: "Hz";
        color: #6b7786;
        font-size: 11px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: right;
    }

    if root.device.selected : ComboBox {
        x: parent.width - 284px;
        y: 8px;
        width: 100px;
        height: 32px;
        model: root.sample-rate-options;
        current-index: root.sample-rate-index(root.device.sample_rate_text);
        selected(value) => { root.sample-rate-selected(value); }
    }

    if root.device.selected : Text {
        x: parent.width - 178px;
        y: 0px;
        width: 32px;
        height: parent.height;
        text: "Buffer";
        color: #6b7786;
        font-size: 11px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: right;
    }

    if root.device.selected : ComboBox {
        x: parent.width - 142px;
        y: 8px;
        width: 100px;
        height: 32px;
        model: root.buffer-size-options;
        current-index: root.buffer-size-index(root.device.buffer_size_text);
        selected(value) => { root.buffer-size-selected(value); }
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: 300px;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.toggled(!root.device.selected); }
    }
}

export component ProjectSettingsPage inherits Rectangle {
    in-out property <string> project-name-draft;
    in-out property <string> status-message;
    in property <[DeviceSelectionItem]> project-devices;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    callback update-project-name(string);
    callback save-audio-settings();
    callback close-project-settings();
    callback toggle-project-device(int, bool);
    callback update-project-sample-rate(int, string);
    callback update-project-buffer-size(int, string);

    background: #171a1f;

    Text {
        x: 32px;
        y: 28px;
        width: 120px;
        height: 16px;
        text: "Nome";
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    FieldBox {
        x: 32px;
        y: 48px;
        width: parent.width - 64px;
        height: 36px;
        text: root.project-name-draft;
        changed(value) => { root.update-project-name(value); }
    }

    Rectangle {
        x: 32px;
        y: 102px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 114px;
        width: parent.width - 64px;
        height: 20px;
        text: "Dispositivos de áudio";
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    ScrollView {
        x: 32px;
        y: 138px;
        width: parent.width - 64px;
        height: parent.height - 200px;
        viewport-height: root.project-devices.length * 48px;

        for device[index] in root.project-devices : DeviceRow {
            x: 0px;
            y: index * 48px;
            width: parent.width - 8px;
            device: device;
            sample-rate-options: root.sample-rate-options;
            buffer-size-options: root.buffer-size-options;
            toggled(selected) => { root.toggle-project-device(index, selected); }
            sample-rate-selected(value) => { root.update-project-sample-rate(index, value); }
            buffer-size-selected(value) => { root.update-project-buffer-size(index, value); }
        }
    }

    FooterButton {
        x: parent.width - 196px;
        y: parent.height - 52px;
        label: "Cancelar";
        clicked => { root.close-project-settings(); }
    }

    FooterButton {
        x: parent.width - 92px;
        y: parent.height - 52px;
        label: "OK";
        primary: true;
        clicked => { root.save-audio-settings(); }
    }
}
