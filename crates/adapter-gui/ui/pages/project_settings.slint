import { CheckBox, ComboBox, ScrollView } from "std-widgets.slint";
import { DeviceSelectionItem } from "../models.slint";
component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 112px : 104px;
    height: 38px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component FieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1d2025;
    border-width: 1px;
    border-color: #41454e;
    border-radius: 4px;

    TextInput {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.text = self.text;
            root.changed(self.text);
        }
    }
}

component DeviceConfigRow inherits Rectangle {
    in property <DeviceSelectionItem> device;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    callback toggled(bool);
    callback sample-rate-selected(string);
    callback buffer-size-selected(string);

    height: 44px;
    background: root.device.selected ? #16212acc : #ffffff06;
    border-width: 1px;
    border-color: root.device.selected ? #2d5274 : #2b313b66;
    border-radius: 4px;

    pure function sample-rate-index(value: string) -> int {
        return value == "44100" ? 0
            : value == "48000" ? 1
            : value == "88200" ? 2
            : value == "96000" ? 3
            : 1;
    }

    pure function buffer-size-index(value: string) -> int {
        return value == "32" ? 0
            : value == "64" ? 1
            : value == "128" ? 2
            : value == "256" ? 3
            : value == "512" ? 4
            : value == "1024" ? 5
            : 3;
    }

    CheckBox {
        x: 14px;
        y: 10px;
        width: parent.width - (root.device.selected ? 310px : 28px);
        height: 24px;
        text: root.device.name;
        checked: root.device.selected;
        toggled => {
            root.toggled(self.checked);
        }
    }

    if root.device.selected : ComboBox {
        x: parent.width - 240px;
        y: 6px;
        width: 88px;
        height: 32px;
        model: root.sample-rate-options;
        current-index: root.sample-rate-index(root.device.sample_rate_text);
        selected(value) => {
            root.sample-rate-selected(value);
        }
    }

    if root.device.selected : ComboBox {
        x: parent.width - 104px;
        y: 6px;
        width: 88px;
        height: 32px;
        model: root.buffer-size-options;
        current-index: root.buffer-size-index(root.device.buffer_size_text);
        selected(value) => {
            root.buffer-size-selected(value);
        }
    }

    if root.device.selected : Rectangle {
        x: parent.width - 272px;
        y: 12px;
        width: 24px;
        height: 20px;
        background: transparent;
        border-width: 1px;
        border-color: #46617d;
        border-radius: 3px;

        Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: "Hz";
            color: #9eb9d7;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if root.device.selected : Rectangle {
        x: parent.width - 136px;
        y: 12px;
        width: 24px;
        height: 20px;
        background: transparent;
        border-width: 1px;
        border-color: #46617d;
        border-radius: 3px;

        Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: "Buf";
            color: #9eb9d7;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

}

export component ProjectSettingsPage inherits Rectangle {
    in-out property <string> project-name-draft;
    in-out property <string> status-message;
    in property <[DeviceSelectionItem]> project-devices;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    callback update-project-name(string);
    callback save-audio-settings();
    callback close-project-settings();
    callback toggle-project-device(int, bool);
    callback update-project-sample-rate(int, string);
    callback update-project-buffer-size(int, string);

    background: #171a1f;

    Rectangle {
        x: 24px;
        y: 24px;
        width: parent.width - 48px;
        height: parent.height - 48px;
        background: transparent;
        border-width: 1px;
        border-color: #32363d55;
        border-radius: 6px;

        Text {
            x: 18px;
            y: 18px;
            width: 160px;
            height: 18px;
            text: "Nome do projeto";
            color: #cad2de;
            font-size: 13px;
            font-weight: 600;
        }

        FieldBox {
            x: 18px;
            y: 42px;
            width: parent.width - 36px;
            height: 36px;
            text: root.project-name-draft;
            changed(value) => { root.update-project-name(value); }
        }

        Rectangle {
            x: 18px;
            y: 98px;
            width: parent.width - 36px;
            height: parent.height - 198px;
            background: #12161bcc;
            border-width: 1px;
            border-color: #2f344055;
            border-radius: 4px;

            Image {
                x: 16px;
                y: 18px;
                width: 16px;
                height: 16px;
                source: @image-url("/Users/joao.faria/Projetos/github.com/jpfaria/OpenRig/crates/adapter-gui/ui/assets/usb.svg");
                image-fit: contain;
                colorize: #9eb9d7;
            }

            Text {
                x: 40px;
                y: 14px;
                width: parent.width - 56px;
                height: 22px;
                text: "Dispositivos";
                color: #edf2f9;
                font-size: 16px;
                font-weight: 650;
            }

            ScrollView {
                x: 12px;
                y: 46px;
                width: parent.width - 24px;
                height: parent.height - 58px;
                viewport-height: root.project-devices.length * 52px;

                for device[index] in root.project-devices : DeviceConfigRow {
                    x: 0px;
                    y: index * 52px;
                    width: parent.width - 12px;
                    device: device;
                    sample-rate-options: root.sample-rate-options;
                    buffer-size-options: root.buffer-size-options;
                    toggled(selected) => { root.toggle-project-device(index, selected); }
                    sample-rate-selected(value) => { root.update-project-sample-rate(index, value); }
                    buffer-size-selected(value) => { root.update-project-buffer-size(index, value); }
                }
            }
        }

        FooterButton {
            x: parent.width - 234px;
            y: parent.height - 56px;
            label: "Cancelar";
            clicked => { root.close-project-settings(); }
        }

        FooterButton {
            x: parent.width - 122px;
            y: parent.height - 56px;
            label: "OK";
            primary: true;
            clicked => { root.save-audio-settings(); }
        }
    }
}
