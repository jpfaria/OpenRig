component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 112px : 104px;
    height: 38px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component FieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1d2025;
    border-width: 1px;
    border-color: #41454e;
    border-radius: 4px;

    TextInput {
        x: 12px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.text = self.text;
            root.changed(self.text);
        }
    }
}

component EditRow inherits Rectangle {
    in property <string> label;
    in property <string> summary;
    callback clicked();

    height: 52px;
    background: transparent;

    property <bool> hovered: false;

    states [
        hovered when hovered: {
            background: #1e2229;
        }
    ]

    border-radius: 6px;

    Text {
        x: 0px;
        y: 6px;
        width: parent.width - 24px;
        height: 18px;
        text: root.label;
        color: #edf2f9;
        font-size: 13px;
        font-weight: 700;
        vertical-alignment: center;
    }

    Text {
        x: 0px;
        y: 28px;
        width: parent.width - 24px;
        height: 18px;
        text: root.summary;
        color: #6b7786;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }

    Text {
        x: parent.width - 20px;
        y: 0px;
        width: 20px;
        height: parent.height;
        text: "›";
        color: #4c5566;
        font-size: 18px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.move) {
                root.hovered = true;
            }
        }
        clicked => { root.clicked(); }
    }
}

export component ChainEditorPage inherits Rectangle {
    in property <string> title;
    in property <string> save-label;
    in-out property <string> chain-name;
    in property <string> input-summary;
    in property <string> output-summary;
    in-out property <string> status-message;
    in property <bool> is-create-mode: true;
    in-out property <int> selected-instrument-index: 0;
    in-out property <int> selected-input-mode-index: 0;
    in property <[string]> instrument-labels: ["Guitarra", "Violao", "Baixo", "Voz", "Teclado", "Bateria", "Outro"];
    in property <[string]> input-mode-labels: ["Mono", "Stereo", "Dual Mono"];
    callback update-chain-name(string);
    callback open-input();
    callback open-output();
    callback save-chain();
    callback cancel-chain();
    callback select-instrument(int);
    callback select-input-mode(int);

    background: #171a1f;

    Text {
        x: 32px;
        y: 28px;
        width: parent.width - 64px;
        height: 28px;
        text: root.title;
        color: #edf2f9;
        font-size: 20px;
        font-weight: 800;
    }

    Rectangle {
        x: 32px;
        y: 68px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 84px;
        width: 120px;
        height: 16px;
        text: "Nome";
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    FieldBox {
        x: 32px;
        y: 104px;
        width: parent.width - 64px;
        height: 36px;
        text: root.chain-name;
        changed(value) => { root.update-chain-name(value); }
    }

    Rectangle {
        x: 32px;
        y: 156px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 168px;
        width: 120px;
        height: 16px;
        text: "Instrumento";
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    Rectangle {
        x: 32px;
        y: 188px;
        width: parent.width - 64px;
        height: 48px;
        background: transparent;

        for label[index] in root.instrument-labels : Rectangle {
            x: index * 100px;
            y: 0px;
            width: 92px;
            height: 44px;
            background: index == root.selected-instrument-index ? #2a5da8 : #1d2025;
            border-width: 1px;
            border-color: index == root.selected-instrument-index ? #45a7ff : #41454e;
            border-radius: 4px;
            opacity: 1.0;

            Image {
                x: (parent.width - 16px) / 2;
                y: 4px;
                width: 16px;
                height: 16px;
                source: index == 0 ? @image-url("../../../../assets/instruments/electric_guitar.svg")
                    : index == 1 ? @image-url("../../../../assets/instruments/acoustic_guitar.svg")
                    : index == 2 ? @image-url("../../../../assets/instruments/bass.svg")
                    : index == 3 ? @image-url("../../../../assets/instruments/voice.svg")
                    : index == 4 ? @image-url("../../../../assets/instruments/keys.svg")
                    : index == 5 ? @image-url("../../../../assets/instruments/drums.svg")
                    : @image-url("../../../../assets/instruments/generic.svg");
                image-fit: contain;
                colorize: index == root.selected-instrument-index ? #f4f7fb : #8a94a2;
            }

            Text {
                x: 0;
                y: 22px;
                width: parent.width;
                height: 18px;
                text: label;
                color: index == root.selected-instrument-index ? #f4f7fb : #8a94a2;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 9px;
                font-weight: 600;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => {
                    root.selected-instrument-index = index;
                    root.select-instrument(index);
                }
            }
        }
    }

    Rectangle {
        x: 32px;
        y: 236px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 248px;
        width: 120px;
        height: 16px;
        text: "Tipo de Entrada";
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    Rectangle {
        x: 32px;
        y: 268px;
        width: parent.width - 64px;
        height: 48px;
        background: transparent;

        for label[index] in root.input-mode-labels : Rectangle {
            x: index * 120px;
            y: 0px;
            width: 108px;
            height: 44px;
            background: index == root.selected-input-mode-index ? #2a5da8 : #1d2025;
            border-width: 1px;
            border-color: index == root.selected-input-mode-index ? #45a7ff : #41454e;
            border-radius: 4px;

            Text {
                width: parent.width;
                height: parent.height;
                text: label;
                color: index == root.selected-input-mode-index ? #f4f7fb : #8a94a2;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 12px;
                font-weight: 600;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => {
                    root.selected-input-mode-index = index;
                    root.select-input-mode(index);
                }
            }
        }
    }

    Rectangle {
        x: 32px;
        y: 324px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    EditRow {
        x: 32px;
        y: 332px;
        width: parent.width - 64px;
        label: "Entrada";
        summary: root.input-summary;
        clicked => { root.open-input(); }
    }

    Rectangle {
        x: 32px;
        y: 384px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    EditRow {
        x: 32px;
        y: 392px;
        width: parent.width - 64px;
        label: "Saída";
        summary: root.output-summary;
        clicked => { root.open-output(); }
    }

    Rectangle {
        x: 32px;
        y: 444px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: parent.height - 58px;
        width: parent.width - 64px - 240px;
        height: 38px;
        text: root.status-message;
        color: #8db9ff;
        font-size: 12px;
        vertical-alignment: center;
    }

    FooterButton {
        x: parent.width - 232px;
        y: parent.height - 58px;
        label: "Cancelar";
        clicked => { root.cancel-chain(); }
    }

    FooterButton {
        x: parent.width - 120px;
        y: parent.height - 58px;
        label: root.save-label;
        primary: true;
        clicked => { root.save-chain(); }
    }
}
