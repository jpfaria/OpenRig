import { ScrollView } from "std-widgets.slint";
import { IoGroupItem, ChainBindingChoice } from "../models.slint";

component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 112px : 104px;
    height: 38px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component FieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1d2025;
    border-width: 1px;
    border-color: #41454e;
    border-radius: 4px;

    TextInput {
        x: 12px;
        width: parent.width - 24px;
        height: parent.height;
        text <=> root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.changed(self.text);
        }
    }
}

export component ChainEditorPage inherits Rectangle {
    in property <string> title;
    in property <string> save-label;
    in-out property <string> chain-name;
    in property <[IoGroupItem]> input-groups;
    in property <[IoGroupItem]> output-groups;
    // #716: the I/O bindings this chain can select (checklist replaces the old
    // per-endpoint add-input/add-output flow).
    in property <[ChainBindingChoice]> bindings;
    in-out property <string> status-message;
    in property <bool> is-create-mode: true;
    in-out property <int> selected-instrument-index: 0;
    in property <[string]> instrument-labels: [
        @tr("instrument-guitar"),
        @tr("instrument-acoustic-guitar"),
        @tr("instrument-bass"),
        @tr("instrument-voice"),
        @tr("instrument-keyboard"),
        @tr("instrument-drums"),
        @tr("instrument-other"),
    ];
    callback update-chain-name(string);
    callback edit-input(int);
    callback remove-input(int);
    callback add-input();
    callback edit-output(int);
    callback remove-output(int);
    callback add-output();
    callback save-chain();
    callback cancel-chain();
    callback select-instrument(int);
    // #716: toggle whether the chain uses binding at `index` (selected on/off).
    callback toggle-binding(int, bool);

    background: #171a1f;

    Text {
        x: 32px;
        y: 28px;
        width: parent.width - 64px;
        height: 28px;
        text: root.is-create-mode ? @tr("title-new-chain") : @tr("title-configure-chain");
        color: #edf2f9;
        font-size: 20px;
        font-weight: 800;
    }

    Rectangle {
        x: 32px;
        y: 68px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 84px;
        width: 120px;
        height: 16px;
        text: @tr("label-name");
        color: #7a8694;
        font-size: 11px;
    }

    FieldBox {
        x: 32px;
        y: 104px;
        width: parent.width - 64px;
        height: 36px;
        text: root.chain-name;
        changed(value) => { root.update-chain-name(value); }
    }

    Rectangle {
        x: 32px;
        y: 156px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 168px;
        width: 120px;
        height: 16px;
        text: @tr("label-instrument");
        color: #7a8694;
        font-size: 11px;
    }

    Rectangle {
        x: 32px;
        y: 188px;
        width: parent.width - 64px;
        height: 48px;
        background: transparent;

        for label[index] in root.instrument-labels : Rectangle {
            x: index * 100px;
            y: 0px;
            width: 92px;
            height: 44px;
            background: index == root.selected-instrument-index ? #2a5da8 : #1d2025;
            border-width: 1px;
            border-color: index == root.selected-instrument-index ? #45a7ff : #41454e;
            border-radius: 4px;
            opacity: 1.0;

            Image {
                x: (parent.width - 16px) / 2;
                y: 4px;
                width: 16px;
                height: 16px;
                source: index == 0 ? @image-url("../../../../assets/instruments/electric_guitar.svg")
                    : index == 1 ? @image-url("../../../../assets/instruments/acoustic_guitar.svg")
                    : index == 2 ? @image-url("../../../../assets/instruments/bass.svg")
                    : index == 3 ? @image-url("../../../../assets/instruments/voice.svg")
                    : index == 4 ? @image-url("../../../../assets/instruments/keys.svg")
                    : index == 5 ? @image-url("../../../../assets/instruments/drums.svg")
                    : @image-url("../../../../assets/instruments/generic.svg");
                image-fit: contain;
                colorize: index == root.selected-instrument-index ? #f4f7fb : #8a94a2;
            }

            Text {
                x: 0;
                y: 22px;
                width: parent.width;
                height: 18px;
                text: label;
                color: index == root.selected-instrument-index ? #f4f7fb : #8a94a2;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 9px;
                font-weight: 600;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => {
                    root.selected-instrument-index = index;
                    root.select-instrument(index);
                }
            }
        }
    }

    Rectangle {
        x: 32px;
        y: 236px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    // --- I/O bindings checklist (#716) ---
    // The chain SELECTS which I/O bindings it uses; input/output is discovered
    // from those bindings. Replaces the old per-endpoint add-input/add-output.
    Text {
        x: 32px;
        y: 248px;
        width: parent.width - 64px;
        height: 16px;
        text: @tr("label-chain-io-bindings");
        color: #7a8694;
        font-size: 11px;
    }

    if root.bindings.length == 0 : Text {
        x: 32px;
        y: 278px;
        width: parent.width - 64px;
        height: 20px;
        text: @tr("empty-no-bindings-for-chain");
        color: #5a6270;
        font-size: 12px;
        wrap: word-wrap;
    }

    ScrollView {
        x: 32px;
        y: 272px;
        width: parent.width - 64px;
        height: parent.height - 272px - 72px;

        VerticalLayout {
            alignment: start;
            spacing: 2px;

            for choice[index] in root.bindings : chain-binding-cell := Rectangle {
                height: 40px;
                border-radius: 6px;
                background: cell-ta.has-hover ? #1e2229 : transparent;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 12px;

                    Rectangle {
                        width: 20px;
                        height: 20px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 5px;
                        background: choice.selected ? #2f80ff : #1d2025;
                        border-width: 1px;
                        border-color: choice.selected ? #2f80ff : #41454e;
                        if choice.selected : Image {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: 12px;
                            height: 12px;
                            source: @image-url("../assets/check.svg");
                            colorize: #ffffff;
                        }
                    }

                    Text {
                        horizontal-stretch: 1;
                        text: choice.name;
                        color: choice.selected ? #f4f7fb : #c4ccd6;
                        font-size: 14px;
                        font-weight: choice.selected ? 600 : 500;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                cell-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.toggle-binding(index, !choice.selected); }
                }
            }
        }
    }

    // --- Separator before footer ---
    Rectangle {
        x: 32px;
        y: parent.height - 72px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: parent.height - 58px;
        width: parent.width - 64px - 240px;
        height: 38px;
        text: root.status-message;
        color: #8db9ff;
        font-size: 12px;
        vertical-alignment: center;
    }

    FooterButton {
        x: parent.width - 232px;
        y: parent.height - 58px;
        label: @tr("btn-cancel");
        clicked => { root.cancel-chain(); }
    }

    FooterButton {
        x: parent.width - 120px;
        y: parent.height - 58px;
        label: root.is-create-mode ? @tr("btn-create-chain") : @tr("btn-save-chain");
        primary: true;
        clicked => { root.save-chain(); }
    }
}
