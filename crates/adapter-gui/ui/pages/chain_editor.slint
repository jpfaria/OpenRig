component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 112px : 104px;
    height: 38px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component FieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1d2025;
    border-width: 1px;
    border-color: #41454e;
    border-radius: 4px;

    TextInput {
        x: 12px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.text = self.text;
            root.changed(self.text);
        }
    }
}

component EditRow inherits Rectangle {
    in property <string> label;
    in property <string> summary;
    callback clicked();

    height: 52px;
    background: transparent;

    property <bool> hovered: false;

    states [
        hovered when hovered: {
            background: #1e2229;
        }
    ]

    border-radius: 6px;

    Text {
        x: 0px;
        y: 6px;
        width: parent.width - 24px;
        height: 18px;
        text: root.label;
        color: #edf2f9;
        font-size: 13px;
        font-weight: 700;
        vertical-alignment: center;
    }

    Text {
        x: 0px;
        y: 28px;
        width: parent.width - 24px;
        height: 18px;
        text: root.summary;
        color: #6b7786;
        font-size: 12px;
        overflow: elide;
        vertical-alignment: center;
    }

    Text {
        x: parent.width - 20px;
        y: 0px;
        width: 20px;
        height: parent.height;
        text: "›";
        color: #4c5566;
        font-size: 18px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.move) {
                root.hovered = true;
            }
        }
        clicked => { root.clicked(); }
    }
}

export component ChainEditorPage inherits Rectangle {
    in property <string> title;
    in property <string> save-label;
    in-out property <string> chain-name;
    in property <string> input-summary;
    in property <string> output-summary;
    in-out property <string> status-message;
    callback update-chain-name(string);
    callback open-input();
    callback open-output();
    callback save-chain();
    callback cancel-chain();

    background: #171a1f;

    Text {
        x: 32px;
        y: 28px;
        width: parent.width - 64px;
        height: 28px;
        text: root.title;
        color: #edf2f9;
        font-size: 20px;
        font-weight: 800;
    }

    Rectangle {
        x: 32px;
        y: 68px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 84px;
        width: 120px;
        height: 16px;
        text: "Nome";
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    FieldBox {
        x: 32px;
        y: 104px;
        width: parent.width - 64px;
        height: 36px;
        text: root.chain-name;
        changed(value) => { root.update-chain-name(value); }
    }

    Rectangle {
        x: 32px;
        y: 160px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    EditRow {
        x: 32px;
        y: 168px;
        width: parent.width - 64px;
        label: "Entrada";
        summary: root.input-summary;
        clicked => { root.open-input(); }
    }

    Rectangle {
        x: 32px;
        y: 220px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    EditRow {
        x: 32px;
        y: 228px;
        width: parent.width - 64px;
        label: "Saída";
        summary: root.output-summary;
        clicked => { root.open-output(); }
    }

    Rectangle {
        x: 32px;
        y: 280px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: parent.height - 58px;
        width: parent.width - 64px - 240px;
        height: 38px;
        text: root.status-message;
        color: #8db9ff;
        font-size: 12px;
        vertical-alignment: center;
    }

    FooterButton {
        x: parent.width - 232px;
        y: parent.height - 58px;
        label: "Cancelar";
        clicked => { root.cancel-chain(); }
    }

    FooterButton {
        x: parent.width - 120px;
        y: parent.height - 58px;
        label: root.save-label;
        primary: true;
        clicked => { root.save-chain(); }
    }
}
