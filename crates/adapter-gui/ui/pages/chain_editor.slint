component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 112px : 104px;
    height: 38px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component FieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1d2025;
    border-width: 1px;
    border-color: #41454e;
    border-radius: 4px;

    TextInput {
        x: 12px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.text = self.text;
            root.changed(self.text);
        }
    }
}

component SummaryCard inherits Rectangle {
    in property <string> title;
    in property <string> summary;
    callback clicked();

    background: #12161bcc;
    border-width: 1px;
    border-color: #2f344080;
    border-radius: 6px;

    Text {
        x: 16px;
        y: 14px;
        width: parent.width - 32px;
        height: 18px;
        text: root.title;
        color: #edf2f9;
        font-size: 15px;
        font-weight: 700;
    }

    Text {
        x: 16px;
        y: 40px;
        width: parent.width - 32px;
        height: 36px;
        text: root.summary;
        color: #aeb9c8;
        font-size: 12px;
        wrap: word-wrap;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component ChainEditorPage inherits Rectangle {
    in property <string> title;
    in property <string> save-label;
    in-out property <string> chain-name;
    in property <string> input-summary;
    in property <string> output-summary;
    in-out property <string> status-message;
    callback update-chain-name(string);
    callback open-input();
    callback open-output();
    callback save-chain();
    callback cancel-chain();

    background: #171a1f;

    Rectangle {
        x: 24px;
        y: 24px;
        width: parent.width - 48px;
        height: parent.height - 48px;
        background: transparent;
        border-width: 1px;
        border-color: #32363d55;
        border-radius: 6px;

        Text {
            x: 18px;
            y: 18px;
            width: parent.width - 36px;
            height: 26px;
            text: root.title;
            color: #edf2f9;
            font-size: 22px;
            font-weight: 800;
        }

        Text {
            x: 18px;
            y: 64px;
            width: 160px;
            height: 18px;
            text: "Nome da chain";
            color: #cad2de;
            font-size: 13px;
            font-weight: 600;
        }

        FieldBox {
            x: 18px;
            y: 88px;
            width: parent.width - 36px;
            height: 36px;
            text: root.chain-name;
            changed(value) => { root.update-chain-name(value); }
        }

        SummaryCard {
            x: 18px;
            y: 152px;
            width: parent.width - 36px;
            height: 92px;
            title: "Entrada";
            summary: root.input-summary;
            clicked => { root.open-input(); }
        }

        SummaryCard {
            x: 18px;
            y: 262px;
            width: parent.width - 36px;
            height: 92px;
            title: "Saída";
            summary: root.output-summary;
            clicked => { root.open-output(); }
        }

        Text {
            x: 18px;
            y: parent.height - 84px;
            width: parent.width - 36px - 240px;
            height: 18px;
            text: root.status-message;
            color: #8db9ff;
            font-size: 12px;
            vertical-alignment: center;
        }

        FooterButton {
            x: parent.width - 224px;
            y: parent.height - 58px;
            label: "Cancelar";
            clicked => { root.cancel-chain(); }
        }

        FooterButton {
            x: parent.width - 112px;
            y: parent.height - 58px;
            label: root.save-label;
            primary: true;
            clicked => { root.save-chain(); }
        }
    }
}
