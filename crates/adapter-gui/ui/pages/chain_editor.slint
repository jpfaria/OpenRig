import { ScrollView } from "std-widgets.slint";
import { IoGroupItem } from "../models.slint";

component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 112px : 104px;
    height: 38px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component FieldBox inherits Rectangle {
    in-out property <string> text;
    callback changed(string);

    background: #1d2025;
    border-width: 1px;
    border-color: #41454e;
    border-radius: 4px;

    TextInput {
        x: 12px;
        width: parent.width - 24px;
        height: parent.height;
        text <=> root.text;
        color: #f3f6fb;
        single-line: true;
        vertical-alignment: center;
        font-size: 13px;
        edited => {
            root.changed(self.text);
        }
    }
}

component IoGroupRow inherits Rectangle {
    in property <string> group-summary;
    callback edit-clicked();
    callback remove-clicked();

    height: 36px;
    background: transparent;

    property <bool> hovered: false;

    states [
        hovered when hovered: {
            background: #1e2229;
        }
    ]

    border-radius: 6px;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width - 60px;
        height: parent.height;
        text: root.group-summary;
        color: #edf2f9;
        font-size: 13px;
        font-weight: 600;
        overflow: elide;
        vertical-alignment: center;
    }

    // Remove button
    Rectangle {
        x: parent.width - 52px;
        y: 10px;
        width: 24px;
        height: 32px;
        border-radius: 4px;

        Text {
            width: parent.width;
            height: parent.height;
            text: @tr("✕");
            color: #5a6270;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.remove-clicked(); }
        }
    }

    // Edit chevron
    Text {
        x: parent.width - 20px;
        y: 0px;
        width: 20px;
        height: parent.height;
        text: @tr("›");
        color: #4c5566;
        font-size: 18px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width - 56px;
        height: parent.height;
        mouse-cursor: pointer;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.move) {
                root.hovered = true;
            }
        }
        clicked => { root.edit-clicked(); }
    }
}

component AddGroupButton inherits Rectangle {
    in property <string> label;
    callback clicked();

    height: 36px;
    background: transparent;
    border-width: 1px;
    border-color: #2a2f38;
    border-radius: 6px;

    property <bool> hovered: false;

    states [
        hovered when hovered: {
            border-color: #45a7ff;
        }
    ]

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #45a7ff;
        font-size: 12px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.move) {
                root.hovered = true;
            }
        }
        clicked => { root.clicked(); }
    }
}

export component ChainEditorPage inherits Rectangle {
    in property <string> title;
    in property <string> save-label;
    in-out property <string> chain-name;
    in property <[IoGroupItem]> input-groups;
    in property <[IoGroupItem]> output-groups;
    in-out property <string> status-message;
    in property <bool> is-create-mode: true;
    in-out property <int> selected-instrument-index: 0;
    in property <[string]> instrument-labels: [
        @tr("instrument-guitar"),
        @tr("instrument-acoustic-guitar"),
        @tr("instrument-bass"),
        @tr("instrument-voice"),
        @tr("instrument-keyboard"),
        @tr("instrument-drums"),
        @tr("instrument-other"),
    ];
    callback update-chain-name(string);
    callback edit-input(int);
    callback remove-input(int);
    callback add-input();
    callback edit-output(int);
    callback remove-output(int);
    callback add-output();
    callback save-chain();
    callback cancel-chain();
    callback select-instrument(int);

    background: #171a1f;

    Text {
        x: 32px;
        y: 28px;
        width: parent.width - 64px;
        height: 28px;
        text: root.title;
        color: #edf2f9;
        font-size: 20px;
        font-weight: 800;
    }

    Rectangle {
        x: 32px;
        y: 68px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 84px;
        width: 120px;
        height: 16px;
        text: @tr("Nome");
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    FieldBox {
        x: 32px;
        y: 104px;
        width: parent.width - 64px;
        height: 36px;
        text: root.chain-name;
        changed(value) => { root.update-chain-name(value); }
    }

    Rectangle {
        x: 32px;
        y: 156px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 168px;
        width: 120px;
        height: 16px;
        text: @tr("Instrumento");
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    Rectangle {
        x: 32px;
        y: 188px;
        width: parent.width - 64px;
        height: 48px;
        background: transparent;

        for label[index] in root.instrument-labels : Rectangle {
            x: index * 100px;
            y: 0px;
            width: 92px;
            height: 44px;
            background: index == root.selected-instrument-index ? #2a5da8 : #1d2025;
            border-width: 1px;
            border-color: index == root.selected-instrument-index ? #45a7ff : #41454e;
            border-radius: 4px;
            opacity: 1.0;

            Image {
                x: (parent.width - 16px) / 2;
                y: 4px;
                width: 16px;
                height: 16px;
                source: index == 0 ? @image-url("../../../../assets/instruments/electric_guitar.svg")
                    : index == 1 ? @image-url("../../../../assets/instruments/acoustic_guitar.svg")
                    : index == 2 ? @image-url("../../../../assets/instruments/bass.svg")
                    : index == 3 ? @image-url("../../../../assets/instruments/voice.svg")
                    : index == 4 ? @image-url("../../../../assets/instruments/keys.svg")
                    : index == 5 ? @image-url("../../../../assets/instruments/drums.svg")
                    : @image-url("../../../../assets/instruments/generic.svg");
                image-fit: contain;
                colorize: index == root.selected-instrument-index ? #f4f7fb : #8a94a2;
            }

            Text {
                x: 0;
                y: 22px;
                width: parent.width;
                height: 18px;
                text: label;
                color: index == root.selected-instrument-index ? #f4f7fb : #8a94a2;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 9px;
                font-weight: 600;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => {
                    root.selected-instrument-index = index;
                    root.select-instrument(index);
                }
            }
        }
    }

    Rectangle {
        x: 32px;
        y: 236px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    // --- Inputs section ---
    Text {
        x: 32px;
        y: 248px;
        width: 120px;
        height: 16px;
        text: @tr("Entradas");
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    Rectangle {
        x: 32px;
        y: 268px;
        width: parent.width - 64px;
        height: Math.max(0px, root.input-groups.length * 36px);
        background: transparent;

        for group[index] in root.input-groups : IoGroupRow {
            x: 0px;
            y: index * 36px;
            width: parent.width;
            group-summary: group.summary;
            edit-clicked => { root.edit-input(index); }
            remove-clicked => { root.remove-input(index); }
        }
    }

    AddGroupButton {
        x: 32px;
        y: 268px + Math.max(0px, root.input-groups.length * 36px);
        width: parent.width - 64px;
        label: @tr("btn-add-input");
        clicked => { root.add-input(); }
    }

    // --- Separator between inputs and outputs ---
    Rectangle {
        x: 32px;
        y: 316px + Math.max(0px, root.input-groups.length * 36px);
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    // --- Outputs section ---
    Text {
        x: 32px;
        y: 328px + Math.max(0px, root.input-groups.length * 36px);
        width: 120px;
        height: 16px;
        text: @tr("Saidas");
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    Rectangle {
        x: 32px;
        y: 348px + Math.max(0px, root.input-groups.length * 36px);
        width: parent.width - 64px;
        height: Math.max(0px, root.output-groups.length * 36px);
        background: transparent;

        for group[index] in root.output-groups : IoGroupRow {
            x: 0px;
            y: index * 36px;
            width: parent.width;
            group-summary: group.summary;
            edit-clicked => { root.edit-output(index); }
            remove-clicked => { root.remove-output(index); }
        }
    }

    AddGroupButton {
        x: 32px;
        y: 348px + Math.max(0px, root.input-groups.length * 36px) + Math.max(0px, root.output-groups.length * 36px);
        width: parent.width - 64px;
        label: @tr("btn-add-output");
        clicked => { root.add-output(); }
    }

    // --- Separator before footer ---
    Rectangle {
        x: 32px;
        y: 396px + Math.max(0px, root.input-groups.length * 36px) + Math.max(0px, root.output-groups.length * 36px);
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: parent.height - 58px;
        width: parent.width - 64px - 240px;
        height: 38px;
        text: root.status-message;
        color: #8db9ff;
        font-size: 12px;
        vertical-alignment: center;
    }

    FooterButton {
        x: parent.width - 232px;
        y: parent.height - 58px;
        label: @tr("btn-cancel");
        clicked => { root.cancel-chain(); }
    }

    FooterButton {
        x: parent.width - 120px;
        y: parent.height - 58px;
        label: root.save-label;
        primary: true;
        clicked => { root.save-chain(); }
    }
}
