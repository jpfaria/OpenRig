// Right-side panel of the project chains page when use-panel-editor is
// false: full block editor with the model picker, parameter list, knob
// overlays, EQ widgets. Bound to the AppWindow's shared block_*_options
// VecModels.

import { ListView, ScrollView } from "std-widgets.slint";
import { BlockTypePickerItem, BlockModelPickerItem, BlockParameterItem, MultiSliderPoint, CurveEditorPoint, BlockStreamData, BlockKnobOverlay } from "../models.slint";
import { EffectTypeIcon } from "../components/effect_type_icon.slint";
import { BlockPanelEditor } from "./block_panel_editor.slint";
import { CurveEditorControl, MultiSliderControl } from "./eq_widget.slint";
import { ModelSelectWithSearch } from "../components/model_select_with_search.slint";
import { BlockParameterRow } from "../components/block_parameter_row.slint";
import { BlockTypeCard, ToolbarButton } from "../components/block_value_widgets.slint";
import { ChainActionIcon, ChainPowerToggle } from "../components/chain_chips.slint";

export component BlockEditorPanel inherits Rectangle {
    in property <[BlockTypePickerItem]> block-type-options;
    in property <[BlockModelPickerItem]> block-model-options;
    in property <[BlockModelPickerItem]> filtered-block-model-options;
    in property <[string]> block-model-option-labels;
    in property <string> block-drawer-title;
    in property <string> block-drawer-confirm-label;
    in property <string> block-drawer-status-message;
    in property <bool> block-drawer-edit-mode;
    in property <int> block-drawer-selected-type-index;
    in-out property <int> block-drawer-selected-model-index;
    in-out property <string> block-model-search-text;
    in property <bool> block-drawer-enabled;
    in property <[BlockParameterItem]> block-parameter-items;
    in property <[MultiSliderPoint]> multi-slider-points;
    in property <[CurveEditorPoint]> curve-editor-points;
    in property <string> eq-total-curve;
    in property <[string]> eq-band-curves;
    callback choose-block-model(int);
    callback choose-block-model-by-id(string);
    callback search-block-model(string);
    callback close-block-drawer();
    callback save-block-drawer();
    callback delete-block-drawer();
    callback show-plugin-info(string, string);  // effect_type, model_id
    callback toggle-block-drawer-enabled();
    callback update-block-parameter-text(string, string);
    callback update-block-parameter-number(string, float);
    callback update-block-parameter-number-text(string, string);
    callback update-block-parameter-bool(string, bool);
    callback select-block-parameter-option(string, int);
    callback pick-block-parameter-file(string);
    callback open-vst3-editor(string); // model-id

    // Realtime data stream from engine (tuner, spectrum analyzer, etc.)
    in property <BlockStreamData> block-stream-data;

    // Computed helpers
    property <bool> is-preamp:
        root.block-drawer-selected-type-index >= 0
        && root.block-drawer-selected-type-index < root.block-type-options.length
        && root.block-type-options[root.block-drawer-selected-type-index].icon_kind == "preamp";

    // True when a tuner (or other non-spectrum stream) is the active block — show stream area even while silent
    property <bool> has-tuner-stream: root.block-stream-data.stream-kind != "" && root.block-stream-data.stream-kind != "spectrum";

    property <bool> is-vst3:
        root.block-drawer-selected-type-index >= 0
        && root.block-drawer-selected-type-index < root.block-type-options.length
        && root.block-type-options[root.block-drawer-selected-type-index].icon_kind == "vst3";

    property <string> selected-model-id:
        root.block-drawer-selected-model-index >= 0
        && root.block-drawer-selected-model-index < root.block-model-options.length
        ? root.block-model-options[root.block-drawer-selected-model-index].model_id
        : "";

    background: transparent;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #171a20f8;
        border-width: 1px;
        border-color: #2d3340;

        // ── CABEÇALHO ────────────────────────────────────────────
        EffectTypeIcon {
            x: 20px;
            y: 18px;
            width: 28px;
            height: 28px;
            icon-kind: root.block-drawer-selected-type-index >= 0 && root.block-drawer-selected-type-index < root.block-type-options.length
                ? root.block-type-options[root.block-drawer-selected-type-index].icon_kind
                : "";
            tint: #f3f6fb;
        }

        Text {
            x: 56px;
            y: 20px;
            width: parent.width - 160px;
            height: 24px;
            text: root.block-drawer-selected-type-index >= 0 && root.block-drawer-selected-type-index < root.block-type-options.length
                ? root.block-type-options[root.block-drawer-selected-type-index].label
                : "";
            color: #f3f6fb;
            font-size: 18px;
            font-weight: 800;
            vertical-alignment: center;
        }

        if root.block-drawer-edit-mode : ChainPowerToggle {
            x: parent.width - 72px;
            y: 20px;
            enabled: root.block-drawer-enabled;
            tooltip: root.block-drawer-enabled ? "Desativar" : "Ativar";
            clicked => { root.toggle-block-drawer-enabled(); }
        }

        if root.block-drawer-edit-mode : ChainActionIcon {
            x: parent.width - 40px;
            y: 20px;
            icon: @image-url("../assets/trash.svg");
            tooltip: @tr("tooltip-delete");
            clicked => { root.delete-block-drawer(); }
        }

        Rectangle {
            x: 20px;
            y: 62px;
            width: parent.width - 40px;
            height: 1px;
            background: #313743;
        }

        // ── AMP HEAD: seletor de modelo + imagem do painel + parâmetros ───────
        if root.is-preamp : ModelSelectWithSearch {
            x: 20px;
            y: 74px;
            width: parent.width - 40px;
            popup-height: 480px;
            filtered-models: root.filtered-block-model-options;
            selected-model: root.block-drawer-selected-model-index >= 0
                && root.block-drawer-selected-model-index < root.block-model-options.length
                ? root.block-model-options[root.block-drawer-selected-model-index]
                : { effect_type: "", model_id: "", label: "", display_name: "", subtitle: "", icon_kind: "", brand: "", type_label: "", panel_bg: #00000000, panel_text: #00000000, brand_strip_bg: #00000000, model_font: "", photo_offset_x: 0, photo_offset_y: 0 };
            search-text <=> root.block-model-search-text;
            select(model-id) => { root.choose-block-model-by-id(model-id); }
            search-text-changed(text) => { root.search-block-model(text); }
        }

        if root.is-preamp && root.block-drawer-selected-model-index >= 0 && root.block-drawer-selected-model-index < root.block-model-options.length : Text {
            x: 20px;
            y: 120px;
            width: parent.width - 40px;
            height: 16px;
            text: root.block-model-options[root.block-drawer-selected-model-index].subtitle;
            color: #94a0b0;
            font-size: 11px;
        }

        // (controls.svg removidos — painel agora é renderizado pelo BlockPanelEditor)

        // Parâmetros do amp head
        if root.is-preamp : ScrollView {
            x: 20px;
            y: 140px + (parent.width - 16px) / 4 + 12px;
            width: parent.width - 40px;
            height: parent.height - (140px + (parent.width - 16px) / 4 + 12px) - (root.block-drawer-edit-mode ? 20px : 74px);
            viewport-width: self.width;
            viewport-height: root.block-parameter-items.length * 96px;

            for param-item[index] in root.block-parameter-items : BlockParameterRow {
                x: 0px;
                y: index * 96px;
                width: parent.width - 24px;
                item: param-item;
                text-changed(path, value) => { root.update-block-parameter-text(path, value); }
                number-changed(path, value) => { root.update-block-parameter-number(path, value); }
                number-text-changed(path, value) => { root.update-block-parameter-number-text(path, value); }
                bool-changed(path, value) => { root.update-block-parameter-bool(path, value); }
                option-changed(path, value) => { root.select-block-parameter-option(path, value); }
                file-picked(path) => { root.pick-block-parameter-file(path); }
            }
        }

        // ── OUTROS TIPOS: layout original ───────────────────────
        if !root.is-preamp : ModelSelectWithSearch {
            x: 20px;
            y: 78px;
            width: parent.width - 40px;
            popup-height: 480px;
            filtered-models: root.filtered-block-model-options;
            selected-model: root.block-drawer-selected-model-index >= 0
                && root.block-drawer-selected-model-index < root.block-model-options.length
                ? root.block-model-options[root.block-drawer-selected-model-index]
                : { effect_type: "", model_id: "", label: "", display_name: "", subtitle: "", icon_kind: "", brand: "", type_label: "", panel_bg: #00000000, panel_text: #00000000, brand_strip_bg: #00000000, model_font: "", photo_offset_x: 0, photo_offset_y: 0 };
            search-text <=> root.block-model-search-text;
            select(model-id) => { root.choose-block-model-by-id(model-id); }
            search-text-changed(text) => { root.search-block-model(text); }
        }

        if !root.is-preamp && root.block-drawer-selected-model-index >= 0 && root.block-drawer-selected-model-index < root.block-model-options.length : Text {
            x: 20px;
            y: 124px;
            width: parent.width - 40px;
            height: 16px;
            text: root.block-model-options[root.block-drawer-selected-model-index].subtitle;
            color: #94a0b0;
            font-size: 11px;
        }

        if !root.is-preamp && root.curve-editor-points.length > 0 : CurveEditorControl {
            x: 8px;
            y: 148px;
            width: parent.width - 16px;
            points: root.curve-editor-points;
            total-curve: root.eq-total-curve;
            band-curves: root.eq-band-curves;
            update-parameter(path, val) => { root.update-block-parameter-number(path, val); }
        }

        if !root.is-preamp && root.multi-slider-points.length > 0 && root.curve-editor-points.length == 0 : MultiSliderControl {
            x: 8px;
            y: 148px;
            width: parent.width - 16px;
            points: root.multi-slider-points;
            update-parameter(path, val) => { root.update-block-parameter-number(path, val); }
        }

        // ── Stream display (tuner, spectrum) — for non-preamp utility blocks ──
        if !root.is-preamp && root.has-tuner-stream : Rectangle {
            x: 20px;
            y: 148px;
            width: parent.width - 40px;
            height: 200px;
            background: #0a0c14;
            border-radius: 8px;
            border-width: 1px;
            border-color: #2d3340;

            // Waiting for signal — shown until pitch is detected
            if !root.block-stream-data.active : Text {
                x: 0; y: 0; width: parent.width; height: parent.height;
                text: @tr("–");
                color: #3a4050;
                font-size: 52px; font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            for entry[ei] in root.block-stream-data.entries : Rectangle {
                property <length> slot-w: parent.width / root.block-stream-data.entries.length;
                x: ei * slot-w;
                y: 0;
                width: slot-w;
                height: parent.height;
                background: transparent;

                Text {
                    x: 0; y: 8px; width: parent.width; height: 12px;
                    text: entry.key;
                    color: #506070;
                    font-size: 7px; font-weight: 700; letter-spacing: 1.5px;
                    horizontal-alignment: center;
                }

                Text {
                    x: 0; y: 20px; width: parent.width; height: parent.height - 48px;
                    text: entry.text;
                    color: entry.value > 0.5 ? #29df85 : #f3f6fb;
                    font-size: entry.text.character-count <= 3 ? 52px : 20px;
                    font-weight: 900;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                if entry.key == "cents" : Rectangle {
                    x: 16px; y: parent.height - 24px;
                    width: parent.width - 32px; height: 8px;
                    background: #1a1e28;
                    border-radius: 4px;

                    Rectangle {
                        x: (parent.width - 1px) / 2;
                        y: 0; width: 1px; height: parent.height;
                        background: #405060;
                    }

                    Rectangle {
                        property <float> norm: (entry.value / 50.0).clamp(-1.0, 1.0);
                        x: (parent.width / 2) + self.norm * (parent.width / 2) - 4px;
                        y: 0; width: 8px; height: parent.height;
                        background: self.norm > -0.1 && self.norm < 0.1 ? #29df85 : #ff6a57;
                        border-radius: 4px;
                    }
                }
            }
        }

        if !root.is-preamp && root.block-stream-data.active && root.block-stream-data.stream-kind == "spectrum" : Rectangle {
            x: 20px;
            y: 148px;
            width: parent.width - 40px;
            height: 200px;
            background: #06060e;
            border-radius: 8px;
            clip: true;

            for entry[ei] in root.block-stream-data.entries : Rectangle {
                property <length> bar-slot-w: parent.width / root.block-stream-data.entries.length;
                x: ei * self.bar-slot-w;
                y: 0;
                width: self.bar-slot-w;
                height: parent.height;
                background: transparent;

                Rectangle {
                    property <length> bar-h: Math.max(1px, entry.value * parent.height);
                    x: 1px;
                    y: parent.height - self.bar-h;
                    width: parent.width - 2px;
                    height: self.bar-h;
                    background: entry.value > 0.85 ? #ff4433 : entry.value > 0.65 ? #ffaa22 : entry.value > 0.3 ? #44cc88 : #4488ff;
                    border-radius: 1px;
                }
            }
        }

        if !root.is-preamp && root.curve-editor-points.length == 0 && root.multi-slider-points.length == 0 : ScrollView {
            x: 20px;
            y: root.has-tuner-stream || (root.block-stream-data.active && root.block-stream-data.stream-kind == "spectrum") ? 360px : 144px;
            width: parent.width - 40px;
            height: root.has-tuner-stream || (root.block-stream-data.active && root.block-stream-data.stream-kind == "spectrum") ? (parent.height - 380px) : (parent.height - 164px);
            viewport-width: self.width;
            viewport-height: root.block-parameter-items.length * 96px;

            for param-item[index] in root.block-parameter-items : BlockParameterRow {
                x: 0px;
                y: index * 96px;
                width: parent.width - 24px;
                item: param-item;
                text-changed(path, value) => { root.update-block-parameter-text(path, value); }
                number-changed(path, value) => { root.update-block-parameter-number(path, value); }
                number-text-changed(path, value) => { root.update-block-parameter-number-text(path, value); }
                bool-changed(path, value) => { root.update-block-parameter-bool(path, value); }
                option-changed(path, value) => { root.select-block-parameter-option(path, value); }
                file-picked(path) => { root.pick-block-parameter-file(path); }
            }
        }

        if !root.block-drawer-edit-mode : ToolbarButton {
            x: parent.width - 116px;
            y: parent.height - 54px;
            width: 96px;
            label: root.block-drawer-confirm-label;
            primary: true;
            clicked => { root.save-block-drawer(); }
        }
    }
}

