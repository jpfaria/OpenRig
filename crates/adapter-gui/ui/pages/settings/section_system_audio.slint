// Master-detail right pane content for System / Audio (issue #513).
// Wrapped in a plain Rectangle — the SettingsPage shell renders the
// section title and divider; this component only renders the body.

import { DeviceSelectionItem } from "../../models.slint";
import { ComboBox, ScrollView } from "std-widgets.slint";

// Inline helper — not promoted to components/ because it is only used here.
component AudioDeviceRow inherits Rectangle {
    in property <DeviceSelectionItem> device;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    in property <[string]> bit-depth-options;
    callback toggled(bool);
    callback sample-rate-selected(string);
    callback buffer-size-selected(string);
    callback bit-depth-selected(string);

    height: 48px;
    background: transparent;

    pure function sample-rate-index(value: string) -> int {
        return value == "44100" ? 0
            : value == "48000" ? 1
            : value == "88200" ? 2
            : value == "96000" ? 3
            : 1;
    }

    pure function buffer-size-index(value: string) -> int {
        return value == "32" ? 0
            : value == "64" ? 1
            : value == "128" ? 2
            : value == "256" ? 3
            : value == "512" ? 4
            : value == "1024" ? 5
            : 3;
    }

    pure function bit-depth-index(value: string) -> int {
        return value == "16" ? 0
            : value == "24" ? 1
            : value == "32" ? 2
            : 2;
    }

    // Separator line
    Rectangle {
        x: 0px;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: #252a33;
    }

    // Custom toggle indicator
    Rectangle {
        x: 0px;
        y: 14px;
        width: 20px;
        height: 20px;
        background: root.device.selected ? #188cff : #1e2229;
        border-width: 1px;
        border-color: root.device.selected ? #45a7ff : #3d4450;
        border-radius: 8px;

        if root.device.selected : Image {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 12px;
            height: 12px;
            source: @image-url("../../assets/check.svg");
            colorize: #ffffff;
        }
    }

    Text {
        x: 32px;
        y: 0px;
        width: parent.width - 32px - (root.device.selected ? 420px : 0px);
        height: parent.height;
        text: root.device.name;
        color: root.device.selected ? #edf2f9 : #8a95a5;
        font-size: 13px;
        font-weight: root.device.selected ? 600 : 400;
        vertical-alignment: center;
        overflow: elide;
    }

    if root.device.selected : Text {
        x: parent.width - 424px;
        y: 0px;
        width: 26px;
        height: parent.height;
        text: @tr("label-hz");
        color: #6b7786;
        font-size: 11px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: right;
    }

    if root.device.selected : ComboBox {
        x: parent.width - 394px;
        y: 8px;
        width: 100px;
        height: 32px;
        model: root.sample-rate-options;
        current-index: root.sample-rate-index(root.device.sample_rate_text);
        selected(value) => { root.sample-rate-selected(value); }
    }

    if root.device.selected : Text {
        x: parent.width - 288px;
        y: 0px;
        width: 32px;
        height: parent.height;
        text: @tr("label-buffer");
        color: #6b7786;
        font-size: 11px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: right;
    }

    if root.device.selected : ComboBox {
        x: parent.width - 252px;
        y: 8px;
        width: 100px;
        height: 32px;
        model: root.buffer-size-options;
        current-index: root.buffer-size-index(root.device.buffer_size_text);
        selected(value) => { root.buffer-size-selected(value); }
    }

    if root.device.selected : Text {
        x: parent.width - 146px;
        y: 0px;
        width: 26px;
        height: parent.height;
        text: @tr("label-bits");
        color: #6b7786;
        font-size: 11px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: right;
    }

    if root.device.selected : ComboBox {
        x: parent.width - 116px;
        y: 8px;
        width: 76px;
        height: 32px;
        model: root.bit-depth-options;
        current-index: root.bit-depth-index(root.device.bit_depth_text);
        selected(value) => { root.bit-depth-selected(value); }
    }

    TouchArea {
        x: 0px;
        y: 0px;
        width: 300px;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.toggled(!root.device.selected); }
    }
}

export component SectionSystemAudio inherits Rectangle {
    in property <[DeviceSelectionItem]> project-devices;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    in property <[string]> bit-depth-options;
    callback refresh-devices();
    callback toggle-project-device(int, bool);
    callback update-project-sample-rate(int, string);
    callback update-project-buffer-size(int, string);
    callback update-project-bit-depth(int, string);

    background: transparent;

    VerticalLayout {
        spacing: 8px;

        // Header row: refresh button aligned to the right
        HorizontalLayout {
            alignment: end;

            Rectangle {
                width: 28px;
                height: 28px;
                border-radius: 8px;
                background: refresh-ta.has-hover ? #2a3340 : #1e2229;
                border-width: 1px;
                border-color: #3d4450;
                animate background { duration: 200ms; }

                Image {
                    x: 6px;
                    y: 6px;
                    width: 16px;
                    height: 16px;
                    source: @image-url("../../modules/surrealism-ui/icons/refresh.svg");
                    colorize: refresh-ta.has-hover ? #c5cdd9 : #8a95a5;
                }

                refresh-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.refresh-devices(); }
                }
            }
        }

        // Device list — height tracks the row count.
        ScrollView {
            horizontal-stretch: 1;
            height: root.project-devices.length * 48px;
            viewport-height: root.project-devices.length * 48px;

            for device[index] in root.project-devices : AudioDeviceRow {
                x: 0px;
                y: index * 48px;
                width: parent.width - 8px;
                device: device;
                sample-rate-options: root.sample-rate-options;
                buffer-size-options: root.buffer-size-options;
                bit-depth-options: root.bit-depth-options;
                toggled(selected) => { root.toggle-project-device(index, selected); }
                sample-rate-selected(value) => { root.update-project-sample-rate(index, value); }
                buffer-size-selected(value) => { root.update-project-buffer-size(index, value); }
                bit-depth-selected(value) => { root.update-project-bit-depth(index, value); }
            }
        }
    }
}
