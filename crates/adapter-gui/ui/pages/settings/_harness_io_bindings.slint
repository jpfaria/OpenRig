// TEMP render harness for the REAL SectionSystemIoBindings with mock data.
// Confirms the model-driven port lays out like the approved mockup.
import { SectionSystemIoBindings } from "section_io_bindings.slint";
import "../../fonts/BebasNeue.ttf";

export component Harness inherits Window {
    default-font-family: "Bebas Neue";
    default-font-size: 14px;
    preferred-width: 840px;
    preferred-height: 560px;
    background: #09090b;

    VerticalLayout {
        padding: 28px;
        SectionSystemIoBindings {
            input-device-names: ["Scarlett 2i2 USB", "MacBook Pro Microphone"];
            input-device-ids: ["a", "b"];
            output-device-names: ["Scarlett 2i2 USB"];
            output-device-ids: ["a"];
            channel-options: [
                { index: 0, label: "1", selected: true, available: true },
                { index: 1, label: "2", selected: false, available: true },
            ];
            io-bindings: [
                {
                    id: "main", name: "Guitarra",
                    inputs: [ { name: "In 1", device_label: "Scarlett 2i2 USB", mode: "mono", channels_label: "Canal 1" } ],
                    outputs: [ { name: "Out 1", device_label: "Scarlett 2i2 USB", mode: "stereo", channels_label: "Canais 1, 2" } ],
                },
                {
                    id: "voz", name: "Voz",
                    inputs: [ { name: "In 1", device_label: "MacBook Pro Microphone", mode: "mono", channels_label: "Canal 1" } ],
                    outputs: [ { name: "Out 1", device_label: "Scarlett 2i2 USB", mode: "stereo", channels_label: "Canais 1, 2" } ],
                },
            ];
        }
    }
}
