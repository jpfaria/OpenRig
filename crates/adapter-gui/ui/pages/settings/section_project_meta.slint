// Project / Metadata section (#513). Holds the project's display name
// and shows the on-disk file path. Both rows align on a fixed-width
// label column so the inputs line up.
//
// The Name LineEdit is clamped to 28px tall — without an explicit
// height it expanded to consume all vertical stretch from the parent
// VerticalLayout and rendered as a huge multi-line box.

import { SettingsSection, SettingsScope } from "../../components/settings_section.slint";
import { LineEdit } from "std-widgets.slint";

export component SectionProjectMeta inherits SettingsSection {
    scope: SettingsScope.project;
    title: @tr("title-section-project-meta");

    in property <string> project-name;
    in property <string> project-path-display;
    callback edit-project-name(string);

    VerticalLayout {
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            Text {
                text: @tr("label-name");
                color: #cfd5e0;
                width: 80px;
                vertical-alignment: center;
            }
            // Focus-ring wrapper: provides visible 2px bright-blue border on
            // focus per ui-ux-pro-max HIGH-severity focus ring rule.
            Rectangle {
                horizontal-stretch: 1;
                height: 28px;
                border-radius: 8px;
                border-width: name-edit.has-focus ? 2px : 1px;
                border-color: name-edit.has-focus ? #45a7ff : #2a2f38;
                animate border-color, border-width { duration: 150ms; }

                name-edit := LineEdit {
                    text: root.project-name;
                    height: parent.height;
                    width: parent.width;
                    edited(t) => { root.edit-project-name(t); }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            Text {
                text: @tr("label-file");
                color: #cfd5e0;
                width: 80px;
                vertical-alignment: center;
            }
            Text {
                text: root.project-path-display == ""
                    ? @tr("placeholder-project-unsaved")
                    : root.project-path-display;
                color: #8a92a3;
                font-size: 11px;
                horizontal-stretch: 1;
                vertical-alignment: center;
                wrap: word-wrap;
            }
        }
    }
}
