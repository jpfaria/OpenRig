// Project / Metadata section (#513). Master-detail content pane —
// the SettingsPage shell renders the title. Holds the project's
// display name, shows the on-disk file path, and exposes an explicit
// "Save project" button. Name edits auto-dispatch UpdateProjectName,
// but the user expects a Save affordance — the button forwards to
// AppWindow.save-project (Command::SaveProject).

import { Button, LineEdit } from "std-widgets.slint";

export component SectionProjectMeta inherits Rectangle {
    in property <string> project-name;
    in property <string> project-path-display;
    callback edit-project-name(string);
    callback save-project();

    background: transparent;

    VerticalLayout {
        spacing: 12px;
        alignment: start;

        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            height: 32px;
            Text {
                text: @tr("label-name");
                color: #cfd5e0;
                font-size: 16px;
                width: 80px;
                vertical-alignment: center;
            }
            // Focus-ring wrapper: provides visible 2px bright-blue border on
            // focus per ui-ux-pro-max HIGH-severity focus ring rule.
            Rectangle {
                horizontal-stretch: 1;
                height: 28px;
                border-radius: 8px;
                border-width: name-edit.has-focus ? 2px : 1px;
                border-color: name-edit.has-focus ? #45a7ff : #2a2f38;
                animate border-color, border-width { duration: 150ms; }

                name-edit := LineEdit {
                    text: root.project-name;
                    height: parent.height;
                    width: parent.width;
                    font-size: 16px;
                    edited(t) => { root.edit-project-name(t); }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            height: 28px;
            Text {
                text: @tr("label-file");
                color: #cfd5e0;
                font-size: 16px;
                width: 80px;
                vertical-alignment: center;
            }
            Text {
                text: root.project-path-display == ""
                    ? @tr("placeholder-project-unsaved")
                    : root.project-path-display;
                color: #8a92a3;
                font-size: 14px;
                horizontal-stretch: 1;
                vertical-alignment: center;
                wrap: word-wrap;
            }
        }

        // Save affordance — even though name edits auto-dispatch
        // UpdateProjectName, users expect an explicit Save button.
        HorizontalLayout {
            alignment: end;
            spacing: 8px;
            height: 36px;
            Button {
                text: @tr("btn-save-project");
                height: 32px;
                clicked => { root.save-project(); }
            }
        }
    }
}
