import { SettingsSection, SettingsScope } from "../../components/settings_section.slint";
import { MidiDeviceRow } from "../../models.slint";
import { ScrollView } from "std-widgets.slint";

export component SectionSystemMidiDevices inherits SettingsSection {
    scope: SettingsScope.system;
    // Translation key added in task 13 (docs+strings). Hardcoded for now
    // so the section ships in English and gets localized in the docs pass.
    title: "MIDI devices";

    in property <[MidiDeviceRow]> devices;
    callback refresh-midi-devices();
    callback toggle-midi-device(int, bool);
    callback edit-midi-device-alias(int, string);

    // Header row: refresh button aligned to the right (mirrors the
    // audio devices section so the user sees the same affordance).
    HorizontalLayout {
        alignment: end;

        Rectangle {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            background: refresh-ta.has-hover ? #2a3340 : #1e2229;
            border-width: 1px;
            border-color: #3d4450;

            Image {
                x: 6px;
                y: 6px;
                width: 16px;
                height: 16px;
                source: @image-url("../../modules/surrealism-ui/icons/refresh.svg");
                colorize: refresh-ta.has-hover ? #c5cdd9 : #8a95a5;
            }

            refresh-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.refresh-midi-devices(); }
            }
        }
    }

    ScrollView {
        width: parent.width - 32px;
        height: Math.max(48px, root.devices.length * 48px);
        viewport-height: root.devices.length * 48px;

        for d[i] in root.devices : Rectangle {
            x: 0px;
            y: i * 48px;
            width: parent.width - 8px;
            height: 44px;
            background: #1d2025;
            border-radius: 4px;
            border-width: 1px;
            border-color: d.enabled ? #2f4a6a : #2a2f38;

            // Custom toggle indicator (same visual as the audio device row)
            Rectangle {
                x: 12px;
                y: 12px;
                width: 20px;
                height: 20px;
                background: d.enabled ? #188cff : #1e2229;
                border-width: 1px;
                border-color: d.enabled ? #45a7ff : #3d4450;
                border-radius: 4px;

                if d.enabled : Text {
                    width: parent.width;
                    height: parent.height;
                    text: "✓";
                    color: #ffffff;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                toggle-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.toggle-midi-device(i, !d.enabled); }
                }
            }

            // Alias input
            Rectangle {
                x: 44px;
                y: 8px;
                width: parent.width - 44px - 220px;
                height: 28px;
                background: #14171c;
                border-width: 1px;
                border-color: alias-input.has-focus ? #45a7ff : #2a2f38;
                border-radius: 4px;

                alias-input := TextInput {
                    x: 8px;
                    width: parent.width - 16px;
                    height: parent.height;
                    text: d.alias;
                    color: #f3f6fb;
                    single-line: true;
                    vertical-alignment: center;
                    font-size: 13px;
                    edited => {
                        root.edit-midi-device-alias(i, self.text);
                    }
                }
            }

            // Raw port name + instance hint (read-only)
            Text {
                x: parent.width - 212px;
                y: 0px;
                width: 200px;
                height: parent.height;
                text: d.instance == 0 ? d.name : "\{d.name} (#\{d.instance})";
                color: #8a92a3;
                vertical-alignment: center;
                horizontal-alignment: right;
                font-size: 11px;
                overflow: elide;
            }
        }
    }
}
