// System / I/O Bindings — create, edit and delete per-machine I/O binding
// registry entries (issue #716). Each binding groups one or more input and
// output audio endpoints under a shared name so chain blocks can reference
// them symbolically.
//
// The section is a pure dispatcher (LAW: no business logic in Slint):
//   - callbacks fire upward; Rust wiring owns the mutation and Command dispatch.
//   - the binding list is seeded by Rust via the `io-bindings` model
//     ([IoBindingModel] with nested input/output endpoints).
//   - the endpoint pickers carry STRUCTURED values (device id + selected
//     channel indices + mode wire token) — no free text. Channel options for
//     the active add-row come from the shared `channel-options` model that
//     Rust rebuilds from the chosen device's reported channel count.
//
// LOC budget: ≤ 500 lines (slint-best-practices cap).

import { IoBindingModel, IoEndpointModel, ChannelOptionItem } from "../../models.slint";
import { IoEndpointRow } from "io_endpoint_row.slint";
import { IoEndpointAddRow } from "io_endpoint_add_row.slint";

export component SectionSystemIoBindings inherits Rectangle {
    // ── Data surface ────────────────────────────────────────────────────────
    in property <[IoBindingModel]> io-bindings;
    // Real enumerated devices (id + display name) for the pickers.
    in property <[string]> input-device-ids;
    in property <[string]> input-device-names;
    in property <[string]> output-device-ids;
    in property <[string]> output-device-names;
    // Channel checkboxes for the currently-active add-row (Rust rebuilds it
    // whenever the active device changes).
    in property <[ChannelOptionItem]> channel-options;
    // Inline error (e.g. delete rejected because binding is referenced).
    in-out property <string> io-binding-error: "";

    // ── Callbacks ────────────────────────────────────────────────────────────
    // Returns the generated id for the new binding.
    callback create-io-binding(string /* name */) -> string;
    // Returns "" on success, error message on reject.
    callback delete-io-binding(string /* id */) -> string;
    callback rename-io-binding(string /* id */, string /* new_name */);
    // The active add-row's device picker changed: (binding_id, is_input, device_id).
    callback endpoint-device-changed(string, bool, string);
    // Toggle a channel checkbox for the active add-row: (index, selected).
    callback toggle-endpoint-channel(int, bool);
    // Commit a structured input endpoint: (binding_id, device_id, mode).
    // Rust reads the selected channel indices from the shared channel-options.
    callback add-input-endpoint(string, string, string);
    // Commit a structured output endpoint: (binding_id, device_id, mode).
    callback add-output-endpoint(string, string, string);
    // Remove an existing endpoint: (binding_id, ep_name, is_input).
    callback remove-endpoint(string, string, bool);

    // ── Private state ─────────────────────────────────────────────────────────
    // Index of the binding row open in the inline editor (-1 = none).
    private property <int> editing-index: -1;
    // Draft for renaming the open binding.
    private property <string> rename-draft: "";
    // Which add-row is active inside the open binding: id + side.
    private property <string> active-binding-id: "";
    private property <bool>   active-is-input: true;
    // Draft for a new binding name.
    private property <string> new-binding-name: "";

    background: transparent;

    VerticalLayout {
        spacing: 12px;

        // ── Create new binding row ──────────────────────────────────────────
        Rectangle {
            height: 52px;
            background: #1d2025;
            border-radius: 8px;
            border-width: 1px;
            border-color: #2a2f38;

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 8px;
                spacing: 8px;
                alignment: center;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 32px;
                    Text {
                        x: 0px;
                        width: 100%;
                        height: 100%;
                        vertical-alignment: center;
                        text: @tr("placeholder-binding-name");
                        color: #5a6472;
                        font-size: 14px;
                        visible: root.new-binding-name == "";
                    }
                    TextInput {
                        width: 100%;
                        height: 100%;
                        text <=> root.new-binding-name;
                        color: #f3f6fb;
                        font-size: 14px;
                        single-line: true;
                        vertical-alignment: center;
                        accepted => {
                            root.create-io-binding(root.new-binding-name);
                            root.new-binding-name = "";
                        }
                    }
                }

                // Add button — always creates a binding (Rust assigns a
                // default name when the field is empty), then it can be renamed.
                Rectangle {
                    width: 40px;
                    height: 40px;
                    background: #188cff;
                    border-radius: 8px;

                    Image {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 15px;
                        height: 15px;
                        source: @image-url("../../assets/plus.svg");
                        colorize: #ffffff;
                    }

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.create-io-binding(root.new-binding-name);
                            root.new-binding-name = "";
                        }
                    }
                }
            }
        }

        // ── Inline error banner ─────────────────────────────────────────────
        if root.io-binding-error != "" : Rectangle {
            height: 36px;
            background: #3a1a1a;
            border-radius: 6px;
            border-width: 1px;
            border-color: #8b2020;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                spacing: 8px;
                alignment: center;

                Text {
                    horizontal-stretch: 1;
                    text: root.io-binding-error;
                    color: #e07070;
                    font-size: 13px;
                    overflow: elide;
                }

                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: transparent;
                    Image {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 12px;
                        height: 12px;
                        source: @image-url("../../assets/close.svg");
                        colorize: #e07070;
                    }
                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.io-binding-error = ""; }
                    }
                }
            }
        }

        // ── Binding list ────────────────────────────────────────────────────
        for binding[i] in root.io-bindings : Rectangle {
            background: #1d2025;
            border-radius: 8px;
            border-width: 1px;
            border-color: root.editing-index == i ? #2f4a6a : #2a2f38;
            animate border-color { duration: 150ms; }

            VerticalLayout {
                spacing: 0px;

                // Row header: chevron + name + delete.
                Rectangle {
                    height: 52px;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 8px;
                        spacing: 10px;
                        alignment: center;

                        Image {
                            width: 14px;
                            height: 14px;
                            source: root.editing-index == i
                                ? @image-url("../../assets/arrow-down.svg")
                                : @image-url("../../assets/arrow-right.svg");
                            colorize: #8a92a3;
                        }

                        Text {
                            horizontal-stretch: 1;
                            text: binding.name;
                            color: #dde3ec;
                            font-size: 15px;
                            font-weight: root.editing-index == i ? 600 : 400;
                            overflow: elide;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            width: 40px;
                            height: 40px;
                            background: del-ta.has-hover ? #3a1a1a : transparent;
                            border-radius: 6px;
                            animate background { duration: 120ms; }
                            Image {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                width: 14px;
                                height: 14px;
                                source: @image-url("../../assets/trash.svg");
                                colorize: del-ta.has-hover ? #e07070 : #6b7786;
                            }
                            del-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if root.editing-index == i { root.editing-index = -1; }
                                    let err = root.delete-io-binding(binding.id);
                                    if err != "" { root.io-binding-error = err; }
                                }
                            }
                        }
                    }

                    TouchArea {
                        width: parent.width - 60px;
                        height: parent.height;
                        x: 0px;
                        mouse-cursor: pointer;
                        clicked => {
                            root.editing-index = (root.editing-index == i) ? -1 : i;
                            root.rename-draft = binding.name;
                            root.active-binding-id = "";
                        }
                    }
                }

                // ── Inline editor ────────────────────────────────────────────
                if root.editing-index == i : VerticalLayout {
                    padding-left: 14px;
                    padding-right: 14px;
                    padding-bottom: 14px;
                    spacing: 14px;

                    Rectangle { height: 1px; background: #25292f; }

                    // Rename row.
                    HorizontalLayout {
                        spacing: 10px;
                        alignment: center;
                        Text {
                            text: @tr("label-binding-name");
                            color: #8a92a3;
                            font-size: 13px;
                            width: 90px;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 36px;
                            background: #15181d;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #2a2f38;
                            TextInput {
                                x: 10px;
                                width: parent.width - 20px;
                                height: 100%;
                                text <=> root.rename-draft;
                                color: #f3f6fb;
                                font-size: 14px;
                                single-line: true;
                                vertical-alignment: center;
                                accepted => { root.rename-io-binding(binding.id, root.rename-draft); }
                            }
                        }
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            background: #1e2229;
                            border-radius: 6px;
                            Image {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                width: 14px;
                                height: 14px;
                                source: @image-url("../../assets/check.svg");
                                colorize: #8a92a3;
                            }
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.rename-io-binding(binding.id, root.rename-draft); }
                            }
                        }
                    }

                    // ── Entradas group ──────────────────────────────────────
                    Text {
                        text: @tr("label-group-inputs");
                        color: #c4ccd8;
                        font-size: 13px;
                        font-weight: 600;
                    }
                    if binding.inputs.length == 0 : Text {
                        text: @tr("empty-no-input-endpoints");
                        color: #5a6472;
                        font-size: 12px;
                    }
                    for ep[ei] in binding.inputs : IoEndpointRow {
                        endpoint: ep;
                        remove-requested => { root.remove-endpoint(binding.id, ep.name, true); }
                    }
                    Rectangle {
                        height: add-input.preferred-height;
                        background: #15181d;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #262b33;
                        add-input := IoEndpointAddRow {
                            x: 12px;
                            y: 12px;
                            width: parent.width - 24px;
                            is-input: true;
                            device-names: root.input-device-names;
                            device-ids: root.input-device-ids;
                            channel-options: (root.active-binding-id == binding.id && root.active-is-input)
                                ? root.channel-options : [];
                            device-changed(dev) => {
                                root.active-binding-id = binding.id;
                                root.active-is-input = true;
                                root.endpoint-device-changed(binding.id, true, dev);
                            }
                            toggle-channel(idx, sel) => { root.toggle-endpoint-channel(idx, sel); }
                            add-endpoint(dev, mode) => {
                                root.add-input-endpoint(binding.id, dev, mode);
                                root.active-binding-id = "";
                            }
                        }
                    }

                    // ── Saídas group ────────────────────────────────────────
                    Text {
                        text: @tr("label-group-outputs");
                        color: #c4ccd8;
                        font-size: 13px;
                        font-weight: 600;
                    }
                    if binding.outputs.length == 0 : Text {
                        text: @tr("empty-no-output-endpoints");
                        color: #5a6472;
                        font-size: 12px;
                    }
                    for ep[eo] in binding.outputs : IoEndpointRow {
                        endpoint: ep;
                        remove-requested => { root.remove-endpoint(binding.id, ep.name, false); }
                    }
                    Rectangle {
                        height: add-output.preferred-height;
                        background: #15181d;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #262b33;
                        add-output := IoEndpointAddRow {
                            x: 12px;
                            y: 12px;
                            width: parent.width - 24px;
                            is-input: false;
                            device-names: root.output-device-names;
                            device-ids: root.output-device-ids;
                            channel-options: (root.active-binding-id == binding.id && !root.active-is-input)
                                ? root.channel-options : [];
                            device-changed(dev) => {
                                root.active-binding-id = binding.id;
                                root.active-is-input = false;
                                root.endpoint-device-changed(binding.id, false, dev);
                            }
                            toggle-channel(idx, sel) => { root.toggle-endpoint-channel(idx, sel); }
                            add-endpoint(dev, mode) => {
                                root.add-output-endpoint(binding.id, dev, mode);
                                root.active-binding-id = "";
                            }
                        }
                    }
                }
            }
        }

        // Bottom padding to keep the last item off the scroll edge.
        Rectangle { height: 8px; }
    }
}
