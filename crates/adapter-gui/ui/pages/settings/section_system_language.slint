// Language section — inline labeled ComboBox so the user can see the
// current language and pick a new one without opening a popover. The
// section title is rendered by the master-detail SettingsPage shell.

import { ComboBox } from "std-widgets.slint";

export component SectionSystemLanguage inherits Rectangle {
    in property <[string]> language-options;
    in property <[string]> language-codes;
    in property <int> selected-language-index;
    callback language-selected(int);

    background: transparent;

    HorizontalLayout {
        alignment: start;
        combo := ComboBox {
            model: root.language-options;
            current-index: root.selected-language-index;
            height: 28px;
            width: 240px;
            selected(_) => { root.language-selected(combo.current-index); }
        }
    }
}
