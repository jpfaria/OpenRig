// Language section — inline ComboBox mirroring the Audio Interface
// section's pattern (Hz/Buffer/Bits dropdowns). The previous
// LanguageSelector popover hid the current value behind a globe icon
// and felt out of place next to the rest of the settings rows.
// Property forwarding through ProjectSettingsWindow → SettingsPage was
// fixed in 371857e2, so std-widgets ComboBox now renders the model
// correctly inside the secondary window.

import { ComboBox } from "std-widgets.slint";

export component SectionSystemLanguage inherits Rectangle {
    in property <[string]> language-options;
    in property <[string]> language-codes;
    in property <int> selected-language-index;
    callback language-selected(int);

    background: transparent;

    HorizontalLayout {
        spacing: 12px;
        alignment: start;
        height: 32px;

        Text {
            text: @tr("label-language");
            color: #cfd5e0;
            font-size: 16px;
            width: 120px;
            vertical-alignment: center;
        }

        combo := ComboBox {
            model: root.language-options;
            current-index: root.selected-language-index;
            height: 28px;
            width: 280px;
            selected(_) => { root.language-selected(combo.current-index); }
        }
    }
}
