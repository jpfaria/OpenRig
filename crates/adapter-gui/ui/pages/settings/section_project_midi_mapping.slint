// Project / MIDI mapping editor (#513, #493). Replaces hand-edited
// `midi-map.yaml`. Each row shows the trigger label, a dropdown of
// available `Command` names, and a Delete/Cancel button. Drafts (rows
// in Learn mode) read "(listening...)" on the trigger column and turn
// the action button into "Cancel".
//
// The section renders at its natural height — there is no internal
// ScrollView (the outer SettingsPage tab wraps its content in a
// ScrollView, so an over-tall section scrolls as part of the tab).

import { SettingsSection, SettingsScope } from "../../components/settings_section.slint";
import { MidiBindingRow } from "../../models.slint";
import { Button, ComboBox } from "std-widgets.slint";

export component SectionProjectMidiMapping inherits SettingsSection {
    scope: SettingsScope.project;
    title: @tr("title-section-midi-mapping");

    in property <[MidiBindingRow]> bindings;
    in property <[string]> available-commands;
    callback add-midi-binding();
    callback delete-midi-binding(int);
    callback pick-midi-binding-command(int, string);
    callback cancel-midi-binding-draft(int);

    VerticalLayout {
        spacing: 8px;

        HorizontalLayout {
            alignment: end;
            Button {
                text: @tr("btn-add-midi-binding");
                clicked => { root.add-midi-binding(); }
            }
        }

        for b[i] in root.bindings : Rectangle {
            background: #1d2025;
            border-radius: 8px;
            height: 40px;
            HorizontalLayout {
                padding: 8px;
                spacing: 10px;
                alignment: stretch;
                Text {
                    text: b.learning ? @tr("placeholder-midi-listen") : b.trigger-label;
                    color: b.learning ? #ffd166 : #f3f6fb;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                ComboBox {
                    model: root.available-commands;
                    current-value: b.command-label;
                    selected(c) => { root.pick-midi-binding-command(i, c); }
                }
                Button {
                    text: b.learning ? @tr("btn-cancel") : @tr("btn-delete");
                    clicked => {
                        if (b.learning) {
                            root.cancel-midi-binding-draft(i);
                        } else {
                            root.delete-midi-binding(i);
                        }
                    }
                }
            }
        }
    }
}
