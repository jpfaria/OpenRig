// Track detail / multi-stem player view (#553).
//
// Skeumorphic rack-style layout matching the rest of OpenRig:
// stage_floor texture as the window backdrop, each stem rendered
// as a brushed-metal channel strip with the matching instrument
// icon from `assets/instruments/`, LED-style M/S indicators, and a
// chunky transport panel at the bottom.

import { ScrollView, Slider } from "std-widgets.slint";

export struct StemRowData {
    index: int,
    label: string,
    icon: image,
    peaks: image,
    muted: bool,
    soloed: bool,
    gain: float,
    pan: float,
}

component MetaChip inherits Rectangle {
    in property <string> label;
    in property <string> value;
    height: 36px;
    background: @linear-gradient(180deg, #2a2d33 0%, #1a1c20 100%);
    border-width: 1px;
    border-color: #3d4148;
    border-radius: 6px;
    drop-shadow-color: #00000080;
    drop-shadow-offset-y: 1px;
    drop-shadow-blur: 2px;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.label;
            color: #8a929e;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.5px;
            vertical-alignment: center;
        }
        Text {
            text: root.value;
            color: #f4f7fb;
            font-size: 13px;
            font-weight: 800;
            vertical-alignment: center;
        }
    }
}

component LedButton inherits Rectangle {
    in property <string> letter;
    in property <bool> active;
    in property <color> glow;
    callback clicked();

    width: 44px;
    height: 44px;
    background: @linear-gradient(180deg, #1a1c20 0%, #0c0d10 100%);
    border-width: 1px;
    border-color: root.active ? root.glow.brighter(0.3) : #2f3339;
    border-radius: 8px;
    drop-shadow-color: root.active ? root.glow : #00000060;
    drop-shadow-offset-y: root.active ? 0px : 1px;
    drop-shadow-blur: root.active ? 12px : 3px;

    // LED dot
    Rectangle {
        x: parent.width - 10px;
        y: 4px;
        width: 6px;
        height: 6px;
        border-radius: 3px;
        background: root.active ? root.glow : #2f3339;
    }

    Text {
        text: root.letter;
        color: root.active ? root.glow.brighter(0.4) : #b6bcc4;
        font-size: 18px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component StemStrip inherits Rectangle {
    in property <StemRowData> data;
    in property <float> progress: 0.0; // 0..1 playhead position
    callback mute-toggled(int, bool);
    callback solo-toggled(int, bool);
    callback gain-changed(int, float);
    callback pan-changed(int, float);
    callback seek-fraction(float);

    height: 112px;
    background: @linear-gradient(180deg,
        #2a2d33 0%,
        #1f2228 50%,
        #15181d 100%);
    border-width: 1px;
    border-color: root.data.soloed
        ? #d9a83b
        : (root.data.muted ? #b94a4a : #3d4148);
    border-radius: 10px;
    drop-shadow-color: root.data.soloed
        ? #d9a83b88
        : (root.data.muted ? #b94a4a55 : #00000080);
    drop-shadow-offset-y: 2px;
    drop-shadow-blur: root.data.soloed || root.data.muted ? 10px : 4px;
    clip: true;

    // Waveform behind everything (dimmed when muted, soft blue otherwise).
    Image {
        x: 240px;
        y: 0;
        width: parent.width - 240px;
        height: parent.height;
        source: root.data.peaks;
        image-fit: fill;
        opacity: root.data.muted ? 0.22 : (root.data.soloed ? 0.92 : 0.55);
        colorize: root.data.soloed ? #ffe9a8 : (root.data.muted ? #5a2a2a : transparent);
    }

    // Playhead line over the waveform.
    Rectangle {
        x: 240px + (parent.width - 240px) * root.progress;
        y: 6px;
        width: 1px;
        height: parent.height - 12px;
        background: #ffe9a8;
        opacity: 0.85;
    }

    // Click-to-seek hotspot covering the waveform area.
    waveform-area := TouchArea {
        x: 240px;
        y: 0;
        width: parent.width - 240px;
        height: parent.height;
        clicked => {
            root.seek-fraction(Math.max(0.0, Math.min(1.0, self.mouse-x / self.width)));
        }
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 18px;
        padding-top: 12px;
        padding-bottom: 12px;
        spacing: 18px;
        alignment: stretch;

        // Instrument icon + label
        HorizontalLayout {
            spacing: 12px;
            alignment: center;

            Rectangle {
                width: 56px;
                height: 56px;
                background: @linear-gradient(180deg, #0c0d10 0%, #1a1c20 100%);
                border-radius: 8px;
                border-width: 1px;
                border-color: #2f3339;

                Image {
                    x: 8px;
                    y: 8px;
                    width: 40px;
                    height: 40px;
                    source: root.data.icon;
                    image-fit: contain;
                    colorize: root.data.muted ? #6a6e74 : #e8ecf1;
                }
            }

            Text {
                text: root.data.label;
                color: #f4f7fb;
                font-size: 16px;
                font-weight: 800;
                vertical-alignment: center;
                width: 80px;
            }
        }

        // M / S column
        HorizontalLayout {
            spacing: 8px;
            alignment: center;
            LedButton {
                letter: "M";
                active: root.data.muted;
                glow: #b94a4a;
                clicked => { root.mute-toggled(root.data.index, !root.data.muted); }
            }
            LedButton {
                letter: "S";
                active: root.data.soloed;
                glow: #d9a83b;
                clicked => { root.solo-toggled(root.data.index, !root.data.soloed); }
            }
        }

        // Gain
        VerticalLayout {
            spacing: 4px;
            alignment: center;
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: "GAIN";
                    color: #8a929e;
                    font-size: 10px;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    vertical-alignment: center;
                }
                Text {
                    text: Math.round(root.data.gain * 100) + "%";
                    color: #f4f7fb;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    horizontal-alignment: right;
                }
            }
            Slider {
                minimum: 0.0;
                maximum: 1.5;
                value: root.data.gain;
                width: 180px;
                changed(v) => { root.gain-changed(root.data.index, v); }
            }
        }

        // Pan
        VerticalLayout {
            spacing: 4px;
            alignment: center;
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: "PAN";
                    color: #8a929e;
                    font-size: 10px;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    vertical-alignment: center;
                }
                Text {
                    text: Math.abs(root.data.pan) < 0.05
                        ? "C"
                        : (root.data.pan < 0
                            ? "L" + Math.round(Math.abs(root.data.pan) * 100)
                            : "R" + Math.round(root.data.pan * 100));
                    color: #f4f7fb;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    horizontal-alignment: right;
                }
            }
            Slider {
                minimum: -1.0;
                maximum: 1.0;
                value: root.data.pan;
                width: 140px;
                changed(v) => { root.pan-changed(root.data.index, v); }
            }
        }

        // The right side is filled by the waveform behind the strip.
        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }
    }
}

component TransportButton inherits Rectangle {
    in property <image> icon;
    in property <string> fallback-label;
    in property <bool> primary: false;
    callback clicked();

    width: root.primary ? 72px : 52px;
    height: root.primary ? 72px : 52px;
    background: root.primary
        ? @linear-gradient(180deg, #2eaaff 0%, #0e7adb 100%)
        : @linear-gradient(180deg, #2a2d33 0%, #16181c 100%);
    border-width: 1px;
    border-color: root.primary ? #56beff : #3d4148;
    border-radius: root.primary ? 36px : 26px;
    drop-shadow-color: root.primary ? #2eaaff80 : #00000080;
    drop-shadow-offset-y: 2px;
    drop-shadow-blur: root.primary ? 10px : 4px;

    Text {
        text: root.fallback-label;
        color: #f4f7fb;
        font-size: root.primary ? 16px : 13px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component TrackDetailPage inherits Rectangle {
    in property <string> title;
    in property <string> artist;
    in property <image> cover-art;
    in property <string> bpm-text;
    in property <string> key-text;
    in property <string> position-text;
    in property <string> duration-text;
    in property <[StemRowData]> stems;
    in property <bool> playing;
    in property <float> progress: 0.0;

    callback back-clicked();
    callback play-toggle();
    callback seek-relative(int);
    callback seek-fraction(float);
    callback stem-mute-toggled(int, bool);
    callback stem-solo-toggled(int, bool);
    callback stem-gain-changed(int, float);
    callback stem-pan-changed(int, float);

    background: #0a0c10;

    // Stage-floor texture under everything, dimmed so the cards pop.
    Image {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        source: @image-url("../../../../assets/backgrounds/stage_floor.jpg");
        image-fit: cover;
        opacity: 0.18;
    }

    VerticalLayout {
        padding: 20px;
        spacing: 14px;

        // ── Header ────────────────────────────────────────────────
        Rectangle {
            height: 68px;
            background: @linear-gradient(180deg, #1a1c20 0%, #101216 100%);
            border-width: 1px;
            border-color: #2f3339;
            border-radius: 10px;
            drop-shadow-color: #00000080;
            drop-shadow-offset-y: 2px;
            drop-shadow-blur: 6px;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 14px;
                alignment: stretch;

                Rectangle {
                    width: 76px;
                    height: 40px;
                    y: (parent.height - 40px) / 2;
                    background: @linear-gradient(180deg, #2a2d33 0%, #16181c 100%);
                    border-width: 1px;
                    border-color: #3d4148;
                    border-radius: 6px;

                    Text {
                        text: @tr("track-back");
                        color: #f4f7fb;
                        font-size: 12px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                    TouchArea { clicked => { root.back-clicked(); } }
                }

                // Cover thumbnail
                Rectangle {
                    width: 52px;
                    height: 52px;
                    y: (parent.height - 52px) / 2;
                    background: @linear-gradient(180deg, #2a2d33 0%, #16181c 100%);
                    border-width: 1px;
                    border-color: #3d4148;
                    border-radius: 6px;
                    clip: true;

                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: root.cover-art;
                        image-fit: cover;
                    }
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 2px;
                    alignment: center;
                    Text {
                        text: root.title;
                        color: #f4f7fb;
                        font-size: 22px;
                        font-weight: 800;
                    }
                    Text {
                        text: root.artist;
                        color: #b6bcc4;
                        font-size: 13px;
                        font-weight: 500;
                    }
                }

                MetaChip {
                    width: 96px;
                    y: (parent.height - 36px) / 2;
                    label: "BPM";
                    value: root.bpm-text;
                }
                MetaChip {
                    width: 104px;
                    y: (parent.height - 36px) / 2;
                    label: @tr("track-key-label");
                    value: root.key-text;
                }
            }
        }

        // ── Stem strips ───────────────────────────────────────────
        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                spacing: 10px;
                for stem in root.stems : StemStrip {
                    data: stem;
                    progress: root.progress;
                    mute-toggled(i, m) => { root.stem-mute-toggled(i, m); }
                    solo-toggled(i, s) => { root.stem-solo-toggled(i, s); }
                    gain-changed(i, g) => { root.stem-gain-changed(i, g); }
                    pan-changed(i, p) => { root.stem-pan-changed(i, p); }
                    seek-fraction(f) => { root.seek-fraction(f); }
                }
            }
        }

        // ── Transport ─────────────────────────────────────────────
        Rectangle {
            height: 100px;
            background: @linear-gradient(180deg, #1a1c20 0%, #101216 100%);
            border-width: 1px;
            border-color: #2f3339;
            border-radius: 10px;
            drop-shadow-color: #00000080;
            drop-shadow-offset-y: 2px;
            drop-shadow-blur: 6px;

            HorizontalLayout {
                padding-left: 24px;
                padding-right: 24px;
                spacing: 24px;
                alignment: center;

                Text {
                    text: root.position-text;
                    color: #f4f7fb;
                    font-size: 18px;
                    font-weight: 800;
                    vertical-alignment: center;
                    width: 96px;
                    horizontal-alignment: right;
                }

                TransportButton {
                    fallback-label: "« 5s";
                    clicked => { root.seek-relative(-5); }
                }
                TransportButton {
                    fallback-label: root.playing ? "❚❚" : "▶";
                    primary: true;
                    clicked => { root.play-toggle(); }
                }
                TransportButton {
                    fallback-label: "5s »";
                    clicked => { root.seek-relative(5); }
                }

                Text {
                    text: root.duration-text;
                    color: #8a929e;
                    font-size: 18px;
                    font-weight: 500;
                    vertical-alignment: center;
                    width: 96px;
                }
            }
        }
    }
}
