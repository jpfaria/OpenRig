import { ComboBox } from "std-widgets.slint";
import { IoEndpointModel } from "../models.slint";

// ── Internal helpers ──────────────────────────────────────────────────────────

component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 80px : 96px;
    height: 36px;
    background: primary ? #188cff : #2a2f38;
    border-width: 1px;
    border-color: primary ? #45a7ff : #41464f;
    border-radius: 6px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component SectionLabel inherits Text {
    color: #7a8694;
    font-size: 11px;
    font-weight: 600;
    height: 16px;
}

// ── Public component ──────────────────────────────────────────────────────────

export component ChainEndpointEditorPage inherits Rectangle {
    // Block kind: true = input block, false = output block.
    // Determines which side of the binding (inputs vs outputs) is listed in the
    // endpoint picker.
    in property <bool> is-input: true;

    in property <string> title;

    // Binding picker — names of all configured I/O bindings.
    in property <[string]> io-binding-names;
    in-out property <int> selected-io-index: -1;

    // Endpoint picker — names of endpoints within the selected binding,
    // scoped to inputs (for input blocks) or outputs (for output blocks).
    // Populated by the Rust side after a binding is selected.
    in property <[string]> endpoint-options;
    in-out property <string> selected-endpoint-name: "";

    // Resolved info for the currently selected (io, endpoint) pair.
    // Populated by the Rust side via `resolve_block_io_endpoint`.
    in property <IoEndpointModel> resolved-endpoint;
    in property <bool> has-resolved-endpoint: false;

    in-out property <string> status-message;

    callback select-io(int);
    callback select-endpoint(string);
    callback save();
    callback cancel();

    background: #171a1f;

    // ── Title ─────────────────────────────────────────────────────────────────

    Text {
        x: 32px;
        y: 28px;
        width: parent.width - 64px;
        height: 28px;
        text: root.title;
        color: #edf2f9;
        font-size: 20px;
        font-weight: 800;
    }

    Rectangle {
        x: 32px;
        y: 68px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    // ── I/O binding picker ────────────────────────────────────────────────────

    SectionLabel {
        x: 32px;
        y: 80px;
        width: parent.width - 64px;
        text: @tr("label-io-binding");
    }

    ComboBox {
        x: 32px;
        y: 100px;
        width: parent.width - 64px;
        height: 36px;
        model: root.io-binding-names;
        current-index: Math.max(0, root.selected-io-index);
        selected(value) => {
            root.selected-io-index = self.current-index;
            root.select-io(self.current-index);
        }
    }

    Rectangle {
        x: 32px;
        y: 148px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    // ── Endpoint picker ───────────────────────────────────────────────────────

    SectionLabel {
        x: 32px;
        y: 160px;
        width: parent.width - 64px;
        text: root.is-input ? @tr("label-input-endpoint") : @tr("label-output-endpoint");
    }

    ComboBox {
        x: 32px;
        y: 180px;
        width: parent.width - 64px;
        height: 36px;
        model: root.endpoint-options;
        current-index: 0;
        enabled: root.selected-io-index >= 0 && root.endpoint-options.length > 0;
        selected(value) => {
            root.selected-endpoint-name = value;
            root.select-endpoint(value);
        }
    }

    Rectangle {
        x: 32px;
        y: 228px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    // ── Resolved info (read-only labels) ─────────────────────────────────────

    SectionLabel {
        x: 32px;
        y: 240px;
        width: parent.width - 64px;
        text: @tr("label-resolved-info");
    }

    if root.has-resolved-endpoint : Text {
        x: 32px;
        y: 260px;
        width: parent.width - 64px;
        height: 20px;
        text: root.resolved-endpoint.device-label;
        color: #8a95a5;
        font-size: 12px;
        vertical-alignment: center;
    }

    if root.has-resolved-endpoint : Text {
        x: 32px;
        y: 284px;
        width: parent.width - 64px;
        height: 20px;
        text: root.resolved-endpoint.mode;
        color: #8a95a5;
        font-size: 12px;
        vertical-alignment: center;
    }

    if root.has-resolved-endpoint : Text {
        x: 32px;
        y: 308px;
        width: parent.width - 64px;
        height: 20px;
        text: @tr("label-channels") + ": " + root.resolved-endpoint.channels-label;
        color: #8a95a5;
        font-size: 12px;
        vertical-alignment: center;
    }

    if !root.has-resolved-endpoint : Text {
        x: 32px;
        y: 260px;
        width: parent.width - 64px;
        height: 36px;
        text: @tr("placeholder-select-endpoint");
        color: #4a5060;
        font-size: 12px;
        font-italic: true;
        vertical-alignment: center;
    }

    // ── Status message ────────────────────────────────────────────────────────

    if root.status-message != "" : Text {
        x: 32px;
        y: parent.height - 50px;
        width: parent.width - 320px;
        height: 32px;
        text: root.status-message;
        color: #ff6b6b;
        font-size: 13px;
        font-weight: 600;
        vertical-alignment: center;
        wrap: word-wrap;
    }

    // ── Footer buttons ────────────────────────────────────────────────────────

    FooterButton {
        x: parent.width - 196px;
        y: parent.height - 52px;
        label: @tr("btn-cancel");
        clicked => { root.cancel(); }
    }

    FooterButton {
        x: parent.width - 92px;
        y: parent.height - 52px;
        label: @tr("btn-ok");
        primary: true;
        clicked => { root.save(); }
    }
}
