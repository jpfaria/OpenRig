import { CheckBox, ComboBox, ScrollView } from "std-widgets.slint";
import { ChannelOptionItem } from "../models.slint";

component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 112px : 104px;
    height: 38px;
    background: primary ? #188cff : #2f3339;
    border-width: 1px;
    border-color: primary ? #45a7ff : #4c515b;
    border-radius: 4px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component ChannelRow inherits Rectangle {
    in property <ChannelOptionItem> channel;
    callback toggled(bool);

    height: 38px;
    background: transparent;
    border-width: 1px;
    border-color: #2b313b;
    border-radius: 4px;

    CheckBox {
        x: 12px;
        y: 7px;
        width: parent.width - 24px;
        height: 24px;
        text: root.channel.label;
        checked: root.channel.selected;
        enabled: root.channel.available;
        toggled => { root.toggled(self.checked); }
    }
}

export component ChainEndpointEditorPage inherits Rectangle {
    in property <string> title;
    in property <[string]> device-options;
    in-out property <int> selected-device-index;
    in property <[ChannelOptionItem]> channels;
    in-out property <string> status-message;
    callback select-device(int);
    callback toggle-channel(int, bool);
    callback save();
    callback cancel();

    background: #171a1f;

    Rectangle {
        x: 24px;
        y: 24px;
        width: parent.width - 48px;
        height: parent.height - 48px;
        background: transparent;
        border-width: 1px;
        border-color: #32363d55;
        border-radius: 6px;

        Text {
            x: 18px;
            y: 18px;
            width: parent.width - 36px;
            height: 26px;
            text: root.title;
            color: #edf2f9;
            font-size: 22px;
            font-weight: 800;
        }

        Rectangle {
            x: 18px;
            y: 62px;
            width: parent.width - 36px;
            height: 1px;
            background: #323a46;
        }

        ComboBox {
            x: 18px;
            y: 84px;
            width: parent.width - 36px;
            height: 36px;
            model: root.device-options;
            current-index <=> root.selected-device-index;
            selected(value) => { root.select-device(self.current-index); }
        }

        ScrollView {
            x: 18px;
            y: 138px;
            width: parent.width - 36px;
            height: parent.height - 228px;
            viewport-width: self.width;
            viewport-height: Math.max(self.height, root.channels.length * 46px);

            for channel[index] in root.channels : ChannelRow {
                x: 0px;
                y: index * 46px;
                width: parent.width - 12px;
                channel: channel;
                toggled(selected) => { root.toggle-channel(index, selected); }
            }
        }

        Text {
            x: 18px;
            y: parent.height - 84px;
            width: parent.width - 36px - 240px;
            height: 18px;
            text: root.status-message;
            color: #8db9ff;
            font-size: 12px;
            vertical-alignment: center;
        }

        FooterButton {
            x: parent.width - 224px;
            y: parent.height - 58px;
            label: "Cancelar";
            clicked => { root.cancel(); }
        }

        FooterButton {
            x: parent.width - 112px;
            y: parent.height - 58px;
            label: "OK";
            primary: true;
            clicked => { root.save(); }
        }
    }
}
