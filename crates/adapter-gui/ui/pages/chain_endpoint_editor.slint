import { ComboBox, ScrollView } from "std-widgets.slint";
import { ChannelOptionItem } from "../models.slint";

component FooterButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 80px : 96px;
    height: 36px;
    background: primary ? #188cff : #2a2f38;
    border-width: 1px;
    border-color: primary ? #45a7ff : #41464f;
    border-radius: 6px;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component ChannelRow inherits Rectangle {
    in property <ChannelOptionItem> channel;
    callback toggled(bool);

    height: 48px;
    background: transparent;

    // Separator line
    Rectangle {
        x: 0px;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: #252a33;
    }

    // Custom toggle indicator
    Rectangle {
        x: 0px;
        y: 14px;
        width: 20px;
        height: 20px;
        background: root.channel.selected ? #188cff : #1e2229;
        border-width: 1px;
        border-color: root.channel.selected ? #45a7ff : (root.channel.available ? #3d4450 : #2a2f38);
        border-radius: 4px;
        opacity: root.channel.available ? 1 : 0.4;

        if root.channel.selected : Text {
            width: parent.width;
            height: parent.height;
            text: @tr("✓");
            color: #ffffff;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: 32px;
        y: 0px;
        width: parent.width - 32px;
        height: parent.height;
        text: root.channel.label;
        color: root.channel.available
            ? (root.channel.selected ? #edf2f9 : #8a95a5)
            : #4a5060;
        font-size: 13px;
        font-weight: root.channel.selected ? 600 : 400;
        vertical-alignment: center;
    }

    if root.channel.available : TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.toggled(!root.channel.selected); }
    }
}

export component ChainEndpointEditorPage inherits Rectangle {
    in property <string> title;
    in property <[string]> device-options;
    in-out property <int> selected-device-index;
    in property <[ChannelOptionItem]> channels;
    in-out property <string> status-message;
    in property <bool> show-mode-selector: false;
    in property <[string]> mode-labels: [];
    in-out property <int> selected-mode-index: 0;
    callback select-device(int);
    callback toggle-channel(int, bool);
    callback select-mode(int);
    callback save();
    callback cancel();

    background: #171a1f;

    Text {
        x: 32px;
        y: 28px;
        width: parent.width - 64px;
        height: 28px;
        text: root.title;
        color: #edf2f9;
        font-size: 20px;
        font-weight: 800;
    }

    Rectangle {
        x: 32px;
        y: 68px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: 80px;
        width: 120px;
        height: 16px;
        text: @tr("Dispositivo");
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    ComboBox {
        x: 32px;
        y: 100px;
        width: parent.width - 64px;
        height: 36px;
        model: root.device-options;
        current-index <=> root.selected-device-index;
        selected(value) => { root.select-device(self.current-index); }
    }

    // Mode selector section — shown for both input and output when mode-labels is non-empty
    if root.show-mode-selector : Rectangle {
        x: 32px;
        y: 150px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    if root.show-mode-selector : Text {
        x: 32px;
        y: 163px;
        width: 120px;
        height: 16px;
        text: @tr("Modo");
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    if root.show-mode-selector : Rectangle {
        x: 32px;
        y: 183px;
        width: parent.width - 64px;
        height: 44px;
        background: transparent;

        for label[index] in root.mode-labels : Rectangle {
            x: index * 120px;
            y: 0px;
            width: 108px;
            height: 44px;
            background: index == root.selected-mode-index ? #2a5da8 : #1d2025;
            border-width: 1px;
            border-color: index == root.selected-mode-index ? #45a7ff : #41454e;
            border-radius: 4px;

            Text {
                width: parent.width;
                height: parent.height;
                text: label;
                color: index == root.selected-mode-index ? #f4f7fb : #8a94a2;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 12px;
                font-weight: 600;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => {
                    root.selected-mode-index = index;
                    root.select-mode(index);
                }
            }
        }
    }

    Rectangle {
        x: 32px;
        y: root.show-mode-selector ? 246px : 154px;
        width: parent.width - 64px;
        height: 1px;
        background: #2a2f38;
    }

    Text {
        x: 32px;
        y: root.show-mode-selector ? 258px : 166px;
        width: 120px;
        height: 16px;
        text: @tr("Canais");
        color: #7a8694;
        font-size: 11px;
        font-weight: 600;
    }

    ScrollView {
        x: 32px;
        y: root.show-mode-selector ? 278px : 188px;
        width: parent.width - 64px;
        height: parent.height - (root.show-mode-selector ? 342px : 252px);
        viewport-width: self.width;
        viewport-height: Math.max(self.height, root.channels.length * 48px);

        for channel[index] in root.channels : ChannelRow {
            x: 0px;
            y: index * 48px;
            width: parent.width - 8px;
            channel: channel;
            toggled(selected) => { root.toggle-channel(index, selected); }
        }
    }

    if root.status-message != "" : Text {
        x: 32px;
        y: parent.height - 50px;
        width: parent.width - 320px;
        height: 32px;
        text: root.status-message;
        color: #ff6b6b;
        font-size: 13px;
        font-weight: 600;
        vertical-alignment: center;
        wrap: word-wrap;
    }

    FooterButton {
        x: parent.width - 196px;
        y: parent.height - 52px;
        label: "Cancelar";
        clicked => { root.cancel(); }
    }

    FooterButton {
        x: parent.width - 92px;
        y: parent.height - 52px;
        label: "OK";
        primary: true;
        clicked => { root.save(); }
    }
}
