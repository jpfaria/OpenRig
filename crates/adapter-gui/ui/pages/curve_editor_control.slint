import { CurveEditorPoint } from "../models.slint";

export component CurveEditorControl inherits Rectangle {
    in property <[CurveEditorPoint]> points;
    in property <string> total-curve;
    in property <[string]> band-curves;

    callback update-parameter(string, float);

    height: 200px;
    background: #06060e;
    border-radius: 6px;
    clip: true;

    // Bottom 20px reserved for frequency labels
    private property <length> chart-h: root.height - 20px;

    // 0 dB center line
    Rectangle {
        x: 0; y: root.chart-h / 2;
        width: parent.width; height: 1px;
        background: #ffffff30;
    }
    // +6 dB
    Rectangle {
        x: 0;
        y: root.chart-h / 2 - root.chart-h * (6.0 / 36.0);
        width: parent.width; height: 1px;
        background: #ffffff10;
    }
    // -6 dB
    Rectangle {
        x: 0;
        y: root.chart-h / 2 + root.chart-h * (6.0 / 36.0);
        width: parent.width; height: 1px;
        background: #ffffff10;
    }

    // Per-band vertical sliders — same layout as MultiSlider
    for point[i] in root.points : Rectangle {
        private property <float> norm: (point.y-value - point.y-min) / Math.max(0.001, point.y-max - point.y-min);

        property <length> slider-w: Math.max(4px, (root.width - 2px) / Math.max(1, root.points.length) - 1px);
        x: i * (self.slider-w + 1px);
        y: 0;
        width: self.slider-w;
        height: parent.height;

        // Track
        Rectangle {
            x: parent.width / 2 - 1px;
            y: 4px;
            width: 2px;
            height: root.chart-h - 8px;
            background: #ffffff15;
        }

        // Fill from 0 dB to current gain
        Rectangle {
            property <float> center-norm: (0.0 - point.y-min) / Math.max(0.001, point.y-max - point.y-min);
            property <length> center-y: (1.0 - parent.norm) * (root.chart-h - 8px) + 4px;
            property <length> zero-y: (1.0 - self.center-norm) * (root.chart-h - 8px) + 4px;
            x: parent.width / 2 - 2px;
            y: Math.min(self.center-y, self.zero-y);
            width: 4px;
            height: Math.abs(self.center-y - self.zero-y);
            background: point.band-color;
            opacity: 0.5;
        }

        // Thumb (capped width so it looks like a vertical slider even with few bands)
        Rectangle {
            property <float> current-norm: (point.y-value - point.y-min) / Math.max(0.001, point.y-max - point.y-min);
            property <length> thumb-w: Math.min(parent.width - 8px, 48px);
            x: (parent.width - self.thumb-w) / 2;
            y: (1.0 - parent.norm) * (root.chart-h - 8px) + 4px - 4px;
            width: self.thumb-w;
            height: 8px;
            border-radius: 4px;
            background: point.band-color;

            TouchArea {
                mouse-cursor: ns-resize;
                moved => {
                    let dy = (self.mouse-y - self.pressed-y) / root.chart-h;
                    let new-norm = Math.clamp(parent.current-norm - dy, 0.0, 1.0);
                    let new-gain = Math.clamp(
                        point.y-min + new-norm * (point.y-max - point.y-min),
                        point.y-min, point.y-max);
                    root.update-parameter(point.y-path, new-gain);
                }
            }
        }

        // Gain label above thumb
        Text {
            x: 0;
            y: (1.0 - parent.norm) * (root.chart-h - 8px) + 4px - 16px;
            width: parent.width;
            text: point.y-label;
            color: point.band-color;
            font-size: 9px;
            horizontal-alignment: center;
        }

        // Frequency label at bottom
        Text {
            x: 0;
            y: root.chart-h + 4px;
            width: parent.width;
            text: point.x-label;
            color: point.band-color;
            font-size: 10px;
            horizontal-alignment: center;
        }
    }

    // Pure helper functions (kept for potential future use)
    pure function freq-to-norm(freq: float) -> float {
        Math.log(Math.max(20.0, freq) / 20.0, 1000.0)
    }

    pure function norm-to-freq(norm: float) -> float {
        20.0 * Math.pow(1000.0, norm)
    }

    pure function gain-to-norm(gain: float, gmin: float, gmax: float) -> float {
        1.0 - (gain - gmin) / Math.max(0.001, gmax - gmin)
    }

    pure function norm-to-gain(norm: float, gmin: float, gmax: float) -> float {
        gmin + (1.0 - norm) * (gmax - gmin)
    }
}
