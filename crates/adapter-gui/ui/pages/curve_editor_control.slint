import { CurveEditorPoint } from "../models.slint";
import { PanelSlider } from "../components/panel_slider.slint";

export component CurveEditorControl inherits Rectangle {
    in property <[CurveEditorPoint]> points;
    in property <string> total-curve;
    in property <[string]> band-curves;

    callback update-parameter(string, float);

    height: 200px;
    background: #06060e;
    border-radius: 6px;
    clip: true;

    // Bottom 20px reserved for frequency labels
    private property <length> chart-h: root.height - 20px;

    // 0 dB center line
    Rectangle {
        x: 0; y: root.chart-h / 2;
        width: parent.width; height: 1px;
        background: #ffffff30;
    }
    // +6 dB
    Rectangle {
        x: 0;
        y: root.chart-h / 2 - root.chart-h * (6.0 / 36.0);
        width: parent.width; height: 1px;
        background: #ffffff10;
    }
    // -6 dB
    Rectangle {
        x: 0;
        y: root.chart-h / 2 + root.chart-h * (6.0 / 36.0);
        width: parent.width; height: 1px;
        background: #ffffff10;
    }

    // Per-band vertical sliders
    for point[i] in root.points : Rectangle {
        property <length> slider-w: Math.max(24px, (root.width - 16px) / Math.max(1, root.points.length));
        property <length> fader-w: Math.min(self.slider-w - 8px, 36px);
        x: 8px + i * self.slider-w;
        y: 0;
        width: self.slider-w;
        height: parent.height;

        // PanelSlider sprite
        PanelSlider {
            x: (parent.width - parent.fader-w) / 2;
            y: 4px;
            width: parent.fader-w;
            height: root.chart-h - 8px;
            value: point.y-value;
            min-val: point.y-min;
            max-val: point.y-max;
            step: 0.1;
            path: point.y-path;
            changed(p, v) => { root.update-parameter(p, v); }
        }

        // Frequency label at bottom
        Text {
            x: 0;
            y: root.chart-h + 4px;
            width: parent.width;
            text: point.x-label;
            color: #ffffff80;
            font-size: 10px;
            horizontal-alignment: center;
        }
    }
}
