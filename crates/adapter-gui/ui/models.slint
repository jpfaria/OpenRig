export struct DeviceSelectionItem {
    device_id: string,
    name: string,
    selected: bool,
    sample_rate_text: string,
    buffer_size_text: string,
}

export struct TrackStageItem {
    kind: string,
    label: string,
    family: string,
    enabled: bool,
}

export struct ProjectTrackItem {
    title: string,
    subtitle: string,
    enabled: bool,
    stage_count_label: string,
    stages: [TrackStageItem],
}

export struct StageTypePickerItem {
    effect_type: string,
    label: string,
    subtitle: string,
    icon_kind: string,
}

export struct StageModelPickerItem {
    effect_type: string,
    model_id: string,
    label: string,
    subtitle: string,
    icon_kind: string,
}

export struct StageParameterItem {
    path: string,
    label: string,
    group: string,
    widget_kind: string,
    unit_text: string,
    value_text: string,
    numeric_value: float,
    numeric_min: float,
    numeric_max: float,
    numeric_step: float,
    numeric_integer: bool,
    bool_value: bool,
    selected_option_index: int,
    option_labels: [string],
    option_values: [string],
    file_extensions: [string],
    optional: bool,
    allow_empty: bool,
}

export struct RecentProjectItem {
    original_index: int,
    title: string,
    subtitle: string,
    is_valid: bool,
    invalid_reason: string,
}

export struct ChannelOptionItem {
    index: int,
    label: string,
    selected: bool,
    available: bool,
}
