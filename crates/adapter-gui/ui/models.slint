export struct DeviceSelectionItem {
    device_id: string,
    name: string,
    selected: bool,
    sample_rate_text: string,
    buffer_size_text: string,
}

export struct TrackStageItem {
    kind: string,
    label: string,
    family: string,
    enabled: bool,
}

export struct ProjectTrackItem {
    title: string,
    subtitle: string,
    enabled: bool,
    stage_count_label: string,
    stages: [TrackStageItem],
}

export struct StageTypePickerItem {
    effect_type: string,
    label: string,
    subtitle: string,
    icon_kind: string,
}

export struct StageModelPickerItem {
    effect_type: string,
    model_id: string,
    label: string,
    subtitle: string,
    icon_kind: string,
}

export struct RecentProjectItem {
    original_index: int,
    title: string,
    subtitle: string,
    is_valid: bool,
    invalid_reason: string,
}

export struct ChannelOptionItem {
    index: int,
    label: string,
    selected: bool,
    available: bool,
}
