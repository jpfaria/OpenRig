export struct DeviceSelectionItem {
    device_id: string,
    name: string,
    selected: bool,
    sample_rate_text: string,
    buffer_size_text: string,
}

export struct ChainBlockItem {
    kind: string,
    icon_kind: string,
    type_label: string,
    label: string,
    family: string,
    enabled: bool,
    real_index: int,
    thumbnail: image,
    has_thumbnail: bool,
    thumb_width: float,
    thumb_height: float,
    accent_color: color,
    icon_source: image,
}

export struct ProjectChainItem {
    instrument: string,
    title: string,
    subtitle: string,
    enabled: bool,
    block_count_label: string,
    input_label: string,
    input_tooltip: string,
    output_label: string,
    output_tooltip: string,
    latency_ms: float,
    blocks: [ChainBlockItem],
}

export struct BlockTypePickerItem {
    effect_type: string,
    label: string,
    subtitle: string,
    icon_kind: string,
    use_panel_editor: bool,
    accent_color: color,
    icon_source: image,
}

export struct BlockModelPickerItem {
    effect_type: string,
    model_id: string,
    label: string,
    display_name: string,
    subtitle: string,
    icon_kind: string,
    brand: string,
    type_label: string,
    panel_bg: color,
    panel_text: color,
    brand_strip_bg: color,
    model_font: string,
    photo_offset_x: float,
    photo_offset_y: float,
}

export struct BlockKnobOverlay {
    path: string,
    label: string,
    svg_cx: float,
    svg_cy: float,
    svg_r: float,
    value: float,
    min_val: float,
    max_val: float,
    step: float,
}

export struct BlockParameterItem {
    path: string,
    label: string,
    group: string,
    widget_kind: string,
    unit_text: string,
    value_text: string,
    numeric_value: float,
    numeric_min: float,
    numeric_max: float,
    numeric_step: float,
    numeric_integer: bool,
    bool_value: bool,
    selected_option_index: int,
    option_labels: [string],
    option_values: [string],
    file_extensions: [string],
    optional: bool,
    allow_empty: bool,
}

// Point in a MultiSlider widget (one vertical slider per point)
export struct MultiSliderPoint {
    path: string,
    label: string,
    value: float,
    min_val: float,
    max_val: float,
    step: float,
}

// Point in a CurveEditor widget (draggable on 2D plane)
export struct CurveEditorPoint {
    group: string,
    band_color: color,
    // Y axis (gain)
    y_path: string,
    y_value: float,
    y_min: float,
    y_max: float,
    y_step: float,
    y_label: string,  // formatted gain, e.g. "+3.5", "0.0"
    // X axis (frequency) — optional, 0 if not present
    has_x: bool,
    x_path: string,
    x_value: float,
    x_min: float,
    x_max: float,
    x_step: float,
    x_label: string,  // formatted frequency, e.g. "200Hz", "1.0k"
    // Width (Q/BW) — optional, 0 if not present
    has_width: bool,
    width_path: string,
    width_value: float,
    width_min: float,
    width_max: float,
    width_step: float,
}

// Key-value entry for realtime data streams
export struct BlockStreamEntry {
    key: string,
    value: float,
    text: string,
    peak: float,
}

// Realtime data stream for blocks that produce live readings (tuner, meter, analyzer).
// The block editor polls this data and renders it when a stream is active.
export struct BlockStreamData {
    active: bool,
    stream_kind: string,          // "tuner", "meter", "analyzer"
    entries: [BlockStreamEntry],  // arbitrary key-value pairs
}

export struct CompactBlockItem {
    chain_index: int,
    block_index: int,
    effect_type: string,
    model_id: string,
    icon_kind: string,
    brand: string,
    display_name: string,
    type_label: string,
    display_label: string,
    enabled: bool,
    panel_bg: color,
    panel_text: color,
    accent_color: color,
    icon_source: image,
    knob_overlays: [BlockKnobOverlay],
    parameter_items: [BlockParameterItem],
    model_labels: [string],
    model_selected_index: int,
    stream_data: BlockStreamData,
}

export struct RecentProjectItem {
    original_index: int,
    title: string,
    subtitle: string,
    is_valid: bool,
    invalid_reason: string,
}

export struct ChannelOptionItem {
    index: int,
    label: string,
    selected: bool,
    available: bool,
}

export struct IoGroupItem {
    name: string,
    summary: string,
}

