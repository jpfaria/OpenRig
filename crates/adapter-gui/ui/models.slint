export struct DeviceSelectionItem {
    device_id: string,
    name: string,
    selected: bool,
    sample_rate_text: string,
    buffer_size_text: string,
    bit_depth_text: string,
}

// Per-row payload for the System / MIDI devices section (#513). The
// pair (name, instance) is the stable key so the Rust side can pair
// edits back with the persisted `MidiDeviceSelection`.
export struct MidiDeviceRow {
    name: string,
    instance: int,
    alias: string,
    enabled: bool,
}

// Per-row payload for the Project / MIDI mapping editor (#513, #493).
// `learning = true` marks a draft row whose trigger is being captured
// in MIDI Learn mode; the trigger label then reads "(listening...)"
// until the daemon emits `Event::MidiEventReceived`. `command-label`
// is empty for drafts that haven't picked a Command yet.
export struct MidiBindingRow {
    trigger-label: string,
    command-label: string,
    learning: bool,
}

export struct BlockParamSummaryEntry {
    label: string,    // parameter name in uppercase (e.g. "GAIN")
    value: string,    // formatted current value (e.g. "65")
    unit: string,     // optional unit suffix (e.g. "%", "ms", "dB")
}

export struct StreamMeter {
    in_dbfs: float,
    out_dbfs: float,
}

export struct ChainBlockItem {
    kind: string,
    icon_kind: string,
    type_label: string,
    label: string,
    family: string,
    enabled: bool,
    // #606: the model is not installed/loadable (uninstalled NAM/IR/LV2
    // pack, or unsupported on this platform). The tile renders it as
    // deactivated and its enable toggle is inert — the user cannot turn on
    // a pedal that cannot build.
    unavailable: bool,
    real_index: int,
    thumbnail: image,
    has_thumbnail: bool,
    thumb_width: float,
    thumb_height: float,
    accent_color: color,
    icon_source: image,
    // Hover-tooltip metadata. `display_name` is the human model name;
    // `backend_label` is the DSP backend in uppercase
    // ("NATIVE"/"NAM"/"IR"/"LV2"); `brand` is the manufacturer slug used
    // by `BrandLogo` (e.g. "marshall", "fender", "boss") to optionally
    // render the logo; `param_entries` is the list of currently-set
    // parameters split into label/value/unit so the tooltip can render
    // each part with distinct typography. All four are empty for I/O and
    // Insert blocks where the tooltip would add no signal.
    display_name: string,
    backend_label: string,
    brand: string,
    param_entries: [BlockParamSummaryEntry],
}

export struct ProjectChainItem {
    instrument: string,
    title: string,
    subtitle: string,
    enabled: bool,
    block_count_label: string,
    input_label: string,
    input_tooltip: string,
    output_label: string,
    output_tooltip: string,
    latency_ms: float,
    /// Output volume da chain em percentual (issue #440). 100 = unity.
    /// Slider expõe range 0-200. Bind ao `Chain.volume` no Rust.
    volume: int,
    /// Issue #496 / #32 / #36: per-chain peak-meter readings (dBFS).
    /// Refreshed by the GUI timer polling `engine::output_meter`.
    /// Value -120.0 = silent (no signal). > 0 = clipping (red).
    /// Mapped to colour in `chain_row.slint`:
    ///   >  0     → red
    ///   -6..0   → green (sweet spot)
    ///   -18..-6 → yellow
    ///   < -18   → grey/orange (low)
    meter_in_dbfs: float,
    meter_out_dbfs: float,
    /// Per-stream meter readings. One entry per stream the runtime
    /// exposes for this chain. A multi-input chain (3 entries on its
    /// Input block) gets 3 pairs here so the GUI can draw 3 in/out
    /// bars instead of a single aggregate.
    stream_meters: [StreamMeter],
    blocks: [ChainBlockItem],
    /// Issue #614: true while the DI loop is armed (playing) for this chain.
    /// Refreshed by the meter timer at ~30 Hz via `ChainRuntimeState::has_di_loop`.
    di_loop_playing: bool,
    /// Issue #614: ordered list of available DI loop source names for the
    /// chain-tile ComboBox. Bundled ids first, then "Choose file…" sentinel.
    di_loop_sources: [string],
    /// Issue #661: index into `di_loop_sources` of the currently loaded DI
    /// loop source, or -1 when none. Refreshed by the meter timer from the
    /// dispatcher so the popup ComboBox highlights the active source on reopen.
    di_loop_selected_index: int,
}

// #436 #1: per-chain rig preset/scene navigation, aligned 1:1 with the
// `ProjectChainItem` list. `has-rig` false ⇒ the selector is hidden
// (non-rig chain). Built by `chain_rig_nav::rig_nav_rows`.
export struct ChainRigNav {
    has_rig: bool,
    preset_labels: [string],
    active_preset_index: int,
    scene: int,
    // How many scenes the active preset has (scenes grow on demand;
    // a preset starts with just 1). The UI shows 1..scene-count + a
    // "+" to add the next one.
    scene_count: int,
}

export struct BlockTypePickerItem {
    effect_type: string,
    label: string,
    subtitle: string,
    icon_kind: string,
    use_panel_editor: bool,
    // Issue #608: false for the generic NAM/IR file-loader blocks, which
    // have no catalog model to choose — the Block Editor hides the model
    // select/search picker for them. Computed in Rust via
    // `block_core::effect_type_uses_model_catalog`.
    uses_model_catalog: bool,
    accent_color: color,
    icon_source: image,
}

export struct BlockModelPickerItem {
    effect_type: string,
    model_id: string,
    label: string,
    display_name: string,
    subtitle: string,
    icon_kind: string,
    brand: string,
    type_label: string,
    panel_bg: color,
    panel_text: color,
    brand_strip_bg: color,
    model_font: string,
    available: bool,
    thumbnail_path: string,
}

// One row of the chain preset bank dropdown (`PresetSelect`), already
// filtered by the search field. `slot` is the row's ORIGINAL position in
// the unfiltered bank — selecting it dispatches `Preset(slot)`, so it must
// survive filtering (the filtered list reorders/drops rows). Issue #659.
export struct PresetOption {
    label: string,
    slot: int,
}

export struct BlockKnobOverlay {
    path: string,
    label: string,
    svg_cx: float,
    svg_cy: float,
    svg_r: float,
    value: float,
    min_val: float,
    max_val: float,
    step: float,
}

export struct BlockParameterItem {
    path: string,
    label: string,
    group: string,
    widget_kind: string,
    unit_text: string,
    value_text: string,
    numeric_value: float,
    numeric_min: float,
    numeric_max: float,
    numeric_step: float,
    numeric_integer: bool,
    bool_value: bool,
    selected_option_index: int,
    option_labels: [string],
    option_values: [string],
    file_extensions: [string],
    optional: bool,
    allow_empty: bool,
}

// Point in a MultiSlider widget (one vertical slider per point)
export struct MultiSliderPoint {
    path: string,
    label: string,
    value: float,
    min_val: float,
    max_val: float,
    step: float,
}

// Point in a CurveEditor widget (draggable on 2D plane)
export struct CurveEditorPoint {
    group: string,
    band_color: color,
    // Y axis (gain)
    y_path: string,
    y_value: float,
    y_min: float,
    y_max: float,
    y_step: float,
    y_label: string,  // formatted gain, e.g. "+3.5", "0.0"
    // X axis (frequency) — optional, 0 if not present
    has_x: bool,
    x_path: string,
    x_value: float,
    x_min: float,
    x_max: float,
    x_step: float,
    x_label: string,  // formatted frequency, e.g. "200Hz", "1.0k"
    // Width (Q/BW) — optional, 0 if not present
    has_width: bool,
    width_path: string,
    width_value: float,
    width_min: float,
    width_max: float,
    width_step: float,
}

// Key-value entry for realtime data streams
export struct BlockStreamEntry {
    key: string,
    value: float,
    text: string,
    peak: float,
}

// Realtime data stream for blocks that produce live readings (tuner, meter, analyzer).
// The block editor polls this data and renders it when a stream is active.
export struct BlockStreamData {
    active: bool,
    stream_kind: string,          // "tuner", "meter", "analyzer"
    entries: [BlockStreamEntry],  // arbitrary key-value pairs
}

export struct CompactBlockItem {
    chain_index: int,
    block_index: int,
    block_id: string,
    effect_type: string,
    model_id: string,
    icon_kind: string,
    brand: string,
    display_name: string,
    type_label: string,
    display_label: string,
    enabled: bool,
    panel_bg: color,
    panel_text: color,
    accent_color: color,
    icon_source: image,
    knob_overlays: [BlockKnobOverlay],
    parameter_items: [BlockParameterItem],
    multi_slider_points: [MultiSliderPoint],
    curve_editor_points: [CurveEditorPoint],
    model_labels: [string],
    model_selected_index: int,
    models: [BlockModelPickerItem],
    filtered_models: [BlockModelPickerItem],
    stream_data: BlockStreamData,
    has_external_gui: bool,
}

export struct RecentProjectItem {
    original_index: int,
    title: string,
    subtitle: string,
    is_valid: bool,
    invalid_reason: string,
}

export struct ChannelOptionItem {
    index: int,
    label: string,
    selected: bool,
    available: bool,
}

export struct IoGroupItem {
    summary: string,
}

// Inline plugin info overlay payload (issue #307). Carried as a single struct so the
// AppWindow → DesktopMain/TouchMain propagation is one binding instead of nine.
export struct PluginInfoData {
    screenshot: image,
    has-screenshot: bool,
    plugin-name: string,
    brand: string,
    type-label: string,
    description: string,
    license: string,
    homepage: string,
    has-homepage: bool,
}

