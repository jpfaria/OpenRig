export struct DeviceSelectionItem {
    device_id: string,
    name: string,
    selected: bool,
    sample_rate_text: string,
    buffer_size_text: string,
}

export struct ChainBlockItem {
    kind: string,
    icon_kind: string,
    type_label: string,
    label: string,
    family: string,
    enabled: bool,
}

export struct ProjectChainItem {
    title: string,
    subtitle: string,
    enabled: bool,
    block_count_label: string,
    input_label: string,
    input_tooltip: string,
    output_label: string,
    output_tooltip: string,
    latency_ms: float,
    blocks: [ChainBlockItem],
}

export struct BlockTypePickerItem {
    effect_type: string,
    label: string,
    subtitle: string,
    icon_kind: string,
}

export struct BlockModelPickerItem {
    effect_type: string,
    model_id: string,
    label: string,
    subtitle: string,
    icon_kind: string,
    brand: string,
    type_label: string,
}

export struct BlockKnobOverlay {
    path: string,
    label: string,
    svg_cx: float,
    svg_cy: float,
    svg_r: float,
    value: float,
    min_val: float,
    max_val: float,
    step: float,
}

export struct BlockParameterItem {
    path: string,
    label: string,
    group: string,
    widget_kind: string,
    unit_text: string,
    value_text: string,
    numeric_value: float,
    numeric_min: float,
    numeric_max: float,
    numeric_step: float,
    numeric_integer: bool,
    bool_value: bool,
    selected_option_index: int,
    option_labels: [string],
    option_values: [string],
    file_extensions: [string],
    optional: bool,
    allow_empty: bool,
}

export struct RecentProjectItem {
    original_index: int,
    title: string,
    subtitle: string,
    is_valid: bool,
    invalid_reason: string,
}

export struct ChannelOptionItem {
    index: int,
    label: string,
    selected: bool,
    available: bool,
}

