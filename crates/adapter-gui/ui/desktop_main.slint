import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { ChannelOptionItem, DeviceSelectionItem, ProjectTrackItem, RecentProjectItem } from "models.slint";
import { Header } from "blocks/blocks.slint";
import { ProjectLauncherPage, ProjectSettingsPage, ProjectTracksPage, TrackEditorPage, WizardConfigPage } from "pages/pages.slint";

export component DesktopMain inherits Rectangle {
    in property <bool> show-project-launcher;
    in property <bool> show-project-tracks;
    in property <bool> show-track-editor;
    in property <bool> show-project-settings;
    in property <bool> project-running;
    in property <string> project-path-label;
    in property <string> project-title;
    in-out property <string> project-name-draft;
    in property <bool> show-audio-settings;
    in-out property <int> wizard-step;
    in property <[DeviceSelectionItem]> input-devices;
    in property <[DeviceSelectionItem]> output-devices;
    in property <[ProjectTrackItem]> project-tracks;
    in property <[RecentProjectItem]> recent-projects;
    in property <string> track-editor-title;
    in property <string> track-editor-save-label;
    in-out property <string> track-draft-name;
    in property <[string]> track-input-device-options;
    in property <[string]> track-output-device-options;
    in property <int> selected-track-input-device-index;
    in property <int> selected-track-output-device-index;
    in property <[ChannelOptionItem]> track-input-channels;
    in property <[ChannelOptionItem]> track-output-channels;
    in-out property <string> status-message;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    callback toggle-input-device(int, bool);
    callback toggle-output-device(int, bool);
    callback update-input-sample-rate(int, string);
    callback update-input-buffer-size(int, string);
    callback update-output-sample-rate(int, string);
    callback update-output-buffer-size(int, string);
    callback go-to-output-step();
    callback go-to-input-step();
    callback update-project-name(string);
    callback save-audio-settings();
    callback close-project-settings();
    callback open-project-file();
    callback create-project-file();
    callback open-recent-project(int);
    callback remove-recent-project(int);
    callback back-to-launcher();
    callback add-track();
    callback save-project();
    callback configure-project();
    callback remove-track(int);
    callback toggle-track-enabled(int);
    callback configure-track(int);
    callback save-track-preset(int);
    callback configure-track-preset(int);
    callback start-project();
    callback stop-project();
    callback update-track-name(string);
    callback select-track-input-device(int);
    callback select-track-output-device(int);
    callback toggle-track-input-channel(int, bool);
    callback toggle-track-output-channel(int, bool);
    callback save-track();
    callback cancel-track();
    private property <int> visible-device-count: wizard-step == 0 ? input-devices.length : output-devices.length;
    private property <length> wizard-page-height: 24px + 20px + 24px + ((visible-device-count * 44px) + (visible-device-count > 0 ? (visible-device-count - 1) * 8px : 0px)) + 24px + 44px + 24px;

    background: Theme.palette.background-gradient;

    VerticalBox {
        padding-top: 24px;
        spacing: 24px;

        Header {}

        HorizontalBox {
            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }

            Rectangle {
                width: 720px;
                height: root.show-project-launcher ? 320px : root.show-track-editor ? 620px : root.show-project-settings ? 720px : root.show-project-tracks ? 700px : root.wizard-page-height;
                background: transparent;

                if root.show-project-launcher : ProjectLauncherPage {
                    project-path-label: root.project-path-label;
                    recent-projects: root.recent-projects;
                    status-message: root.status-message;
                    open-project-file => { root.open-project-file(); }
                    create-project-file => { root.create-project-file(); }
                    open-recent-project(index) => { root.open-recent-project(index); }
                    remove-recent-project(index) => { root.remove-recent-project(index); }
                }

                if root.show-project-tracks : ProjectTracksPage {
                    project-title: root.project-title;
                    tracks: root.project-tracks;
                    project-running: root.project-running;
                    status-message: root.status-message;
                    back-to-launcher => { root.back-to-launcher(); }
                    add-track => { root.add-track(); }
                    save-project => { root.save-project(); }
                    configure-project => { root.configure-project(); }
                    remove-track(index) => { root.remove-track(index); }
                    toggle-track-enabled(index) => { root.toggle-track-enabled(index); }
                    configure-track(index) => { root.configure-track(index); }
                    save-track-preset(index) => { root.save-track-preset(index); }
                    configure-track-preset(index) => { root.configure-track-preset(index); }
                    start-project => { root.start-project(); }
                    stop-project => { root.stop-project(); }
                }

                if root.show-track-editor : TrackEditorPage {
                    title: root.track-editor-title;
                    save-label: root.track-editor-save-label;
                    track-name: root.track-draft-name;
                    input-device-options: root.track-input-device-options;
                    output-device-options: root.track-output-device-options;
                    selected-input-device-index: root.selected-track-input-device-index;
                    selected-output-device-index: root.selected-track-output-device-index;
                    input-channel-options: root.track-input-channels;
                    output-channel-options: root.track-output-channels;
                    status-message: root.status-message;
                    update-track-name(value) => { root.update-track-name(value); }
                    select-input-device(index) => { root.select-track-input-device(index); }
                    select-output-device(index) => { root.select-track-output-device(index); }
                    toggle-input-channel(index, selected) => { root.toggle-track-input-channel(index, selected); }
                    toggle-output-channel(index, selected) => { root.toggle-track-output-channel(index, selected); }
                    save-track => { root.save-track(); }
                    cancel-track => { root.cancel-track(); }
                }

                if root.show-project-settings : ProjectSettingsPage {
                    project-name: root.project-name-draft;
                    input-devices: root.input-devices;
                    output-devices: root.output-devices;
                    status-message: root.status-message;
                    sample-rate-options: root.sample-rate-options;
                    buffer-size-options: root.buffer-size-options;
                    toggle-input-device(index, selected) => { root.toggle-input-device(index, selected); }
                    toggle-output-device(index, selected) => { root.toggle-output-device(index, selected); }
                    update-input-sample-rate(index, value) => { root.update-input-sample-rate(index, value); }
                    update-input-buffer-size(index, value) => { root.update-input-buffer-size(index, value); }
                    update-output-sample-rate(index, value) => { root.update-output-sample-rate(index, value); }
                    update-output-buffer-size(index, value) => { root.update-output-buffer-size(index, value); }
                    update-project-name(value) => { root.update-project-name(value); }
                    save-project-settings => { root.save-audio-settings(); }
                    close-project-settings => { root.close-project-settings(); }
                }

                if !root.show-project-launcher && !root.show-project-tracks && !root.show-track-editor && !root.show-project-settings : WizardConfigPage {
                    wizard-step: root.wizard-step;
                    show-project-name-field: false;
                    project-name: root.project-name-draft;
                    input-devices: root.input-devices;
                    output-devices: root.output-devices;
                    status-message: root.status-message;
                    sample-rate-options: root.sample-rate-options;
                    buffer-size-options: root.buffer-size-options;
                    toggle-input-device(index, selected) => { root.toggle-input-device(index, selected); }
                    toggle-output-device(index, selected) => { root.toggle-output-device(index, selected); }
                    update-input-sample-rate(index, value) => { root.update-input-sample-rate(index, value); }
                    update-input-buffer-size(index, value) => { root.update-input-buffer-size(index, value); }
                    update-output-sample-rate(index, value) => { root.update-output-sample-rate(index, value); }
                    update-output-buffer-size(index, value) => { root.update-output-buffer-size(index, value); }
                    go-to-output-step => { root.go-to-output-step(); }
                    go-to-input-step => { root.go-to-input-step(); }
                    update-project-name(value) => { root.update-project-name(value); }
                    save-audio-settings => { root.save-audio-settings(); }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }
        }
    }
}
