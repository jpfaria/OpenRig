import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { ChannelOptionItem, DeviceSelectionItem, ProjectChainItem, RecentProjectItem, BlockModelPickerItem, BlockParameterItem, BlockTypePickerItem, IoGroupItem, MultiSliderPoint, CurveEditorPoint, BlockStreamData, BlockKnobOverlay } from "models.slint";
import { ProjectLauncherPage, ProjectSetupPage, ProjectSettingsPage, ProjectChainsPage, ChainEditorPage, ChainEndpointEditorPage, ChainIoGroupsPage, TunerPanel, TunerRow, SpectrumPanel, SpectrumRow } from "pages/pages.slint";
import { LanguageSelector } from "components/language_selector.slint";

export component DesktopMain inherits Rectangle {
    in property <string> app-version;
    in property <bool> show-project-launcher;
    in property <bool> show-project-setup;
    in property <bool> show-project-chains;
    in property <bool> show-chain-editor;
    in property <bool> show-project-settings;
    in property <bool> project-dirty;
    in property <bool> auto-save: false;
    in property <bool> fullscreen: false;
    in property <bool> skip-launcher: false;
    in property <string> project-path-label;
    in property <string> project-title;
    in-out property <string> project-name-draft;
    in property <bool> show-audio-settings;
    in-out property <int> wizard-step;
    in property <[DeviceSelectionItem]> input-devices;
    in property <[DeviceSelectionItem]> output-devices;
    in property <[ProjectChainItem]> project-chains;
    in property <[RecentProjectItem]> recent-projects;
    in-out property <string> recent-project-search;
    in property <string> chain-editor-title;
    in property <string> chain-editor-save-label;
    in-out property <string> chain-draft-name;
    in property <string> chain-input-summary;
    in property <string> chain-output-summary;
    in property <[string]> chain-input-device-options;
    in property <[string]> chain-output-device-options;
    in property <int> selected-chain-input-device-index;
    in property <int> selected-chain-output-device-index;
    in property <int> selected-chain-block-chain-index;
    in property <int> selected-chain-block-index;
    in property <[BlockTypePickerItem]> block-type-options;
    in property <[BlockModelPickerItem]> block-model-options;
    in property <[BlockModelPickerItem]> filtered-block-model-options;
    in property <[string]> block-model-option-labels;
    in-out property <string> block-model-search-text;
    in property <string> block-picker-title;
    in property <bool> show-block-type-picker;
    in property <bool> show-block-model-picker;
    in property <bool> show-block-drawer;
    in property <string> block-drawer-title;
    in property <string> block-drawer-confirm-label;
    in property <string> block-drawer-status-message;
    in property <bool> block-drawer-edit-mode;
    in property <int> block-drawer-selected-type-index;
    in-out property <int> block-drawer-selected-model-index;
    in property <bool> block-drawer-enabled;
    in property <[BlockParameterItem]> block-parameter-items;
    in property <[MultiSliderPoint]> multi-slider-points;
    in property <[CurveEditorPoint]> curve-editor-points;
    in property <string> eq-total-curve;
    in property <[string]> eq-band-curves;
    in property <BlockStreamData> block-stream-data;
    in property <[BlockKnobOverlay]> block-knob-overlays;
    in property <[ChannelOptionItem]> chain-input-channels;
    in property <[ChannelOptionItem]> chain-output-channels;
    in-out property <string> status-message;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    in property <[string]> bit-depth-options;
    // Fullscreen inline project settings
    in property <[DeviceSelectionItem]> project-devices;
    // Fullscreen inline chain editor
    in property <[IoGroupItem]> chain-editor-input-groups;
    in property <[IoGroupItem]> chain-editor-output-groups;
    in property <bool> chain-editor-is-create-mode: true;
    in-out property <int> chain-editor-selected-instrument-index: 0;
    callback toggle-input-device(int, bool);
    callback toggle-output-device(int, bool);
    callback update-input-sample-rate(int, string);
    callback update-input-buffer-size(int, string);
    callback update-output-sample-rate(int, string);
    callback update-output-buffer-size(int, string);
    callback go-to-output-step();
    callback go-to-input-step();
    callback update-project-name(string);
    callback save-audio-settings();
    callback close-project-settings();
    callback open-project-file();
    callback create-project-file();
    callback confirm-new-project();
    callback cancel-new-project();
    callback open-recent-project(int);
    callback remove-recent-project(int);
    callback filter-recent-projects(string);
    callback back-to-launcher();
    callback add-chain();
    callback save-project();
    callback configure-project();
    callback open-tuner-window();
    in property <bool> show-tuner;
    in property <[TunerRow]> tuner-rows;
    in property <bool> tuner-mute-active;
    in property <bool> tuner-enabled: false;
    callback close-tuner();
    callback toggle-tuner-mute(bool);
    callback toggle-tuner-enabled(bool);
    callback open-spectrum-window();
    in property <bool> show-spectrum;
    in property <[SpectrumRow]> spectrum-rows;
    in property <bool> spectrum-enabled: false;
    callback close-spectrum();
    callback toggle-spectrum-enabled(bool);
    callback remove-chain(int);
    callback toggle-chain-enabled(int);
    callback configure-chain(int);
    callback configure-chain-input(int);
    callback configure-chain-output(int);
    callback save-chain-preset(int);
    callback probe-chain-latency(int);
    callback configure-chain-preset(int);
    callback open-compact-chain-view(int);
    callback update-chain-name(string);
    callback open-chain-input-editor();
    callback open-chain-output-editor();
    callback select-chain-input-device(int);
    callback select-chain-output-device(int);
    callback toggle-chain-input-channel(int, bool);
    callback toggle-chain-output-channel(int, bool);
    callback select-chain-block(int, int);
    callback clear-chain-block();
    callback toggle-chain-block-enabled(int, int);
    callback start-block-insert(int, int);
    callback reorder-chain-block(int, int, int);
    callback choose-block-type(int);
    callback choose-block-model(int);
    callback choose-block-model-by-id(string);
    callback search-block-model(string);
    callback cancel-block-picker();
    callback close-block-drawer();
    callback save-block-drawer();
    callback delete-block-drawer();
    callback show-plugin-info(string, string);  // effect_type, model_id
    callback toggle-block-drawer-enabled();
    callback update-block-parameter-text(string, string);
    callback update-block-parameter-number(string, float);
    callback update-block-parameter-number-text(string, string);
    callback update-block-parameter-bool(string, bool);
    callback select-block-parameter-option(string, int);
    callback pick-block-parameter-file(string);
    callback open-vst3-editor(string); // model-id
    callback save-chain();
    callback cancel-chain();
    // Fullscreen inline project settings callbacks
    callback toggle-project-device(int, bool);
    callback update-project-sample-rate(int, string);
    callback update-project-buffer-size(int, string);
    callback update-project-bit-depth(int, string);
    callback refresh-devices();
    // Fullscreen inline chain editor callbacks
    callback edit-chain-input(int);
    callback remove-chain-input(int);
    callback add-chain-input();
    callback edit-chain-output(int);
    callback remove-chain-output(int);
    callback add-chain-output();
    callback select-chain-instrument(int);
    // Fullscreen inline I/O endpoint editor
    in property <bool> show-chain-io-editor: false;
    in property <string> chain-io-editor-title;
    in property <[string]> chain-io-device-options;
    in-out property <int> chain-io-selected-device-index: -1;
    in property <[ChannelOptionItem]> chain-io-channels;
    in-out property <string> chain-io-editor-status: "";
    in property <bool> chain-io-show-mode-selector: false;
    in property <[string]> chain-io-mode-labels;
    in-out property <int> chain-io-selected-mode-index: 0;
    callback chain-io-select-device(int);
    callback chain-io-toggle-channel(int, bool);
    callback chain-io-select-mode(int);
    callback chain-io-save();
    callback chain-io-cancel();
    // Fullscreen inline I/O groups editor (list of input/output entries)
    in property <bool> show-chain-io-groups: false;
    in property <string> chain-io-groups-title;
    in property <string> chain-io-groups-add-label;
    in property <[IoGroupItem]> chain-io-groups-items;
    in-out property <string> chain-io-groups-status: "";
    in property <bool> chain-io-groups-show-block-controls: false;
    in property <bool> chain-io-groups-block-enabled: true;
    callback chain-io-groups-edit(int);
    callback chain-io-groups-remove(int);
    callback chain-io-groups-add();
    callback chain-io-groups-save();
    callback chain-io-groups-cancel();
    callback chain-io-groups-toggle-enabled();
    callback chain-io-groups-delete-block();
    // Language selector — driven by adapter_gui::SUPPORTED_LANGUAGES on Rust side.
    in property <[string]> language-options;
    in property <int> selected-language-index;
    callback change-language(int);
    private property <int> visible-device-count: wizard-step == 0 ? input-devices.length : output-devices.length;
    private property <length> wizard-page-height: 24px + 20px + 24px + ((visible-device-count * 44px) + (visible-device-count > 0 ? (visible-device-count - 1) * 8px : 0px)) + 24px + 44px + 24px;

    background: root.show-project-launcher ? #1e1f22 : Theme.palette.background-gradient;

    if root.show-project-launcher : ProjectLauncherPage {
        width: parent.width;
        height: parent.height;
        app-version: root.app-version;
        recent-projects: root.recent-projects;
        recent-project-search: root.recent-project-search;
        status-message: root.status-message;
        open-project-file => { root.open-project-file(); }
        create-project-file => { root.create-project-file(); }
        open-recent-project(index) => { root.open-recent-project(index); }
        remove-recent-project(index) => { root.remove-recent-project(index); }
        filter-recent-projects(value) => { root.filter-recent-projects(value); }
    }

    if root.show-project-setup : ProjectSetupPage {
        width: parent.width;
        height: parent.height;
        project-name <=> root.project-name-draft;
        status-message <=> root.status-message;
        confirm => { root.confirm-new-project(); }
        cancel => { root.cancel-new-project(); }
    }

    if !root.show-project-launcher && !root.show-project-setup : Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        if root.show-project-chains && !(root.fullscreen && (root.show-project-settings || root.show-chain-editor)) : ProjectChainsPage {
            width: parent.width;
            height: parent.height;
            project-title: root.project-title;
            project-path-label: root.project-path-label;
            project-dirty: root.project-dirty;
            auto-save: root.auto-save;
            fullscreen: root.fullscreen;
            skip-launcher: root.skip-launcher;
            project-chains: root.project-chains;
            selected-chain-block-chain-index: root.selected-chain-block-chain-index;
            selected-chain-block-index: root.selected-chain-block-index;
            block-type-options: root.block-type-options;
            block-model-options: root.block-model-options;
            filtered-block-model-options: root.filtered-block-model-options;
            block-model-option-labels: root.block-model-option-labels;
            block-model-search-text <=> root.block-model-search-text;
            show-block-type-picker: root.show-block-type-picker;
            show-block-drawer: root.show-block-drawer;
            show-inline-block-drawer: root.fullscreen;
            block-drawer-title: root.block-drawer-title;
            block-drawer-confirm-label: root.block-drawer-confirm-label;
            block-drawer-status-message: root.block-drawer-status-message;
            block-drawer-edit-mode: root.block-drawer-edit-mode;
            block-drawer-selected-type-index: root.block-drawer-selected-type-index;
            block-drawer-selected-model-index <=> root.block-drawer-selected-model-index;
            block-drawer-enabled: root.block-drawer-enabled;
            block-parameter-items: root.block-parameter-items;
            multi-slider-points: root.multi-slider-points;
            curve-editor-points: root.curve-editor-points;
            eq-total-curve: root.eq-total-curve;
            eq-band-curves: root.eq-band-curves;
            block-stream-data: root.block-stream-data;
            block-knob-overlays: root.block-knob-overlays;
            status-message: root.status-message;
            back-to-launcher => { root.back-to-launcher(); }
            add-chain => { root.add-chain(); }
            save-project => { root.save-project(); }
            configure-project => { root.configure-project(); }
            open-tuner-window => { root.open-tuner-window(); }
            open-spectrum-window => { root.open-spectrum-window(); }
            remove-chain(index) => { root.remove-chain(index); }
            toggle-chain-enabled(index) => { root.toggle-chain-enabled(index); }
            configure-chain(index) => { root.configure-chain(index); }
            configure-chain-input(index) => { root.configure-chain-input(index); }
            configure-chain-output(index) => { root.configure-chain-output(index); }
            configure-chain-preset(index) => { root.configure-chain-preset(index); }
            save-chain-preset(index) => { root.save-chain-preset(index); }
            probe-chain-latency(index) => { root.probe-chain-latency(index); }
            open-compact-chain-view(index) => { root.open-compact-chain-view(index); }
            select-chain-block(chain-index, block-index) => { root.select-chain-block(chain-index, block-index); }
            clear-chain-block => { root.clear-chain-block(); }
            toggle-chain-block-enabled(chain-index, block-index) => { root.toggle-chain-block-enabled(chain-index, block-index); }
            start-block-insert(chain-index, before-index) => { root.start-block-insert(chain-index, before-index); }
            reorder-chain-block(chain-index, from-index, before-index) => { root.reorder-chain-block(chain-index, from-index, before-index); }
            choose-block-type(index) => { root.choose-block-type(index); }
            choose-block-model(index) => { root.choose-block-model(index); }
            choose-block-model-by-id(mid) => { root.choose-block-model-by-id(mid); }
            search-block-model(text) => { root.search-block-model(text); }
            cancel-block-picker => { root.cancel-block-picker(); }
            close-block-drawer => { root.close-block-drawer(); }
            save-block-drawer => { root.save-block-drawer(); }
            delete-block-drawer => { root.delete-block-drawer(); }
            show-plugin-info(effect_type, model_id) => { root.show-plugin-info(effect_type, model_id); }
            toggle-block-drawer-enabled => { root.toggle-block-drawer-enabled(); }
            update-block-parameter-text(path, value) => { root.update-block-parameter-text(path, value); }
            update-block-parameter-number(path, value) => { root.update-block-parameter-number(path, value); }
            update-block-parameter-number-text(path, value) => { root.update-block-parameter-number-text(path, value); }
            update-block-parameter-bool(path, value) => { root.update-block-parameter-bool(path, value); }
            select-block-parameter-option(path, index) => { root.select-block-parameter-option(path, index); }
            pick-block-parameter-file(path) => { root.pick-block-parameter-file(path); }
            open-vst3-editor(model-id) => { root.open-vst3-editor(model-id); }
        }

        // Fullscreen inline project settings
        if root.fullscreen && root.show-project-settings : ProjectSettingsPage {
            width: parent.width;
            height: parent.height;
            project-name-draft <=> root.project-name-draft;
            project-devices: root.project-devices;
            sample-rate-options: root.sample-rate-options;
            buffer-size-options: root.buffer-size-options;
            bit-depth-options: root.bit-depth-options;
            status-message: root.status-message;
            update-project-name(value) => { root.update-project-name(value); }
            save-audio-settings => { root.save-audio-settings(); }
            close-project-settings => { root.close-project-settings(); }
            toggle-project-device(index, selected) => { root.toggle-project-device(index, selected); }
            update-project-sample-rate(index, value) => { root.update-project-sample-rate(index, value); }
            update-project-buffer-size(index, value) => { root.update-project-buffer-size(index, value); }
            update-project-bit-depth(index, value) => { root.update-project-bit-depth(index, value); }
            refresh-devices => { root.refresh-devices(); }
        }

        // Fullscreen inline tuner overlay (windowed mode uses TunerWindow instead)
        if root.fullscreen && root.show-tuner : TunerPanel {
            width: parent.width;
            height: parent.height;
            tuner-rows: root.tuner-rows;
            mute-active: root.tuner-mute-active;
            tuner-enabled: root.tuner-enabled;
            show-close-button: true;
            close-tuner => { root.close-tuner(); }
            toggle-mute(m) => { root.toggle-tuner-mute(m); }
            toggle-enabled(e) => { root.toggle-tuner-enabled(e); }
        }

        // Fullscreen inline spectrum overlay (windowed mode uses SpectrumWindow instead)
        if root.fullscreen && root.show-spectrum : SpectrumPanel {
            width: parent.width;
            height: parent.height;
            spectrum-rows: root.spectrum-rows;
            spectrum-enabled: root.spectrum-enabled;
            show-close-button: true;
            close-spectrum => { root.close-spectrum(); }
            toggle-enabled(e) => { root.toggle-spectrum-enabled(e); }
        }

        // Fullscreen inline chain editor
        if root.fullscreen && root.show-chain-editor && !root.show-chain-io-editor && !root.show-chain-io-groups : ChainEditorPage {
            width: parent.width;
            height: parent.height;
            title: root.chain-editor-title;
            save-label: root.chain-editor-save-label;
            chain-name: root.chain-draft-name;
            input-groups: root.chain-editor-input-groups;
            output-groups: root.chain-editor-output-groups;
            status-message: root.status-message;
            is-create-mode: root.chain-editor-is-create-mode;
            selected-instrument-index <=> root.chain-editor-selected-instrument-index;
            update-chain-name(value) => { root.update-chain-name(value); }
            edit-input(index) => { root.edit-chain-input(index); }
            remove-input(index) => { root.remove-chain-input(index); }
            add-input => { root.add-chain-input(); }
            edit-output(index) => { root.edit-chain-output(index); }
            remove-output(index) => { root.remove-chain-output(index); }
            add-output => { root.add-chain-output(); }
            save-chain => { root.save-chain(); }
            cancel-chain => { root.cancel-chain(); }
            select-instrument(index) => { root.select-chain-instrument(index); }
        }

        // Fullscreen inline I/O groups editor (list of input/output entries)
        if root.fullscreen && root.show-chain-io-groups && !root.show-chain-io-editor : ChainIoGroupsPage {
            width: parent.width;
            height: parent.height;
            title: root.chain-io-groups-title;
            add-label: root.chain-io-groups-add-label;
            groups: root.chain-io-groups-items;
            status-message <=> root.chain-io-groups-status;
            show-block-controls: root.chain-io-groups-show-block-controls;
            block-enabled: root.chain-io-groups-block-enabled;
            edit-group(index) => { root.chain-io-groups-edit(index); }
            remove-group(index) => { root.chain-io-groups-remove(index); }
            add-group => { root.chain-io-groups-add(); }
            save => { root.chain-io-groups-save(); }
            cancel => { root.chain-io-groups-cancel(); }
            toggle-enabled => { root.chain-io-groups-toggle-enabled(); }
            delete-block => { root.chain-io-groups-delete-block(); }
        }

        // Fullscreen inline I/O endpoint editor (input or output device selection)
        if root.fullscreen && root.show-chain-io-editor : ChainEndpointEditorPage {
            width: parent.width;
            height: parent.height;
            title: root.chain-io-editor-title;
            device-options: root.chain-io-device-options;
            selected-device-index <=> root.chain-io-selected-device-index;
            channels: root.chain-io-channels;
            status-message <=> root.chain-io-editor-status;
            show-mode-selector: root.chain-io-show-mode-selector;
            mode-labels: root.chain-io-mode-labels;
            selected-mode-index <=> root.chain-io-selected-mode-index;
            select-device(index) => { root.chain-io-select-device(index); }
            toggle-channel(index, selected) => { root.chain-io-toggle-channel(index, selected); }
            select-mode(index) => { root.chain-io-select-mode(index); }
            save => { root.chain-io-save(); }
            cancel => { root.chain-io-cancel(); }
        }

        if !root.show-project-chains : Rectangle {
            width: parent.width;
            height: parent.height;
            background: transparent;
        }
    }

    if root.show-project-settings : ProjectSettingsPage {
        width: parent.width;
        height: parent.height;
        project-name-draft <=> root.project-name-draft;
        status-message <=> root.status-message;
        project-devices: root.project-devices;
        sample-rate-options: root.sample-rate-options;
        buffer-size-options: root.buffer-size-options;
        bit-depth-options: root.bit-depth-options;
        update-project-name(value) => { root.update-project-name(value); }
        save-audio-settings => { root.save-audio-settings(); }
        close-project-settings => { root.close-project-settings(); }
        toggle-project-device(index, selected) => { root.toggle-project-device(index, selected); }
        update-project-sample-rate(index, value) => { root.update-project-sample-rate(index, value); }
        update-project-buffer-size(index, value) => { root.update-project-buffer-size(index, value); }
        update-project-bit-depth(index, value) => { root.update-project-bit-depth(index, value); }
        refresh-devices => { root.refresh-devices(); }
    }

    // Floating language selector — top-right, visible on every screen.
    LanguageSelector {
        x: parent.width - self.width - 16px;
        y: 12px;
        z: 200;
        compact: true;
        language-options: root.language-options;
        selected-language-index: root.selected-language-index;
        language-selected(i) => { root.change-language(i); }
    }
}

