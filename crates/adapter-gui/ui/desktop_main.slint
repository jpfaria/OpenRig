import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { ChannelOptionItem, DeviceSelectionItem, ProjectTrackItem, RecentProjectItem, StageModelPickerItem, StageParameterItem, StageTypePickerItem } from "models.slint";
import { ProjectLauncherPage, ProjectSettingsPage, ProjectTracksPage, TrackEditorPage } from "pages/pages.slint";

export component DesktopMain inherits Rectangle {
    in property <bool> show-project-launcher;
    in property <bool> show-project-tracks;
    in property <bool> show-track-editor;
    in property <bool> show-project-settings;
    in property <bool> project-running;
    in property <bool> project-dirty;
    in property <string> project-path-label;
    in property <string> project-title;
    in-out property <string> project-name-draft;
    in property <bool> show-audio-settings;
    in-out property <int> wizard-step;
    in property <[DeviceSelectionItem]> input-devices;
    in property <[DeviceSelectionItem]> output-devices;
    in property <[ProjectTrackItem]> project-tracks;
    in property <[RecentProjectItem]> recent-projects;
    in-out property <string> recent-project-search;
    in property <string> track-editor-title;
    in property <string> track-editor-save-label;
    in-out property <string> track-draft-name;
    in property <[string]> track-input-device-options;
    in property <[string]> track-output-device-options;
    in property <int> selected-track-input-device-index;
    in property <int> selected-track-output-device-index;
    in property <int> selected-track-stage-track-index;
    in property <int> selected-track-stage-index;
    in property <[StageTypePickerItem]> stage-type-options;
    in property <[StageModelPickerItem]> stage-model-options;
    in property <string> stage-picker-title;
    in property <bool> show-stage-type-picker;
    in property <bool> show-stage-model-picker;
    in property <bool> show-stage-drawer;
    in property <string> stage-drawer-title;
    in property <string> stage-drawer-confirm-label;
    in property <string> stage-drawer-status-message;
    in property <bool> stage-drawer-edit-mode;
    in property <int> stage-drawer-selected-type-index;
    in property <int> stage-drawer-selected-model-index;
    in property <bool> stage-drawer-enabled;
    in property <[StageParameterItem]> stage-parameter-items;
    in property <[ChannelOptionItem]> track-input-channels;
    in property <[ChannelOptionItem]> track-output-channels;
    in-out property <string> status-message;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    callback toggle-input-device(int, bool);
    callback toggle-output-device(int, bool);
    callback update-input-sample-rate(int, string);
    callback update-input-buffer-size(int, string);
    callback update-output-sample-rate(int, string);
    callback update-output-buffer-size(int, string);
    callback go-to-output-step();
    callback go-to-input-step();
    callback update-project-name(string);
    callback save-audio-settings();
    callback close-project-settings();
    callback open-project-file();
    callback create-project-file();
    callback open-recent-project(int);
    callback remove-recent-project(int);
    callback filter-recent-projects(string);
    callback back-to-launcher();
    callback add-track();
    callback save-project();
    callback configure-project();
    callback remove-track(int);
    callback toggle-track-enabled(int);
    callback configure-track(int);
    callback save-track-preset(int);
    callback configure-track-preset(int);
    callback start-project();
    callback stop-project();
    callback update-track-name(string);
    callback select-track-input-device(int);
    callback select-track-output-device(int);
    callback toggle-track-input-channel(int, bool);
    callback toggle-track-output-channel(int, bool);
    callback select-track-stage(int, int);
    callback clear-track-stage();
    callback toggle-track-stage-enabled(int, int);
    callback start-stage-insert(int, int);
    callback choose-stage-type(int);
    callback choose-stage-model(int);
    callback cancel-stage-picker();
    callback close-stage-drawer();
    callback save-stage-drawer();
    callback delete-stage-drawer();
    callback toggle-stage-drawer-enabled();
    callback update-stage-parameter-text(string, string);
    callback update-stage-parameter-number(string, float);
    callback update-stage-parameter-bool(string, bool);
    callback select-stage-parameter-option(string, int);
    callback pick-stage-parameter-file(string);
    callback save-track();
    callback cancel-track();
    private property <int> visible-device-count: wizard-step == 0 ? input-devices.length : output-devices.length;
    private property <length> wizard-page-height: 24px + 20px + 24px + ((visible-device-count * 44px) + (visible-device-count > 0 ? (visible-device-count - 1) * 8px : 0px)) + 24px + 44px + 24px;

    background: root.show-project-launcher ? #1e1f22 : Theme.palette.background-gradient;

    if root.show-project-launcher : ProjectLauncherPage {
        width: parent.width;
        height: parent.height;
        recent-projects: root.recent-projects;
        recent-project-search: root.recent-project-search;
        status-message: root.status-message;
        open-project-file => { root.open-project-file(); }
        create-project-file => { root.create-project-file(); }
        open-recent-project(index) => { root.open-recent-project(index); }
        remove-recent-project(index) => { root.remove-recent-project(index); }
        filter-recent-projects(value) => { root.filter-recent-projects(value); }
    }

    if !root.show-project-launcher : Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        if root.show-project-tracks : ProjectTracksPage {
            width: parent.width;
            height: parent.height;
            project-title: root.project-title;
            project-path-label: root.project-path-label;
            project-running: root.project-running;
            project-dirty: root.project-dirty;
            project-tracks: root.project-tracks;
            selected-track-stage-track-index: root.selected-track-stage-track-index;
            selected-track-stage-index: root.selected-track-stage-index;
            stage-type-options: root.stage-type-options;
            stage-model-options: root.stage-model-options;
            show-stage-type-picker: root.show-stage-type-picker;
            show-stage-drawer: root.show-stage-drawer;
            stage-drawer-title: root.stage-drawer-title;
            stage-drawer-confirm-label: root.stage-drawer-confirm-label;
            stage-drawer-status-message: root.stage-drawer-status-message;
            stage-drawer-edit-mode: root.stage-drawer-edit-mode;
            stage-drawer-selected-type-index: root.stage-drawer-selected-type-index;
            stage-drawer-selected-model-index: root.stage-drawer-selected-model-index;
            stage-drawer-enabled: root.stage-drawer-enabled;
            stage-parameter-items: root.stage-parameter-items;
            status-message: root.status-message;
            back-to-launcher => { root.back-to-launcher(); }
            add-track => { root.add-track(); }
            save-project => { root.save-project(); }
            configure-project => { root.configure-project(); }
            remove-track(index) => { root.remove-track(index); }
            toggle-track-enabled(index) => { root.toggle-track-enabled(index); }
            configure-track(index) => { root.configure-track(index); }
            save-track-preset(index) => { root.save-track-preset(index); }
            start-project => { root.start-project(); }
            stop-project => { root.stop-project(); }
            select-track-stage(track-index, stage-index) => { root.select-track-stage(track-index, stage-index); }
            clear-track-stage => { root.clear-track-stage(); }
            toggle-track-stage-enabled(track-index, stage-index) => { root.toggle-track-stage-enabled(track-index, stage-index); }
            start-stage-insert(track-index, before-index) => { root.start-stage-insert(track-index, before-index); }
            choose-stage-type(index) => { root.choose-stage-type(index); }
            choose-stage-model(index) => { root.choose-stage-model(index); }
            cancel-stage-picker => { root.cancel-stage-picker(); }
            close-stage-drawer => { root.close-stage-drawer(); }
            save-stage-drawer => { root.save-stage-drawer(); }
            delete-stage-drawer => { root.delete-stage-drawer(); }
            toggle-stage-drawer-enabled => { root.toggle-stage-drawer-enabled(); }
            update-stage-parameter-text(path, value) => { root.update-stage-parameter-text(path, value); }
            update-stage-parameter-number(path, value) => { root.update-stage-parameter-number(path, value); }
            update-stage-parameter-bool(path, value) => { root.update-stage-parameter-bool(path, value); }
            select-stage-parameter-option(path, index) => { root.select-stage-parameter-option(path, index); }
            pick-stage-parameter-file(path) => { root.pick-stage-parameter-file(path); }
        }

        if !root.show-project-tracks : Rectangle {
            width: parent.width;
            height: parent.height;
            background: transparent;
        }
    }
}
