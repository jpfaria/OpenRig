// #436 #1 — the chain row's title slot. For a rig chain it IS the
// preset picker (the title is the song you pick) + an "add preset"
// button + a scene icon that reveals the scene select on press; for a
// non-rig chain it falls back to the plain clickable title. Own file so
// chain_row.slint (over the 500-line cap) shrinks instead of growing.

import { ComboBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ChainRigNav } from "../models.slint";

// Small square icon button (press to toggle a panel). Mirrors the look
// of the chain action icons; own copy so this file has no chain_row dep.
component IconButton inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    in property <string> a11y;
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: 5px;
    background: root.active
        ? Theme.palette.accent-end
        : (ta.has-hover ? Theme.palette.card-secondary : transparent);
    animate background { duration: 150ms; }
    Image {
        x: 5px;
        y: 5px;
        width: 18px;
        height: 18px;
        source: root.icon;
        image-fit: contain;
        colorize: root.active ? #ffffff : (ta.has-hover ? #ffffff : #8a94a2);
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
    accessible-role: button;
    accessible-label: root.a11y;
}

export component ChainTitlePreset inherits Rectangle {
    in property <string> title;
    in property <ChainRigNav> nav;
    in property <bool> fullscreen: false;
    callback open-compact();
    // preset-picked(slot): slot >= 0 selects that combo entry; the
    // sentinel -1 means "add a new preset" (reuses this callback so no
    // new callback has to be threaded through the over-cap shells).
    callback preset-picked(int);
    callback scene-picked(int);
    private property <bool> show-scene: false;

    // ── Non-rig chain: the plain clickable title (unchanged behaviour).
    if !root.nav.has-rig : Rectangle {
        Text {
            width: parent.width;
            height: parent.height;
            text: root.title;
            color: title-ta.has-hover ? #ffffff : #f1f4f8;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
        }
        title-ta := TouchArea {
            mouse-cursor: root.fullscreen ? default : pointer;
            clicked => {
                if !root.fullscreen {
                    root.open-compact();
                }
            }
        }
    }

    // ── Rig chain: preset picker + add button + scene icon.
    if root.nav.has-rig : HorizontalLayout {
        spacing: Theme.spaces.small;
        alignment: start;
        ComboBox {
            // Same widget + size as the block editor's enum select
            // (block_parameter_row.slint): std ComboBox, height 32px,
            // no font/color override → identical font and colour.
            width: 240px;
            height: 32px;
            model: root.nav.preset-labels;
            current-index: root.nav.active-preset-index;
            enabled: root.nav.preset-labels.length > 0;
            selected => {
                root.preset-picked(self.current-index);
            }
            accessible-label: @tr("Preset selector");
        }
        VerticalLayout {
            alignment: center;
            IconButton {
                icon: @image-url("../assets/plus.svg");
                a11y: @tr("Add preset");
                clicked => {
                    root.preset-picked(-1);
                }
            }
        }
        VerticalLayout {
            alignment: center;
            IconButton {
                icon: @image-url("../assets/scene.svg");
                active: root.show-scene;
                a11y: @tr("Scene selector");
                clicked => {
                    root.show-scene = !root.show-scene;
                }
            }
        }
        Rectangle {
            horizontal-stretch: 1;
        }
    }

    // ── Scene select — revealed only when the scene icon is pressed.
    // Floats below the row (absolute + high z) so it is not clipped.
    if root.nav.has-rig && root.show-scene : Rectangle {
        x: 252px;
        y: 36px;
        width: 132px;
        height: 36px;
        z: 100;
        ComboBox {
            width: parent.width;
            height: 32px;
            model: ["Scene 1", "Scene 2", "Scene 3", "Scene 4", "Scene 5", "Scene 6", "Scene 7", "Scene 8"];
            current-index: root.nav.scene - 1;
            selected => {
                root.scene-picked(self.current-index + 1);
                root.show-scene = false;
            }
            accessible-label: @tr("Scene selector");
        }
    }
}
