// #436 #1 — the chain row's title slot. For a rig chain it IS the
// preset picker + scene strip (the title is the song you pick); for a
// non-rig chain it falls back to the plain clickable title. Own file so
// chain_row.slint (over the 500-line cap) shrinks instead of growing.

import { ComboBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ChainRigNav } from "../models.slint";

component SceneCell inherits Rectangle {
    in property <int> n;
    in property <bool> active;
    callback picked();
    width: 24px;
    height: 24px;
    border-radius: 5px;
    border-width: 1px;
    border-color: root.active ? Theme.palette.accent-border : Theme.palette.border;
    background: root.active
        ? Theme.palette.accent-end
        : (touch.has-hover ? Theme.palette.card-secondary : Theme.palette.card);
    animate background { duration: 150ms; }
    Text {
        text: root.n;
        color: root.active ? #ffffff : Theme.palette.text-muted;
        font-size: Theme.typo.caption.size;
        font-weight: root.active ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked();
        }
    }
    accessible-role: button;
    accessible-label: "Scene " + root.n;
}

export component ChainTitlePreset inherits Rectangle {
    in property <string> title;
    in property <ChainRigNav> nav;
    in property <bool> fullscreen: false;
    callback open-compact();
    callback preset-picked(int);
    callback scene-picked(int);

    // ── Non-rig chain: the plain clickable title (unchanged behaviour).
    if !root.nav.has-rig : Rectangle {
        Text {
            width: parent.width;
            height: parent.height;
            text: root.title;
            color: title-ta.has-hover ? #ffffff : #f1f4f8;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
        }
        title-ta := TouchArea {
            mouse-cursor: root.fullscreen ? default : pointer;
            clicked => {
                if !root.fullscreen {
                    root.open-compact();
                }
            }
        }
    }

    // ── Rig chain: the title slot becomes the preset picker + scenes.
    if root.nav.has-rig : HorizontalLayout {
        spacing: Theme.spaces.medium;
        ComboBox {
            width: 220px;
            model: root.nav.preset-labels;
            current-index: root.nav.active-preset-index;
            enabled: root.nav.preset-labels.length > 0;
            selected => {
                root.preset-picked(self.current-index);
            }
            accessible-label: @tr("Preset selector");
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: @tr("SCENE");
                color: Theme.palette.text-muted;
                font-size: Theme.typo.caption.size;
                letter-spacing: 1px;
            }
        }
        HorizontalLayout {
            spacing: 4px;
            for i in 8: SceneCell {
                n: i + 1;
                active: root.nav.scene == i + 1;
                picked => {
                    root.scene-picked(i + 1);
                }
            }
        }
        Rectangle {
            horizontal-stretch: 1;
        }
    }
}
