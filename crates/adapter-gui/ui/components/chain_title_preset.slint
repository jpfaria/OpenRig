// #436 #1 — the chain row's title slot. For a rig chain it IS the
// preset picker (the title is the song you pick) + an "add preset"
// button + an always-visible scene stepper (just the number, no
// dropdown); for a non-rig chain it falls back to the plain clickable
// title. Own file so chain_row.slint (over the 500-line cap) shrinks
// instead of growing.

import { ComboBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ChainRigNav } from "../models.slint";

// Small square icon button (press to fire). Mirrors the look of the
// chain action icons; own copy so this file has no chain_row dep.
component IconButton inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    in property <string> a11y;
    in property <bool> enabled: true;
    callback clicked();
    width: 28px;
    height: 28px;
    border-radius: 5px;
    background: root.active
        ? Theme.palette.accent-end
        : (ta.has-hover && root.enabled ? Theme.palette.card-secondary : transparent);
    animate background { duration: 150ms; }
    Image {
        x: 5px;
        y: 5px;
        width: 18px;
        height: 18px;
        source: root.icon;
        image-fit: contain;
        colorize: !root.enabled
            ? #4a525f
            : (root.active ? #ffffff : (ta.has-hover ? #ffffff : #8a94a2));
    }
    ta := TouchArea {
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if root.enabled {
                root.clicked();
            }
        }
    }
    accessible-role: button;
    accessible-label: root.a11y;
}

// Always-visible scene selector: just the number, flanked by ‹ ›. No
// dropdown — prettier and one-tap. Clamped 1..8; each arrow fires
// `picked` with the new scene (no-op at the ends, arrow dims).
component SceneStepper inherits Rectangle {
    in property <int> scene;
    callback picked(int);
    private property <bool> at-min: root.scene <= 1;
    private property <bool> at-max: root.scene >= 8;
    width: 86px;
    height: 32px;
    border-radius: 6px;
    background: Theme.palette.card-secondary;
    border-width: 1px;
    border-color: #3b4250;

    HorizontalLayout {
        padding: 2px;
        IconButton {
            icon: @image-url("../assets/arrow-left.svg");
            a11y: @tr("Previous scene");
            enabled: !root.at-min;
            clicked => {
                root.picked(root.scene - 1);
            }
        }
        Text {
            horizontal-stretch: 1;
            text: root.scene;
            color: #f1f4f8;
            font-size: 15px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        IconButton {
            icon: @image-url("../assets/arrow-right.svg");
            a11y: @tr("Next scene");
            enabled: !root.at-max;
            clicked => {
                root.picked(root.scene + 1);
            }
        }
    }
    accessible-role: text;
    accessible-label: @tr("Scene {}", root.scene);
}

export component ChainTitlePreset inherits Rectangle {
    in property <string> title;
    in property <ChainRigNav> nav;
    in property <bool> fullscreen: false;
    callback open-compact();
    // preset-picked(slot): slot >= 0 selects that combo entry; the
    // sentinel -1 means "add a new preset" (reuses this callback so no
    // new callback has to be threaded through the over-cap shells).
    callback preset-picked(int);
    callback scene-picked(int);

    // ── Non-rig chain: the plain clickable title (unchanged behaviour).
    if !root.nav.has-rig : Rectangle {
        Text {
            width: parent.width;
            height: parent.height;
            text: root.title;
            color: title-ta.has-hover ? #ffffff : #f1f4f8;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
        }
        title-ta := TouchArea {
            mouse-cursor: root.fullscreen ? default : pointer;
            clicked => {
                if !root.fullscreen {
                    root.open-compact();
                }
            }
        }
    }

    // ── Rig chain: preset picker + add button + scene stepper.
    if root.nav.has-rig : HorizontalLayout {
        spacing: Theme.spaces.small;
        alignment: start;
        ComboBox {
            // Same widget + size as the block editor's enum select
            // (block_parameter_row.slint): std ComboBox, height 32px,
            // no font/color override → identical font and colour.
            width: 240px;
            height: 32px;
            model: root.nav.preset-labels;
            current-index: root.nav.active-preset-index;
            enabled: root.nav.preset-labels.length > 0;
            selected => {
                root.preset-picked(self.current-index);
            }
            accessible-label: @tr("Preset selector");
        }
        VerticalLayout {
            alignment: center;
            IconButton {
                icon: @image-url("../assets/plus.svg");
                a11y: @tr("Add preset");
                clicked => {
                    root.preset-picked(-1);
                }
            }
        }
        VerticalLayout {
            alignment: center;
            SceneStepper {
                scene: root.nav.scene;
                picked(s) => {
                    root.scene-picked(s);
                }
            }
        }
        Rectangle {
            horizontal-stretch: 1;
        }
    }
}
