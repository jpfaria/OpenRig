// Rotary selector knob — same sprite as PanelKnob but snapped to discrete positions.
// Labels displayed below the knob.
export component SelectorKnob inherits Rectangle {
    in property <int> num-options;       // 2, 3, or 4
    in property <int> selected-index;    // 0-based
    in property <[string]> labels;
    callback select(int);

    private property <int> frame-count: 65;
    private property <int> frame-index:
        root.num-options <= 1 ? 0
        : Math.min(Math.max(Math.round(root.selected-index * (root.frame-count - 1) / (root.num-options - 1)), 0), root.frame-count - 1);
    private property <length> ks: Math.min(root.width, root.height - 16px);

    background: transparent;

    // ── Knob sprite ──
    Rectangle {
        x: (root.width - root.ks) / 2;
        y: 0;
        width: root.ks;
        height: root.ks;
        clip: true;

        Image {
            source: @image-url("../assets/sprites/knob-strip.png");
            x: -root.frame-index * root.ks;
            y: 0;
            width: root.frame-count * root.ks;
            height: root.ks;
            image-fit: fill;
            image-rendering: smooth;
        }
    }

    // ── Click on knob cycles to next option ──
    TouchArea {
        x: (root.width - root.ks) / 2;
        y: 0;
        width: root.ks;
        height: root.ks;
        mouse-cursor: pointer;
        clicked => {
            root.select(root.selected-index >= root.num-options - 1 ? 0 : root.selected-index + 1);
        }
    }

    // ── Labels below knob ──
    HorizontalLayout {
        x: 0;
        y: root.ks + 1px;
        width: root.width;
        height: 14px;

        for label[i] in root.labels : Rectangle {
            horizontal-stretch: 1;
            height: parent.height;

            Text {
                width: parent.width;
                height: parent.height;
                text: label;
                color: i == root.selected-index ? #ff8833 : #8090a0;
                font-size: 7px;
                font-weight: i == root.selected-index ? 700 : 400;
                letter-spacing: 0.3px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }

            TouchArea {
                mouse-cursor: pointer;
                clicked => { root.select(i); }
            }
        }
    }
}
