// Rotary selector knob — chicken-head pointer sprite, snapped to discrete positions.
// ALL option labels are always visible at fixed arc positions around the knob.
// Selected label is highlighted in orange; unselected labels are dimmed.
// Knob rotation: frame 0 = 7 o'clock (bottom-left), frame 64 = 5 o'clock (bottom-right).
export component SelectorKnob inherits Rectangle {
    in property <int> num-options;
    in property <int> selected-index;
    in property <[string]> labels;
    in property <color> text-color: #c0c8d0;
    callback select(int);

    private property <int> frame-count: 65;
    private property <int> frame-index:
        root.num-options <= 1 ? 0
        : Math.min(Math.max(Math.round(root.selected-index * (root.frame-count - 1) / (root.num-options - 1)), 0), root.frame-count - 1);
    private property <length> ks: 48px;
    private property <length> cx: root.width / 2;
    // 14px reserved at top for the 12h label
    private property <length> cy: root.ks / 2 + 14px;
    private property <length> lw: (root.width - root.ks) / 2 - 4px;

    background: transparent;

    // ── Knob sprite ──
    Rectangle {
        x: root.cx - root.ks / 2;
        y: root.cy - root.ks / 2;
        width: root.ks;
        height: root.ks;
        clip: true;

        Image {
            source: @image-url("../assets/sprites/selector-knob-strip.png");
            x: -root.frame-index * root.ks;
            y: 0;
            width: root.frame-count * root.ks;
            height: root.ks;
            image-fit: fill;
            image-rendering: smooth;
        }
    }

    // Click on knob cycles
    TouchArea {
        x: root.cx - root.ks / 2;
        y: root.cy - root.ks / 2;
        width: root.ks;
        height: root.ks;
        mouse-cursor: pointer;
        clicked => {
            root.select(root.selected-index >= root.num-options - 1 ? 0 : root.selected-index + 1);
        }
    }

    // ═══════════════════════════════════════════
    // 2 OPTIONS: bottom-left (7h), bottom-right (5h)
    // ═══════════════════════════════════════════
    if root.num-options == 2 : Rectangle {
        Text {
            x: 0;
            y: root.cy + root.ks / 2 - 2px;
            width: root.lw;
            height: 14px;
            text: root.labels.length > 0 ? root.labels[0] : "";
            color: 0 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 0 == root.selected-index ? 700 : 400;
            horizontal-alignment: right;
            overflow: elide;
        }
        Text {
            x: root.cx + root.ks / 2 + 4px;
            y: root.cy + root.ks / 2 - 2px;
            width: root.lw;
            height: 14px;
            text: root.labels.length > 1 ? root.labels[1] : "";
            color: 1 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 1 == root.selected-index ? 700 : 400;
            horizontal-alignment: left;
            overflow: elide;
        }
        TouchArea { x: 0; y: root.cy + root.ks / 2 - 2px; width: root.lw; height: 14px; mouse-cursor: pointer; clicked => { root.select(0); } }
        TouchArea { x: root.cx + root.ks / 2 + 4px; y: root.cy + root.ks / 2 - 2px; width: root.lw; height: 14px; mouse-cursor: pointer; clicked => { root.select(1); } }
    }

    // ═══════════════════════════════════════════
    // 3 OPTIONS: bottom-left (7h), top-center (12h), bottom-right (5h)
    // ═══════════════════════════════════════════
    if root.num-options == 3 : Rectangle {
        // Option 0 — bottom-left (7 o'clock)
        Text {
            x: 0;
            y: root.cy + root.ks / 2 - 2px;
            width: root.lw;
            height: 14px;
            text: root.labels.length > 0 ? root.labels[0] : "";
            color: 0 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 0 == root.selected-index ? 700 : 400;
            horizontal-alignment: right;
            overflow: elide;
        }
        // Option 1 — top-center (12 o'clock)
        Text {
            x: root.cx - 60px;
            y: 0;
            width: 120px;
            height: 14px;
            text: root.labels.length > 1 ? root.labels[1] : "";
            color: 1 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 1 == root.selected-index ? 700 : 400;
            horizontal-alignment: center;
            overflow: elide;
        }
        // Option 2 — bottom-right (5 o'clock)
        Text {
            x: root.cx + root.ks / 2 + 4px;
            y: root.cy + root.ks / 2 - 2px;
            width: root.lw;
            height: 14px;
            text: root.labels.length > 2 ? root.labels[2] : "";
            color: 2 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 2 == root.selected-index ? 700 : 400;
            horizontal-alignment: left;
            overflow: elide;
        }
        TouchArea { x: 0; y: root.cy + root.ks / 2 - 2px; width: root.lw; height: 14px; mouse-cursor: pointer; clicked => { root.select(0); } }
        TouchArea { x: root.cx - 60px; y: 0; width: 120px; height: 14px; mouse-cursor: pointer; clicked => { root.select(1); } }
        TouchArea { x: root.cx + root.ks / 2 + 4px; y: root.cy + root.ks / 2 - 2px; width: root.lw; height: 14px; mouse-cursor: pointer; clicked => { root.select(2); } }
    }

    // ═══════════════════════════════════════════
    // 4 OPTIONS: bottom-left (7h), upper-left (10h), upper-right (2h), bottom-right (5h)
    // ═══════════════════════════════════════════
    if root.num-options == 4 : Rectangle {
        // Option 0 — bottom-left (7 o'clock)
        Text {
            x: 0;
            y: root.cy + root.ks / 2 + 2px;
            width: root.lw;
            height: 14px;
            text: root.labels.length > 0 ? root.labels[0] : "";
            color: 0 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 0 == root.selected-index ? 700 : 400;
            horizontal-alignment: right;
            overflow: elide;
        }
        // Option 1 — upper-left (10 o'clock)
        Text {
            x: 0;
            y: 0;
            width: root.lw;
            height: 14px;
            text: root.labels.length > 1 ? root.labels[1] : "";
            color: 1 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 1 == root.selected-index ? 700 : 400;
            horizontal-alignment: right;
            overflow: elide;
        }
        // Option 2 — upper-right (2 o'clock)
        Text {
            x: root.cx + root.ks / 2 + 4px;
            y: 0;
            width: root.lw;
            height: 14px;
            text: root.labels.length > 2 ? root.labels[2] : "";
            color: 2 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 2 == root.selected-index ? 700 : 400;
            horizontal-alignment: left;
            overflow: elide;
        }
        // Option 3 — bottom-right (5 o'clock)
        Text {
            x: root.cx + root.ks / 2 + 4px;
            y: root.cy + root.ks / 2 + 2px;
            width: root.lw;
            height: 14px;
            text: root.labels.length > 3 ? root.labels[3] : "";
            color: 3 == root.selected-index ? #ffaa44 : root.text-color.with-alpha(0.7);
            font-size: 12px;
            font-weight: 3 == root.selected-index ? 700 : 400;
            horizontal-alignment: left;
            overflow: elide;
        }
        TouchArea { x: 0; y: root.cy + root.ks / 2 + 2px; width: root.lw; height: 14px; mouse-cursor: pointer; clicked => { root.select(0); } }
        TouchArea { x: 0; y: 0; width: root.lw; height: 14px; mouse-cursor: pointer; clicked => { root.select(1); } }
        TouchArea { x: root.cx + root.ks / 2 + 4px; y: 0; width: root.lw; height: 14px; mouse-cursor: pointer; clicked => { root.select(2); } }
        TouchArea { x: root.cx + root.ks / 2 + 4px; y: root.cy + root.ks / 2 + 2px; width: root.lw; height: 14px; mouse-cursor: pointer; clicked => { root.select(3); } }
    }
}
