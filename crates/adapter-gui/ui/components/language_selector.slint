// Icon-only language selector — same visual as HeaderIconAction
// (24x24 flat, hover overlay, tooltip below). Click toggles a dropdown
// anchored below.
//
// Lower visual weight than nearby action icons because language is a
// rarely-used preference, not a primary action.

export component LanguageSelector inherits Rectangle {
    in property <[string]> language-options;
    in property <int> selected-language-index;
    callback language-selected(int);

    width: 24px;
    height: 24px;
    background: hover-area.has-hover ? #ffffff10 : transparent;

    private property <bool> dropdown-open: false;
    private property <string> current-label:
        root.selected-language-index >= 0 && root.selected-language-index < root.language-options.length
            ? root.language-options[root.selected-language-index]
            : "";

    Image {
        x: 2px;
        y: 2px;
        width: 20px;
        height: 20px;
        source: @image-url("../assets/globe.svg");
        image-fit: contain;
        colorize: hover-area.has-hover ? #ffffff : #8a94a2;
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => {
            root.dropdown-open = !root.dropdown-open;
        }
    }

    accessible-role: combobox;
    accessible-label: @tr("accessible-language-selector");

    // Hover tooltip — shows current language while not open.
    if hover-area.has-hover && !root.dropdown-open && root.current-label != "" : Rectangle {
        x: -56px;
        y: parent.height + 4px;
        width: 136px;
        height: 24px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 1000;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.current-label;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // Dropdown anchored to the right edge so it grows leftward.
    if root.dropdown-open : Rectangle {
        x: parent.width - 200px;
        y: parent.height + 4px;
        width: 200px;
        height: list-layout.preferred-height;
        background: #2f3339;
        border-color: #4c515b;
        border-width: 1px;
        border-radius: 4px;
        z: 100;

        list-layout := VerticalLayout {
            padding: 4px;
            spacing: 2px;

            for option[i] in root.language-options : Rectangle {
                height: 30px;
                background: option-touch.has-hover ? #3b4250 : transparent;
                border-radius: 3px;

                Text {
                    x: 10px;
                    text: option;
                    color: #f4f7fb;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    width: parent.width - 20px;
                    overflow: elide;
                }

                option-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => {
                        root.dropdown-open = false;
                        root.language-selected(i);
                    }
                }
            }
        }
    }
}
