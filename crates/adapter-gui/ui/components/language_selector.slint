// Language selector with two visual modes:
//  - compact (24x24, flat) — matches HeaderIconAction (chain editor headers).
//  - default (40x40, bordered) — matches IconLauncherButton (project launcher).
// Click toggles dropdown; hover shows tooltip with current language.

export component LanguageSelector inherits Rectangle {
    in property <[string]> language-options;
    // Parallel array of language CODES ("auto", "de-DE", "zh-CN", ...) used
    // to look up the country flag SVG for each dropdown row. Same length
    // and ordering as `language-options`.
    in property <[string]> language-codes;
    in property <int> selected-language-index;
    in property <bool> compact: false;
    callback language-selected(int);

    width: root.compact ? 24px : 40px;
    height: root.compact ? 24px : 40px;
    background: root.compact
        ? (hover-area.has-hover ? #ffffff10 : transparent)
        : #2f3339;
    border-width: root.compact ? 0px : 1px;
    border-color: #4c515b;
    border-radius: root.compact ? 0px : 4px;

    private property <bool> dropdown-open: false;
    private property <length> icon-size: root.compact ? 20px : 20px;
    private property <length> icon-offset: root.compact ? 2px : 10px;
    private property <string> current-label:
        root.selected-language-index >= 0 && root.selected-language-index < root.language-options.length
            ? root.language-options[root.selected-language-index]
            : "";

    Image {
        x: root.icon-offset;
        y: root.icon-offset;
        width: root.icon-size;
        height: root.icon-size;
        source: @image-url("../assets/globe.svg");
        image-fit: contain;
        colorize: hover-area.has-hover ? #ffffff : (root.compact ? #eef2f8 : #cfd5de);
    }

    hover-area := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => {
            root.dropdown-open = !root.dropdown-open;
        }
    }

    accessible-role: combobox;
    accessible-label: @tr("accessible-language-selector");

    // Hover tooltip — shows current language while not open. Right-anchored
    // so it never overflows the window edge (the selector lives at the
    // top-right corner on every screen).
    if hover-area.has-hover && !root.dropdown-open && root.current-label != "" : Rectangle {
        x: parent.width - 136px;
        y: parent.height + 4px;
        width: 136px;
        height: 24px;
        background: #11141ad9;
        border-width: 1px;
        border-color: #3b4250;
        border-radius: 4px;
        z: 1000;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.current-label;
            color: #eef2f8;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
            // Override AppWindow's Bebas Neue so CJK/Hindi tooltips render.
            font-family: "Helvetica Neue";
        }
    }

    // Dropdown anchored to the right edge so it grows leftward.
    if root.dropdown-open : Rectangle {
        x: parent.width - 200px;
        y: parent.height + 4px;
        width: 200px;
        height: list-layout.preferred-height;
        background: #2f3339;
        border-color: #4c515b;
        border-width: 1px;
        border-radius: 4px;
        z: 1000;

        list-layout := VerticalLayout {
            padding: 4px;
            spacing: 2px;

            for option[i] in root.language-options : Rectangle {
                height: 30px;
                background: option-touch.has-hover ? #3b4250 : transparent;
                border-radius: 3px;

                // Selected indicator (✓) on the left so the user sees
                // which locale is currently active.
                Text {
                    x: 8px;
                    text: i == root.selected-language-index ? "✓" : "";
                    color: #4ad28e;
                    font-size: 13px;
                    font-weight: 700;
                    width: 16px;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    // Override the AppWindow's Bebas Neue (Latin-only display
                    // font) so glyphs render against the system fallback chain
                    // — required for CJK/Hindi names in the dropdown.
                    font-family: "Helvetica Neue";
                }

                // Country flag SVG. @image-url requires compile-time literal,
                // so we ternary-chain over the language code from
                // `language-codes[i]` instead of building the path at runtime.
                Image {
                    x: 28px;
                    y: 7px;
                    width: 24px;
                    height: 16px;
                    image-fit: contain;
                    source: i < root.language-codes.length
                        ? (root.language-codes[i] == "auto"  ? @image-url("../assets/flags/auto.svg")
                          : root.language-codes[i] == "de-DE" ? @image-url("../assets/flags/de.svg")
                          : root.language-codes[i] == "zh-CN" ? @image-url("../assets/flags/cn.svg")
                          : root.language-codes[i] == "ko-KR" ? @image-url("../assets/flags/kr.svg")
                          : root.language-codes[i] == "es-ES" ? @image-url("../assets/flags/es.svg")
                          : root.language-codes[i] == "fr-FR" ? @image-url("../assets/flags/fr.svg")
                          : root.language-codes[i] == "hi-IN" ? @image-url("../assets/flags/in.svg")
                          : root.language-codes[i] == "en-US" ? @image-url("../assets/flags/us.svg")
                          : root.language-codes[i] == "ja-JP" ? @image-url("../assets/flags/jp.svg")
                          : root.language-codes[i] == "pt-BR" ? @image-url("../assets/flags/br.svg")
                          : @image-url("../assets/flags/auto.svg"))
                        : @image-url("../assets/flags/auto.svg");
                }

                Text {
                    x: 60px;
                    text: option;
                    color: #f4f7fb;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    width: parent.width - 68px;
                    overflow: elide;
                    // Same reason as the tick above — AppWindow's default
                    // Bebas Neue lacks CJK and Devanagari glyphs.
                    font-family: "Helvetica Neue";
                }

                option-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => {
                        root.dropdown-open = false;
                        root.language-selected(i);
                    }
                }
            }
        }
    }
}
