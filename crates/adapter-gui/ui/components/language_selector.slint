// Language selector — visual identity matches IconLauncherButton /
// LauncherButton: 40px tall, #2f3339 background, #4c515b border, 4px
// radius, #f4f7fb text. Same hover tooltip pattern as IconLauncherButton.
//
// Used at the top-right of DesktopMain. The dropdown opens upward-anchored
// to the trigger so it doesn't overlap UI below.
//
// Driven from Rust by adapter_gui::SUPPORTED_LANGUAGES. The component is
// naive about which locales exist.

export component LanguageSelector inherits Rectangle {
    in property <[string]> language-options;
    in property <int> selected-language-index;
    in property <bool> compact: false;
    callback language-selected(int);

    width: compact ? 130px : 180px;
    height: 40px;
    background: #2f3339;
    border-width: 1px;
    border-color: #4c515b;
    border-radius: 4px;

    private property <bool> dropdown-open: false;
    private property <string> current-label:
        root.selected-language-index >= 0 && root.selected-language-index < root.language-options.length
            ? root.language-options[root.selected-language-index]
            : "Auto";

    Text {
        x: 12px;
        y: 0px;
        width: parent.width - 32px;
        height: parent.height;
        text: "🌐  " + root.current-label;
        color: #f4f7fb;
        horizontal-alignment: left;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 600;
        overflow: elide;
    }

    Text {
        x: parent.width - 18px;
        y: 0px;
        width: 12px;
        height: parent.height;
        text: root.dropdown-open ? "▴" : "▾";
        color: #93a1b7;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 11px;
    }

    TouchArea {
        clicked => {
            root.dropdown-open = !root.dropdown-open;
        }
        accessible-role: combobox;
        accessible-label: @tr("Idioma");
    }

    if root.dropdown-open : Rectangle {
        x: 0;
        y: parent.height + 4px;
        width: parent.width;
        height: list-layout.preferred-height;
        background: #2f3339;
        border-color: #4c515b;
        border-width: 1px;
        border-radius: 4px;
        z: 100;

        list-layout := VerticalLayout {
            padding: 4px;
            spacing: 2px;

            for option[i] in root.language-options : Rectangle {
                height: 30px;
                background: option-touch.has-hover ? #3b4250 : transparent;
                border-radius: 3px;

                Text {
                    x: 10px;
                    text: option;
                    color: #f4f7fb;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    width: parent.width - 20px;
                    overflow: elide;
                }

                option-touch := TouchArea {
                    clicked => {
                        root.dropdown-open = false;
                        root.language-selected(i);
                    }
                }
            }
        }
    }
}
