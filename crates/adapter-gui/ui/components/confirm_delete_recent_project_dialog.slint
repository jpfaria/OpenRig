// Modal dialog asking the user to confirm removal of a recent-project
// entry from the launcher list (issue #360). Mirrors the block/chain
// dialog shape; copy is per-component so each translation file stays
// self-explanatory for translators.
// Used as an overlay inside AppWindow when `show-confirm-delete-recent-project` is true.

export component ConfirmDeleteRecentProjectDialog inherits Rectangle {
    in property <string> project-name;
    callback cancel();
    callback confirm();

    background: #000000b0;
    TouchArea { }

    Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: min(root.width * 0.7, 400px);
        height: 170px;
        background: #1e1f22;
        border-radius: 10px;
        drop-shadow-blur: 16px;
        drop-shadow-offset-y: 4px;
        drop-shadow-color: #000000c0;

        VerticalLayout {
            padding: 20px;
            spacing: 12px;
            Text {
                text: @tr("title-dialog-delete-recent-project");
                font-size: 16px;
                color: #ffffff;
                font-weight: 700;
                horizontal-alignment: center;
            }
            Text {
                // Literal pt-BR source string with `{}` placeholder.
                text: @tr("Remover o projeto \"{}\" dos recentes?", root.project-name);
                font-size: 13px;
                color: #aaaaaa;
                horizontal-alignment: center;
                overflow: elide;
                wrap: no-wrap;
            }
            HorizontalLayout {
                spacing: 8px;
                Rectangle {
                    horizontal-stretch: 1;
                    height: 40px;
                    border-radius: 6px;
                    background: cancel-area.has-hover ? #444 : #2d2e32;
                    cancel-area := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.cancel(); }
                    }
                    Text {
                        text: @tr("btn-cancel");
                        font-size: 13px;
                        color: #aaaaaa;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    height: 40px;
                    border-radius: 6px;
                    background: confirm-area.has-hover ? #c0392b : #e74c3c;
                    confirm-area := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.confirm(); }
                    }
                    Text {
                        text: @tr("btn-remove");
                        font-size: 13px;
                        color: #ffffff;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
