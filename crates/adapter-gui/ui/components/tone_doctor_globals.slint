// #791 — shared state for the Tone Doctor panel: a stethoscope icon in a chain
// row seeds these and flips `open`; a single root overlay renders
// ToneDoctorPanel (so it is never clipped by the chain list). One panel open at
// a time, mirroring the DI loop's `DiPanel`.
export global ToneDoctorState {
    in-out property <bool> open;
    // window-absolute position, from the triggering icon's `absolute-position`.
    in-out property <length> x;
    in-out property <length> y;
    // routes the panel's diagnose / apply back to the right chain.
    in-out property <int> chain-index;

    // ── diagnosis result, written by Rust after an offline run ────────────
    // true while the offline ablation is running.
    in-out property <bool> running;
    // true once a diagnosis has completed at least once for the open panel.
    in-out property <bool> has-result;
    // 0 = healthy (green), 1 = warn (amber), 2 = unhealthy (red).
    in-out property <int> symptom-level;
    // e.g. "Fizz", "Mud", "Clipping", "OK".
    in-out property <string> symptom-text;
    // the guilty block's model identity, empty when healthy.
    in-out property <string> culprit-label;
    // e.g. "Presence 7.2 → 5.0", empty when there is nothing to change.
    in-out property <string> suggestion-text;
    in-out property <bool> has-suggestion;
}
