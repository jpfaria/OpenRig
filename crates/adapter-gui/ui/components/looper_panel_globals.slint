// #323 — shared state for the looper panel, mirroring the DI panel (#749):
// the loop button in a chain row seeds these and flips `open`; a single root
// overlay renders LooperPanel so it is never clipped by the chain list.
// One panel open at a time.

export global LooperPanel {
    in-out property <bool> open;
    // window-absolute position, from the triggering button's `absolute-position`.
    in-out property <length> x;
    in-out property <length> y;
    // routes every action back to the right chain.
    in-out property <int> chain-index;
    // which row has its parameter drawer open; -1 = none.
    in-out property <int> expanded-uid: -1;
}
