// #436 — Pedalboard rig screen (MOD-/Quad-Cortex-quality).
//
// The chain is rendered with the app's REAL pedal component (`BlockChip`,
// per-model thumbnail art) on a premium board background, linked by thick
// patch cables — NOT generic boxes. PURE DISPATCHER: every interaction is a
// callback; every value comes from `in` properties (no logic here).

import { Theme } from "../theme.slint";
import { BankNavItem, ChainBlockItem } from "../models.slint";
import { BlockChip } from "block_chip.slint";

component QcButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();
    accessible-role: button;
    accessible-label: root.text;
    accessible-action-default => { root.clicked(); }
    height: 30px;
    border-radius: 7px;
    border-width: 1px;
    border-color: root.active ? Theme.palette.accent-border : Theme.palette.border-strong;
    background: root.active
        ? Theme.palette.accent-end
        : ta.has-hover ? Theme.palette.card-secondary : Theme.palette.card.with-alpha(0.85);
    animate background { duration: 120ms; }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        Text {
            text: root.text;
            color: root.active ? #ffffff : Theme.palette.text-secondary;
            vertical-alignment: center;
            font-size: 12px;
            font-weight: 600;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component SceneSwitch inherits Rectangle {
    in property <int> number;
    in property <bool> active;
    callback clicked();
    accessible-role: button;
    accessible-label: "scene \{root.number}";
    accessible-action-default => { root.clicked(); }
    width: 40px;
    height: 30px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? Theme.palette.accent-border : Theme.palette.border;
    background: root.active ? Theme.palette.accent-end : Theme.palette.card.with-alpha(0.8);
    animate background, border-color { duration: 130ms; }
    Text {
        text: "\{root.number}";
        color: root.active ? #ffffff : Theme.palette.text-muted;
        font-size: 13px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    TouchArea { clicked => { root.clicked(); } }
}

// One patch-cable segment between two pedals.
component Cable inherits Rectangle {
    width: 34px;
    background: transparent;
    Rectangle {
        width: parent.width;
        height: 7px;
        y: parent.height / 2 - self.height / 2;
        border-radius: 4px;
        background: @linear-gradient(90deg, #6d3bd6 0%, #8c52ff 50%, #6d3bd6 100%);
        drop-shadow-blur: 4px;
        drop-shadow-color: #00000088;
    }
}

// Input / Output jack endpoint.
component Jack inherits Rectangle {
    in property <string> text;
    width: 58px;
    height: 64px;
    border-radius: 8px;
    background: Theme.palette.card-secondary;
    border-width: 1px;
    border-color: Theme.palette.border-strong;
    Text {
        text: root.text;
        color: Theme.palette.text-muted;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component BankSceneNavigator inherits Rectangle {
    in property <bool> project-open;
    in property <string> project-title;
    in property <[BankNavItem]> inputs;
    in property <[BankNavItem]> selected;       // 0 or 1 (focused input)
    in property <[ChainBlockItem]> chain-blocks; // pedals of the focused chain

    callback open-project();
    callback create-project();
    callback select-input(string);
    callback bank-prev(string);
    callback bank-next(string);
    callback select-scene(string, int);
    callback node-clicked(string);

    background: Theme.palette.pure-black;

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        // ── Header (kept clear of the app's global top-right chrome) ──
        Rectangle {
            height: 52px;
            border-radius: 10px;
            background: Theme.palette.card;
            border-width: 1px;
            border-color: Theme.palette.border;
            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 14px;
                for it in root.selected : HorizontalLayout {
                    spacing: 14px;
                    Text {
                        text: "\{it.active-preset}·S\{it.active-scene}";
                        color: Theme.palette.accent-border;
                        font-size: 24px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Text {
                        text: it.label != "" ? it.label : it.input;
                        color: #ffffff;
                        font-size: 17px;
                        font-weight: 650;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    QcButton { text: "◀ BANK"; clicked => { root.bank-prev(it.input); } }
                    QcButton { text: "BANK ▶"; clicked => { root.bank-next(it.input); } }
                }
                if !root.project-open : Text {
                    text: @tr("No project open");
                    color: Theme.palette.text-muted;
                    font-size: 17px;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: root.project-open ? 0.0 : 1.0; }
                QcButton { text: @tr("↻"); clicked => { root.open-project(); } }
                QcButton { text: @tr("Classic ▶"); clicked => { root.create-project(); } }
                // Right inset so we never sit under the window's global icons.
                Rectangle { width: 44px; }
            }
        }

        // ── Input tabs ───────────────────────────────────────────────
        Flickable {
            height: 34px;
            viewport-width: tabs.preferred-width;
            tabs := HorizontalLayout {
                spacing: 8px;
                for it in root.inputs : QcButton {
                    text: it.label != "" ? it.label : it.input;
                    active: it.selected;
                    clicked => { root.select-input(it.input); }
                }
            }
        }

        // ── HERO: the pedalboard ─────────────────────────────────────
        Rectangle {
            vertical-stretch: 1;
            border-radius: 12px;
            clip: true;
            Image {
                width: 100%;
                height: 100%;
                source: @image-url("../assets/launcher-stage-bg.jpg");
                image-fit: cover;
            }
            Rectangle { background: #05070bcc; } // darken for contrast

            Flickable {
                viewport-width: board.preferred-width + 48px;
                board := HorizontalLayout {
                    x: 24px;
                    spacing: 0px;
                    Jack { text: @tr("IN"); }
                    for b in root.chain-blocks : HorizontalLayout {
                        spacing: 0px;
                        Cable { }
                        TouchArea {
                            width: 104px;
                            height: 104px;
                            clicked => { root.node-clicked(b.label); }
                            BlockChip { block: b; }
                        }
                    }
                    Cable { }
                    Jack { text: @tr("OUT"); }
                }
            }
            if root.chain-blocks.length == 0 : Text {
                text: @tr("Open a project to see the pedalboard");
                color: Theme.palette.text-secondary;
                font-size: 15px;
            }
        }

        // ── Scenes (compact) ─────────────────────────────────────────
        for it in root.selected : HorizontalLayout {
            height: 32px;
            spacing: 6px;
            Text {
                text: @tr("SCENE");
                color: Theme.palette.text-muted;
                font-size: 11px;
                font-weight: 600;
                vertical-alignment: center;
            }
            SceneSwitch { number: 1; active: it.active-scene == 1; clicked => { root.select-scene(it.input, 1); } }
            SceneSwitch { number: 2; active: it.active-scene == 2; clicked => { root.select-scene(it.input, 2); } }
            SceneSwitch { number: 3; active: it.active-scene == 3; clicked => { root.select-scene(it.input, 3); } }
            SceneSwitch { number: 4; active: it.active-scene == 4; clicked => { root.select-scene(it.input, 4); } }
            SceneSwitch { number: 5; active: it.active-scene == 5; clicked => { root.select-scene(it.input, 5); } }
            SceneSwitch { number: 6; active: it.active-scene == 6; clicked => { root.select-scene(it.input, 6); } }
            SceneSwitch { number: 7; active: it.active-scene == 7; clicked => { root.select-scene(it.input, 7); } }
            SceneSwitch { number: 8; active: it.active-scene == 8; clicked => { root.select-scene(it.input, 8); } }
            Rectangle { horizontal-stretch: 1; }
        }
    }
}
