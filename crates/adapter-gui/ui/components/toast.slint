export component Toast inherits Rectangle {
    in property <string> message;
    in property <string> level: "info"; // "error", "warning", "info"
    in property <length> container-width;
    in property <length> container-height;
    callback report-error(string); // triggered when user clicks "Reportar" on an error toast

    // Visible when message is not empty
    visible: root.message != "";

    x: (root.container-width - self.width) / 2;
    y: root.container-height - 60px;
    width: Math.min(root.container-width - 40px, 500px);
    height: 40px;
    border-radius: 8px;
    background: root.level == "error" ? #dc2626cc
             : root.level == "warning" ? #d97706cc
             : #2563ebcc;

    Text {
        width: root.level == "error" ? parent.width - 110px : parent.width - 24px;
        height: parent.height;
        x: 12px;
        text: root.message;
        color: #ffffff;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
    }

    if root.level == "error" : Rectangle {
        x: parent.width - 92px;
        y: 6px;
        width: 80px;
        height: 28px;
        background: #ffffff22;
        border-width: 1px;
        border-color: #ffffff44;
        border-radius: 5px;

        Text {
            width: parent.width; height: parent.height;
            text: "Reportar";
            color: #ffffff;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 11px;
            font-weight: 700;
        }
        TouchArea {
            width: parent.width; height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.report-error(root.message); }
        }
    }
}
