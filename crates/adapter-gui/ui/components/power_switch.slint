// Sprite-based power switch (on/off).
// Vertical strip: 56×56 px, 2 frames (each 56×28). Top=off, bottom=on.
export component PowerSwitch inherits Rectangle {
    in property <bool> enabled;
    callback clicked();

    background: transparent;

    Rectangle {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        clip: true;

        Image {
            source: @image-url("../assets/sprites/power-switch.png");
            x: 0;
            y: root.enabled ? -parent.height : 0;
            width: parent.width;
            height: 2 * parent.height;
            image-fit: fill;
            image-rendering: smooth;
        }
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}
