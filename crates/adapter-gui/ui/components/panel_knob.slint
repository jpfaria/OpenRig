// Dark spherical knob with purple line indicator.
// Used in both block_panel_editor and compact_chain_view.
export component PanelKnob inherits Rectangle {
    in property <float> value;
    in property <float> min-val;
    in property <float> max-val;
    in property <float> step: 1.0;
    in property <string> path;
    callback changed(string, float);

    private property <float> current-val: root.preview-active ? root.preview-val : root.value;
    private property <float> norm: root.max-val > root.min-val
        ? Math.max(0.0, Math.min(1.0, (root.current-val - root.min-val) / (root.max-val - root.min-val)))
        : 0.0;
    private property <float> drag-y0: 0;
    private property <float> drag-val0: 0;
    private property <bool> preview-active: false;
    private property <float> preview-val: 0;
    private property <angle> indicator-angle: 225deg + root.norm * 270deg;
    private property <length> ks: Math.min(root.width, root.height);
    private property <length> cx: root.width / 2;
    private property <length> cy: root.height / 2;
    // Trig as float (for Path coordinates)
    private property <float> sin-a: Math.sin(root.indicator-angle);
    private property <float> cos-a: Math.cos(root.indicator-angle);
    private property <float> ks-f: root.ks / 1px;
    private property <float> half: root.ks-f / 2;
    private property <float> r-inner: root.half - 18;
    private property <float> r-outer: root.half - 4;

    background: transparent;

    // ── Shadow (depth) ──
    Rectangle {
        x: root.cx - root.ks / 2 + 1px;
        y: root.cy - root.ks / 2 + 2px;
        width: root.ks;
        height: root.ks;
        border-radius: root.ks / 2;
        background: #00000044;
    }

    // ── Knob body — dark sphere with top-lit gradient ──
    Rectangle {
        x: root.cx - root.ks / 2;
        y: root.cy - root.ks / 2;
        width: root.ks;
        height: root.ks;
        border-radius: root.ks / 2;
        background: @linear-gradient(180deg, #302e36 0%, #1a181e 40%, #0e0d10 100%);
        border-width: 1px;
        border-color: @linear-gradient(180deg, #44404c 0%, #1a181e 50%, #0a090c 100%);
    }

    // ── Inner body (slight recess for depth) ──
    Rectangle {
        property <length> inner: root.ks - 4px;
        x: root.cx - self.inner / 2;
        y: root.cy - self.inner / 2;
        width: self.inner;
        height: self.inner;
        border-radius: self.inner / 2;
        background: @linear-gradient(170deg, #28262e 0%, #151318 45%, #0c0b0e 100%);
    }

    // ── Top specular highlight (light from above) ──
    Rectangle {
        property <length> hl: root.ks * 0.7;
        x: root.cx - self.hl / 2;
        y: root.cy - root.ks / 2 + 2px;
        width: self.hl;
        height: self.hl * 0.35;
        border-radius: self.hl / 2;
        background: @linear-gradient(180deg, #ffffff18 0%, #ffffff00 100%);
    }

    // ── Purple indicator line (real line via Path) ──
    Path {
        x: root.cx - root.ks / 2;
        y: root.cy - root.ks / 2;
        width: root.ks;
        height: root.ks;
        viewbox-width: root.ks-f;
        viewbox-height: root.ks-f;
        stroke: ta.pressed ? #cc99ff : ta.has-hover ? #aa77ee : #8855cc;
        stroke-width: 2.5px;

        MoveTo {
            x: root.half + root.sin-a * root.r-inner;
            y: root.half - root.cos-a * root.r-inner;
        }
        LineTo {
            x: root.half + root.sin-a * root.r-outer;
            y: root.half - root.cos-a * root.r-outer;
        }
    }

    // ── Value text (centered in knob, subtle) ──
    Text {
        x: root.cx - root.ks / 2;
        y: root.cy - root.ks / 2;
        width: root.ks;
        height: root.ks;
        text: root.step >= 1.0
            ? Math.round(root.current-val) + ""
            : Math.round(root.current-val * 10) / 10 + "";
        color: ta.pressed ? #cccccc : ta.has-hover ? #aaaaaa : #777777;
        font-family: "Bebas Neue";
        font-size: 10px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // ── Touch/drag ──
    ta := TouchArea {
        mouse-cursor: ta.pressed ? none : ns-resize;

        pointer-event(ev) => {
            if ev.kind == PointerEventKind.down {
                root.drag-y0 = ta.mouse-y / 1px;
                root.drag-val0 = root.value;
                root.preview-active = true;
                root.preview-val = root.value;
            }
            if ev.kind == PointerEventKind.up {
                if root.preview-active {
                    root.changed(root.path, root.preview-val);
                    root.preview-active = false;
                }
            }
        }

        moved => {
            if ta.pressed {
                let delta = root.drag-y0 - ta.mouse-y / 1px;
                let range = root.max-val - root.min-val;
                let raw = root.drag-val0 + delta * range / 120.0;
                let clamped = raw < root.min-val ? root.min-val : (raw > root.max-val ? root.max-val : raw);
                let stepped = root.step > 0.0 ? Math.round(clamped / root.step) * root.step : clamped;
                root.preview-val = stepped;
            }
        }
    }
}
