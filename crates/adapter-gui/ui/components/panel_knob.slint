// Dark matte knob with purple line indicator — inspired by pro audio plugin UIs.
// Used in both block_panel_editor and compact_chain_view.
export component PanelKnob inherits Rectangle {
    in property <float> value;
    in property <float> min-val;
    in property <float> max-val;
    in property <float> step: 1.0;
    in property <string> path;
    callback changed(string, float);

    // Current displayed value (preview during drag, actual otherwise)
    private property <float> current-val: root.preview-active ? root.preview-val : root.value;
    // Normalized 0..1 — always uses (val - min) / (max - min)
    private property <float> norm: root.max-val > root.min-val
        ? Math.max(0.0, Math.min(1.0, (root.current-val - root.min-val) / (root.max-val - root.min-val)))
        : 0.0;
    private property <float> drag-y0: 0;
    private property <float> drag-val0: 0;
    private property <bool> preview-active: false;
    private property <float> preview-val: 0;
    // Angle: 225deg (min, 7:30) → 495deg (max, 4:30) = 270deg arc
    private property <angle> indicator-angle: 225deg + root.norm * 270deg;
    private property <length> ks: Math.min(root.width, root.height);
    private property <length> cx: root.width / 2;
    private property <length> cy: root.height / 2;

    background: transparent;

    // ── Subtle drop shadow ──
    Rectangle {
        x: root.cx - root.ks / 2 + 1px;
        y: root.cy - root.ks / 2 + 1.5px;
        width: root.ks;
        height: root.ks;
        border-radius: root.ks / 2;
        background: #00000040;
    }

    // ── Outer edge ring (subtle rim light) ──
    Rectangle {
        x: root.cx - root.ks / 2;
        y: root.cy - root.ks / 2;
        width: root.ks;
        height: root.ks;
        border-radius: root.ks / 2;
        background: @linear-gradient(155deg, #2e2e2e 0%, #0e0e0e 50%, #252525 100%);
        border-width: 0.5px;
        border-color: #3a3a3a;
    }

    // ── Knob body (dark matte with subtle 3D) ──
    Rectangle {
        property <length> body: root.ks - 4px;
        x: root.cx - self.body / 2;
        y: root.cy - self.body / 2;
        width: self.body;
        height: self.body;
        border-radius: self.body / 2;
        background: @linear-gradient(145deg, #2a2a2e 0%, #141416 50%, #1e1e22 100%);
        border-width: 0.5px;
        border-color: ta.pressed ? #7755cc44 : ta.has-hover ? #55448844 : #08080800;
    }

    // ── Top-left specular highlight ──
    Rectangle {
        property <length> hl: root.ks * 0.55;
        x: root.cx - self.hl / 2 - 3px;
        y: root.cy - root.ks / 2 + 3px;
        width: self.hl;
        height: self.hl * 0.4;
        border-radius: self.hl / 2;
        background: @linear-gradient(180deg, #ffffff0d 0%, #ffffff00 100%);
    }

    // ── Purple indicator line (7 dots tightly spaced = continuous line) ──
    Rectangle {
        property <length> r: root.ks / 2 - 5px;
        x: root.cx + Math.sin(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        y: root.cy - Math.cos(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        width: 3px; height: 3px; border-radius: 1.5px;
        background: ta.pressed ? #bb88ff : #9966dd;
    }
    Rectangle {
        property <length> r: root.ks / 2 - 8px;
        x: root.cx + Math.sin(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        y: root.cy - Math.cos(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        width: 3px; height: 3px; border-radius: 1.5px;
        background: ta.pressed ? #bb88ff : #9966dd;
    }
    Rectangle {
        property <length> r: root.ks / 2 - 11px;
        x: root.cx + Math.sin(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        y: root.cy - Math.cos(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        width: 3px; height: 3px; border-radius: 1.5px;
        background: ta.pressed ? #bb88ffdd : #9966dddd;
    }
    Rectangle {
        property <length> r: root.ks / 2 - 14px;
        x: root.cx + Math.sin(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        y: root.cy - Math.cos(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        width: 3px; height: 3px; border-radius: 1.5px;
        background: ta.pressed ? #bb88ffcc : #9966ddcc;
    }
    Rectangle {
        property <length> r: root.ks / 2 - 17px;
        x: root.cx + Math.sin(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        y: root.cy - Math.cos(root.indicator-angle) * (self.r / 1px) * 1px - 1.5px;
        width: 3px; height: 3px; border-radius: 1.5px;
        background: ta.pressed ? #bb88ffbb : #9966ddbb;
    }
    Rectangle {
        property <length> r: root.ks / 2 - 20px;
        x: root.cx + Math.sin(root.indicator-angle) * (self.r / 1px) * 1px - 1px;
        y: root.cy - Math.cos(root.indicator-angle) * (self.r / 1px) * 1px - 1px;
        width: 2px; height: 2px; border-radius: 1px;
        background: ta.pressed ? #bb88ff99 : #9966dd99;
    }

    // ── Value text (center, subtle) ──
    Text {
        x: root.cx - root.ks / 2;
        y: root.cy - root.ks / 2;
        width: root.ks;
        height: root.ks;
        text: root.step >= 1.0
            ? Math.round(root.current-val) + ""
            : Math.round(root.current-val * 10) / 10 + "";
        color: ta.pressed ? #dddddd : ta.has-hover ? #bbbbbb : #888888;
        font-family: "Bebas Neue";
        font-size: 10px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // ── Touch/drag interaction ──
    ta := TouchArea {
        mouse-cursor: ta.pressed ? none : ns-resize;

        pointer-event(ev) => {
            if ev.kind == PointerEventKind.down {
                root.drag-y0 = ta.mouse-y / 1px;
                root.drag-val0 = root.value;
                root.preview-active = true;
                root.preview-val = root.value;
            }
            if ev.kind == PointerEventKind.up {
                if root.preview-active {
                    root.changed(root.path, root.preview-val);
                    root.preview-active = false;
                }
            }
        }

        moved => {
            if ta.pressed {
                let delta = root.drag-y0 - ta.mouse-y / 1px;
                let range = root.max-val - root.min-val;
                let raw = root.drag-val0 + delta * range / 120.0;
                let clamped = raw < root.min-val ? root.min-val : (raw > root.max-val ? root.max-val : raw);
                let stepped = root.step > 0.0 ? Math.round(clamped / root.step) * root.step : clamped;
                root.preview-val = stepped;
            }
        }
    }
}
