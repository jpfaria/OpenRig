// Shared dial knob — dark circle, dot indicator on edge, value in center.
// Used in both block_panel_editor and compact_chain_view.
export component PanelKnob inherits Rectangle {
    in property <float> value;
    in property <float> min-val;
    in property <float> max-val;
    in property <float> step: 1.0;
    in property <string> path;
    callback changed(string, float);

    private property <float> norm: root.preview-active ? (root.preview-val - root.min-val) / (root.max-val - root.min-val) : root.value / 100.0;
    private property <float> drag-y0: 0;
    private property <float> drag-val0: 0;
    private property <bool> preview-active: false;
    private property <float> preview-val: 0;
    // Angle: 225deg (min, 7:30) -> 495deg (max, 4:30)
    private property <angle> dot-angle: 225deg + root.norm * 270deg;
    private property <length> knob-size: Math.min(root.width, root.height);
    private property <length> orbit: root.knob-size / 2 - 6px;

    background: transparent;

    // Dark circle base
    Rectangle {
        x: (parent.width - root.knob-size) / 2;
        y: (parent.height - root.knob-size) / 2;
        width: root.knob-size;
        height: root.knob-size;
        border-radius: root.knob-size / 2;
        background: #111;
        border-width: ta.pressed ? 2.5px : ta.has-hover ? 2px : 1.5px;
        border-color: ta.pressed ? #6688ff : ta.has-hover ? #4466bb : #333;
    }

    // Dot indicator on circumference
    Rectangle {
        x: parent.width / 2 + Math.sin(root.dot-angle) * (root.orbit / 1px) * 1px - 4px;
        y: parent.height / 2 - Math.cos(root.dot-angle) * (root.orbit / 1px) * 1px - 4px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: ta.pressed ? #ffffff : ta.has-hover ? #ddeeff : #aabbdd;
    }

    // Value in center
    Text {
        x: (parent.width - root.knob-size) / 2;
        y: (parent.height - root.knob-size) / 2;
        width: root.knob-size;
        height: root.knob-size;
        text: root.preview-active
            ? (root.step >= 1.0
                ? Math.round(root.preview-val) + ""
                : Math.round(root.preview-val * 10) / 10 + "")
            : (root.step >= 1.0
                ? Math.round(root.value) + ""
                : Math.round(root.value * 10) / 10 + "");
        color: ta.pressed ? #ffffff : ta.has-hover ? #ddeeff : #ccdde8;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        mouse-cursor: ta.pressed ? none : ns-resize;

        pointer-event(ev) => {
            if ev.kind == PointerEventKind.down {
                root.drag-y0 = ta.mouse-y / 1px;
                root.drag-val0 = root.value;
                root.preview-active = true;
                root.preview-val = root.value;
            }
            if ev.kind == PointerEventKind.up {
                if root.preview-active {
                    root.changed(root.path, root.preview-val);
                    root.preview-active = false;
                }
            }
        }

        moved => {
            if ta.pressed {
                let delta = root.drag-y0 - ta.mouse-y / 1px;
                let range = root.max-val - root.min-val;
                let raw = root.drag-val0 + delta * range / 120.0;
                let clamped = raw < root.min-val ? root.min-val : (raw > root.max-val ? root.max-val : raw);
                let stepped = root.step > 0.0 ? Math.round(clamped / root.step) * root.step : clamped;
                root.preview-val = stepped;
            }
        }
    }
}
