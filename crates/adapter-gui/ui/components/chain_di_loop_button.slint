// #614 / #749 — per-chain virtual DI loop control. The source picker is the
// ONE shared `Select` (identical to the preset bank select: a field showing the
// current source + caret that opens a search + list dropdown). Search is backed
// by the `DiSourcePicker` global (Rust filter), mirroring `PresetPicker`.
// A separate header PLAY/STOP button (proven by the headless interaction test)
// sits to the right of the field once a source is selected.
//
// Callbacks forwarded up: di-loop-source-selected / di-loop-choose-file /
// di-loop-play / di-loop-stop.

import { Select } from "select.slint";
import { DiSourcePicker } from "di_source_picker_globals.slint";

export component ChainDiLoopButton inherits Rectangle {
    in property <bool> playing: false;
    in property <[string]> sources: [];
    in property <int> selected-index: -1;

    callback di-loop-source-selected(string);
    callback di-loop-choose-file();
    callback di-loop-play();
    callback di-loop-stop();

    private property <bool> has-selection:
        root.selected-index >= 0 && root.selected-index < root.sources.length;
    private property <string> selected-source:
        root.has-selection ? root.sources[root.selected-index] : "";

    width: 212px;
    height: 30px;

    // ── source select (the shared component) ──────────────────────────────
    Select {
        x: 0;
        y: 0;
        width: 176px;
        field-icon: @image-url("../assets/headphones.svg");
        field-icon-active: root.playing;
        field-label: root.selected-source;
        field-font-size: 14px;
        field-font-weight: 700;
        active-key: root.selected-source;
        options: DiSourcePicker.options;
        search <=> DiSourcePicker.search;
        popup-x: 0px;
        popup-width: 380px;
        opened => {
            DiSourcePicker.open(root.sources);
        }
        query-changed(q) => {
            DiSourcePicker.query-changed(q);
        }
        picked(key) => {
            if key == "Choose file…" {
                root.di-loop-choose-file();
            } else {
                root.di-loop-source-selected(key);
            }
        }
    }

    // ── PLAY / STOP (right of the field, only once a source is selected) ───
    if root.has-selection : Rectangle {
        x: 184px;
        width: 28px;
        height: 28px;
        y: 1px;
        border-radius: 5px;
        background: root.playing ? #6e8aff28
                    : play-ta.has-hover ? #ffffff10
                    : transparent;
        animate background { duration: 150ms; }

        Image {
            x: 4px;
            y: 4px;
            width: 20px;
            height: 20px;
            source: root.playing
                ? @image-url("../assets/stop.svg")
                : @image-url("../assets/play.svg");
            image-fit: contain;
            colorize: root.playing
                ? #f87171
                : play-ta.has-hover ? #ffffff : #8a94a2;
            animate colorize { duration: 100ms; }
        }

        play-ta := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                if root.playing {
                    root.di-loop-stop();
                } else {
                    root.di-loop-play();
                }
            }
        }
        accessible-role: button;
        accessible-label: root.playing ? @tr("di-loop-stop-label") : @tr("di-loop-play-label");
    }
}
