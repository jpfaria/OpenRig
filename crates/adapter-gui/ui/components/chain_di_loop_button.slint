// #614 / #749 — per-chain virtual DI loop control.
//
// Two header controls, both reusing app-wide building blocks:
//   * the source picker is the shared `Select` component (#749 — one select for
//     the whole app, parameters only); the fone icon is its trigger and the
//     dropdown is identical to the preset select. Picking a source dispatches it
//     and closes the dropdown (Select's proven behaviour).
//   * PLAY / STOP — a separate header button to the LEFT of the fone, shown once
//     a source is selected. It lives in the main window (not the popup), so its
//     click IS covered by a headless interaction test
//     (`issue_749_di_loop_popup_interaction.rs`).
//
// ## Callbacks (forwarded up to ChainRow / project_chains / AppWindow)
//   di-loop-source-selected(source) / di-loop-choose-file / di-loop-play / di-loop-stop

import { Select } from "select.slint";

export component ChainDiLoopButton inherits Rectangle {
    in property <bool> playing: false;
    in property <[string]> sources: [];
    in property <int> selected-index: -1;

    callback di-loop-source-selected(string);
    callback di-loop-choose-file();
    callback di-loop-play();
    callback di-loop-stop();

    private property <bool> has-selection:
        root.selected-index >= 0 && root.selected-index < root.sources.length;

    // fone (x:32) + play slot (x:0) — fixed width so the cluster never reflows.
    width: 60px;
    height: 28px;

    // ── PLAY / STOP (left, only once a source is selected) ────────────────
    if root.has-selection : Rectangle {
        x: 0;
        width: 28px;
        height: 28px;
        border-radius: 5px;
        background: root.playing ? #6e8aff28
                    : play-ta.has-hover ? #ffffff10
                    : transparent;
        animate background { duration: 150ms; }

        Image {
            x: 4px;
            y: 4px;
            width: 20px;
            height: 20px;
            source: root.playing
                ? @image-url("../assets/stop.svg")
                : @image-url("../assets/play.svg");
            image-fit: contain;
            colorize: root.playing
                ? #f87171
                : play-ta.has-hover ? #ffffff : #8a94a2;
            animate colorize { duration: 100ms; }
        }

        play-ta := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                if root.playing {
                    root.di-loop-stop();
                } else {
                    root.di-loop-play();
                }
            }
        }
        accessible-role: button;
        accessible-label: root.playing ? @tr("di-loop-stop-label") : @tr("di-loop-play-label");
    }

    // ── FONE = the shared Select's trigger ────────────────────────────────
    Select {
        x: 32px;
        y: 0;
        trigger-icon: @image-url("../assets/headphones.svg");
        icon-active: root.playing;
        options: root.sources;
        active-index: root.selected-index;
        // Anchor the dropdown's right edge at the fone (like the old popup).
        popup-x: -352px;
        popup-width: 380px;
        picked(src) => {
            if src == "Choose file…" {
                root.di-loop-choose-file();
            } else {
                root.di-loop-source-selected(src);
            }
        }
    }
    accessible-role: button;
    accessible-label: @tr("di-loop-button-label");
}
