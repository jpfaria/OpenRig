// #614 / #749 — the DI loop trigger in a chain header: just the fone icon.
// Clicking it opens the DI panel (a janela with a select + play) at the window
// root via the `DiPanel` global, seeded with this chain's data and the fone's
// absolute position. The panel itself (DiLoopPanel) lives in app-window's root
// overlay so it is never clipped by the chain list.

import { DiPanel } from "di_panel_globals.slint";

export component ChainDiLoopButton inherits Rectangle {
    in property <bool> playing: false;
    in property <[string]> sources: [];
    in property <int> selected-index: -1;
    in property <int> chain-index;

    width: 28px;
    height: 28px;
    border-radius: 5px;
    background: root.playing ? #6e8aff28
                : ta.has-hover ? #ffffff10
                : transparent;
    animate background { duration: 150ms; }

    Image {
        x: 5px;
        y: 5px;
        width: 18px;
        height: 18px;
        source: @image-url("../assets/headphones.svg");
        image-fit: contain;
        colorize: root.playing ? #6e8aff
                  : ta.has-hover ? #ffffff
                  : #8a94a2;
        animate colorize { duration: 150ms; }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            DiPanel.chain-index = root.chain-index;
            DiPanel.sources = root.sources;
            DiPanel.selected-index = root.selected-index;
            DiPanel.playing = root.playing;
            // Open below the fone, the panel's right edge near it.
            DiPanel.x = root.absolute-position.x - 332px;
            DiPanel.y = root.absolute-position.y + 32px;
            DiPanel.open = true;
        }
    }

    accessible-role: button;
    accessible-label: @tr("di-loop-button-label");
}
