// #614 — per-chain virtual DI loop control (icon + popup with source
// selector + play/stop). Visually paired with ChainVolumeButton: same
// 28×28 px touch target, same icon-hover colouring.
//
// #749: the source picker is an INLINE scrollable list, NOT a std-widgets
// `ComboBox`. A ComboBox opens its dropdown as a SEPARATE top-level
// PopupWindow; Slint only keeps one PopupWindow open at a time, so opening
// the dropdown immediately closed THIS popup — the user could never keep a
// source selected nor reach the play button. The inline list lives inside
// this popup (clicks count as "inside", so `close-on-click-outside` does not
// fire), mirroring `model_select_with_search` / `preset_select`. Picking a
// source keeps the popup open so the user can press play in the same step.
//
// ## Callbacks (all forwarded up to ChainRow / project_chains / AppWindow)
//   di-loop-source-selected(source: string) — user picked a list entry that
//       is NOT the "Choose file…" sentinel. Rust resolves it via
//       `parse_di_loop_source` and dispatches `SetChainDiLoopSource`.
//   di-loop-choose-file                     — user picked "Choose file…".
//       Rust opens the file picker and, on a result, dispatches the command.
//   di-loop-play                            — user pressed ▶. Rust dispatches
//       `SetChainDiLoopEnabled { enabled: true }`.
//   di-loop-stop                            — user pressed ■. Rust dispatches
//       `SetChainDiLoopEnabled { enabled: false }`.

import { Theme } from "../theme.slint";

export component ChainDiLoopButton inherits Rectangle {
    in property <bool> playing: false;
    in property <[string]> sources: [];
    // #661: index of the currently loaded source within `sources`, or -1 for
    // none. Highlights the active row so the popup shows what is loaded/playing.
    in property <int> selected-index: -1;

    callback di-loop-source-selected(string);
    callback di-loop-choose-file();
    callback di-loop-play();
    callback di-loop-stop();

    width: 28px;
    height: 28px;
    border-radius: 5px;
    // Highlight the icon in blue when the loop is playing so the user can
    // glance at the chain tile and know the DI is active.
    background: root.playing ? #6e8aff28
                : ta.has-hover ? #ffffff10
                : transparent;
    animate background { duration: 150ms; }

    Image {
        x: 5px;
        y: 5px;
        width: 18px;
        height: 18px;
        source: @image-url("../assets/headphones.svg");
        image-fit: contain;
        colorize: root.playing ? #6e8aff
                  : ta.has-hover ? #ffffff
                  : #8a94a2;
        animate colorize { duration: 150ms; }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { pop.show(); }
    }

    accessible-role: button;
    accessible-label: @tr("di-loop-button-label");

    pop := PopupWindow {
        // Opens below and to the left of the button (which sits on the right
        // edge of the chain header) so it stays within the row and does not
        // overlap the volume popup. #661: widened so long bundled source ids
        // (e.g. "phil-STRATO-barao_vermelho-pro_dia_nascer_feliz") are legible.
        x: -352px;
        y: 32px;
        width: 380px;
        height: 236px;
        // #749: an inline list (below) keeps every click inside the popup, so
        // close-on-click-outside dismisses ONLY on a click elsewhere — never on
        // a source pick or a play press.
        close-policy: close-on-click-outside;

        Rectangle {
            width: 380px;
            height: 236px;
            border-radius: 8px;
            background: #11141af2;
            border-width: 1px;
            border-color: #3b4250;
            clip: true;

            // ── header: play / stop on the right ──────────────────────────
            play-btn := Rectangle {
                x: 344px;
                y: 8px;
                width: 28px;
                height: 28px;
                border-radius: 5px;
                background: play-ta.has-hover ? #ffffff18 : transparent;
                animate background { duration: 150ms; }

                Image {
                    x: 4px;
                    y: 4px;
                    width: 20px;
                    height: 20px;
                    source: root.playing
                        ? @image-url("../assets/stop.svg")
                        : @image-url("../assets/play.svg");
                    image-fit: contain;
                    colorize: root.playing
                        ? #f87171
                        : play-ta.has-hover ? #ffffff : #8a94a2;
                    animate colorize { duration: 100ms; }
                }

                play-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        if root.playing {
                            root.di-loop-stop();
                        } else {
                            root.di-loop-play();
                        }
                    }
                }
                accessible-role: button;
                accessible-label: root.playing ? @tr("di-loop-stop-label") : @tr("di-loop-play-label");
            }

            // Separator under the header.
            Rectangle {
                x: 8px;
                y: 44px;
                width: parent.width - 16px;
                height: 1px;
                background: #2a3040;
            }

            // ── inline scrollable source list ─────────────────────────────
            if root.sources.length > 0 : Flickable {
                x: 0;
                y: 50px;
                width: parent.width;
                height: parent.height - 58px;
                viewport-width: self.width;
                viewport-height: root.sources.length * 34px + 8px;

                for src[i] in root.sources : Rectangle {
                    x: 6px;
                    y: 4px + i * 34px;
                    width: parent.width - 12px;
                    height: 32px;
                    border-radius: 5px;
                    background: i == root.selected-index
                        ? #2a3050
                        : row-ta.has-hover ? #ffffff10 : transparent;
                    animate background { duration: 100ms; }

                    Text {
                        x: 12px;
                        y: 0;
                        width: parent.width - 24px;
                        height: parent.height;
                        text: src;
                        color: i == root.selected-index ? #8aa0ff : #b0bce0;
                        font-size: 17px;
                        font-weight: i == root.selected-index ? 700 : 400;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    row-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            // The popup stays open (no `pop.close()`) so the
                            // user can press play right after picking.
                            if src == "Choose file…" {
                                root.di-loop-choose-file();
                            } else {
                                root.di-loop-source-selected(src);
                            }
                        }
                    }
                    accessible-role: button;
                    accessible-label: src;
                }
            }
        }
    }
}
