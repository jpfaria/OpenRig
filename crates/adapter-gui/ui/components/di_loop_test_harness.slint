// #749 TEST-ONLY harness: hosts DiLoopPanel in a real Window so the headless
// interaction tests (i-slint-backend-testing) can dispatch real pointer events
// at the select field, the option rows, and the play button — all INLINE (the
// reason the panel isn't a PopupWindow). Imported by app-window.slint purely so
// slint-build emits the Rust type; never shown in the running app.
import { DiLoopPanel } from "di_loop_panel.slint";

export component DiLoopHarness inherits Window {
    width: 600px;
    height: 520px;
    in property <[string]> sources;
    in property <int> selected-index: -1;
    in property <bool> playing: false;
    callback source-picked(int, string);
    callback choose-file();
    callback play();
    callback stop();

    DiLoopPanel {
        x: 20px;
        y: 20px;
        sources: root.sources;
        selected-index: root.selected-index;
        playing: root.playing;
        source-picked(i, s) => { root.source-picked(i, s); }
        choose-file => { root.choose-file(); }
        play => { root.play(); }
        stop => { root.stop(); }
    }
}
