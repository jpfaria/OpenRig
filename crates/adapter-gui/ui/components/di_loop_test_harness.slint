// #749 TEST-ONLY harness: hosts ChainDiLoopButton in a real Window so the
// headless interaction tests (i-slint-backend-testing) can open its popup and
// dispatch real pointer events at the source rows / play button. Imported by
// app-window.slint purely so slint-build emits the Rust type; it is never
// shown in the running app.
import { ChainDiLoopButton } from "chain_di_loop_button.slint";

export component DiLoopHarness inherits Window {
    width: 800px;
    height: 400px;
    in property <[string]> sources;
    in property <int> selected-index: -1;
    in property <bool> playing: false;
    callback source-selected(string);
    callback choose-file();
    callback play();
    callback stop();

    di := ChainDiLoopButton {
        x: 740px;
        y: 16px;
        sources: root.sources;
        selected-index: root.selected-index;
        playing: root.playing;
        di-loop-source-selected(s) => { root.source-selected(s); }
        di-loop-choose-file => { root.choose-file(); }
        di-loop-play => { root.play(); }
        di-loop-stop => { root.stop(); }
    }
}
