// Shared state + actions for the chain DI loop source dropdown (the shared
// `Select` component), issue #749. Only one DI source dropdown popup is open at
// a time (PopupWindow closes on click-outside), so a single global backs
// whichever picker is currently open — no per-chain-row filtered model, which
// would otherwise hit the in-place mutation dance of #537.
//
// Rust owns the filter logic (Slint has no string `contains`): `open` caches
// the picker's full source list and publishes `options` (all rows); each
// keystroke fires `query-changed`, and Rust republishes `options` filtered.
// DI sources are plain strings, so each `SelectOption` carries the source
// string in both `key` and `label`.
import { SelectOption } from "../models.slint";

export global DiSourcePicker {
    // Filtered rows for the currently-open dropdown. Each `key` and `label`
    // is the DI source string itself.
    in property <[SelectOption]> options;
    // Two-way bound to the search field's text so Rust can reset it on open.
    in-out property <string> search;

    // Fired when a dropdown opens, carrying that picker's full (unfiltered)
    // source list. Rust caches it and publishes `options` with every row.
    callback open([string]);
    // Fired on every keystroke in the search field.
    callback query-changed(string);
}
