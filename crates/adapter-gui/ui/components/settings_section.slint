// Settings section — flat, macOS-Preferences style. No card chrome,
// no scope badge (the tab header already names the scope). The title
// row doubles as an accordion toggle; collapsed sections render only
// the title row so a tab with many sections fits in a small window.

export enum SettingsScope { system, project }

export component SettingsSection inherits Rectangle {
    // `scope` is kept in the API surface so existing call sites keep
    // compiling; it is no longer visualised.
    in property <SettingsScope> scope: SettingsScope.system;
    in property <string> title;

    in-out property <bool> expanded: true;

    background: transparent;

    VerticalLayout {
        spacing: 0px;

        // Header row: uppercase tracked label + chevron, full-width
        // hit target. macOS-style settings header — quiet but legible.
        // The wrapping Rectangle provides the animated hover background.
        Rectangle {
            height: 32px;
            border-radius: 8px;
            background: header-ta.has-hover ? #1e2229 : transparent;
            animate background { duration: 200ms; }

            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 8px;
                alignment: stretch;

                Text {
                    text: root.title;
                    color: #c5cdd9;
                    font-size: 11px;
                    font-weight: 700;
                    letter-spacing: 0.8px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Image {
                    width: 10px;
                    height: 10px;
                    y: (parent.height - self.height) / 2;
                    source: root.expanded
                        ? @image-url("../assets/arrow-down.svg")
                        : @image-url("../assets/arrow-right.svg");
                    colorize: #6b7786;
                }
            }

            header-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.expanded = !root.expanded; }
            }
        }

        // Hairline separator under the header.
        Rectangle {
            background: #25292f;
            height: 1px;
        }

        // Body — collapses to 0 height when not expanded. Slint forbids
        // `@children` inside `if`, so we toggle visibility + height.
        body := VerticalLayout {
            padding-top: 12px;
            padding-bottom: 8px;
            spacing: 8px;
            visible: root.expanded;
            height: root.expanded ? self.preferred-height : 0px;

            @children
        }
    }
}
