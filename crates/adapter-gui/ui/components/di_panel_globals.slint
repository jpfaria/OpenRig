// #749 — shared state for the DI loop panel. The fone in a chain row sets these
// and flips `open`; a single overlay at the window root renders `DiLoopPanel`
// (so it is never clipped by the chain list). Only one panel is open at a time.
export global DiPanel {
    in-out property <bool> open;
    // Absolute position (window coords) where the panel should appear — set
    // from the triggering fone's absolute-position.
    in-out property <length> x;
    in-out property <length> y;
    // Which chain the open panel acts on, so the root overlay can route
    // pick/play/stop back to the right chain.
    in-out property <int> chain-index;
    // Live data mirrored from that chain (kept fresh by the meter poll while
    // the panel is open).
    in-out property <[string]> sources;
    in-out property <int> selected-index;
    in-out property <bool> playing;
}
