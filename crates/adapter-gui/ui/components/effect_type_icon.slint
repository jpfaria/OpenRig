// Single source of truth for effect type → icon mapping.
// Use this component everywhere instead of duplicating the ternary chain.

export component EffectTypeIcon inherits Rectangle {
    in property <string> icon-kind;
    in property <color> tint: #ffffff;
    // When true, always use flat colorized SVG (e.g. block type selector).
    // When false (default), photos are used for input/output/insert/vst3 (chain view).
    in property <bool> force-flat: false;

    background: transparent;

    if !root.force-flat && root.icon-kind == "input" : Image {
        width: 100%; height: 100%;
        source: @image-url("../assets/connector-input.png");
        image-fit: contain;
    }

    if !root.force-flat && root.icon-kind == "output" : Image {
        width: 100%; height: 100%;
        source: @image-url("../assets/connector-output.png");
        image-fit: contain;
    }

    if !root.force-flat && root.icon-kind == "insert" : Image {
        width: 100%; height: 100%;
        source: @image-url("../assets/insert-pedalboard.png");
        image-fit: contain;
    }

    if !root.force-flat && root.icon-kind == "vst3" : Image {
        width: 100%; height: 100%;
        source: @image-url("../assets/vst3-pedal.png");
        image-fit: contain;
    }

    // Flat colorized SVG: used for all types when force-flat=true,
    // and for types without dedicated photos when force-flat=false.
    if root.force-flat || (root.icon-kind != "input" && root.icon-kind != "output" && root.icon-kind != "insert" && root.icon-kind != "vst3") : Image {
        width: 100%;
        height: 100%;
        source: root.icon-kind == "vst3"         ? @image-url("../assets/vst3-plugin.svg")
            : root.icon-kind == "input"          ? @image-url("../assets/input.svg")
            : root.icon-kind == "output"         ? @image-url("../assets/output.svg")
            : root.icon-kind == "insert"         ? @image-url("../assets/insert_loop.svg")
            : root.icon-kind == "preamp"         ? @image-url("../assets/amp-head.svg")
            : root.icon-kind == "amp"            ? @image-url("../assets/amp-combo.svg")
            : root.icon-kind == "cab"            ? @image-url("../assets/cab.svg")
            : root.icon-kind == "body"           ? @image-url("../assets/body.svg")
            : root.icon-kind == "ir"             ? @image-url("../assets/ir-loader.svg")
            : root.icon-kind == "full_rig"       ? @image-url("../assets/full-rig.svg")
            : root.icon-kind == "gain"           ? @image-url("../assets/gain.svg")
            : root.icon-kind == "dynamics"       ? @image-url("../assets/dyn.svg")
            : root.icon-kind == "filter"         ? @image-url("../assets/filter.svg")
            : root.icon-kind == "wah"            ? @image-url("../assets/expression.svg")
            : root.icon-kind == "modulation"     ? @image-url("../assets/mod.svg")
            : root.icon-kind == "delay"          ? @image-url("../assets/delay.svg")
            : root.icon-kind == "reverb"         ? @image-url("../assets/reverb.svg")
            : root.icon-kind == "utility"        ? @image-url("../assets/util.svg")
            : root.icon-kind == "nam"            ? @image-url("../assets/nam.svg")
            : root.icon-kind == "pitch"          ? @image-url("../assets/pitch.svg")
            : @image-url("../assets/gear.svg");
        image-fit: contain;
        colorize: root.tint;
    }
}
