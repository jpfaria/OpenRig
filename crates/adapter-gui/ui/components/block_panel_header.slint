import { BlockModelPickerItem } from "../models.slint";
import { ModelSelectWithSearch } from "model_select_with_search.slint";

// Top-most strip of BlockPanelEditor: type icon, type label, model selector with
// embedded search, type badge (NATIVE/NAM/IR), and trailing action buttons
// (info + delete in edit mode, save in insert mode).
export component BlockPanelHeader inherits Rectangle {
    in property <image> selected-icon-source;
    in property <string> block-type-label;
    in property <length> badge-width;
    in property <bool> edit-mode;
    in property <[BlockModelPickerItem]> filtered-models;
    in property <BlockModelPickerItem> selected-model;
    in-out property <string> search-text;
    in property <string> type-label;
    in property <string> icon-kind;
    in property <string> selected-model-id;

    callback choose-model-by-id(string);
    callback search-model(string);
    callback show-plugin-info(string, string);
    callback delete-block();
    callback save-block();

    background: #06060c;

    // Block type icon (left)
    Image {
        x: 10px;
        y: (parent.height - 24px) / 2;
        width: 24px;
        height: 24px;
        source: root.selected-icon-source;
        image-fit: contain;
        colorize: #f1f4f8;
    }

    // Block type label (left, after icon)
    Text {
        x: 38px; y: 0;
        width: 60px;
        height: parent.height;
        text: root.block-type-label;
        color: #f1f4f8;
        font-size: 10px;
        font-weight: 900;
        vertical-alignment: center;
        letter-spacing: 1.5px;
    }

    // Model selector with embedded search (fills middle)
    ModelSelectWithSearch {
        x: 100px;
        y: (parent.height - 40px) / 2;
        width: parent.width - 100px - root.badge-width - (root.edit-mode ? 80px : 48px);
        filtered-models: root.filtered-models;
        selected-model: root.selected-model;
        search-text <=> root.search-text;
        select(model-id) => { root.choose-model-by-id(model-id); }
        search-text-changed(text) => { root.search-model(text); }
    }

    // Type badge
    if root.type-label != "" : Rectangle {
        x: parent.width - root.badge-width - (root.edit-mode ? 72px : 40px);
        y: (parent.height - 22px) / 2;
        width: root.badge-width;
        height: 22px;
        border-radius: 4px;
        background: root.type-label == "NATIVE" ? #0d2a0d
            : root.type-label == "NAM" ? #0d1a2e
            : #2e1a0d;
        border-width: 1px;
        border-color: root.type-label == "NATIVE" ? #1a6b1a
            : root.type-label == "NAM" ? #1a4488
            : #883300;

        Text {
            x: 8px; y: 0;
            width: parent.width - 16px;
            height: parent.height;
            text: root.type-label;
            color: root.type-label == "NATIVE" ? #33bb33
                : root.type-label == "NAM" ? #4499ff
                : #ff8833;
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 0.8px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }

    // Info button (edit mode, ao lado do delete)
    if root.edit-mode : Rectangle {
        x: parent.width - 64px;
        y: (parent.height - 24px) / 2;
        width: 24px;
        height: 24px;
        border-radius: 4px;
        background: ta-info.has-hover ? #001a1a : transparent;

        Image {
            x: 3px; y: 3px;
            width: 18px; height: 18px;
            source: @image-url("../assets/info.svg");
            image-fit: contain;
            colorize: ta-info.has-hover ? #22C55E : #336655;
        }

        ta-info := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                root.show-plugin-info(root.icon-kind, root.selected-model-id);
            }
        }
    }

    // Delete button (edit mode, ao lado do badge)
    if root.edit-mode : Rectangle {
        x: parent.width - 32px;
        y: (parent.height - 24px) / 2;
        width: 24px;
        height: 24px;
        border-radius: 4px;
        background: ta-del.has-hover ? #1a0000 : transparent;

        Image {
            x: 3px; y: 3px;
            width: 18px; height: 18px;
            source: @image-url("../assets/trash.svg");
            image-fit: contain;
            colorize: ta-del.has-hover ? #ff4433 : #662222;
        }

        ta-del := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.delete-block(); }
        }
    }

    // Save button (insert mode, ao lado do badge)
    if !root.edit-mode : Rectangle {
        x: parent.width - 32px;
        y: (parent.height - 24px) / 2;
        width: 24px;
        height: 24px;
        border-radius: 4px;
        background: ta-save.has-hover ? #0a1a30 : transparent;

        Image {
            x: 3px; y: 3px;
            width: 18px; height: 18px;
            source: @image-url("../assets/save.svg");
            image-fit: contain;
            colorize: ta-save.has-hover ? #4499ff : #224488;
        }

        ta-save := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.save-block(); }
        }
    }
}
