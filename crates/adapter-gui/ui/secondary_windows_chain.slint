import { ChannelOptionItem, DeviceSelectionItem, IoGroupItem, MidiDeviceRow, MidiBindingRow } from "models.slint";
import { Locale } from "locale_globals.slint";
import { SettingsPage, ChainEditorPage, ChainEndpointEditorPage, ChainInsertEditorPage, ChainIoGroupsPage } from "pages/pages.slint";

export component ProjectSettingsWindow inherits Window {
    icon: @image-url("assets/openrig-logomark.svg");
    default-font-family: Locale.font-family;
    default-font-size: 13px;
    in-out property <string> project-name-draft;
    in-out property <string> status-message;
    in property <[DeviceSelectionItem]> project-devices;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    in property <[string]> bit-depth-options;
    // Issue #513 — forward the full SettingsPage surface so the
    // master-detail panel renders identically inside the secondary
    // window. Without these the inner SettingsPage saw empty language
    // dropdowns, empty MIDI devices list, empty MIDI mapping commands
    // and empty project metadata.
    in property <[string]> language-options;
    in property <[string]> language-codes;
    in property <int> selected-language-index;
    in property <[MidiDeviceRow]> midi-devices;
    in property <string> project-path-display;
    callback update-project-name(string);
    callback save-audio-settings();
    // Project / Metadata "Save project" button (#513). Mirror of the
    // main AppWindow callback so the secondary settings window can
    // dispatch Command::SaveProject through the same Rust handler.
    callback save-project();
    callback close-settings();
    callback toggle-project-device(int, bool);
    callback update-project-sample-rate(int, string);
    callback update-project-buffer-size(int, string);
    callback update-project-bit-depth(int, string);
    callback refresh-devices();
    callback language-selected(int);
    callback refresh-midi-devices();
    callback toggle-midi-device(int, bool);
    callback edit-midi-device-alias(int, string);
    // #712: System / Integrations master switches.
    in property <bool> midi-enabled;
    in property <bool> mcp-enabled;
    callback set-midi-enabled(bool);
    callback set-mcp-enabled(bool);
    // #716: System / I/O bindings section.
    in property <[string]> io-binding-ids;
    in property <[string]> io-binding-names;
    in-out property <string> io-binding-error: "";
    callback create-io-binding(string) -> string;
    callback delete-io-binding(string) -> string;
    callback rename-io-binding(string, string);
    callback add-input-endpoint(string, string, string, string, string);
    callback add-output-endpoint(string, string, string, string, string);
    callback remove-endpoint(string, string, bool);
    callback edit-project-name(string);
    // System / Paths section (#513 + #582). Empty = OS default.
    in property <string> presets-path;
    in property <string> plugins-path;
    in property <string> evaluations-path;
    // #561: plugin catalog reload row in the Paths section.
    in property <string> plugin-catalog-status;
    callback pick-presets-path();
    callback reset-presets-path();
    callback pick-plugins-path();
    callback reset-plugins-path();
    callback pick-evaluations-path();
    callback reset-evaluations-path();
    callback reload-plugin-catalog();
    title: @tr("title-window-project-settings");
    min-width: 860px;
    min-height: 540px;
    preferred-width: 1100px;
    preferred-height: 640px;
    background: #040708;

    SettingsPage {
        width: parent.width;
        height: parent.height;
        project-name-draft <=> root.project-name-draft;
        project-devices: root.project-devices;
        sample-rate-options: root.sample-rate-options;
        buffer-size-options: root.buffer-size-options;
        bit-depth-options: root.bit-depth-options;
        status-message: root.status-message;
        language-options: root.language-options;
        language-codes: root.language-codes;
        selected-language-index: root.selected-language-index;
        midi-devices: root.midi-devices;
        midi-enabled: root.midi-enabled;
        mcp-enabled: root.mcp-enabled;
        project-path-display: root.project-path-display;
        update-project-name(value) => { root.update-project-name(value); }
        save-audio-settings => { root.save-audio-settings(); }
        save-project => { root.save-project(); }
        close-settings => { root.close-settings(); }
        toggle-project-device(index, selected) => { root.toggle-project-device(index, selected); }
        update-project-sample-rate(index, value) => { root.update-project-sample-rate(index, value); }
        update-project-buffer-size(index, value) => { root.update-project-buffer-size(index, value); }
        update-project-bit-depth(index, value) => { root.update-project-bit-depth(index, value); }
        refresh-devices => { root.refresh-devices(); }
        language-selected(i) => { root.language-selected(i); }
        refresh-midi-devices => { root.refresh-midi-devices(); }
        toggle-midi-device(i, on) => { root.toggle-midi-device(i, on); }
        edit-midi-device-alias(i, s) => { root.edit-midi-device-alias(i, s); }
        set-midi-enabled(on) => { root.set-midi-enabled(on); }
        set-mcp-enabled(on) => { root.set-mcp-enabled(on); }
        io-binding-ids: root.io-binding-ids;
        io-binding-names: root.io-binding-names;
        io-binding-error <=> root.io-binding-error;
        create-io-binding(name) => { return root.create-io-binding(name); }
        delete-io-binding(id) => { return root.delete-io-binding(id); }
        rename-io-binding(id, n) => { root.rename-io-binding(id, n); }
        add-input-endpoint(id, en, dev, mode, ch) => { root.add-input-endpoint(id, en, dev, mode, ch); }
        add-output-endpoint(id, en, dev, mode, ch) => { root.add-output-endpoint(id, en, dev, mode, ch); }
        remove-endpoint(id, en, inp) => { root.remove-endpoint(id, en, inp); }
        edit-project-name(t) => { root.edit-project-name(t); }
        presets-path: root.presets-path;
        plugins-path: root.plugins-path;
        evaluations-path: root.evaluations-path;
        plugin-catalog-status: root.plugin-catalog-status;
        pick-presets-path => { root.pick-presets-path(); }
        reset-presets-path => { root.reset-presets-path(); }
        pick-plugins-path => { root.pick-plugins-path(); }
        reset-plugins-path => { root.reset-plugins-path(); }
        pick-evaluations-path => { root.pick-evaluations-path(); }
        reset-evaluations-path => { root.reset-evaluations-path(); }
        reload-plugin-catalog => { root.reload-plugin-catalog(); }
    }
}

export component ChainEditorWindow inherits Window {
    icon: @image-url("assets/openrig-logomark.svg");
    default-font-family: Locale.font-family;
    default-font-size: 13px;
    in property <string> editor-title;
    in property <string> editor-save-label;
    in-out property <string> chain-name;
    in property <[IoGroupItem]> input-groups;
    in property <[IoGroupItem]> output-groups;
    in-out property <string> status-message;
    in property <bool> is-create-mode: true;
    in-out property <int> selected-instrument-index: 0;
    callback update-chain-name(string);
    callback edit-input(int);
    callback remove-input(int);
    callback add-input();
    callback edit-output(int);
    callback remove-output(int);
    callback add-output();
    callback save-chain();
    callback cancel-chain();
    callback select-instrument(int);
    // Inline input endpoint editor
    in property <bool> show-input-editor: false;
    in property <[string]> input-device-options;
    in-out property <int> input-selected-device-index: -1;
    in property <[ChannelOptionItem]> input-channels;
    in-out property <string> input-editor-status: "";
    in-out property <int> input-mode-index: 0;
    callback input-select-device(int);
    callback input-toggle-channel(int, bool);
    callback input-select-mode(int);
    callback input-save();
    callback input-cancel();
    in property <[string]> input-io-binding-names;
    in-out property <int> input-selected-io-index: -1;
    in property <[string]> input-endpoint-options;
    in-out property <string> input-selected-io-name: "";
    in-out property <string> input-selected-endpoint-name: "";
    callback input-select-io(int);
    callback input-select-endpoint(string);
    // Inline output endpoint editor
    in property <bool> show-output-editor: false;
    in property <[string]> output-device-options;
    in-out property <int> output-selected-device-index: -1;
    in property <[ChannelOptionItem]> output-channels;
    in-out property <string> output-editor-status: "";
    in-out property <int> output-mode-index: 0;
    callback output-select-device(int);
    callback output-toggle-channel(int, bool);
    callback output-select-mode(int);
    callback output-save();
    callback output-cancel();
    in property <[string]> output-io-binding-names;
    in-out property <int> output-selected-io-index: -1;
    in property <[string]> output-endpoint-options;
    in-out property <string> output-selected-io-name: "";
    in-out property <string> output-selected-endpoint-name: "";
    callback output-select-io(int);
    callback output-select-endpoint(string);
    title: @tr("title-window-chain-editor");
    min-width: 860px;
    min-height: 540px;
    preferred-width: 1100px;
    preferred-height: 640px;
    background: #040708;

    ChainEditorPage {
        width: parent.width;
        height: parent.height;
        title: root.editor-title;
        save-label: root.editor-save-label;
        chain-name: root.chain-name;
        input-groups: root.input-groups;
        output-groups: root.output-groups;
        status-message: root.status-message;
        is-create-mode: root.is-create-mode;
        selected-instrument-index: root.selected-instrument-index;
        update-chain-name(value) => { root.update-chain-name(value); }
        edit-input(index) => { root.edit-input(index); }
        remove-input(index) => { root.remove-input(index); }
        add-input => { root.add-input(); }
        edit-output(index) => { root.edit-output(index); }
        remove-output(index) => { root.remove-output(index); }
        add-output => { root.add-output(); }
        save-chain => { root.save-chain(); }
        cancel-chain => { root.cancel-chain(); }
        select-instrument(index) => { root.select-instrument(index); }
    }

    if root.show-input-editor : ChainEndpointEditorPage {
        width: parent.width;
        height: parent.height;
        title: @tr("title-section-input");
        io-binding-names: root.input-io-binding-names;
        selected-io-index <=> root.input-selected-io-index;
        endpoint-options: root.input-endpoint-options;
        selected-endpoint-name <=> root.input-selected-endpoint-name;
        status-message <=> root.input-editor-status;
        select-io(index) => { root.input-select-io(index); }
        select-endpoint(name) => { root.input-select-endpoint(name); }
        save => { root.input-save(); }
        cancel => { root.input-cancel(); }
    }

    if root.show-output-editor : ChainEndpointEditorPage {
        width: parent.width;
        height: parent.height;
        title: @tr("title-section-output");
        io-binding-names: root.output-io-binding-names;
        selected-io-index <=> root.output-selected-io-index;
        endpoint-options: root.output-endpoint-options;
        selected-endpoint-name <=> root.output-selected-endpoint-name;
        status-message <=> root.output-editor-status;
        select-io(index) => { root.output-select-io(index); }
        select-endpoint(name) => { root.output-select-endpoint(name); }
        save => { root.output-save(); }
        cancel => { root.output-cancel(); }
    }
}

export component ChainInputWindow inherits Window {
    icon: @image-url("assets/openrig-logomark.svg");
    default-font-family: Locale.font-family;
    default-font-size: 13px;
    in property <[string]> device-options;
    in-out property <int> selected-device-index;
    in property <[ChannelOptionItem]> channels;
    in-out property <string> status-message;
    in-out property <int> selected-input-mode-index: 0;
    callback select-device(int);
    callback toggle-channel(int, bool);
    callback select-input-mode(int);
    callback save();
    callback cancel();
    title: @tr("title-window-chain-input");
    min-width: 680px;
    min-height: 500px;
    preferred-width: 820px;
    preferred-height: 620px;
    background: #040708;

    ChainEndpointEditorPage {
        width: parent.width;
        height: parent.height;
        title: @tr("title-section-input");
        io-binding-names: [];
        endpoint-options: [];
        status-message: root.status-message;
        save => { root.save(); }
        cancel => { root.cancel(); }
    }
}

