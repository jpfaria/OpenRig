import { ChannelOptionItem, DeviceSelectionItem, IoGroupItem } from "models.slint";
import { ProjectSettingsPage, ChainEditorPage, ChainEndpointEditorPage, ChainInsertEditorPage, ChainIoGroupsPage } from "pages/pages.slint";

export component ProjectSettingsWindow inherits Window {
    icon: @image-url("assets/openrig-logomark.svg");
    default-font-family: "Helvetica Neue";
    default-font-size: 13px;
    in-out property <string> project-name-draft;
    in-out property <string> status-message;
    in property <[DeviceSelectionItem]> project-devices;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    in property <[string]> bit-depth-options;
    callback update-project-name(string);
    callback save-audio-settings();
    callback close-project-settings();
    callback toggle-project-device(int, bool);
    callback update-project-sample-rate(int, string);
    callback update-project-buffer-size(int, string);
    callback update-project-bit-depth(int, string);
    callback refresh-devices();
    title: "OpenRig · Configurar projeto";
    min-width: 860px;
    min-height: 540px;
    preferred-width: 1100px;
    preferred-height: 640px;
    background: #040708;

    ProjectSettingsPage {
        width: parent.width;
        height: parent.height;
        project-name-draft <=> root.project-name-draft;
        project-devices: root.project-devices;
        sample-rate-options: root.sample-rate-options;
        buffer-size-options: root.buffer-size-options;
        bit-depth-options: root.bit-depth-options;
        status-message: root.status-message;
        update-project-name(value) => { root.update-project-name(value); }
        save-audio-settings => { root.save-audio-settings(); }
        close-project-settings => { root.close-project-settings(); }
        toggle-project-device(index, selected) => { root.toggle-project-device(index, selected); }
        update-project-sample-rate(index, value) => { root.update-project-sample-rate(index, value); }
        update-project-buffer-size(index, value) => { root.update-project-buffer-size(index, value); }
        update-project-bit-depth(index, value) => { root.update-project-bit-depth(index, value); }
        refresh-devices => { root.refresh-devices(); }
    }
}

export component ChainEditorWindow inherits Window {
    icon: @image-url("assets/openrig-logomark.svg");
    default-font-family: "Helvetica Neue";
    default-font-size: 13px;
    in property <string> editor-title;
    in property <string> editor-save-label;
    in-out property <string> chain-name;
    in property <[IoGroupItem]> input-groups;
    in property <[IoGroupItem]> output-groups;
    in-out property <string> status-message;
    in property <bool> is-create-mode: true;
    in-out property <int> selected-instrument-index: 0;
    callback update-chain-name(string);
    callback edit-input(int);
    callback remove-input(int);
    callback add-input();
    callback edit-output(int);
    callback remove-output(int);
    callback add-output();
    callback save-chain();
    callback cancel-chain();
    callback select-instrument(int);
    // Inline input endpoint editor
    in property <bool> show-input-editor: false;
    in property <[string]> input-device-options;
    in-out property <int> input-selected-device-index: -1;
    in property <[ChannelOptionItem]> input-channels;
    in-out property <string> input-editor-status: "";
    in-out property <int> input-mode-index: 0;
    callback input-select-device(int);
    callback input-toggle-channel(int, bool);
    callback input-select-mode(int);
    callback input-save();
    callback input-cancel();
    // Inline output endpoint editor
    in property <bool> show-output-editor: false;
    in property <[string]> output-device-options;
    in-out property <int> output-selected-device-index: -1;
    in property <[ChannelOptionItem]> output-channels;
    in-out property <string> output-editor-status: "";
    in-out property <int> output-mode-index: 0;
    callback output-select-device(int);
    callback output-toggle-channel(int, bool);
    callback output-select-mode(int);
    callback output-save();
    callback output-cancel();
    title: "OpenRig · Configurar chain";
    min-width: 860px;
    min-height: 540px;
    preferred-width: 1100px;
    preferred-height: 640px;
    background: #040708;

    ChainEditorPage {
        width: parent.width;
        height: parent.height;
        title: root.editor-title;
        save-label: root.editor-save-label;
        chain-name: root.chain-name;
        input-groups: root.input-groups;
        output-groups: root.output-groups;
        status-message: root.status-message;
        is-create-mode: root.is-create-mode;
        selected-instrument-index: root.selected-instrument-index;
        update-chain-name(value) => { root.update-chain-name(value); }
        edit-input(index) => { root.edit-input(index); }
        remove-input(index) => { root.remove-input(index); }
        add-input => { root.add-input(); }
        edit-output(index) => { root.edit-output(index); }
        remove-output(index) => { root.remove-output(index); }
        add-output => { root.add-output(); }
        save-chain => { root.save-chain(); }
        cancel-chain => { root.cancel-chain(); }
        select-instrument(index) => { root.select-instrument(index); }
    }

    if root.show-input-editor : ChainEndpointEditorPage {
        width: parent.width;
        height: parent.height;
        title: "Entrada";
        device-options: root.input-device-options;
        selected-device-index <=> root.input-selected-device-index;
        channels: root.input-channels;
        status-message <=> root.input-editor-status;
        show-mode-selector: true;
        mode-labels: ["Mono", "Stereo", "Dual Mono"];
        selected-mode-index <=> root.input-mode-index;
        select-device(index) => { root.input-select-device(index); }
        toggle-channel(index, selected) => { root.input-toggle-channel(index, selected); }
        select-mode(index) => { root.input-select-mode(index); }
        save => { root.input-save(); }
        cancel => { root.input-cancel(); }
    }

    if root.show-output-editor : ChainEndpointEditorPage {
        width: parent.width;
        height: parent.height;
        title: "Saída";
        device-options: root.output-device-options;
        selected-device-index <=> root.output-selected-device-index;
        channels: root.output-channels;
        status-message <=> root.output-editor-status;
        show-mode-selector: true;
        mode-labels: ["Mono", "Stereo"];
        selected-mode-index <=> root.output-mode-index;
        select-device(index) => { root.output-select-device(index); }
        toggle-channel(index, selected) => { root.output-toggle-channel(index, selected); }
        select-mode(index) => { root.output-select-mode(index); }
        save => { root.output-save(); }
        cancel => { root.output-cancel(); }
    }
}

export component ChainInputWindow inherits Window {
    icon: @image-url("assets/openrig-logomark.svg");
    default-font-family: "Helvetica Neue";
    default-font-size: 13px;
    in property <[string]> device-options;
    in-out property <int> selected-device-index;
    in property <[ChannelOptionItem]> channels;
    in-out property <string> status-message;
    in-out property <int> selected-input-mode-index: 0;
    callback select-device(int);
    callback toggle-channel(int, bool);
    callback select-input-mode(int);
    callback save();
    callback cancel();
    title: "OpenRig · Entrada da chain";
    min-width: 680px;
    min-height: 500px;
    preferred-width: 820px;
    preferred-height: 620px;
    background: #040708;

    ChainEndpointEditorPage {
        width: parent.width;
        height: parent.height;
        title: "Entrada";
        device-options: root.device-options;
        selected-device-index <=> root.selected-device-index;
        channels: root.channels;
        status-message: root.status-message;
        show-mode-selector: true;
        mode-labels: ["Mono", "Stereo", "Dual Mono"];
        selected-mode-index <=> root.selected-input-mode-index;
        select-device(index) => { root.select-device(index); }
        toggle-channel(index, selected) => { root.toggle-channel(index, selected); }
        select-mode(index) => { root.select-input-mode(index); }
        save => { root.save(); }
        cancel => { root.cancel(); }
    }
}

export component ChainOutputWindow inherits Window {
    icon: @image-url("assets/openrig-logomark.svg");
    default-font-family: "Helvetica Neue";
    default-font-size: 13px;
    in property <[string]> device-options;
    in-out property <int> selected-device-index;
