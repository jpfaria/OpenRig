import { Button, CheckBox, ComboBox, ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";

export struct DeviceSelectionItem {
    name: string,
    selected: bool,
    sample_rate_text: string,
    buffer_size_text: string,
}

export component AppWindow inherits Window {
    in property <string> runtime-mode-label;
    in property <string> interaction-mode-label;
    in property <bool> show-audio-setup;
    in-out property <int> wizard-step;
    in-out property <[DeviceSelectionItem]> input-devices;
    in-out property <[DeviceSelectionItem]> output-devices;
    in-out property <string> status-message;
    in property <[string]> sample-rate-options: ["44100", "48000", "88200", "96000"];
    in property <[string]> buffer-size-options: ["32", "64", "128", "256", "512", "1024"];

    callback toggle-input-device(int, bool);
    callback toggle-output-device(int, bool);
    callback update-input-sample-rate(int, string);
    callback update-input-buffer-size(int, string);
    callback update-output-sample-rate(int, string);
    callback update-output-buffer-size(int, string);
    callback go-to-output-step();
    callback go-to-input-step();
    callback save-audio-settings();

    title: "OpenRig";
    width: 1280px;
    height: 900px;
    background: #111315;

    Rectangle {
        background: #111315;

        if show-audio-setup : Rectangle {
            x: 24px;
            y: 24px;
            width: parent.width - 48px;
            height: parent.height - 48px;
            background: #16181c;
            border-radius: 16px;
            border-width: 1px;
            border-color: #30343a;

            VerticalBox {
                padding: 20px;
                spacing: 14px;

                Text {
                    text: "OpenRig";
                    color: #f3f5f7;
                    font-size: 24px;
                    font-weight: 700;
                }

                Text {
                    text: wizard-step == 0 ? "Escolha o input" : "Escolha o output";
                    color: #f3f5f7;
                    font-size: 24px;
                    font-weight: 700;
                }

                Rectangle {
                    background: #1d2025;
                    border-radius: 14px;
                    border-width: 1px;
                    border-color: #363b42;
                    vertical-stretch: 1;

                    ScrollView {
                        viewport-width: parent.width;
                        viewport-height: parent.height;

                        Rectangle {
                            background: transparent;
                            width: parent.width;

                            VerticalBox {
                                padding: 12px;
                                spacing: 10px;

                                if wizard-step == 0 : VerticalBox {
                                    spacing: 10px;

                                    for device[i] in input-devices : Rectangle {
                                        background: #20242a;
                                        border-radius: 12px;
                                        border-width: 1px;
                                        border-color: #363b42;

                                        HorizontalBox {
                                            padding: 12px;
                                            spacing: 12px;

                                            Rectangle {
                                                background: transparent;
                                                horizontal-stretch: 1;

                                                CheckBox {
                                                    text: device.name;
                                                    checked: device.selected;
                                                    toggled => {
                                                        root.toggle-input-device(i, self.checked);
                                                    }
                                                }
                                            }

                                            if device.selected : ComboBox {
                                                min-width: 150px;
                                                model: root.sample-rate-options;
                                                current-value: device.sample_rate_text;
                                                selected(value) => {
                                                    root.update-input-sample-rate(i, value);
                                                }
                                            }

                                            if device.selected : ComboBox {
                                                min-width: 150px;
                                                model: root.buffer-size-options;
                                                current-value: device.buffer_size_text;
                                                selected(value) => {
                                                    root.update-input-buffer-size(i, value);
                                                }
                                            }
                                        }
                                    }
                                }

                                if wizard-step == 1 : VerticalBox {
                                    spacing: 10px;

                                    for device[i] in output-devices : Rectangle {
                                        background: #20242a;
                                        border-radius: 12px;
                                        border-width: 1px;
                                        border-color: #363b42;

                                        HorizontalBox {
                                            padding: 12px;
                                            spacing: 12px;

                                            Rectangle {
                                                background: transparent;
                                                horizontal-stretch: 1;

                                                CheckBox {
                                                    text: device.name;
                                                    checked: device.selected;
                                                    toggled => {
                                                        root.toggle-output-device(i, self.checked);
                                                    }
                                                }
                                            }

                                            if device.selected : ComboBox {
                                                min-width: 150px;
                                                model: root.sample-rate-options;
                                                current-value: device.sample_rate_text;
                                                selected(value) => {
                                                    root.update-output-sample-rate(i, value);
                                                }
                                            }

                                            if device.selected : ComboBox {
                                                min-width: 150px;
                                                model: root.buffer-size-options;
                                                current-value: device.buffer_size_text;
                                                selected(value) => {
                                                    root.update-output-buffer-size(i, value);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalBox {
                    spacing: 12px;

                    if wizard-step == 1 : Button {
                        text: "Voltar";
                        clicked => {
                            root.go-to-input-step();
                        }
                    }

                    Rectangle { horizontal-stretch: 1; background: transparent; }

                    if wizard-step == 0 : Button {
                        text: "Continuar";
                        clicked => {
                            root.go-to-output-step();
                        }
                    }

                    if wizard-step == 1 : Button {
                        text: "Salvar";
                        clicked => {
                            root.save-audio-settings();
                        }
                    }
                }

                if status-message != "" : Text {
                    text: status-message;
                    color: #c4ccd7;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }
        }
    }
}
