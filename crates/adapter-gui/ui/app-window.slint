import { CheckBox, LineEdit, Button, ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";

export struct DeviceSelectionItem {
    name: string,
    selected: bool,
    sample_rate_text: string,
    buffer_size_text: string,
}

export component AppWindow inherits Window {
    in property <string> runtime-mode-label;
    in property <string> interaction-mode-label;
    in property <bool> show-audio-setup;
    in-out property <[DeviceSelectionItem]> input-devices;
    in-out property <[DeviceSelectionItem]> output-devices;
    in-out property <string> status-message;

    callback toggle-input-device(int, bool);
    callback toggle-output-device(int, bool);
    callback update-input-sample-rate(int, string);
    callback update-input-buffer-size(int, string);
    callback update-output-sample-rate(int, string);
    callback update-output-buffer-size(int, string);
    callback save-audio-settings();

    title: "OpenRig";
    width: 1280px;
    height: 900px;
    background: #111315;

    Rectangle {
        background: #111315;
        border-radius: 18px;

        if show-audio-setup : ScrollView {
            viewport-width: parent.width;
            viewport-height: parent.height;

            Rectangle {
                background: transparent;
                width: 1232px;

                VerticalBox {
                    padding: 24px;
                    spacing: 20px;

                    Rectangle {
                        background: #16181c;
                        border-radius: 20px;
                        border-width: 1px;
                        border-color: #30343a;

                        VerticalBox {
                            padding: 28px;
                            spacing: 24px;

                            Text {
                                text: "OpenRig";
                                color: #f3f5f7;
                                font-size: 30px;
                                font-weight: 700;
                            }

                            Text {
                                text: "Configuração inicial";
                                color: #f3f5f7;
                                font-size: 34px;
                                font-weight: 700;
                            }

                            Rectangle {
                                background: #1d2025;
                                border-radius: 16px;
                                border-width: 1px;
                                border-color: #363b42;

                                VerticalBox {
                                    padding: 18px;
                                    spacing: 12px;

                                    Text {
                                        text: "Inputs";
                                        color: #f3f5f7;
                                        font-size: 22px;
                                        font-weight: 600;
                                    }

                                    VerticalBox {
                                        spacing: 10px;

                                        for device[i] in input-devices : Rectangle {
                                            background: #20242a;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: #363b42;

                                            VerticalBox {
                                                padding: 12px;
                                                spacing: 10px;

                                                HorizontalBox {
                                                    spacing: 10px;
                                                    alignment: start;

                                                    CheckBox {
                                                        text: device.name;
                                                        checked: device.selected;
                                                        min-width: 420px;
                                                        toggled => {
                                                            root.toggle-input-device(i, self.checked);
                                                        }
                                                    }

                                                    if device.selected : Rectangle {
                                                        background: transparent;
                                                        min-width: 180px;
                                                        VerticalBox {
                                                            spacing: 6px;
                                                            Text {
                                                                text: "Sample Rate";
                                                                color: #9ea7b3;
                                                                font-size: 14px;
                                                            }
                                                            LineEdit {
                                                                text: device.sample_rate_text;
                                                                edited(text) => {
                                                                    root.update-input-sample-rate(i, text);
                                                                }
                                                            }
                                                        }
                                                    }

                                                    if device.selected : Rectangle {
                                                        background: transparent;
                                                        min-width: 180px;
                                                        VerticalBox {
                                                            spacing: 6px;
                                                            Text {
                                                                text: "Buffer Size";
                                                                color: #9ea7b3;
                                                                font-size: 14px;
                                                            }
                                                            LineEdit {
                                                                text: device.buffer_size_text;
                                                                edited(text) => {
                                                                    root.update-input-buffer-size(i, text);
                                                                }
                                                            }
                                                        }
                                                    }

                                                    Rectangle { horizontal-stretch: 1; background: transparent; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                background: #1d2025;
                                border-radius: 16px;
                                border-width: 1px;
                                border-color: #363b42;

                                VerticalBox {
                                    padding: 18px;
                                    spacing: 12px;

                                    Text {
                                        text: "Outputs";
                                        color: #f3f5f7;
                                        font-size: 22px;
                                        font-weight: 600;
                                    }

                                    VerticalBox {
                                        spacing: 10px;

                                        for device[i] in output-devices : Rectangle {
                                            background: #20242a;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: #363b42;

                                            VerticalBox {
                                                padding: 12px;
                                                spacing: 10px;

                                                HorizontalBox {
                                                    spacing: 10px;
                                                    alignment: start;

                                                    CheckBox {
                                                        text: device.name;
                                                        checked: device.selected;
                                                        min-width: 420px;
                                                        toggled => {
                                                            root.toggle-output-device(i, self.checked);
                                                        }
                                                    }

                                                    if device.selected : Rectangle {
                                                        background: transparent;
                                                        min-width: 180px;
                                                        VerticalBox {
                                                            spacing: 6px;
                                                            Text {
                                                                text: "Sample Rate";
                                                                color: #9ea7b3;
                                                                font-size: 14px;
                                                            }
                                                            LineEdit {
                                                                text: device.sample_rate_text;
                                                                edited(text) => {
                                                                    root.update-output-sample-rate(i, text);
                                                                }
                                                            }
                                                        }
                                                    }

                                                    if device.selected : Rectangle {
                                                        background: transparent;
                                                        min-width: 180px;
                                                        VerticalBox {
                                                            spacing: 6px;
                                                            Text {
                                                                text: "Buffer Size";
                                                                color: #9ea7b3;
                                                                font-size: 14px;
                                                            }
                                                            LineEdit {
                                                                text: device.buffer_size_text;
                                                                edited(text) => {
                                                                    root.update-output-buffer-size(i, text);
                                                                }
                                                            }
                                                        }
                                                    }

                                                    Rectangle { horizontal-stretch: 1; background: transparent; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            HorizontalBox {
                                spacing: 16px;

                                Button {
                                    text: "Salvar e continuar";
                                    clicked => {
                                        root.save-audio-settings();
                                    }
                                }

                                Rectangle { horizontal-stretch: 1; background: transparent; }
                            }

                            if status-message != "" : Text {
                                text: status-message;
                                color: #c4ccd7;
                                font-size: 15px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }
    }
}
