import { Theme } from "theme.slint";
import { DeviceSelectionItem } from "models.slint";
import { AudioWizard } from "blocks/blocks.slint";

export component AppWindow inherits Window {
    in property <string> runtime-mode-label;
    in property <string> interaction-mode-label;
    in property <bool> show-audio-setup;
    in-out property <int> wizard-step;
    in-out property <[DeviceSelectionItem]> input-devices;
    in-out property <[DeviceSelectionItem]> output-devices;
    in-out property <string> status-message;
    in property <[string]> sample-rate-options: ["44100", "48000", "88200", "96000"];
    in property <[string]> buffer-size-options: ["32", "64", "128", "256", "512", "1024"];

    callback toggle-input-device(int, bool);
    callback toggle-output-device(int, bool);
    callback update-input-sample-rate(int, string);
    callback update-input-buffer-size(int, string);
    callback update-output-sample-rate(int, string);
    callback update-output-buffer-size(int, string);
    callback go-to-output-step();
    callback go-to-input-step();
    callback save-audio-settings();

    title: "OpenRig";
    width: 1280px;
    height: 900px;
    background: Theme.palette.pure-black;
    default-font-family: "Helvetica Neue";
    Rectangle {
        background: Theme.palette.background-gradient;

        if show-audio-setup : Rectangle {
            background: transparent;

            Text {
                x: parent.width / 2 - self.width / 2;
                y: 36px;
                text: "OpenRig";
                color: Theme.palette.text-primary;
                font-size: Theme.typo.brand.size;
                font-weight: Theme.typo.brand.weight;
            }

            AudioWizard {
                x: parent.width / 2 - self.width / 2;
                y: 118px;
                wizard-step: root.wizard-step;
                input-devices: root.input-devices;
                output-devices: root.output-devices;
                status-message: root.status-message;
                sample-rate-options: root.sample-rate-options;
                buffer-size-options: root.buffer-size-options;
                toggle-input-device(index, selected) => {
                    root.toggle-input-device(index, selected);
                }
                toggle-output-device(index, selected) => {
                    root.toggle-output-device(index, selected);
                }
                update-input-sample-rate(index, value) => {
                    root.update-input-sample-rate(index, value);
                }
                update-input-buffer-size(index, value) => {
                    root.update-input-buffer-size(index, value);
                }
                update-output-sample-rate(index, value) => {
                    root.update-output-sample-rate(index, value);
                }
                update-output-buffer-size(index, value) => {
                    root.update-output-buffer-size(index, value);
                }
                go-to-output-step => {
                    root.go-to-output-step();
                }
                go-to-input-step => {
                    root.go-to-input-step();
                }
                save-audio-settings => {
                    root.save-audio-settings();
                }
            }
        }
    }
}
