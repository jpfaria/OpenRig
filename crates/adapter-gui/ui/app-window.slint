import { ChannelOptionItem, DeviceSelectionItem, ProjectTrackItem, RecentProjectItem, StageModelPickerItem, StageParameterItem, StageTypePickerItem } from "models.slint";
import { DesktopMain } from "desktop_main.slint";
import { TouchMain } from "touch_main.slint";
import { ProjectSettingsPage, TrackEditorPage } from "pages/pages.slint";

export component ProjectSettingsWindow inherits Window {
    in-out property <string> project-name-draft;
    in-out property <string> status-message;
    in property <[DeviceSelectionItem]> input-devices;
    in property <[DeviceSelectionItem]> output-devices;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    callback update-project-name(string);
    callback save-audio-settings();
    callback close-project-settings();
    callback toggle-input-device(int, bool);
    callback toggle-output-device(int, bool);
    callback update-input-sample-rate(int, string);
    callback update-input-buffer-size(int, string);
    callback update-output-sample-rate(int, string);
    callback update-output-buffer-size(int, string);
    title: "OpenRig · Configurar projeto";
    min-width: 980px;
    min-height: 680px;
    preferred-width: 1160px;
    preferred-height: 760px;
    background: #040708;

    ProjectSettingsPage {
        width: parent.width;
        height: parent.height;
        project-name-draft: root.project-name-draft;
        input-devices: root.input-devices;
        output-devices: root.output-devices;
        sample-rate-options: root.sample-rate-options;
        buffer-size-options: root.buffer-size-options;
        status-message: root.status-message;
        update-project-name(value) => { root.update-project-name(value); }
        save-audio-settings => { root.save-audio-settings(); }
        close-project-settings => { root.close-project-settings(); }
        toggle-input-device(index, selected) => { root.toggle-input-device(index, selected); }
        toggle-output-device(index, selected) => { root.toggle-output-device(index, selected); }
        update-input-sample-rate(index, value) => { root.update-input-sample-rate(index, value); }
        update-input-buffer-size(index, value) => { root.update-input-buffer-size(index, value); }
        update-output-sample-rate(index, value) => { root.update-output-sample-rate(index, value); }
        update-output-buffer-size(index, value) => { root.update-output-buffer-size(index, value); }
    }
}

export component TrackEditorWindow inherits Window {
    in property <string> editor-title;
    in property <string> editor-save-label;
    in-out property <string> track-name;
    in property <[string]> input-device-options;
    in property <[string]> output-device-options;
    in property <int> selected-input-device-index;
    in property <int> selected-output-device-index;
    in property <[ChannelOptionItem]> input-channels;
    in property <[ChannelOptionItem]> output-channels;
    in-out property <string> status-message;
    callback update-track-name(string);
    callback select-track-input-device(int);
    callback select-track-output-device(int);
    callback toggle-track-input-channel(int, bool);
    callback toggle-track-output-channel(int, bool);
    callback save-track();
    callback cancel-track();
    title: "OpenRig · Configurar track";
    min-width: 980px;
    min-height: 680px;
    preferred-width: 1160px;
    preferred-height: 760px;
    background: #040708;

    TrackEditorPage {
        width: parent.width;
        height: parent.height;
        title: root.editor-title;
        save-label: root.editor-save-label;
        track-name: root.track-name;
        input-device-options: root.input-device-options;
        output-device-options: root.output-device-options;
        selected-input-device-index: root.selected-input-device-index;
        selected-output-device-index: root.selected-output-device-index;
        input-channels: root.input-channels;
        output-channels: root.output-channels;
        status-message: root.status-message;
        update-track-name(value) => { root.update-track-name(value); }
        select-track-input-device(index) => { root.select-track-input-device(index); }
        select-track-output-device(index) => { root.select-track-output-device(index); }
        toggle-track-input-channel(index, selected) => { root.toggle-track-input-channel(index, selected); }
        toggle-track-output-channel(index, selected) => { root.toggle-track-output-channel(index, selected); }
        save-track => { root.save-track(); }
        cancel-track => { root.cancel-track(); }
    }
}

export component AppWindow inherits Window {
