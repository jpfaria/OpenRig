    in-out property <string> toast-message;

    in-out property <string> toast-level: "info";

    Toast {
        message: root.toast-message;
        level: root.toast-level;
        container-width: root.width;
        container-height: root.height;
    }

    // Root-level modal: works in BOTH desktop and touch modes so the
    // bundled presets are always reachable in-app (issue #479 — desktop
    // previously had only a native FileDialog and no visible list).
    PresetPickerOverlay {
        width: root.width;
        height: root.height;
        visible-overlay: root.show-preset-picker;
        items: root.preset-picker-items;
        search-query <=> root.preset-picker-search-query;
        confirm(i) => { root.preset-picker-confirm(i); }
