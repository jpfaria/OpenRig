import { CheckBox, ComboBox, VerticalBox, HorizontalBox } from "std-widgets.slint";

export struct DeviceSelectionItem {
    name: string,
    selected: bool,
    sample_rate_text: string,
    buffer_size_text: string,
}

component PrimaryActionButton inherits Rectangle {
    in property <string> text;
    callback clicked();

    width: 138px;
    height: 44px;
    border-radius: 14px;
    background: @linear-gradient(180deg, #8e73ff 0%, #694dff 100%);

    Text {
        text: root.text;
        color: #f6f8ff;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 15px;
        font-weight: 700;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component SecondaryActionButton inherits Rectangle {
    in property <string> text;
    callback clicked();

    width: 108px;
    height: 44px;
    border-radius: 14px;
    border-width: 1px;
    border-color: #4e5aa6;
    background: @linear-gradient(180deg, #1a2250 0%, #121838 100%);

    Text {
        text: root.text;
        color: #dce2ff;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 15px;
        font-weight: 600;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component AppWindow inherits Window {
    in property <string> runtime-mode-label;
    in property <string> interaction-mode-label;
    in property <bool> show-audio-setup;
    in-out property <int> wizard-step;
    in-out property <[DeviceSelectionItem]> input-devices;
    in-out property <[DeviceSelectionItem]> output-devices;
    in-out property <string> status-message;
    in property <[string]> sample-rate-options: ["44100", "48000", "88200", "96000"];
    in property <[string]> buffer-size-options: ["32", "64", "128", "256", "512", "1024"];
    private property <int> visible-device-count: wizard-step == 0 ? input-devices.length : output-devices.length;
    private property <length> device-row-height: 48px;
    private property <length> device-list-height: 20px + (visible-device-count * device-row-height) + (visible-device-count > 0 ? (visible-device-count - 1) * 8px : 0px);
    private property <length> wizard-card-height: 26px + 28px + 18px + device-list-height + 20px + 18px + 44px + 26px;

    callback toggle-input-device(int, bool);
    callback toggle-output-device(int, bool);
    callback update-input-sample-rate(int, string);
    callback update-input-buffer-size(int, string);
    callback update-output-sample-rate(int, string);
    callback update-output-buffer-size(int, string);
    callback go-to-output-step();
    callback go-to-input-step();
    callback save-audio-settings();

    title: "OpenRig";
    width: 1280px;
    height: 900px;
    background: #040708;
    default-font-family: "Helvetica Neue";

    pure function sample-rate-index(value: string) -> int {
        return value == "44100" ? 0
            : value == "48000" ? 1
            : value == "88200" ? 2
            : value == "96000" ? 3
            : 1;
    }

    pure function buffer-size-index(value: string) -> int {
        return value == "32" ? 0
            : value == "64" ? 1
            : value == "128" ? 2
            : value == "256" ? 3
            : value == "512" ? 4
            : value == "1024" ? 5
            : 3;
    }

    Rectangle {
        background: @radial-gradient(circle, #0d1a7850 0%, #040708 72%);

        if show-audio-setup : Rectangle {
            background: transparent;

            Text {
                x: parent.width / 2 - self.width / 2;
                y: 36px;
                text: "OpenRig";
                color: #ffffff;
                font-size: 24px;
                font-weight: 700;
            }

            Rectangle {
                x: parent.width / 2 - self.width / 2;
                y: 118px;
                width: 920px;
                height: root.wizard-card-height;
                background: #070b2a;
                border-radius: 18px;
                border-width: 1px;
                border-color: #283171;

                VerticalBox {
                    padding: 26px;
                    spacing: 18px;

                    HorizontalBox {
                        spacing: 16px;

                        Text {
                            text: wizard-step == 0 ? "Escolha os dispositivos de entrada" : "Escolha os dispositivos de saída";
                            color: #ffffff;
                            font-size: 18px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        Rectangle { horizontal-stretch: 1; background: transparent; }
                    }

                    Rectangle {
                        background: #090d33;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: #252d6d;
                        height: root.device-list-height;

                        VerticalBox {
                            padding: 10px;
                            spacing: 8px;

                            if wizard-step == 0 : VerticalBox {
                                spacing: 8px;

                                for device[i] in input-devices : Rectangle {
                                    background: @linear-gradient(180deg, #181d44 0%, #121730 100%);
                                    height: root.device-row-height;
                                    border-radius: 12px;
                                    border-width: 1px;
                                    border-color: #2d3669;

                                    HorizontalBox {
                                        padding: 10px;
                                        spacing: 12px;

                                        CheckBox {
                                            text: device.name;
                                            checked: device.selected;
                                            min-width: 430px;
                                            toggled => {
                                                root.toggle-input-device(i, self.checked);
                                            }
                                        }

                                        Rectangle { horizontal-stretch: 1; background: transparent; }

                                        if device.selected : ComboBox {
                                            min-width: 142px;
                                            model: root.sample-rate-options;
                                            current-index: root.sample-rate-index(device.sample_rate_text);
                                            selected(value) => {
                                                root.update-input-sample-rate(i, value);
                                            }
                                        }

                                        if device.selected : ComboBox {
                                            min-width: 142px;
                                            model: root.buffer-size-options;
                                            current-index: root.buffer-size-index(device.buffer_size_text);
                                            selected(value) => {
                                                root.update-input-buffer-size(i, value);
                                            }
                                        }
                                    }
                                }
                            }

                            if wizard-step == 1 : VerticalBox {
                                spacing: 8px;

                                for device[i] in output-devices : Rectangle {
                                    background: @linear-gradient(180deg, #181d44 0%, #121730 100%);
                                    height: root.device-row-height;
                                    border-radius: 12px;
                                    border-width: 1px;
                                    border-color: #2d3669;

                                    HorizontalBox {
                                        padding: 10px;
                                        spacing: 12px;

                                        CheckBox {
                                            text: device.name;
                                            checked: device.selected;
                                            min-width: 430px;
                                            toggled => {
                                                root.toggle-output-device(i, self.checked);
                                            }
                                        }

                                        Rectangle { horizontal-stretch: 1; background: transparent; }

                                        if device.selected : ComboBox {
                                            min-width: 142px;
                                            model: root.sample-rate-options;
                                            current-index: root.sample-rate-index(device.sample_rate_text);
                                            selected(value) => {
                                                root.update-output-sample-rate(i, value);
                                            }
                                        }

                                        if device.selected : ComboBox {
                                            min-width: 142px;
                                            model: root.buffer-size-options;
                                            current-index: root.buffer-size-index(device.buffer_size_text);
                                            selected(value) => {
                                                root.update-output-buffer-size(i, value);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        height: 44px;

                        if status-message != "" : Text {
                            text: status-message;
                            color: #c8d0ee;
                            font-size: 13px;
                            vertical-alignment: center;
                        }

                        Rectangle { horizontal-stretch: 1; background: transparent; }

                        if wizard-step == 1 : SecondaryActionButton {
                            text: "Voltar";
                            clicked => {
                                root.go-to-input-step();
                            }
                        }

                        if wizard-step == 0 : PrimaryActionButton {
                            text: "Continuar";
                            clicked => {
                                root.go-to-output-step();
                            }
                        }

                        if wizard-step == 1 : PrimaryActionButton {
                            text: "Salvar";
                            clicked => {
                                root.save-audio-settings();
                            }
                        }
                    }
                }
            }
        }
    }
}
