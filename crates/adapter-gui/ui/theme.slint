export struct Palette {
    pure-black: brush,
    deep-space: brush,
    card: brush,
    card-secondary: brush,
    row-start: brush,
    row-end: brush,
    border: brush,
    border-strong: brush,
    text-primary: brush,
    text-secondary: brush,
    text-muted: brush,
    accent-start: brush,
    accent-end: brush,
    accent-border: brush,
    secondary-start: brush,
    secondary-end: brush,
    secondary-border: brush,
    background-gradient: brush,
}

export struct Spaces {
    small: length,
    medium: length,
    large: length,
    xlarge: length,
}

struct Font {
    size: length,
    weight: float,
}

export struct Typo {
    brand: Font,
    section: Font,
    body: Font,
    caption: Font,
    button: Font,
}

export global Theme {
    in property <Palette> palette: {
        pure-black: #05070b,
        deep-space: #0a0d12,
        card: #0f131b,
        card-secondary: #151b25,
        row-start: #1b2430,
        row-end: #131922,
        border: #232c3a,
        border-strong: #364457,
        text-primary: #ffffff,
        text-secondary: #dde4ef,
        text-muted: #93a1b7,
        accent-start: #22a7ff,
        accent-end: #0d7eff,
        accent-border: #62c1ff,
        secondary-start: #1a212c,
        secondary-end: #121821,
        secondary-border: #48566c,
        background-gradient: @radial-gradient(circle, #123a7228 0%, #05070b 70%),
    };

    in property <Spaces> spaces: {
        small: 10px,
        medium: 14px,
        large: 20px,
        xlarge: 28px,
    };

    in property <Typo> typo: {
        brand: {
            size: 24px,
            weight: 700
        },
        section: {
            size: 18px,
            weight: 650
        },
        body: {
            size: 14px,
            weight: 400
        },
        caption: {
            size: 12px,
            weight: 400
        },
        button: {
            size: 14px,
            weight: 500
        },
    };
}
