<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v3 Product definition for OpenRig Windows installer.
  File components are harvested at build time by heat.exe (see scripts/package-windows.ps1).
  UpgradeCode must NEVER change between releases.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="OpenRig"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="Joao Paulo Faria"
           UpgradeCode="{6B2F8B9A-1C3D-4E5F-A6B7-C8D9E0F1A2B3}">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine"/>
    <MajorUpgrade DowngradeErrorMessage="A newer version of OpenRig is already installed."/>
    <MediaTemplate EmbedCab="yes"/>

    <!-- Icon shown in Add/Remove Programs and shortcuts -->
    <Icon Id="OpenRigIcon" SourceFile="$(var.IconFile)"/>
    <Property Id="ARPPRODUCTICON" Value="OpenRigIcon"/>

    <Feature Id="ProductFeature" Title="OpenRig" Level="1">
      <ComponentGroupRef Id="StageFiles"/>
      <ComponentRef Id="StartMenuShortcut"/>
      <ComponentRef Id="DesktopShortcut"/>
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="OpenRig"/>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppStartMenuFolder" Name="OpenRig"/>
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop"/>
    </Directory>

    <!-- Start Menu shortcut -->
    <DirectoryRef Id="AppStartMenuFolder">
      <Component Id="StartMenuShortcut" Guid="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}">
        <Shortcut Id="AppStartMenuShortcut"
                  Name="OpenRig"
                  Description="OpenRig virtual guitar pedalboard"
                  Target="[INSTALLFOLDER]openrig.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="OpenRigIcon"/>
        <RemoveFolder Id="RemoveStartMenuFolder" Directory="AppStartMenuFolder" On="uninstall"/>
        <RegistryValue Root="HKCU"
                       Key="Software\OpenRig"
                       Name="StartMenuShortcut"
                       Type="integer" Value="1" KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- Desktop shortcut -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="{B2C3D4E5-F6A7-8901-BCDE-F12345678901}">
        <Shortcut Id="AppDesktopShortcut"
                  Name="OpenRig"
                  Description="OpenRig virtual guitar pedalboard"
                  Target="[INSTALLFOLDER]openrig.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="OpenRigIcon"/>
        <RegistryValue Root="HKCU"
                       Key="Software\OpenRig"
                       Name="DesktopShortcut"
                       Type="integer" Value="1" KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <UIRef Id="WixUI_Minimal"/>
    <WixVariable Id="WixUILicenseRtf" Value="wix\License.rtf"/>

  </Product>
</Wix>
