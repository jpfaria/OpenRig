{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -n '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:\"OpenRig: invoque skills dev-rules, openrig-code-quality, rust-best-practices, slint-best-practices quando tocar código Rust/Slint (openrig-code-quality COMPLEMENTA dev-rules — LAW 1/2/3/5 vivem lá).\"}}'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/main-folder-guard.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "hookify@claude-plugins-official": false,
    "quality-gate@xgodev-quality-gate": true,
    "dev-rules@xgodev-dev-rules": true,
    "skill-rules@xgodev-skill-rules": true,
    "openrig@openrig": true
  }
}
