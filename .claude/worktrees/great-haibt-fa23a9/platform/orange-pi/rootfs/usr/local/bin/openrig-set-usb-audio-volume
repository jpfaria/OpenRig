#!/bin/sh
# Seed ALSA mixer controls to unity gain on USB audio cards.
#
# Fired by a udev rule (ACTION=="add" on controlC*) for hotplug, and at boot
# time by openrig-usb-audio-volume.service for devices already attached when
# udev started.
#
# Why this exists at all: most class-compliant USB audio interfaces ship
# with attenuated factory defaults. The Q-26 in particular boots with
# PCM Playback at -50 dB (0%) — silent — and there is no sound until
# someone runs amixer by hand.
#
#   - playback volumes → 0 dB (unity); fallback 100%
#   - capture volumes  → 0 dB (unity); fallback 50%
#
# Match is by ALSA capability flags ('pvolume' / 'cvolume') from the
# control's info, NOT by name strings ("Playback Volume", "Capture Volume").
# The string approach (used previously) silently passed Scarlett-style
# devices because they expose 'Line In 1 Gain' whose info has 'Capabilities:
# cvolume' but never the literal 'Capture Volume' phrase — capture stayed
# at firmware default (~+25 dB on Scarlett 4th Gen) and unused channels
# captured EMI hum, producing audible noise floor (#332).
#
# Generic — no vendor/model matching. The conservative 50% fallback
# means devices with very large ranges (Scarlett: 0-69 dB → 50% ~ +34 dB)
# stay loud enough to play but unused channels do not blow up. Devices
# with small ranges (Q-26: -23 to +27 dB → 0 dB unity = 46% step) come
# in audible too. User's runtime tweaks are preserved by alsa-store
# on shutdown / alsa-restore on next boot — this script only seeds
# fresh-image / first-attach state.
#
# Usage:
#   openrig-set-usb-audio-volume              # seed every controlC* present
#   openrig-set-usb-audio-volume controlCN    # seed only that one card
#
# udev passes %k → "controlCN" (single device, hotplug). The systemd boot
# oneshot calls the script with no arg → walk every node currently present
# under /dev/snd/, which catches devices that were already attached when
# the udev daemon started (no add event fires for those).

set -u

command -v amixer >/dev/null 2>&1 || exit 0

set_by_name() {
    card="$1"
    name="$2"
    db="$3"
    pct="$4"
    amixer -c "$card" sset "$name" "$db"  >/dev/null 2>&1 \
        || amixer -c "$card" sset "$name" "$pct" >/dev/null 2>&1 \
        || true
}

seed_card() {
    card="$1"
    # Walk every simple mixer control and seed playback/capture volumes
    # according to what the control actually exposes. Robust across vendors.
    amixer -c "$card" scontrols 2>/dev/null \
        | sed -n "s/^Simple mixer control '\\([^']*\\)'.*/\\1/p" \
        | while read -r ctl; do
            info=$(amixer -c "$card" sget "$ctl" 2>/dev/null)
            case "$info" in
                *Capabilities:*pvolume*) set_by_name "$card" "$ctl" "0dB" "100%" ;;
            esac
            case "$info" in
                *Capabilities:*cvolume*) set_by_name "$card" "$ctl" "0dB" "50%"  ;;
            esac
        done
}

DEVNAME="${1:-}"
if [ -n "$DEVNAME" ]; then
    # Single-card mode (udev): expect "controlCN"
    card="${DEVNAME#controlC}"
    case "$card" in
        ''|*[!0-9]*) exit 0 ;;
    esac
    seed_card "$card"
else
    # Sweep mode (boot): every controlC* currently present
    for ctl in /dev/snd/controlC*; do
        [ -e "$ctl" ] || continue
        name="${ctl##*/}"           # controlCN
        card="${name#controlC}"
        seed_card "$card"
    done
fi

exit 0
