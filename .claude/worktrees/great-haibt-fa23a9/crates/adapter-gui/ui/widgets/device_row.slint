import { CheckBox, ComboBox, HorizontalBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export component DeviceRow inherits Rectangle {
    in property <string> name;
    in property <bool> selected;
    in property <string> sample-rate-text;
    in property <string> buffer-size-text;
    in property <string> bit-depth-text;
    in property <[string]> sample-rate-options;
    in property <[string]> buffer-size-options;
    in property <[string]> bit-depth-options;
    callback toggled(bool);
    callback sample-rate-selected(string);
    callback buffer-size-selected(string);
    callback bit-depth-selected(string);

    height: root.selected ? 64px : 52px;
    background: root.selected ? Theme.palette.card-secondary : #0b0d13;
    border-radius: 14px;
    border-width: 1px;
    border-color: root.selected ? Theme.palette.accent-border : Theme.palette.border;

    pure function sample-rate-index(value: string) -> int {
        return value == "44100" ? 0
            : value == "48000" ? 1
            : value == "88200" ? 2
            : value == "96000" ? 3
            : 1;
    }

    pure function buffer-size-index(value: string) -> int {
        return value == "32" ? 0
            : value == "64" ? 1
            : value == "128" ? 2
            : value == "256" ? 3
            : value == "512" ? 4
            : value == "1024" ? 5
            : 3;
    }

    pure function bit-depth-index(value: string) -> int {
        return value == "16" ? 0
            : value == "24" ? 1
            : value == "32" ? 2
            : 2;
    }

    HorizontalBox {
        padding-left: Theme.spaces.medium;
        padding-right: Theme.spaces.medium;
        padding-top: Theme.spaces.medium;
        padding-bottom: Theme.spaces.medium;
        spacing: Theme.spaces.medium;

        CheckBox {
            text: root.name;
            checked: root.selected;
            horizontal-stretch: 1;
            min-height: 18px;
            toggled => {
                root.toggled(self.checked);
            }
        }

        Rectangle { horizontal-stretch: 1; background: transparent; }

        if root.selected : ComboBox {
            min-width: 120px;
            model: root.sample-rate-options;
            current-index: root.sample-rate-index(root.sample-rate-text);
            selected(value) => {
                root.sample-rate-selected(value);
            }
        }

        if root.selected : ComboBox {
            min-width: 120px;
            model: root.buffer-size-options;
            current-index: root.buffer-size-index(root.buffer_size_text);
            selected(value) => {
                root.buffer-size-selected(value);
            }
        }

        if root.selected : ComboBox {
            min-width: 90px;
            model: root.bit-depth-options;
            current-index: root.bit-depth-index(root.bit-depth-text);
            selected(value) => {
                root.bit-depth-selected(value);
            }
        }
    }
}
