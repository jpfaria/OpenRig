[Unit]
Description=Expand root filesystem to fill its partition (OpenRig)
DefaultDependencies=no
Conflicts=shutdown.target
After=systemd-remount-fs.service
Before=local-fs.target shutdown.target openrig.service
ConditionPathIsReadWrite=/

[Service]
Type=oneshot
ExecStart=/usr/local/bin/openrig-resize-rootfs
RemainAfterExit=yes
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
