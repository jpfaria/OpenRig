#!/bin/sh
# openrig-reset-audio — recover a USB audio device from zombie/stuck state
# without restarting OpenRig.
#
# PROBLEM:
#   On RK3588 the scarlett-gen2 + xhci-hcd stack occasionally drops the
#   Scarlett. Symptoms:
#     - Scarlett's front USB LED turns red/dim (device deactivated)
#     - kernel: "scarlett2_notify: Unhandled notification: 0x20000000"
#     - kernel: "xhci-hcd: remove, state 1"
#     - jackd: "ALSA: capture device disconnected"
#   jackd falls into a zombie state (process alive, ALSA driver dead).
#
# RECOVERY:
#   1. Kill the zombie jackd process (releases the dead ALSA handle)
#   2. If the device is still on the USB bus (stuck state), unbind/rebind
#      the xHCI platform driver to force a clean re-enumeration
#   3. Wait for the USB-Audio card to reappear
#   OpenRig's health_timer (2s interval) detects the reconnection and
#   calls ensure_jack_running() to restart jackd and reconnect chains.
#   OpenRig itself is NEVER stopped — hot-swap is transparent to the user.
#
# Usage:
#   openrig-reset-audio          # kill jackd zombie + optional xHCI rebind
#   openrig-reset-audio --force  # always do xHCI rebind even without audio device

set -e

if [ "$(id -u)" -ne 0 ]; then
    echo "openrig-reset-audio: must run as root" >&2
    exit 2
fi

FORCE_REBIND=0
case "$1" in
    --force) FORCE_REBIND=1 ;;
esac

# Find which xhci-hcd platform device currently hosts a USB-Audio interface.
find_audio_xhci() {
    for drv_dev in /sys/bus/platform/drivers/xhci-hcd/xhci-hcd.*.auto; do
        [ -d "$drv_dev" ] || continue
        name=$(basename "$drv_dev")
        for iface in "$drv_dev"/usb*/*/*:*; do
            [ -r "$iface/bInterfaceClass" ] || continue
            cls=$(cat "$iface/bInterfaceClass" 2>/dev/null)
            if [ "$cls" = "01" ]; then
                echo "$name"
                return 0
            fi
        done
    done
    return 1
}

# Step 1: Kill zombie jackd — releases the dead ALSA PCM handle.
# OpenRig's health_timer will detect jackd is gone and call ensure_jack_running()
# to restart it once the device is available again.
echo "openrig-reset-audio: killing jackd process"
killall -9 jackd 2>/dev/null || true
sleep 1

# Step 2: xHCI rebind — only needed when the device is still physically on the
# bus but stuck (scarlett2_notify 0x20000000 zombie). If the device was physically
# unplugged, find_audio_xhci fails and we skip the rebind — jackd will restart
# when the user plugs a device back in.
TARGET=$(find_audio_xhci) || true

if [ -n "$TARGET" ] || [ "$FORCE_REBIND" -eq 1 ]; then
    if [ -z "$TARGET" ]; then
        # --force with no device: rebind the first xHCI controller we find
        TARGET=$(basename "$(ls -d /sys/bus/platform/drivers/xhci-hcd/xhci-hcd.*.auto 2>/dev/null | head -1)" 2>/dev/null) || true
    fi

    if [ -n "$TARGET" ]; then
        echo "openrig-reset-audio: rebinding xHCI controller $TARGET"
        echo "$TARGET" > /sys/bus/platform/drivers/xhci-hcd/unbind
        sleep 2
        echo "$TARGET" > /sys/bus/platform/drivers/xhci-hcd/bind

        echo "openrig-reset-audio: waiting for USB-Audio card to re-enumerate..."
        for _ in $(seq 1 15); do
            if grep -q "USB-Audio" /proc/asound/cards 2>/dev/null; then
                break
            fi
            sleep 1
        done

        if ! grep -q "USB-Audio" /proc/asound/cards 2>/dev/null; then
            echo "openrig-reset-audio: WARNING — USB-Audio not re-enumerated after 15s" >&2
        else
            echo "openrig-reset-audio: USB-Audio card re-enumerated"
        fi
    fi
else
    echo "openrig-reset-audio: device not on bus (physical unplug) — jackd killed, OpenRig will reconnect on next plug"
fi

# OpenRig keeps running. Its health_timer (2s) detects is_healthy()=false,
# calls try_reconnect() → ensure_jack_running() → restarts jackd with the
# correct device when it becomes available.
echo "openrig-reset-audio: done (OpenRig not restarted — health_timer handles reconnect)"
