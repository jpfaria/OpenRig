#!/usr/bin/env bash
# Install OpenRig from SD card to the Orange Pi 5B onboard eMMC.
#
# Run this once after booting from the SD card to install OpenRig
# permanently to internal storage. The SD card will no longer be needed.
#
# Usage (as root):
#   openrig-install-to-emmc          # interactive (asks for confirmation)
#   openrig-install-to-emmc --yes    # non-interactive (skip confirmation, SSH-friendly)

set -euo pipefail

# ── Parse flags ───────────────────────────────────────────────────────────────
AUTO_YES=false
for arg in "$@"; do
    case "$arg" in
        --yes|-y) AUTO_YES=true ;;
    esac
done

# ── Check root ────────────────────────────────────────────────────────────────
if [ "$(id -u)" -ne 0 ]; then
    echo "ERROR: This script must be run as root."
    echo "       Run: sudo openrig-install-to-emmc"
    exit 1
fi

# ── Detect eMMC ───────────────────────────────────────────────────────────────
# eMMC always exposes mmcblkXboot0/boot1 partitions — use that as the signal.
# The SD card (current boot device) is excluded by checking /proc/mounts.
EMMC=""
for dev in /dev/mmcblk0 /dev/mmcblk1 /dev/mmcblk2; do
    [ -b "$dev" ] || continue
    name=$(basename "$dev")
    # Skip if currently mounted as root
    if grep -q "^${dev}" /proc/mounts 2>/dev/null; then
        continue
    fi
    # eMMC has boot partitions (mmcblkXboot0)
    if [ -b "/dev/${name}boot0" ]; then
        EMMC="$dev"
        break
    fi
done

if [ -z "$EMMC" ]; then
    echo "ERROR: Could not detect eMMC device."
    echo "       Is the onboard eMMC present? Check with: lsblk"
    exit 1
fi

SOURCE_DEV=$(findmnt -n -o SOURCE / | sed 's/p[0-9]*$//')
if [ -z "$SOURCE_DEV" ]; then
    echo "ERROR: Could not detect source SD card device."
    exit 1
fi

EMMC_SIZE=$(lsblk -dno SIZE "$EMMC" 2>/dev/null || echo "unknown size")
SOURCE_SIZE=$(lsblk -dno SIZE "$SOURCE_DEV" 2>/dev/null || echo "unknown size")

echo "OpenRig — Install to eMMC"
echo ""
echo "Source:      $SOURCE_DEV ($SOURCE_SIZE — current boot device)"
echo "Destination: $EMMC ($EMMC_SIZE onboard eMMC)"
echo ""
echo "WARNING: ALL DATA ON $EMMC WILL BE ERASED."
echo "         This will install OpenRig permanently to internal storage."
echo ""

if [ "$AUTO_YES" = false ]; then
    read -rp "Type YES to continue: " CONFIRM
    if [ "$CONFIRM" != "YES" ]; then
        echo "Aborted."
        exit 0
    fi
fi

echo ""
echo "Copying $SOURCE_DEV → $EMMC (this may take 5-15 minutes)..."
echo ""

dd if="$SOURCE_DEV" of="$EMMC" bs=4M status=progress conv=fsync
sync

echo ""
echo "Running filesystem check on eMMC partitions..."
for part in "${EMMC}"p*; do
    [ -b "$part" ] || continue
    fsck -y "$part" 2>/dev/null || true
done

echo ""
echo "Installation complete."
echo "Remove the SD card and reboot:"
echo "  reboot"
