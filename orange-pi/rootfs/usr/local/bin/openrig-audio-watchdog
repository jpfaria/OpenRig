#!/bin/sh
# openrig-audio-watchdog — detect jackd zombie state and auto-recover.
#
# PROBLEM:
#   When the Scarlett falls off the USB bus (RK3588 xhci-hcd + scarlett-gen2
#   instability), jackd's ALSA driver dies but the jackd process stays alive.
#   Symptoms in jackd's journal:
#     - "ALSA: capture device disconnected"
#     - "JackAudioDriver::ProcessAsync: read error, stopping..."
#   jackd does NOT recover on its own — the process keeps running with a
#   dead driver, refusing every new client connection. Manual recovery
#   requires running openrig-reset-audio.
#
# SOLUTION:
#   This watchdog follows jackd's journal in real time. When it sees one of
#   the death signals, it triggers openrig-reset-audio, which unbinds the
#   xHCI platform driver, rebinds it, waits for the USB-Audio card to
#   re-enumerate, and restarts jackd + openrig.
#
#   A cooldown file at /run/openrig-audio-watchdog.cooldown prevents
#   run-away loops if the reset itself fails (e.g., hardware actually
#   gone). Minimum 60 seconds between resets.
#
# SAFETY:
#   - Patterns are chosen to match ONLY the real zombie scenario, not normal
#     jackd restart messages. "Cannot start driver" is NOT matched because
#     it also fires on the normal post-restart Broken-pipe retry cycle
#     (which systemd handles correctly on its own).
#   - --since now so we never react to historical log entries at startup.
#   - `journalctl -f` is followed in a simple while-read loop; the watchdog
#     blocks during the reset call, so no concurrent triggers.

set -eu

COOLDOWN_FILE=/run/openrig-audio-watchdog.cooldown
COOLDOWN_SECS=60
RESET_CMD=/usr/local/bin/openrig-reset-audio

log() {
    logger -t openrig-audio-watchdog -- "$*"
    echo "openrig-audio-watchdog: $*"
}

in_cooldown() {
    [ -f "$COOLDOWN_FILE" ] || return 1
    mtime=$(stat -c %Y "$COOLDOWN_FILE" 2>/dev/null || echo 0)
    now=$(date +%s)
    age=$((now - mtime))
    [ "$age" -lt "$COOLDOWN_SECS" ]
}

trigger_reset() {
    if in_cooldown; then
        log "jackd failure detected but still in cooldown, ignoring"
        return
    fi
    touch "$COOLDOWN_FILE"
    log "jackd zombie detected — running $RESET_CMD"
    if "$RESET_CMD"; then
        log "reset succeeded"
    else
        log "reset FAILED with exit $?"
    fi
}

log "starting (cooldown=${COOLDOWN_SECS}s, reset_cmd=$RESET_CMD)"

# --since now: ignore any historical entries at startup (e.g., yesterday's
# "capture device disconnected" that already got handled). -o cat: strip
# the "HOSTNAME SERVICE[PID]:" prefix so we pattern-match the raw message.
# JACK is now launched by OpenRig as a background process (not a systemd
# service), so we filter by _COMM=jackd instead of -u jackd.service.
journalctl -f _COMM=jackd --since now -o cat | while IFS= read -r line; do
    case "$line" in
        *"capture device disconnected"*|*"playback device disconnected"*|*"ProcessAsync: read error"*)
            trigger_reset
            ;;
    esac
done
