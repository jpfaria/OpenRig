tools/__pycache__/
*.pyc

# Compiled gettext catalogs — regenerated from .po by build.rs / scripts.
crates/adapter-gui/translations/*/LC_MESSAGES/*.mo

# Plugin bundle — generated at build-time by OpenRig-plugins'
# scripts/bundle-into-openrig.sh. Shipped inside the installer, extracted
# into the OS plugins dir on first launch. Never versioned.
/plugins/

# private CC auto-memory — must never be versioned
.claude/projects/

# dev-rules gate sentinels (.dev-rules/.red-first-unlocked, .mode-feature) --
# ephemeral/local only, never versioned. If committed, the guard sees them on
# every checkout and never blocks, silently disabling the gate. The bare
# .red-first-unlocked line is kept for the pre-plugin sentinel path.
.dev-rules/
.red-first-unlocked
